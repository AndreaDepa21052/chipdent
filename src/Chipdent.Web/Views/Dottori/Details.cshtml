@model Chipdent.Web.Domain.Entities.Dottore
@{
    ViewData["Title"] = Model.NomeCompleto;
    var cliniche = (Dictionary<string, string>?)ViewData["Cliniche"] ?? new();
    var clinicaNome = Model.ClinicaPrincipaleId is not null && cliniche.TryGetValue(Model.ClinicaPrincipaleId, out var n) ? n : null;
    var alboInScadenza = Model.ScadenzaAlbo is not null && Model.ScadenzaAlbo < DateTime.UtcNow.AddMonths(3);
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>@Model.NomeCompleto</h2>
        <p class="page-head__sub">@Model.Specializzazione · @Model.TipoContratto</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Dottori</a>
        <a class="btn btn--primary" asp-action="Edit" asp-route-id="@Model.Id">Modifica</a>
    </div>
</div>

<div class="detail-grid">
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Anagrafica</h3>
            @if (Model.Attivo)
            {
                <span class="badge badge--success"><span class="dot"></span>attivo</span>
            }
            else
            {
                <span class="badge badge--danger"><span class="dot"></span>non attivo</span>
            }
        </div>
        <dl class="kv">
            <dt>Email</dt><dd>@Model.Email</dd>
            <dt>Telefono</dt><dd>@(Model.Telefono ?? "—")</dd>
            <dt>Specializzazione</dt><dd>@Model.Specializzazione</dd>
            <dt>Contratto</dt><dd>@Model.TipoContratto</dd>
            <dt>Albo</dt>
            <dd>
                @Model.NumeroAlbo
                @if (Model.ScadenzaAlbo is not null)
                {
                    <span style="color: var(--c-ink-soft); font-size:.85em;">· scade @Model.ScadenzaAlbo.Value.ToString("dd MMM yyyy")</span>
                    @if (alboInScadenza)
                    {
                        <span class="badge badge--warning" style="margin-left:6px;"><span class="dot"></span>in scadenza</span>
                    }
                }
            </dd>
            <dt>Sede principale</dt><dd>@(clinicaNome ?? "—")</dd>
        </dl>
    </div>

    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Sintesi</h3>
        </div>
        <dl class="kv">
            <dt>Inserito</dt><dd>@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</dd>
            <dt>Aggiornato</dt><dd>@(Model.UpdatedAt?.ToLocalTime().ToString("dd MMM yyyy") ?? "—")</dd>
        </dl>
    </div>
</div>
