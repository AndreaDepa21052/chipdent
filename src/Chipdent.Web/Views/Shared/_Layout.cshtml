@{
    var section = (ViewData["Section"] as string) ?? "";
    var title = ViewData["Title"] as string ?? "Chipdent";
    var fullName = User.Identity?.Name ?? "";
    var initials = string.IsNullOrWhiteSpace(fullName)
        ? "?"
        : string.Concat(fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                .Take(2)
                                .Select(p => char.ToUpper(p[0])));
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title · Chipdent</title>
    <link rel="icon" type="image/png" href="~/img/logo.png" />
    <link rel="icon" type="image/svg+xml" href="~/img/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Chipdent.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app">
        <aside class="app__sidebar">
            <a class="brand" asp-controller="Dashboard" asp-action="Index">
                <span class="brand__mark">
                    <img src="~/img/logo.png" onerror="this.onerror=null;this.src='/img/logo.svg'" alt="Chipdent" width="44" height="44" />
                </span>
                <span class="brand__text">
                    <span class="brand__name">Chipdent</span>
                    <span class="brand__tag">Dental Suite</span>
                </span>
            </a>

            <nav class="nav">
                <div class="nav__group-title">Operatività</div>
                <a class="nav__item @(section == "dashboard" ? "is-active" : "")" asp-controller="Dashboard" asp-action="Index">
                    <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l9-9 9 9"/><path d="M5 10v10h14V10"/></svg>
                    Dashboard
                </a>
                <a class="nav__item @(section == "turni" ? "is-active" : "")" asp-controller="Turni" asp-action="Index">
                    <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                    Turni
                </a>

                <div class="nav__group-title">Anagrafiche</div>
                <a class="nav__item @(section == "cliniche" ? "is-active" : "")" asp-controller="Cliniche" asp-action="Index">
                    <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 21V12h6v9"/></svg>
                    Cliniche
                </a>
                <a class="nav__item @(section == "dottori" ? "is-active" : "")" asp-controller="Dottori" asp-action="Index">
                    <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
                    Dottori
                </a>
                <a class="nav__item @(section == "dipendenti" ? "is-active" : "")" asp-controller="Dipendenti" asp-action="Index">
                    <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="8" r="4"/><path d="M2 21a7 7 0 0 1 14 0"/><circle cx="17" cy="9" r="3"/><path d="M22 20a5 5 0 0 0-5-5"/></svg>
                    Dipendenti
                </a>

                @if (User.IsInRole("Owner") || User.IsInRole("Admin"))
                {
                    <div class="nav__group-title">Amministrazione</div>
                    <a class="nav__item @(section == "users" ? "is-active" : "")" asp-controller="Users" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M20 8v6M23 11h-6"/></svg>
                        Utenti
                    </a>
                }
            </nav>

            <div style="margin-top:auto; padding: var(--s-3); font-size:.75rem; color: var(--c-ink-soft); border-top:1px solid var(--c-divider);">
                Chipdent v0.1 · <span data-year></span>
            </div>
        </aside>

        <main class="app__main">
            <header class="app__topbar">
                <div style="display:flex; align-items:center; gap:var(--s-4);">
                    <h1 class="topbar__title">@title</h1>
                    <span class="conn" data-conn data-state="connecting">
                        <span class="dot"></span>
                        <span class="label">connessione…</span>
                    </span>
                </div>
                <div class="topbar__right">
                    <label class="search">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                        <input type="search" placeholder="Cerca clinica, dottore, documento…" />
                    </label>
                    <button class="icon-btn" title="Notifiche">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10 21a2 2 0 0 0 4 0"/></svg>
                        <span class="dot"></span>
                    </button>
                    <div class="user-chip">
                        <span class="avatar">@initials</span>
                        <div>
                            <div class="name">@fullName</div>
                            <div class="role">@role</div>
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form" title="Esci">
                            <button type="submit" aria-label="Esci">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="m16 17 5-5-5-5"/><path d="M21 12H9"/></svg>
                            </button>
                        </form>
                    </div>
                </div>
            </header>

            <section class="app__content">
                @RenderBody()
            </section>
        </main>
    </div>

    <div class="toasts" aria-live="polite"></div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
