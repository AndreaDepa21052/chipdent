@model Chipdent.Web.Models.TesoreriaIndexViewModel
@using Chipdent.Web.Models
@using Chipdent.Web.Domain.Entities
@using Chipdent.Web.Domain.Common
@using System.Globalization
@{
    ViewData["Title"] = "Tesoreria — Scadenziario pagamenti";
    var oggi = DateTime.UtcNow.Date;
    var it = new CultureInfo("it-IT");
    // Pre-calcolo set degli id padre per indentare le scadenze figlie F24/ritenute.
    var idPadri = Model.Righe.Where(r => !string.IsNullOrEmpty(r.ScadenzaPadreId))
                              .Select(r => r.ScadenzaPadreId!).ToHashSet();

    // ── Calendario "split-view": determino il mese visibile (cm = "yyyy-MM") ──
    var cmRaw = Context.Request.Query["cm"].ToString();
    DateTime calMese;
    if (!string.IsNullOrEmpty(cmRaw) && DateTime.TryParseExact(cmRaw, "yyyy-MM", CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var parsed))
    {
        calMese = new DateTime(parsed.Year, parsed.Month, 1);
    }
    else if (Model.Filtro.Dal.HasValue)
    {
        calMese = new DateTime(Model.Filtro.Dal.Value.Year, Model.Filtro.Dal.Value.Month, 1);
    }
    else
    {
        calMese = new DateTime(oggi.Year, oggi.Month, 1);
    }

    // Aggrego le scadenze per giorno (solo del mese visibile). Lo statuso più "caldo" vince
    // per la dot principale; il totale euro alimenta l'heatmap.
    var righePerGiorno = Model.Righe
        .Where(r => r.DataScadenza.Year == calMese.Year && r.DataScadenza.Month == calMese.Month)
        .GroupBy(r => r.DataScadenza.Date)
        .ToDictionary(g => g.Key, g => g.ToList());
    var maxTotaleGiorno = righePerGiorno.Count == 0 ? 0m : righePerGiorno.Values.Max(l => l.Sum(r => r.Totale));

    // Helper: costruisce un URL preservando filtri attuali e sostituendo cm/Dal/Al/tab.
    // clearSort = true rimuove eventuali sort/dir preesistenti (utile per i link sull'header
    // della tabella, dove il caller imposta sort/dir nuovi).
    string CalUrl(DateTime? mese = null, DateTime? dataFiltro = null, bool clearDate = false, bool clearSort = false)
    {
        var qp = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrEmpty(Model.Filtro.Q))            qp["Q"] = Model.Filtro.Q;
        if (!string.IsNullOrEmpty(Model.Filtro.FornitoreId))  qp["FornitoreId"] = Model.Filtro.FornitoreId;
        if (!string.IsNullOrEmpty(Model.Filtro.ClinicaId))    qp["ClinicaId"] = Model.Filtro.ClinicaId;
        if (Model.Filtro.Categoria.HasValue)                  qp["Categoria"] = Model.Filtro.Categoria.ToString();
        if (Model.Filtro.Stato.HasValue)                      qp["Stato"] = Model.Filtro.Stato.ToString();
        if (Model.Filtro.Metodo.HasValue)                     qp["Metodo"] = Model.Filtro.Metodo.ToString();
        if (Model.Filtro.SoloFuoriTermini)                    qp["SoloFuoriTermini"] = "true";
        if (!clearSort && !string.IsNullOrEmpty(Model.Filtro.Sort)) qp["Sort"] = Model.Filtro.Sort;
        if (!clearSort && !string.IsNullOrEmpty(Model.Filtro.Dir))  qp["Dir"]  = Model.Filtro.Dir;
        // cm: mese visibile del calendario
        if (mese.HasValue) qp["cm"] = mese.Value.ToString("yyyy-MM");
        // Dal/Al
        if (dataFiltro.HasValue)
        {
            qp["Dal"] = dataFiltro.Value.ToString("yyyy-MM-dd");
            qp["Al"]  = dataFiltro.Value.ToString("yyyy-MM-dd");
        }
        else if (!clearDate)
        {
            if (Model.Filtro.Dal.HasValue) qp["Dal"] = Model.Filtro.Dal.Value.ToString("yyyy-MM-dd");
            if (Model.Filtro.Al.HasValue)  qp["Al"]  = Model.Filtro.Al.Value.ToString("yyyy-MM-dd");
        }
        qp["tab"] = "scadenze";
        var qs = string.Join("&", qp.Where(kv => !string.IsNullOrEmpty(kv.Value))
                                    .Select(kv => $"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(kv.Value!)}"));
        return Url.Action("Index") + (string.IsNullOrEmpty(qs) ? "" : "?" + qs);
    }
}

@functions {
    string Eur(decimal v) => v.ToString("N0", new CultureInfo("it-IT")) + " €";
    string EurDec(decimal v) => v.ToString("N2", new CultureInfo("it-IT")) + " €";

    // Abbrevia un IBAN mantenendo i primi 4 e gli ultimi 4 caratteri
    // (es. "IT60X 03268…0089"). Utile per visualizzazione compatta in
    // tabella; il valore completo è messo in tooltip dal template.
    string ShortIban(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "—";
        var c = new string(v.Where(ch => !char.IsWhiteSpace(ch)).ToArray());
        return c.Length <= 10 ? c : $"{c[..4]}…{c[^4..]}";
    }

    string StatoBadge(StatoScadenza s) => s switch
    {
        StatoScadenza.Pagato => "<span class='badge' style='background:#dff5e6; color:#1f6e3a;'>✓ pagato</span>",
        StatoScadenza.Programmato => "<span class='badge' style='background:#e3edff; color:#2457a4;'>📅 programmato</span>",
        StatoScadenza.DaPagare => "<span class='badge' style='background:#fff2dd; color:#a86010;'>● da pagare</span>",
        StatoScadenza.Insoluto => "<span class='badge' style='background:#fbe1e1; color:#a83a3a;'>⚠ scaduto</span>",
        StatoScadenza.MaiPagato => "<span class='badge' style='background:#444; color:#fff;'>✕ mai pagato</span>",
        StatoScadenza.Annullato => "<span class='badge' style='background:#eee; color:#666;'>annullato</span>",
        _ => $"<span class='badge'>{s}</span>"
    };
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>💰 Tesoreria — Scadenziario pagamenti</h2>
        <p class="page-head__sub">Vista unificata di fatture passive e scadenze fornitori. KPI, grafici, e azioni rapide su pagamenti.</p>
    </div>
    <div class="page-head__actions">
        <button type="button" class="btn btn--ghost btn--ai" data-ai-trigger title="Analisi AI dello scadenziario: criticità, picchi cassa, suggerimenti">
            <span class="btn-ai__sparkle" aria-hidden="true">✦</span> AI
        </button>
        <button type="button" class="btn btn--ghost" data-cal-open-toggle title="Mostra/nascondi il mini-calendario delle scadenze">
            📅 <span data-cal-open-label>Nascondi calendario</span>
        </button>
        <div class="btn-group" role="group" aria-label="Esporta scadenziario" style="display:inline-flex; gap:0;">
            <a class="btn btn--ghost" asp-action="ExportCsv" title="Scarica tutto lo scadenziario in CSV (separatore ; — Excel compatibile)" style="border-top-right-radius:0; border-bottom-right-radius:0;">⬇ CSV</a>
            <a class="btn btn--ghost" asp-action="ExportXlsx" title="Scarica tutto lo scadenziario in Excel (.xlsx)" style="border-top-left-radius:0; border-bottom-left-radius:0; margin-left:-1px;">⬇ XLSX</a>
        </div>
        <a class="btn btn--ghost" asp-action="GeneraScadenziario">⚙️ Genera scadenziario</a>
        <button type="button" class="btn btn--primary" data-new-fattura>＋ Nuova fattura</button>
    </div>
</div>

@if (Model.CountFattureInApprovazione > 0)
{
    <div class="alert alert--info" style="margin-bottom: var(--s-4);">
        📥 <strong>@Model.CountFattureInApprovazione</strong> fatture caricate dai fornitori sono <strong>in attesa di approvazione</strong>.
        Filtra la tabella per <em>stato = DaPagare</em> e cerca le righe contrassegnate "Proposta dal fornitore".
    </div>
}

@{
    var queryTab = Context.Request.Query["tab"].ToString();
    var activeTab = string.IsNullOrEmpty(queryTab) ? "scadenze" : queryTab;
}

<div class="tabs" data-tesoreria-tabs style="margin-bottom: var(--s-4);">
    <a class="tab @(activeTab == "scadenze"  ? "is-active" : "")" href="#" data-tab="scadenze">📋 Scadenze <span class="tab__count">@Model.RigheTotali</span></a>
    <a class="tab @(activeTab == "dashboard" ? "is-active" : "")" href="#" data-tab="dashboard">📊 Dashboard &amp; KPI</a>
    <a class="tab @(activeTab == "regole"    ? "is-active" : "")" href="#" data-tab="regole">📜 Regole <span class="tab__count">@Model.RegoleCustom.Count</span></a>
</div>

<section data-tab-pane="dashboard" style="@(activeTab == "dashboard" ? "" : "display:none;")">
<div class="grid grid--stats" style="margin-bottom: var(--s-4);">
    <div class="stat">
        <div class="stat__label">Esposto prossimi 30gg</div>
        <div class="stat__value">@Eur(Model.EspostoProssimi30gg)</div>
    </div>
    <div class="stat">
        <div class="stat__label">Scaduto / insoluto</div>
        <div class="stat__value" style="color:@(Model.CountScadute > 0 ? "#a83a3a" : "inherit");">@Eur(Model.ImportoScaduto)</div>
        @if (Model.CountScadute > 0)
        {
            <div class="stat__hint">@Model.CountScadute scadenze rosse</div>
        }
    </div>
    <div class="stat">
        <div class="stat__label">Da programmare (settimana)</div>
        <div class="stat__value">@Eur(Model.DaProgrammareSettimana)</div>
        <div class="stat__hint">@Model.CountDaProgrammareSettimana scadenze</div>
    </div>
    <div class="stat">
        <div class="stat__label">Pagato MTD</div>
        <div class="stat__value">@Eur(Model.PagatoMeseCorrente)</div>
        <div class="stat__hint">mese in corso</div>
    </div>
    <div class="stat" style="@(Model.CountFuoriTermini > 0 ? "background: rgba(255, 165, 0, 0.06); border-color: rgba(196, 120, 48, 0.3);" : "")">
        <div class="stat__label">⚠️ Fuori termini</div>
        <div class="stat__value" style="color: @(Model.CountFuoriTermini > 0 ? "#a86010" : "inherit");">@Model.CountFuoriTermini</div>
        <div class="stat__hint">
            @if (Model.CountFuoriTermini > 0)
            {
                <a asp-action="Index" asp-route-SoloFuoriTermini="true">vedi solo questi →</a>
            }
            else
            {
                <text>tolleranza ±@RigaTesoreria.TolleranzaMismatchGiorni gg</text>
            }
        </div>
    </div>
</div>

<div class="grid" style="grid-template-columns: minmax(0, 2fr) minmax(0, 1fr); gap: var(--s-4); margin-bottom: var(--s-4);">
    <div class="card" style="min-width: 0;">
        <div class="card__header">
            <h3 class="card__title">Cash-out previsto (90 giorni)</h3>
            <span class="muted" style="font-size:.85rem;">Aggregato per mese</span>
        </div>
        <div style="height: 280px; padding: var(--s-3);">
            <canvas id="chart-cashout"></canvas>
        </div>
    </div>
    <div class="card" style="min-width: 0;">
        <div class="card__header"><h3 class="card__title">Stati scadenze</h3></div>
        <div style="height: 280px; padding: var(--s-3);">
            <canvas id="chart-stati"></canvas>
        </div>
    </div>
</div>

<div class="grid" style="grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: var(--s-4); margin-bottom: var(--s-4);">
    <div class="card" style="min-width: 0;">
        <div class="card__header"><h3 class="card__title">Spesa per categoria (12m)</h3></div>
        <div style="height: 260px; padding: var(--s-3);">
            <canvas id="chart-categoria"></canvas>
        </div>
    </div>
    <div class="card" style="min-width: 0;">
        <div class="card__header"><h3 class="card__title">Spesa per sede (12m)</h3></div>
        <div style="height: 260px; padding: var(--s-3);">
            <canvas id="chart-sede"></canvas>
        </div>
    </div>
</div>

<div class="card" style="min-width: 0; margin-bottom: var(--s-4);">
        <div class="card__header"><h3 class="card__title">Top fornitori — esposto</h3></div>
        <ul class="list" style="margin: 0;">
            @foreach (var t in Model.TopFornitori)
            {
                <li class="list__item">
                    <div class="list__icon">●</div>
                    <div>
                        <div class="list__title"><strong>@t.Nome</strong></div>
                        <div class="muted" style="font-size:.78rem;">@t.NumeroScadenze scadenze aperte</div>
                    </div>
                    <div class="list__when"><strong>@Eur(t.Esposto)</strong></div>
                </li>
            }
            @if (Model.TopFornitori.Count == 0)
            {
                <li class="muted" style="padding: var(--s-3);">Nessun esposto aperto.</li>
            }
        </ul>
    </div>
</section><!-- /tab dashboard -->

<section data-tab-pane="scadenze" style="@(activeTab == "scadenze" ? "" : "display:none;")">

@{
    var righeConProblemi = Model.Righe.Count(r => r.HaProblemi);
    var righeSenzaIban = Model.Righe.Count(r => r.MancaIbanFornitore);
}
@if (righeConProblemi > 0)
{
    <div class="card" style="background:#fff7e6; border-left: 4px solid #c47830; margin-bottom: var(--s-3); padding: var(--s-3);">
        <strong style="color:#a86010;">⚠️ @righeConProblemi scadenz@(righeConProblemi == 1 ? "a" : "e") con dati incompleti.</strong>
        @if (righeSenzaIban > 0)
        {
            <span class="muted"> — @righeSenzaIban senza IBAN beneficiario valido (non incassabili via SEPA).</span>
        }
        <span class="muted"> Apri la riga per vedere il dettaglio o completa l'anagrafica fornitore.</span>
    </div>
}

<style>
    .scadenze-split { display: grid; grid-template-columns: 320px minmax(0, 1fr); gap: var(--s-4); align-items: start; }
    @@media (max-width: 1100px) { .scadenze-split { grid-template-columns: 1fr; } }
    .scadenze-grid { min-width: 0; }

    /* Calendario sganciato: la griglia occupa tutta la larghezza, il calendario
       diventa un pannello fluttuante draggabile dalla sua testata. */
    .scadenze-split.is-cal-floating { grid-template-columns: minmax(0, 1fr); }
    .scadenze-cal.is-floating {
        position: fixed;
        z-index: 800;
        width: 320px;
        max-height: calc(100vh - 32px);
        overflow-y: auto;
        box-shadow: 0 18px 48px rgba(59,30,12,0.28);
        border-color: rgba(196,120,48,0.55);
    }
    .scadenze-cal.is-floating .scadenze-cal__head { cursor: grab; user-select: none; }
    .scadenze-cal.is-floating.is-dragging { box-shadow: 0 24px 60px rgba(59,30,12,0.40); }
    .scadenze-cal.is-floating.is-dragging .scadenze-cal__head { cursor: grabbing; }
    .scadenze-cal__pin {
        display:inline-flex; align-items:center; justify-content:center;
        width: 22px; height: 22px; border-radius: 6px;
        background: transparent; border: 0; padding: 0;
        cursor: pointer; color: var(--c-ink-muted, #7a5c3a);
        transition: background .12s, color .12s, transform .12s;
    }
    .scadenze-cal__pin:hover { background: rgba(196,120,48,0.16); color: var(--c-accent-strong, #a86010); }

    .scadenze-cal {
        position: sticky; top: var(--s-4);
        background: var(--c-bg-panel, #fff);
        border: 1px solid var(--c-border, #ece0cc);
        border-radius: var(--r-lg, 12px);
        padding: var(--s-3);
        box-shadow: var(--shadow-sm, 0 1px 2px rgba(0,0,0,0.04));
        font-size: .82rem;
    }
    .scadenze-cal__head { display:flex; align-items:center; justify-content:space-between; gap: var(--s-2); margin-bottom: var(--s-2); }
    .scadenze-cal__title { text-align:center; flex: 1; }
    .scadenze-cal__title strong { color: var(--c-ink-strong, #3b1e0c); text-transform: capitalize; }
    .scadenze-cal__nav {
        display:inline-flex; align-items:center; justify-content:center;
        width: 28px; height: 28px; border-radius: 6px;
        text-decoration:none; color: var(--c-ink-muted, #7a5c3a);
        background: rgba(196,120,48,0.06); font-size: 1rem; font-weight: 700;
    }
    .scadenze-cal__nav:hover { background: rgba(196,120,48,0.16); color: var(--c-accent-strong, #a86010); }
    .scadenze-cal__clear {
        display:block; text-align:center; padding: 4px 8px; margin-bottom: var(--s-2);
        font-size:.72rem; text-decoration:none;
        background: rgba(196,120,48,0.10); color: var(--c-accent-strong, #a86010);
        border-radius: 999px; border: 1px solid rgba(196,120,48,0.25);
    }
    .scadenze-cal__clear--today { background: transparent; color: var(--c-ink-muted); border-color: transparent; }
    .scadenze-cal__clear:hover { background: rgba(196,120,48,0.18); }

    .scadenze-cal__grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
    .scadenze-cal__dow { text-align:center; color: #b9a98c; font-size: .68rem; font-weight: 700; padding: 4px 0 6px; text-transform: uppercase; letter-spacing: .04em; }

    .scadenze-cal__cell {
        position: relative;
        display: flex; flex-direction: column; align-items: center; justify-content: flex-start;
        aspect-ratio: 1;
        border-radius: 6px;
        text-decoration: none;
        color: var(--c-ink, #3b1e0c);
        padding: 3px 2px 4px;
        transition: transform .08s ease-out, box-shadow .12s ease-out;
        border: 1px solid transparent;
        overflow: hidden;
    }
    .scadenze-cal__cell:hover { transform: translateY(-1px); box-shadow: 0 2px 6px rgba(59,30,12,0.12); border-color: rgba(196,120,48,0.35); }
    .scadenze-cal__cell--blank { pointer-events: none; }
    .scadenze-cal__cell.is-empty { color: var(--c-ink-muted, #998); cursor: default; pointer-events: none; }
    .scadenze-cal__cell.is-past:not(.is-today) { color: #998; }
    .scadenze-cal__cell.is-today { border-color: var(--c-accent-strong, #a86010); border-width: 2px; padding: 2px 1px 3px; }
    .scadenze-cal__cell.is-selected {
        background: var(--c-accent-strong, #a86010) !important; color: #fff !important;
        box-shadow: 0 4px 12px rgba(168,96,16,0.35);
    }
    .scadenze-cal__cell.is-selected .scadenze-cal__amt { color: rgba(255,255,255,.85); }

    .scadenze-cal__day { font-size: .82rem; font-weight: 600; line-height: 1; }
    .scadenze-cal__amt { font-size: .56rem; line-height: 1; margin-top: 2px; color: var(--c-ink-soft, #7a5c3a); font-variant-numeric: tabular-nums; }
    .scadenze-cal__dots { display:flex; gap: 2px; margin-top: auto; padding-bottom: 1px; }
    .scadenze-cal__dots .dot { width: 4px; height: 4px; border-radius: 50%; }

    .dot.dot--red   { background: #b8442e; }
    .dot.dot--amber { background: #c47830; }
    .dot.dot--blue  { background: #2457a4; }
    .dot.dot--green { background: #2d7a50; }
    .dot.dot--grey  { background: #888; }

    .scadenze-cal__legend { display: flex; flex-wrap: wrap; gap: 6px 10px; align-items: center; margin-top: var(--s-3); padding-top: var(--s-2); border-top: 1px dashed var(--c-divider, #ece0cc); font-size: .68rem; color: var(--c-ink-muted, #998); }
    .scadenze-cal__legend .dot { width: 7px; height: 7px; border-radius: 50%; margin-right: 2px; }

    .scadenze-cal__today { margin-top: var(--s-3); padding-top: var(--s-3); border-top: 1px solid var(--c-divider, #ece0cc); }
    .scadenze-cal__today-head { display: flex; align-items: center; justify-content: space-between; gap: 6px; margin-bottom: 6px; color: var(--c-ink-strong, #3b1e0c); font-size: .82rem; text-transform: capitalize; }
    .scadenze-cal__today-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
    .scadenze-cal__today-list li { display: grid; grid-template-columns: 8px 1fr auto; align-items: center; gap: 6px; font-size: .78rem; padding: 4px 6px; border-radius: 4px; background: rgba(196,120,48,0.04); }
    .scadenze-cal__today-list li:hover { background: rgba(196,120,48,0.10); }
    .scadenze-cal__today-list .dot { width: 7px; height: 7px; border-radius: 50%; }
    .scadenze-cal__today-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--c-ink, #3b1e0c); }
    .scadenze-cal__today-amt { color: var(--c-ink-strong, #3b1e0c); font-variant-numeric: tabular-nums; font-size: .76rem; }
    .scadenze-cal__today-more { display: block; text-align: center; margin-top: 6px; font-size: .72rem; color: var(--c-accent-strong, #a86010); text-decoration: none; }

    /* ── Griglia scadenze: padding ridotti perché il calendario a sx ruba 320px ── */
    .scadenze-grid .table { font-size: .8rem; }
    .scadenze-grid .table thead th { padding: 6px 8px; font-size: .65rem; letter-spacing: .08em; }
    .scadenze-grid .table tbody td { padding: 6px 8px; line-height: 1.25; }
    .scadenze-grid .table .badge { padding: 1px 6px; font-size: .7rem; }
    .scadenze-grid .table code { font-size: .72rem; padding: 1px 4px; }
    .scadenze-grid .table .actions { gap: 2px; }
    .scadenze-grid .table .btn--sm { padding: 2px 6px; font-size: .72rem; }
    /* Cella totale: niente wrap così il numero resta su una riga */
    .scadenze-grid .table td:nth-child(8) { white-space: nowrap; }

    /* Visualizzazione compatta degli IBAN: ordinante (Società che ha
       ricevuto la fattura) sopra, beneficiario (Fornitore) sotto. Il
       valore completo è in una tooltip personalizzata che si apre on hover. */
    .iban-flow { position: relative; display: flex; flex-direction: column; gap: 1px; margin-top: 4px; cursor: help; }
    .iban-flow__row {
        display: flex; align-items: center; gap: 4px;
        font-size: .66rem; line-height: 1.1; color: var(--c-ink-soft, #7a5c3a);
    }
    .iban-flow__label {
        display: inline-block; width: 14px; text-align: right;
        color: var(--c-ink-muted, #998); font-weight: 600; text-transform: lowercase;
    }
    .iban-flow__val {
        font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
        font-size: .68rem; padding: 0 4px; border-radius: 3px;
        background: rgba(196,120,48,0.06); color: var(--c-ink-strong, #3b1e0c);
        letter-spacing: .02em;
    }
    .iban-flow__val--missing { background: rgba(168,58,58,0.08); color: #a83a3a; font-style: italic; }

    /* ─── Tooltip dettaglio bonifico (sexy edition) ─────────────── */
    .iban-pop {
        position: absolute; z-index: 950; left: 0; bottom: calc(100% + 10px);
        min-width: 320px; max-width: 380px;
        padding: 12px 14px 10px;
        background: linear-gradient(180deg, #fffaf2 0%, #fff 100%);
        border: 1px solid rgba(196,120,48,0.35);
        border-radius: 12px;
        box-shadow: 0 18px 48px rgba(59,30,12,0.22), 0 2px 6px rgba(59,30,12,0.08);
        opacity: 0; transform: translateY(6px) scale(.98);
        transform-origin: bottom left;
        transition: opacity .14s ease-out, transform .14s ease-out;
        pointer-events: none;
        text-align: left;
        font-size: .78rem; line-height: 1.35; color: var(--c-ink, #3b1e0c);
    }
    .iban-flow:hover .iban-pop,
    .iban-flow:focus-within .iban-pop {
        opacity: 1; transform: translateY(0) scale(1); pointer-events: auto;
    }
    .iban-pop::after {
        content: ''; position: absolute; left: 24px; bottom: -7px;
        width: 12px; height: 12px; transform: rotate(45deg);
        background: #fff;
        border-right: 1px solid rgba(196,120,48,0.35);
        border-bottom: 1px solid rgba(196,120,48,0.35);
    }
    .iban-pop__title {
        display: flex; align-items: center; gap: 6px;
        font-size: .72rem; text-transform: uppercase; letter-spacing: .06em;
        color: var(--c-ink-muted, #998); font-weight: 700;
        padding-bottom: 8px; margin-bottom: 8px;
        border-bottom: 1px dashed rgba(196,120,48,0.25);
    }
    .iban-pop__icon { font-size: .9rem; }
    .iban-pop__amt {
        margin-left: auto; color: var(--c-accent-strong, #a86010);
        font-variant-numeric: tabular-nums; font-size: .9rem; letter-spacing: 0;
        text-transform: none;
    }
    .iban-pop__leg {
        padding: 6px 8px; border-radius: 8px; margin-bottom: 2px;
        background: rgba(196,120,48,0.05);
    }
    .iban-pop__leg--from { background: rgba(36,87,164,0.06); }
    .iban-pop__leg--to   { background: rgba(45,122,80,0.06); }
    .iban-pop__role {
        font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
        color: var(--c-ink-muted, #998); margin-bottom: 2px;
    }
    .iban-pop__leg--from .iban-pop__role { color: #2457a4; }
    .iban-pop__leg--to   .iban-pop__role { color: #1f6e3a; }
    .iban-pop__entity {
        font-weight: 700; color: var(--c-ink-strong, #3b1e0c);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .iban-pop__iban {
        font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
        font-size: .78rem; letter-spacing: .04em;
        margin-top: 2px; word-break: break-all;
    }
    .iban-pop__meta {
        font-size: .68rem; color: var(--c-ink-muted, #998); margin-top: 2px;
    }
    .iban-pop__arrow {
        display: flex; align-items: center; gap: 6px;
        margin: 2px 0; padding: 0 8px;
        font-size: .72rem; color: var(--c-ink-muted, #998);
    }
    .iban-pop__arrow > span:first-child {
        display: inline-flex; align-items: center; justify-content: center;
        width: 18px; height: 18px; border-radius: 50%;
        background: var(--c-accent-strong, #a86010); color: #fff;
        font-size: .68rem; line-height: 1;
    }
    .iban-pop__foot {
        margin-top: 8px; padding-top: 6px; border-top: 1px dashed rgba(196,120,48,0.25);
        font-size: .68rem; color: var(--c-ink-muted, #998); text-align: center;
    }

    /* ─── Resize colonne ────────────────────────────────────────── */
    .scadenze-grid .table thead th { position: relative; }
    .col-resizer {
        position: absolute; top: 0; right: -3px; width: 7px; height: 100%;
        cursor: col-resize; user-select: none; z-index: 5;
        background: transparent;
    }
    .col-resizer::after {
        content: ''; position: absolute; top: 18%; right: 3px;
        width: 1px; height: 64%; background: rgba(196,120,48,0.25);
        transition: background .12s, width .12s;
    }
    .col-resizer:hover::after, .col-resizer.is-active::after { background: var(--c-accent-strong, #a86010); width: 2px; }
    .scadenze-grid .table { table-layout: fixed; }
    .scadenze-grid .table th, .scadenze-grid .table td { overflow: hidden; text-overflow: ellipsis; }

    /* ─── Tab Regole ───────────────────────────────────────────── */
    .regole-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-4); }
    @@media (max-width: 1100px) { .regole-grid { grid-template-columns: 1fr; } }
    .regola-block { padding: 10px 4px; border-bottom: 1px dashed var(--c-divider, #ece0cc); }
    .regola-block:last-child { border-bottom: 0; }
    .regola-block summary { cursor: pointer; color: var(--c-ink-strong, #3b1e0c); padding: 4px 0; font-size: .92rem; }
    .regola-block summary:hover { color: var(--c-accent-strong, #a86010); }
    .regola-block p { font-size: .85rem; line-height: 1.5; color: var(--c-ink-soft, #5a3f1f); margin: 6px 0 0 18px; }

    .regola-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
    .regola-item {
        border: 1px solid var(--c-border, #ece0cc); border-radius: 10px;
        padding: 10px 12px; background: #fffaf2; transition: border-color .12s;
    }
    .regola-item:hover { border-color: var(--c-accent-strong, #a86010); }
    .regola-item.is-disabled { opacity: .55; background: #f4f0ea; }
    .regola-item__head { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .regola-item__badge {
        font-size: .65rem; padding: 2px 8px; border-radius: 999px; font-weight: 700;
        text-transform: uppercase; letter-spacing: .04em;
    }
    .regola-item__badge--dainterpretare { background: #fff2dd; color: #a86010; }
    .regola-item__badge--interpretata   { background: #dff5e6; color: #1f6e3a; }
    .regola-item__badge--errore         { background: #fbe1e1; color: #a83a3a; }
    .regola-item__badge--off            { background: #e8e8e8; color: #666; }
    .regola-item__text { font-size: .88rem; line-height: 1.45; margin: 0 0 6px; color: var(--c-ink, #3b1e0c); white-space: pre-wrap; }
    .regola-item__nota { font-size: .78rem; margin: 0 0 6px; padding: 6px 8px; background: rgba(36,87,164,0.06); border-left: 2px solid #2457a4; border-radius: 4px; color: #2457a4; }
    .regola-item__foot { display: flex; align-items: center; gap: 8px; font-size: .75rem; }
    .regola-item__foot .muted { margin-right: auto; }

    /* ─── Bottone AI sparkly ───────────────────────────────────── */
    .btn--ai {
        position: relative;
        background: linear-gradient(135deg, #fff7e6 0%, #fff 100%) !important;
        border: 1px solid rgba(196,120,48,0.4) !important;
        color: var(--c-accent-strong, #a86010) !important;
        font-weight: 700;
        overflow: hidden;
    }
    .btn--ai::before {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,0.55) 50%, transparent 100%);
        transform: translateX(-100%);
        animation: ai-shine 3s ease-in-out infinite;
    }
    @@keyframes ai-shine { 0%, 70% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
    .btn-ai__sparkle { display: inline-block; animation: ai-twinkle 1.8s ease-in-out infinite; }
    @@keyframes ai-twinkle { 0%, 100% { transform: rotate(0deg) scale(1); opacity: 1; } 50% { transform: rotate(180deg) scale(1.3); opacity: .7; } }

    /* ─── Modale AI ────────────────────────────────────────────── */
    dialog.dlg-ai {
        border: 0; padding: 0; margin: 5vh auto; width: min(720px, 92vw);
        max-height: 90vh; border-radius: 16px;
        background: linear-gradient(180deg, #fffaf2 0%, #fff 100%);
        box-shadow: 0 30px 80px rgba(59,30,12,0.35);
        overflow: hidden; display: flex; flex-direction: column;
    }
    dialog.dlg-ai::backdrop { background: rgba(59,30,12,0.55); backdrop-filter: blur(2px); }
    .dlg-ai__bar {
        display: flex; align-items: center; gap: 12px;
        padding: 14px 18px; border-bottom: 1px solid var(--c-border, #ece0cc);
        background: linear-gradient(90deg, rgba(196,120,48,0.10) 0%, transparent 60%);
    }
    .dlg-ai__title { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 1.05rem; color: var(--c-ink-strong, #3b1e0c); flex: 1; }
    .dlg-ai__sparkle {
        display: inline-flex; align-items: center; justify-content: center;
        width: 28px; height: 28px; border-radius: 50%;
        background: linear-gradient(135deg, #c47830 0%, #a86010 100%); color: #fff;
        font-size: 1rem; animation: ai-twinkle 1.8s ease-in-out infinite;
    }
    .dlg-ai__body { padding: 22px 24px; overflow-y: auto; }

    .ai-loader { display: flex; flex-direction: column; align-items: center; padding: 30px 10px; }
    .ai-loader__logo { margin-bottom: 22px; }
    .ai-loader__steps { width: 100%; max-width: 460px; }
    .ai-loader__step {
        padding: 8px 12px; margin: 4px 0; border-radius: 8px;
        background: rgba(196,120,48,0.04); color: var(--c-ink-muted, #998);
        font-size: .88rem; opacity: .4; transition: opacity .25s, background .25s, color .25s;
        position: relative; padding-left: 36px;
    }
    .ai-loader__step::before {
        content: '○'; position: absolute; left: 12px; top: 8px; font-size: 1rem;
    }
    .ai-loader__step.is-active { opacity: 1; background: rgba(196,120,48,0.10); color: var(--c-ink, #3b1e0c); font-weight: 600; }
    .ai-loader__step.is-active::before { content: '●'; color: var(--c-accent-strong, #a86010); animation: ai-dot 1s ease-in-out infinite; }
    .ai-loader__step.is-done { opacity: .85; color: #2d7a50; }
    .ai-loader__step.is-done::before { content: '✓'; color: #2d7a50; }
    @@keyframes ai-dot { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.5); } }

    .ai-result__head {
        display: flex; gap: 14px; padding: 12px 14px; margin-bottom: 16px;
        background: rgba(36,87,164,0.06); border-radius: 10px;
        font-size: .85rem; color: var(--c-ink-soft, #5a3f1f);
    }
    .ai-result__head strong { color: var(--c-ink-strong, #3b1e0c); }
    .ai-card {
        position: relative;
        padding: 12px 14px 12px 50px;
        margin: 8px 0;
        border-radius: 10px;
        border: 1px solid var(--c-border, #ece0cc);
        background: #fff;
        animation: ai-card-in .35s ease-out both;
    }
    @@keyframes ai-card-in { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
    .ai-card__icon {
        position: absolute; left: 12px; top: 12px;
        width: 28px; height: 28px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(196,120,48,0.10); font-size: 1.1rem;
    }
    .ai-card__title { font-weight: 700; color: var(--c-ink-strong, #3b1e0c); margin-bottom: 2px; }
    .ai-card__desc { font-size: .85rem; line-height: 1.4; color: var(--c-ink-soft, #5a3f1f); margin-bottom: 4px; }
    .ai-card__action {
        font-size: .8rem; color: var(--c-accent-strong, #a86010);
        padding: 6px 0 0; border-top: 1px dashed rgba(196,120,48,0.25); margin-top: 6px;
    }
    .ai-card__action::before { content: '→ '; font-weight: 700; }
    .ai-card--critical { border-left: 4px solid #a83a3a; }
    .ai-card--critical .ai-card__icon { background: #fbe1e1; }
    .ai-card--warn { border-left: 4px solid #c47830; }
    .ai-card--warn .ai-card__icon { background: #fff2dd; }
    .ai-card--info { border-left: 4px solid #2457a4; }
    .ai-card--info .ai-card__icon { background: rgba(36,87,164,0.10); }
    .ai-card--rule { border-left: 4px solid #7a5c9a; }
    .ai-card--rule .ai-card__icon { background: rgba(122,92,154,0.12); }
    .ai-card--good { border-left: 4px solid #2d7a50; }
    .ai-card--good .ai-card__icon { background: #dff5e6; }
    .ai-disclaimer {
        margin-top: 14px; padding: 10px 12px;
        background: rgba(196,120,48,0.05); border-radius: 8px;
        font-size: .72rem; color: var(--c-ink-muted, #998); text-align: center;
    }

    /* ─── Paginazione ───────────────────────────────────────────── */
    .pager {
        display: flex; align-items: center; gap: var(--s-2);
        padding: 10px 14px; border-top: 1px solid var(--c-border, #ece0cc);
        background: #fbf5e9; flex-wrap: wrap;
    }
    .pager__info { font-size: .78rem; color: var(--c-ink-muted, #998); }
    .pager__nav { display: inline-flex; gap: 4px; margin-left: auto; }
    .pager__btn {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 30px; height: 30px; padding: 0 8px;
        border: 1px solid var(--c-border, #ece0cc);
        background: #fff; color: var(--c-ink, #3b1e0c);
        text-decoration: none; border-radius: 6px;
        font-size: .82rem; font-weight: 600;
    }
    .pager__btn:hover { background: rgba(196,120,48,0.08); border-color: var(--c-accent-strong, #a86010); }
    .pager__btn.is-active {
        background: var(--c-accent-strong, #a86010); color: #fff;
        border-color: var(--c-accent-strong, #a86010);
    }
    .pager__btn.is-disabled { pointer-events: none; opacity: .35; }
    .pager__size { display: inline-flex; align-items: center; gap: 6px; font-size: .78rem; color: var(--c-ink-muted, #998); }
    .pager__size select { padding: 4px 8px; border: 1px solid var(--c-border, #ece0cc); border-radius: 6px; background: #fff; font-size: .82rem; }
</style>

<div class="scadenze-split">
    <aside class="scadenze-cal">
        @{
            var meseLabel = calMese.ToString("MMMM yyyy", it);
            meseLabel = char.ToUpper(meseLabel[0]) + meseLabel[1..];
            var prev = calMese.AddMonths(-1);
            var next = calMese.AddMonths(1);
            var primoGiorno = calMese;
            var ultimoGiorno = calMese.AddMonths(1).AddDays(-1);
            // lunedì = 0
            var startDow = ((int)primoGiorno.DayOfWeek + 6) % 7;
            var giornoFiltrato = (Model.Filtro.Dal.HasValue && Model.Filtro.Al.HasValue && Model.Filtro.Dal.Value.Date == Model.Filtro.Al.Value.Date)
                ? Model.Filtro.Dal!.Value.Date
                : (DateTime?)null;
            var totMese = righePerGiorno.Sum(kv => kv.Value.Sum(r => r.Totale));
            string EurDecLocal(decimal v) => v.ToString("N2", it) + " €";
        }

        <div class="scadenze-cal__head">
            <a class="scadenze-cal__nav" href="@CalUrl(mese: prev)" title="Mese precedente">‹</a>
            <div class="scadenze-cal__title">
                <strong>@meseLabel</strong>
                <div class="muted" style="font-size:.72rem; line-height:1;">@righePerGiorno.Sum(kv => kv.Value.Count) scadenze · @EurDecLocal(totMese)</div>
            </div>
            <a class="scadenze-cal__nav" href="@CalUrl(mese: next)" title="Mese successivo">›</a>
            <button type="button" class="scadenze-cal__pin" data-cal-toggle title="Chiudi calendario" aria-label="Chiudi calendario">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
        </div>

        @if (giornoFiltrato.HasValue)
        {
            <a class="scadenze-cal__clear" href="@CalUrl(mese: calMese, clearDate: true)" title="Rimuovi filtro data">
                ⊗ filtro: @giornoFiltrato.Value.ToString("dd MMM yyyy", it)
            </a>
        }
        else
        {
            <a class="scadenze-cal__clear scadenze-cal__clear--today" href="@CalUrl(mese: new DateTime(oggi.Year, oggi.Month, 1), dataFiltro: oggi)">
                Oggi
            </a>
        }

        <div class="scadenze-cal__grid">
            @foreach (var d in new[] { "L", "M", "M", "G", "V", "S", "D" })
            {
                <div class="scadenze-cal__dow">@d</div>
            }
            @for (var i = 0; i < startDow; i++)
            {
                <div class="scadenze-cal__cell scadenze-cal__cell--blank"></div>
            }
            @for (var d = 1; d <= ultimoGiorno.Day; d++)
            {
                var data = new DateTime(calMese.Year, calMese.Month, d);
                righePerGiorno.TryGetValue(data, out var righe);
                var totGiorno = righe?.Sum(r => r.Totale) ?? 0m;
                var isToday = data == oggi;
                var isSelected = giornoFiltrato.HasValue && giornoFiltrato.Value == data;
                var isPast = data < oggi;

                // Heatmap: intensità relativa al massimo del mese (0..1) → opacity del fill ambra.
                var heat = (maxTotaleGiorno > 0 && totGiorno > 0) ? (double)(totGiorno / maxTotaleGiorno) : 0.0;
                var bgStyle = heat > 0
                    ? $"background: rgba(196, 120, 48, {Math.Round(0.10 + 0.50 * heat, 2).ToString(CultureInfo.InvariantCulture)});"
                    : "";

                // Stati presenti nel giorno (per i pallini)
                var hasOverdue = righe?.Any(r => r.Stato == StatoScadenza.Insoluto) ?? false;
                var hasDaPagare = righe?.Any(r => r.Stato == StatoScadenza.DaPagare && !r.InDistintaSepa) ?? false;
                // Pallino blu = "ha un appuntamento" (programmazione manuale) OPPURE è in distinta SEPA con data esecuzione.
                var hasProgr   = righe?.Any(r => r.Stato == StatoScadenza.Programmato || r.InDistintaSepa) ?? false;
                var hasPagato  = righe?.Any(r => r.Stato == StatoScadenza.Pagato) ?? false;
                var hasMaiPag  = righe?.Any(r => r.Stato == StatoScadenza.MaiPagato) ?? false;

                var clsList = new List<string> { "scadenze-cal__cell" };
                if (isToday)    clsList.Add("is-today");
                if (isSelected) clsList.Add("is-selected");
                if (isPast)     clsList.Add("is-past");
                if (righe is null) clsList.Add("is-empty");

                var tooltip = righe is null
                    ? data.ToString("dd MMM yyyy", it)
                    : $"{data.ToString("dd MMM yyyy", it)} — {righe.Count} scadenz{(righe.Count == 1 ? "a" : "e")} · {EurDecLocal(totGiorno)}";

                <a class="@string.Join(' ', clsList)" style="@bgStyle"
                   href="@CalUrl(mese: calMese, dataFiltro: data)"
                   title="@tooltip">
                    <span class="scadenze-cal__day">@d</span>
                    @if (righe is not null)
                    {
                        <span class="scadenze-cal__amt">@(totGiorno >= 1000 ? $"{Math.Round(totGiorno / 1000, 1).ToString("0.#", it)}k" : Math.Round(totGiorno, 0).ToString("0", it))</span>
                        <span class="scadenze-cal__dots">
                            @if (hasOverdue) { <span class="dot dot--red"   title="Scadute"></span> }
                            @if (hasDaPagare){ <span class="dot dot--amber" title="Da pagare"></span> }
                            @if (hasProgr)   { <span class="dot dot--blue"  title="Programmate"></span> }
                            @if (hasPagato)  { <span class="dot dot--green" title="Pagate"></span> }
                            @if (hasMaiPag)  { <span class="dot dot--grey"  title="Mai pagate"></span> }
                        </span>
                    }
                </a>
            }
        </div>

        <div class="scadenze-cal__legend">
            <span class="dot dot--red"></span>scaduta
            <span class="dot dot--amber"></span>da pagare
            <span class="dot dot--blue"></span>programmata
            <span class="dot dot--green"></span>pagata
        </div>

        @{
            // "Oggi" — sempre calcolato sull'intero set Model.Righe (anche fuori dal mese visibile),
            // così il pannello rimane utile anche navigando i mesi.
            var oggiList = Model.Righe.Where(r => r.DataScadenza.Date == oggi)
                                       .OrderBy(r => r.Stato == StatoScadenza.Pagato ? 1 : 0)
                                       .ThenByDescending(r => r.Totale)
                                       .ToList();
            var oggiTot = oggiList.Sum(r => r.Totale);
        }
        <div class="scadenze-cal__today">
            <div class="scadenze-cal__today-head">
                <strong>📌 Oggi · @oggi.ToString("dddd dd MMM", it)</strong>
                @if (oggiList.Count > 0)
                {
                    <span class="muted" style="font-size:.7rem;">@oggiList.Count · @EurDec(oggiTot)</span>
                }
            </div>
            @if (oggiList.Count == 0)
            {
                <div class="muted" style="font-size:.78rem; padding: var(--s-2) 0;">Nessuna scadenza oggi 🙌</div>
            }
            else
            {
                <ul class="scadenze-cal__today-list">
                    @foreach (var r in oggiList.Take(6))
                    {
                        <li>
                            <span class="dot @(r.Stato == StatoScadenza.Insoluto ? "dot--red" : r.Stato == StatoScadenza.Pagato ? "dot--green" : (r.Stato == StatoScadenza.Programmato || r.InDistintaSepa) ? "dot--blue" : "dot--amber")"></span>
                            <span class="scadenze-cal__today-name" title="@r.FornitoreNome · @r.Categoria.Label()">@r.FornitoreNome</span>
                            <strong class="scadenze-cal__today-amt">@EurDec(r.Totale)</strong>
                        </li>
                    }
                </ul>
                @if (oggiList.Count > 6)
                {
                    <a class="scadenze-cal__today-more" href="@CalUrl(mese: new DateTime(oggi.Year, oggi.Month, 1), dataFiltro: oggi)">vedi tutte →</a>
                }
            }
        </div>
    </aside>

<div class="scadenze-grid" id="scadenze-grid-root">
<div class="card" style="padding:0; margin-bottom: var(--s-4); min-width: 0;" data-grid-card>
    <div class="card__header" style="padding: var(--s-3) var(--s-3) 0; display:flex; align-items:center; gap: var(--s-2);">
        <h3 class="card__title" style="margin: 0;">Scadenze</h3>
        <span class="muted" style="font-size:.85rem;">@Model.Righe.Count righe</span>
        <button type="button"
                class="btn btn--ghost btn--sm"
                data-grid-fullscreen-toggle
                title="Apri la griglia a tutto schermo"
                style="margin-left:auto; display:inline-flex; align-items:center; gap:4px;">
            <span aria-hidden="true">⛶</span>
            <span>A tutto schermo</span>
        </button>
    </div>

    @{
        // Conta i filtri attivi per il riepilogo nel summary del pannello collassabile.
        var filtroAttiviCount = 0;
        if (!string.IsNullOrEmpty(Model.Filtro.Q))           filtroAttiviCount++;
        if (!string.IsNullOrEmpty(Model.Filtro.FornitoreId)) filtroAttiviCount++;
        if (!string.IsNullOrEmpty(Model.Filtro.ClinicaId))   filtroAttiviCount++;
        if (Model.Filtro.Categoria.HasValue)                 filtroAttiviCount++;
        if (Model.Filtro.Stato.HasValue)                     filtroAttiviCount++;
        if (Model.Filtro.Metodo.HasValue)                    filtroAttiviCount++;
        if (Model.Filtro.Dal.HasValue)                       filtroAttiviCount++;
        if (Model.Filtro.Al.HasValue)                        filtroAttiviCount++;
        if (Model.Filtro.SoloFuoriTermini)                   filtroAttiviCount++;
    }

    <details class="tesoreria-filter-wrap" data-persist-key="tesoreria-filtri-aperti">
        <summary>
            <span class="tesoreria-filter-wrap__icon">⚙</span>
            <span>Filtri</span>
            @if (filtroAttiviCount > 0)
            {
                <span class="tesoreria-filter-wrap__count">@filtroAttiviCount attivi</span>
            }
            <span class="tesoreria-filter-wrap__hint muted" style="font-size:.78rem; margin-left:auto;">click per espandere/nascondere</span>
        </summary>

    <form method="get" class="tesoreria-filter" style="display:flex; flex-wrap:wrap; gap:6px; padding: var(--s-3); align-items:center; border-top: 1px solid var(--c-border, #ece0cc); border-bottom: 1px solid var(--c-border, #ece0cc);">
        <style>
            .tesoreria-filter .form-control { font-size: .82rem; padding: 6px 10px; height: 34px; min-width: 0; }
            .tesoreria-filter .btn { height: 34px; }
            .tesoreria-filter .form-check { font-size: .9rem; }
            /* Pulsanti azione sempre alla fine del wrap */
            .tesoreria-filter .filter-actions { margin-left: auto; display: flex; gap: 6px; }
            /* Pannello filtri collassabile */
            .tesoreria-filter-wrap > summary {
                list-style: none; cursor: pointer;
                display: flex; align-items: center; gap: 8px;
                padding: 8px 14px; font-size: .85rem; font-weight: 600; color: var(--c-ink-strong, #3b1e0c);
                background: rgba(196,120,48,0.04);
            }
            .tesoreria-filter-wrap > summary::-webkit-details-marker { display: none; }
            .tesoreria-filter-wrap > summary:hover { background: rgba(196,120,48,0.08); }
            .tesoreria-filter-wrap__icon { display:inline-flex; align-items:center; justify-content:center; width: 22px; height: 22px; border-radius: 50%; background: var(--c-accent, #c47830); color: #fff; font-size: .75rem; }
            .tesoreria-filter-wrap[open] > summary .tesoreria-filter-wrap__icon::after { content: " ▾"; }
            .tesoreria-filter-wrap:not([open]) > summary .tesoreria-filter-wrap__icon::after { content: " ▸"; }
            .tesoreria-filter-wrap__icon::after { font-size: .55rem; margin-left: -1px; }
            .tesoreria-filter-wrap__count {
                display:inline-block; padding: 1px 8px; border-radius: 999px;
                background: var(--c-accent, #c47830); color: #fff; font-size: .68rem; font-weight: 700;
            }
        </style>
        <input class="form-control" name="Q" value="@Model.Filtro.Q" placeholder="🔍 Cerca fornitore, n° doc, note…" style="min-width: 200px; flex: 1 1 200px;" />

        <select class="form-control" name="FornitoreId" title="Fornitore" style="min-width:140px;">
            <option value="">Tutti i fornitori</option>
            @foreach (var f in Model.FornitoriLookup)
            {
                <option value="@f.Id" selected="@(Model.Filtro.FornitoreId == f.Id)">@f.Nome</option>
            }
        </select>

        <select class="form-control" name="ClinicaId" title="Sede" style="min-width:120px;">
            <option value="">Tutte le sedi</option>
            @foreach (var c in Model.CliniceLookup)
            {
                <option value="@c.Id" selected="@(Model.Filtro.ClinicaId == c.Id)">@c.Nome</option>
            }
        </select>

        <select class="form-control" name="Categoria" title="Categoria" style="min-width:160px;">
            <option value="">Tutte le categorie</option>
            @foreach (var v in Enum.GetValues<CategoriaSpesa>().OrderBy(x => x.Label()))
            {
                <option value="@v" selected="@(Model.Filtro.Categoria == v)">@v.Label()</option>
            }
        </select>

        <select class="form-control" name="Stato" title="Stato" style="min-width:120px;">
            <option value="">Tutti gli stati</option>
            @foreach (var v in Enum.GetValues<StatoScadenza>())
            {
                <option value="@v" selected="@(Model.Filtro.Stato == v)">@v.Label()</option>
            }
        </select>

        <select class="form-control" name="Metodo" title="Metodo di pagamento" style="min-width:110px;">
            <option value="">Tutti i metodi</option>
            @foreach (var v in Enum.GetValues<MetodoPagamento>())
            {
                <option value="@v" selected="@(Model.Filtro.Metodo == v)">@v.Label()</option>
            }
        </select>

        <input class="form-control" type="date" name="Dal" value="@Model.Filtro.Dal?.ToString("yyyy-MM-dd")" title="Dal" style="width:140px;" />
        <input class="form-control" type="date" name="Al"  value="@Model.Filtro.Al?.ToString("yyyy-MM-dd")"  title="Al"  style="width:140px;" />

        <label class="form-check" style="white-space:nowrap; display:inline-flex; align-items:center; gap:4px;" title="Mostra solo le scadenze fuori dai termini contrattuali">
            <input type="checkbox" name="SoloFuoriTermini" value="true" @(Model.Filtro.SoloFuoriTermini ? "checked" : "") />
            ⚠️
        </label>

        <div class="filter-actions">
            <button type="submit" class="btn btn--primary btn--sm">Filtra</button>
            <a class="btn btn--ghost btn--sm" asp-action="Index">Reset</a>
        </div>
    </form>
    </details>

        <div id="sepa-toolbar" data-sepa-toolbar style="display:none; padding: 10px 16px; background: #fff7e6; border-top: 1px solid #ece0cc; border-bottom: 1px solid #ece0cc; align-items: center; gap: 12px;">
            <strong style="color:#3b1e0c;">
                <span data-sepa-count>0</span> scadenze selezionate
                · <span data-sepa-total>0,00 €</span>
            </strong>
            <button type="button" class="btn btn--primary btn--sm" data-sepa-open>🏦 Genera distinta SEPA</button>
            <button type="button" class="btn btn--ghost btn--sm" data-sepa-clear>Deseleziona tutto</button>
        </div>

        <div>
            <table class="table" style="font-size: .88rem;">
                @{
                    string SortLink(string col, string label, string? title = null)
                    {
                        // Se la colonna è già attiva, alterno asc↔desc; altrimenti parto da asc.
                        var nextDir = (Model.Filtro.Sort == col && Model.Filtro.Dir == "asc") ? "desc" : "asc";
                        var arrow = (Model.Filtro.Sort == col)
                            ? (Model.Filtro.Dir == "desc" ? " ▼" : " ▲")
                            : "";
                        // CalUrl con clearSort = true così il sort esistente non resta nell'URL
                        // (altrimenti MVC riceverebbe due ?sort= e prenderebbe il primo, ignorando il click).
                        var url = CalUrl(mese: calMese, clearSort: true);
                        var sep = url.Contains('?') ? "&" : "?";
                        url += $"{sep}Sort={col}&Dir={nextDir}";
                        var t = title is null ? "" : $" title=\"{title}\"";
                        return $"<a href=\"{url}\"{t} style=\"color:inherit; text-decoration:none; cursor:pointer;\">{label}<span style=\"opacity:.6\">{arrow}</span></a>";
                    }
                }
                <thead>
                    <tr data-resizable-row>
                        <th style="width: 28px;" data-col="sel"><input type="checkbox" data-sepa-master title="Seleziona tutte le righe bonificabili" /></th>
                        <th data-col="data" style="width: 80px;">@Html.Raw(SortLink("data", "Data", "Scadenza prevista"))<div class="col-resizer" data-col-resizer></div></th>
                        <th data-col="loc"  style="width: 70px;">@Html.Raw(SortLink("loc", "LOC"))<div class="col-resizer" data-col-resizer></div></th>
                        <th data-col="em"   style="width: 50px;">@Html.Raw(SortLink("em", "E/M", "Tipo emissione fattura — E elettronica · M manuale"))<div class="col-resizer" data-col-resizer></div></th>
                        <th data-col="doc"  style="width: 110px;">@Html.Raw(SortLink("doc", "N° Doc"))<div class="col-resizer" data-col-resizer></div></th>
                        <th data-col="forn" style="width: 240px;">@Html.Raw(SortLink("fornitore", "Fornitore / inserita da"))<div class="col-resizer" data-col-resizer></div></th>
                        <th data-col="tot"  style="text-align:right; width: 110px;">@Html.Raw(SortLink("totale", "Totale"))<div class="col-resizer" data-col-resizer></div></th>
                        <th data-col="met"  style="width: 200px;">@Html.Raw(SortLink("metodo", "Met."))<div class="col-resizer" data-col-resizer></div></th>
                        <th data-col="stato" style="width: 160px;">@Html.Raw(SortLink("stato", "Stato"))<div class="col-resizer" data-col-resizer></div></th>
                        <th data-col="act"  style="width: 110px;"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.Righe)
                {
                    var isFiglia = !string.IsNullOrEmpty(r.ScadenzaPadreId);
                    var isPadre  = idPadri.Contains(r.ScadenzaId);
                    var rowStyle = r.MancaIbanFornitore || r.FornitoreSconosciuto
                        ? "background: rgba(168,58,58,0.06); border-left: 3px solid #a83a3a;"
                        : r.ScadenzaFuoriTermini
                            ? "background: rgba(255,165,0,0.05); border-left: 3px solid #c47830;"
                            : r.Stato == StatoScadenza.Insoluto
                                ? "background: rgba(168,58,58,0.06);"
                                : r.Stato == StatoScadenza.MaiPagato
                                    ? "background: rgba(120,120,120,0.06); opacity:.7;"
                                    : "";
                    var bonificabile = r.Stato == StatoScadenza.DaPagare
                        && !r.InDistintaSepa // già inclusa in una distinta: niente doppia inclusione
                        && !r.BonificoMultiploCbi // BM va in distinta CBI multipla, non SEPA singola
                        && !r.MancaIbanFornitore // senza IBAN valido la distinta SEPA verrebbe scartata
                        && (r.Metodo == MetodoPagamento.Bonifico || r.Metodo == MetodoPagamento.Altro);
                    var totaleTooltip = $"Imponibile {EurDec(r.Imponibile)} · IVA {EurDec(r.Iva)} · Categoria {r.Categoria.Label()}";
                    var insertaTooltip = $"Caricata il {r.CaricataIl.ToLocalTime():dd/MM/yyyy HH:mm}";
                    var origineLabel = r.Origine == OrigineFattura.PortaleFornitore ? "📥 Portale fornitore"
                                     : r.Origine == OrigineFattura.ImportExcel ? "📊 Import Excel"
                                     : "🖋 Back-office";
                    <tr style="@rowStyle" data-padre-id="@r.ScadenzaPadreId">
                        <td>
                            @if (bonificabile)
                            {
                                <input type="checkbox" class="sepa-row" data-id="@r.ScadenzaId" data-amount="@r.Totale.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" />
                            }
                        </td>
                        <td>
                            @if (isFiglia) { <span title="Scadenza derivata (es. F24 / ritenute)" style="color:#c47830; margin-right:4px;">↳</span> }
                            <strong>@r.DataScadenza.ToString("dd/MM/yy")</strong>
                            @if (r.ScadenzaFuoriTermini)
                            {
                                var deltaTxt = r.GiorniDelta!.Value > 0 ? $"+{r.GiorniDelta} gg" : $"{r.GiorniDelta} gg";
                                <span title="Scadenza dichiarata diverge dai termini contratto di @deltaTxt (atteso @r.DataScadenzaAttesa?.ToString("dd/MM/yy"))" style="color:#c47830; font-weight:600; cursor:help;">⚠️</span>
                            }
                            <div class="muted" style="font-size: .72rem; line-height: 1;">@r.MeseCompetenza</div>
                        </td>
                        <td>
                            <code>@r.Loc</code>
                            @if (r.IsHolding) { <span class="badge" title="Soggetto pagatore: holding del gruppo" style="margin-left:4px; background:#3b1e0c; color:#f5e8d0; font-size:.62rem;">HOLDING</span> }
                        </td>
                        <td title="@r.TipoEmissione.LabelEsteso()" style="text-align:center; font-weight:600; color: @(r.TipoEmissione == TipoEmissioneFattura.Elettronica ? "#2d7a50" : (r.TipoEmissione == TipoEmissioneFattura.Manuale ? "#c47830" : "#bbb"));">
                            @r.TipoEmissione.Label()
                        </td>
                        <td>
                            @r.NumeroDoc
                            @if (r.HasAllegato)
                            {
                                <a class="muted" href="@Url.Action("ScaricaAllegatoFattura", new { id = r.FatturaId })" title="Scarica allegato">📎</a>
                            }
                        </td>
                        <td>
                            <strong>@r.FornitoreNome</strong>
                            @if (r.HaProblemi)
                            {
                                var problemiTxt = string.Join(" · ", r.Problemi);
                                <span title="@problemiTxt" style="color:#a83a3a; font-weight:600; cursor:help; margin-left:4px;">⚠️</span>
                            }
                            <div class="muted" style="font-size: .7rem; line-height: 1.1;">@r.Categoria.Label()</div>
                            @if (r.MancaIbanFornitore)
                            {
                                <div style="font-size:.68rem; color:#a83a3a; line-height:1.2; margin-top:2px;" title="Senza IBAN valido la scadenza non può essere inclusa in una distinta SEPA.">
                                    🏦 IBAN mancante
                                </div>
                            }
                            else if (r.FornitoreSconosciuto)
                            {
                                <div style="font-size:.68rem; color:#a83a3a; line-height:1.2; margin-top:2px;">
                                    fornitore non in anagrafica
                                </div>
                            }
                            <div class="muted" style="font-size: .68rem; line-height: 1.2; margin-top: 2px;" title="@insertaTooltip">
                                @origineLabel · @r.CaricataDaNome · @r.CaricataIl.ToLocalTime().ToString("dd/MM/yy")
                            </div>
                            @if (!string.IsNullOrWhiteSpace(r.Note))
                            {
                                <div style="font-size:.68rem; line-height:1.25; margin-top:3px; padding:3px 6px; background:rgba(196,120,48,0.08); border-left:2px solid #c47830; border-radius:2px; color:#5a3f1f;" title="@r.Note">
                                    📝 @r.Note
                                </div>
                            }
                        </td>
                        <td style="text-align:right;" title="@totaleTooltip"><strong>@EurDec(r.Totale)</strong></td>
                        <td>
                            <span class="badge">@r.Metodo.Label()</span>
                            @if (r.BonificoMultiploCbi)
                            {
                                <span class="badge" title="Bonifico Multiplo CBI: incluso in distinta multi-beneficiario, non in SEPA singola" style="margin-left:4px; background:#fff7e6; color:#c47830;">CBI</span>
                            }
                            @{
                                var ibanOrd = r.IbanOrdinante;
                                var ibanBen = r.Iban;
                            }
                            <div class="iban-flow" tabindex="0">
                                <div class="iban-flow__row">
                                    <span class="iban-flow__label">da</span>
                                    <code class="iban-flow__val @(string.IsNullOrWhiteSpace(ibanOrd) ? "iban-flow__val--missing" : null)">@ShortIban(ibanOrd)</code>
                                </div>
                                <div class="iban-flow__row">
                                    <span class="iban-flow__label">a</span>
                                    <code class="iban-flow__val @(string.IsNullOrWhiteSpace(ibanBen) ? "iban-flow__val--missing" : null)">@ShortIban(ibanBen)</code>
                                </div>

                                <div class="iban-pop" role="tooltip" aria-hidden="true">
                                    <div class="iban-pop__title">
                                        <span class="iban-pop__icon">🏦</span>
                                        <span>Disposizione di pagamento</span>
                                        <strong class="iban-pop__amt">@EurDec(r.Totale)</strong>
                                    </div>
                                    <div class="iban-pop__leg iban-pop__leg--from">
                                        <div class="iban-pop__role">↑ Ordinante (paga)</div>
                                        <div class="iban-pop__entity">@(string.IsNullOrWhiteSpace(r.SocietaNome) ? "—" : r.SocietaNome)</div>
                                        <div class="iban-pop__iban">@(string.IsNullOrWhiteSpace(ibanOrd) ? "IBAN non configurato" : ibanOrd)</div>
                                        @if (!string.IsNullOrWhiteSpace(r.BicOrdinante))
                                        {
                                            <div class="iban-pop__meta">BIC @r.BicOrdinante</div>
                                        }
                                    </div>
                                    <div class="iban-pop__arrow" aria-hidden="true">
                                        <span>↓</span>
                                        <span class="iban-pop__arrow-meta">@r.Metodo.Label()</span>
                                    </div>
                                    <div class="iban-pop__leg iban-pop__leg--to">
                                        <div class="iban-pop__role">↓ Beneficiario (riceve)</div>
                                        <div class="iban-pop__entity">@r.FornitoreNome</div>
                                        <div class="iban-pop__iban">@(string.IsNullOrWhiteSpace(ibanBen) ? "IBAN non disponibile" : ibanBen)</div>
                                    </div>
                                    <div class="iban-pop__foot">
                                        Scadenza @r.DataScadenza.ToString("dd/MM/yyyy") · @r.Categoria.Label()
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @Html.Raw(StatoBadge(r.Stato))
                            @if (r.InDistintaSepa)
                            {
                                <span class="badge" title="Inclusa in distinta SEPA del @r.DataProgrammata?.ToString("dd/MM/yyyy")"
                                      style="margin-left:4px; background:#e3edff; color:#2457a4; font-size:.65rem;">🏦 in distinta</span>
                            }
                            @if (r.Stato == StatoScadenza.Programmato && r.DataProgrammata.HasValue)
                            {
                                <div class="muted" style="font-size: .68rem; line-height: 1.2; margin-top: 2px;">
                                    il @r.DataProgrammata.Value.ToString("dd/MM/yy")
                                </div>
                            }
                            else if (r.InDistintaSepa && r.DataProgrammata.HasValue)
                            {
                                <div class="muted" style="font-size: .68rem; line-height: 1.2; margin-top: 2px;">
                                    esecuzione il @r.DataProgrammata.Value.ToString("dd/MM/yy")
                                </div>
                            }
                            else if (r.Stato == StatoScadenza.Pagato && r.DataPagamento.HasValue)
                            {
                                <div class="muted" style="font-size: .68rem; line-height: 1.2; margin-top: 2px;">
                                    il @r.DataPagamento.Value.ToString("dd/MM/yy")
                                </div>
                            }
                        </td>
                        <td style="white-space:nowrap;">
                            <button type="button" class="btn btn--ghost btn--sm" data-edit-trigger data-id="@r.ScadenzaId" title="Dettagli e modifica">ℹ️</button>
                            @if (r.Stato == StatoScadenza.DaPagare || r.Stato == StatoScadenza.Insoluto)
                            {
                                <button type="button" class="btn btn--ghost btn--sm" data-pay-trigger data-id="@r.ScadenzaId" title="Segna pagato">✓</button>
                                <button type="button" class="btn btn--ghost btn--sm" data-schedule-trigger data-id="@r.ScadenzaId" title="Programma">📅</button>
                            }
                            else if (r.Stato == StatoScadenza.Programmato)
                            {
                                <button type="button" class="btn btn--ghost btn--sm" data-pay-trigger data-id="@r.ScadenzaId" title="Conferma pagato">✓</button>
                            }
                        </td>
                    </tr>
                }
                @if (Model.Righe.Count == 0)
                {
                    <tr><td colspan="10" class="muted" style="text-align:center; padding: var(--s-5);">Nessuna scadenza per i filtri impostati.</td></tr>
                }
                </tbody>
            </table>
        </div>

        @{
            // Paginazione: link che preservano i query string esistenti (filtri,
            // sort, dir, size). Costruiamo via Url.Action mantenendo Model.Filtro
            // serializzato come dictionary. La sintesi mostra "X–Y su N" e la
            // dropdown del page size ricarica con l'attributo onchange.
            int paginaCorr = Model.Pagina;
            int pagineTot  = Model.PagineTotali;
            int pageStart  = pagineTot == 0 ? 0 : (paginaCorr - 1) * Model.RighePerPagina + 1;
            int pageEnd    = Math.Min(Model.RigheTotali, paginaCorr * Model.RighePerPagina);

            Dictionary<string, object?> PageRoute(int page, int? size = null)
            {
                var d = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
                void put(string k, object? v) { if (v != null && !(v is string s && string.IsNullOrEmpty(s))) d[k] = v; }
                put("FornitoreId", Model.Filtro.FornitoreId);
                put("ClinicaId",   Model.Filtro.ClinicaId);
                put("Categoria",   Model.Filtro.Categoria);
                put("Stato",       Model.Filtro.Stato);
                put("Metodo",      Model.Filtro.Metodo);
                put("Dal",         Model.Filtro.Dal?.ToString("yyyy-MM-dd"));
                put("Al",          Model.Filtro.Al?.ToString("yyyy-MM-dd"));
                put("Q",           Model.Filtro.Q);
                if (Model.Filtro.SoloFuoriTermini) d["SoloFuoriTermini"] = true;
                put("Sort",        Model.Filtro.Sort);
                put("Dir",         Model.Filtro.Dir);
                d["Page"] = page;
                d["Size"] = size ?? Model.RighePerPagina;
                return d;
            }
            // Costruisce la "finestra" di numeri pagina mostrati: max 7 link
            // attorno alla pagina corrente, con primo/ultimo sempre visibili.
            var pageWindow = new List<int>();
            if (pagineTot <= 7)
            {
                for (int i = 1; i <= pagineTot; i++) pageWindow.Add(i);
            }
            else
            {
                pageWindow.Add(1);
                int start = Math.Max(2, paginaCorr - 2);
                int end   = Math.Min(pagineTot - 1, paginaCorr + 2);
                if (start > 2) pageWindow.Add(-1); // ellipsis
                for (int i = start; i <= end; i++) pageWindow.Add(i);
                if (end < pagineTot - 1) pageWindow.Add(-1);
                pageWindow.Add(pagineTot);
            }
        }
        <div class="pager">
            <div class="pager__info">
                @if (Model.RigheTotali == 0)
                {
                    <span>Nessuna scadenza</span>
                }
                else
                {
                    <span><strong>@pageStart–@pageEnd</strong> su <strong>@Model.RigheTotali</strong> scadenze</span>
                }
            </div>
            <div class="pager__size">
                Righe per pagina
                <select onchange="window.location = this.options[this.selectedIndex].dataset.url;">
                    @foreach (var sz in new[] { 25, 50, 100, 200 })
                    {
                        var url = Url.Action(null, PageRoute(1, sz));
                        <option value="@sz" data-url="@url" selected="@(sz == Model.RighePerPagina)">@sz</option>
                    }
                </select>
            </div>
            <nav class="pager__nav" aria-label="Paginazione scadenze">
                @{
                    var prevUrl = Url.Action(null, PageRoute(Math.Max(1, paginaCorr - 1)));
                    var nextUrl = Url.Action(null, PageRoute(Math.Min(pagineTot, paginaCorr + 1)));
                    var firstUrl = Url.Action(null, PageRoute(1));
                    var lastUrl  = Url.Action(null, PageRoute(pagineTot));
                }
                <a class="pager__btn @(paginaCorr <= 1 ? "is-disabled" : "")" href="@firstUrl" title="Prima pagina" aria-label="Prima pagina">«</a>
                <a class="pager__btn @(paginaCorr <= 1 ? "is-disabled" : "")" href="@prevUrl" title="Pagina precedente" aria-label="Pagina precedente">‹</a>
                @foreach (var p in pageWindow)
                {
                    if (p == -1)
                    {
                        <span class="pager__btn is-disabled" aria-hidden="true">…</span>
                    }
                    else
                    {
                        var url = Url.Action(null, PageRoute(p));
                        <a class="pager__btn @(p == paginaCorr ? "is-active" : "")" href="@url" aria-label="Pagina @p" aria-current="@(p == paginaCorr ? "page" : null)">@p</a>
                    }
                }
                <a class="pager__btn @(paginaCorr >= pagineTot ? "is-disabled" : "")" href="@nextUrl" title="Pagina successiva" aria-label="Pagina successiva">›</a>
                <a class="pager__btn @(paginaCorr >= pagineTot ? "is-disabled" : "")" href="@lastUrl" title="Ultima pagina" aria-label="Ultima pagina">»</a>
            </nav>
        </div>
    </div>
</div><!-- /scadenze-grid -->
</div><!-- /scadenze-split -->
</section><!-- /tab scadenze -->

<!-- ── Tab: Regole dello scadenziario ─────────────────────────── -->
<section data-tab-pane="regole" style="@(activeTab == "regole" ? "" : "display:none;")">
    <div class="regole-grid">
        <!-- Colonna 1: regole built-in (sempre attive nel motore) -->
        <div class="card" style="padding: var(--s-4);">
            <h3 class="card__title" style="margin-top:0;">⚙️ Regole built-in (sempre applicate dal motore)</h3>
            <p class="muted" style="font-size:.85rem; margin-top:0;">
                Queste regole sono codificate nel motore <code>ScadenziarioGenerator</code>
                e vengono applicate ad ogni rigenerazione. Documento canonico:
                <code>docs/REGOLE_SCADENZIARIO.md</code>.
            </p>

            <details class="regola-block" open>
                <summary><strong>1. Classificazione del fornitore</strong> per tipo operativo</summary>
                <p>Ogni fornitore viene classificato (Medico, Direzione Sanitaria, Laboratorio,
                Invisalign, Carta di credito, Compass, Deutsche Bank, Locazione, Importo Fisso, RIBA,
                Generico) leggendo nome e causale. La classificazione governa termini di pagamento e snap.</p>
            </details>

            <details class="regola-block">
                <summary><strong>2. Match fornitore</strong> per P.IVA → CF → Ragione sociale</summary>
                <p>I fornitori vengono matchati con l'anagrafica prima per P.IVA, poi per Codice Fiscale,
                infine per nome normalizzato. Se non trovato, viene autocreato con codice F#### progressivo.</p>
            </details>

            <details class="regola-block">
                <summary><strong>3. Risoluzione LOC</strong> (clinica destinataria)</summary>
                <p>Priorità: (1) cessionario PDF → Società → Clinica via <code>Clinica.SocietaId</code>;
                (2) sezione CSV "CCH" → holding; (3) sigla LOC rilevata nel testo descrittivo del PDF;
                (4) match su <code>Clinica.NomeAbbreviato</code>; (5) tabella statica di fallback.</p>
            </details>

            <details class="regola-block">
                <summary><strong>4. Mese di competenza</strong></summary>
                <p>Estratto con priorità: PDF (Periodo di riferimento) → causale CSV (regex sui mesi italiani)
                → fallback al mese della data fattura. Usato anche per calcolare la scadenza 60gg FM dei medici.</p>
            </details>

            <details class="regola-block">
                <summary><strong>5. Termini di pagamento</strong> per tipologia</summary>
                <p>Medici / Direzione Sanitaria / Laboratorio: 60 giorni fine mese di competenza.<br/>
                Invisalign: 150 giorni dalla data fattura.<br/>
                Generici: termini configurati sul fornitore (default 30gg fine mese).</p>
            </details>

            <details class="regola-block">
                <summary><strong>6. Snap dei bonifici</strong> al 10 o al 30/31</summary>
                <p>I bonifici sono programmati SOLO al giorno 10 o al 30/31 del mese. Le date calcolate
                vengono "snappate" al giorno più vicino. Invisalign anticipa per difetto.</p>
            </details>

            <details class="regola-block">
                <summary><strong>7. RID / RIBA</strong> copiano la data scadenza del documento</summary>
                <p>Per Compass / Deutsche Bank (RID) e fornitori RIBA si copia la data scadenza letta dal PDF.
                Se il PDF non l'ha esposta, fallback ai termini contrattuali + alert.</p>
            </details>

            <details class="regola-block">
                <summary><strong>8. Ritenuta d'acconto</strong> separa netto + F24</summary>
                <p>Quando la fattura ha ritenuta, si generano due scadenze: il netto (bonifico al fornitore)
                e la ritenuta (F24 al 16 del mese successivo). La rata F24 è figlia della principale.</p>
            </details>

            <details class="regola-block">
                <summary><strong>9. Note di credito</strong></summary>
                <p>Importo registrato in negativo. NC Compass/DB → RID compensativa marcata pagata.
                NC generiche → bonifico fine mese fattura con alert "verificare compensazione".</p>
            </details>

            <details class="regola-block">
                <summary><strong>10. Carta di credito</strong> → già pagato</summary>
                <p>Le fatture di Amex / American Express vengono registrate come Pagato alla data fattura
                con riferimento "estratto conto".</p>
            </details>

            <details class="regola-block">
                <summary><strong>11. «Pagamenti manuali»</strong> (override globale)</summary>
                <p>Se <code>Fornitore.PagamentiManuali = true</code>, la fattura è registrata ma NON viene
                generata alcuna scadenza. La posizione confluisce nell'alert "pagamenti manuali" per
                il calcolo a mano (vince su tutte le altre regole).</p>
            </details>

            <details class="regola-block">
                <summary><strong>12. «Fattura dopo il pagamento»</strong> → scadenza già pagata</summary>
                <p>Se <code>Fornitore.EmissioneFattura = DopoIlPagamento</code>, tutte le scadenze generate
                vengono marcate come Pagato alla data fattura (il bonifico è già stato disposto).</p>
            </details>

            <details class="regola-block">
                <summary><strong>13. Note del fornitore</strong> in coda alla scadenza</summary>
                <p>La nota primaria (<code>Fornitore.Note</code>) viene SEMPRE concatenata a <code>Scadenza.Note</code>.
                La nota secondaria viene aggiunta solo se il flag <code>AggiungiNotaSecondariaAutomaticamente</code>
                è true. Stessa cosa per il blocco clinica (cumulativo).</p>
            </details>

            <details class="regola-block">
                <summary><strong>14. Duplicate detection</strong> & scostamento importo</summary>
                <p>Cristal / Infinity / Locazioni: alert se l'importo differisce dalla fattura precedente.
                Altri fornitori: alert se stesso importo + ≤ 60gg dalla precedente (possibile doppione).</p>
            </details>

            <details class="regola-block">
                <summary><strong>15. Codice scadenza</strong> SC-YYYYMM-NNNN</summary>
                <p>Ogni scadenza riceve un codice progressivo per anno+mese della data scadenza al momento
                della generazione (es. <code>SC-202604-0017</code>). Le scadenze pre-esistenti vengono
                backfilled al primo avvio.</p>
            </details>
        </div>

        <!-- Colonna 2: regole custom dell'utente -->
        <div class="card" style="padding: var(--s-4);">
            <h3 class="card__title" style="margin-top:0;">🧠 Le tue regole personalizzate</h3>
            <div class="alert alert--info" style="font-size:.82rem; margin: 0 0 var(--s-3);">
                <strong>Come funziona oggi:</strong> scrivi la regola in italiano. Viene salvata e mostrata
                come <em>promemoria all'operatore</em> nella pagina «Genera scadenziario» e nell'analisi AI.
                <br/>
                <strong>Roadmap:</strong> l'interpretazione automatica (LLM → modifica del motore) sarà
                attivata in un secondo step. Per ora il motore segue solo le regole built-in qui sopra.
            </div>

            <form method="post" asp-action="NuovaRegolaCustom" style="margin-bottom: var(--s-3);">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Titolo breve</label>
                    <input class="form-control" name="titolo" required maxlength="120"
                           placeholder="es. «Royalties pagate sempre il 15 del mese successivo»" />
                </div>
                <div class="form-group">
                    <label class="form-label">Regola (linguaggio naturale)</label>
                    <textarea class="form-control" name="testo" required rows="3"
                              placeholder="Scrivi la regola come la racconteresti a un collega. Esempi:&#10;• Se il fornitore è AGESP, paga sempre il 30 del mese.&#10;• Per le fatture del laboratorio Romano, sposta la scadenza a 90 giorni invece di 60.&#10;• Quando l'importo supera 5000€, segnala come «da approvare» prima di pagare."></textarea>
                </div>
                <button type="submit" class="btn btn--primary">＋ Aggiungi regola</button>
            </form>

            @if (Model.RegoleCustom.Count == 0)
            {
                <div class="muted" style="text-align:center; padding: var(--s-4); border: 1px dashed var(--c-border, #ece0cc); border-radius: 8px;">
                    Nessuna regola personalizzata. Aggiungila qui sopra.
                </div>
            }
            else
            {
                <ul class="regola-list">
                    @foreach (var r in Model.RegoleCustom)
                    {
                        <li class="regola-item @(r.Attiva ? "" : "is-disabled")">
                            <div class="regola-item__head">
                                <strong>@r.Titolo</strong>
                                <span class="regola-item__badge regola-item__badge--@r.Stato.ToString().ToLowerInvariant()">
                                    @(r.Stato == StatoRegola.Interpretata ? "✓ interpretata" :
                                      r.Stato == StatoRegola.Errore ? "⚠ errore" : "🕓 promemoria")
                                </span>
                                @if (!r.Attiva)
                                {
                                    <span class="regola-item__badge regola-item__badge--off">disattivata</span>
                                }
                            </div>
                            <p class="regola-item__text">@r.Testo</p>
                            @if (!string.IsNullOrWhiteSpace(r.NotaInterpretazione))
                            {
                                <p class="regola-item__nota">🤖 @r.NotaInterpretazione</p>
                            }
                            <div class="regola-item__foot">
                                <span class="muted">creata da @r.CreataDaNome · @r.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                <form method="post" asp-action="ToggleRegolaCustom" asp-route-id="@r.Id" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn--ghost btn--sm">@(r.Attiva ? "Disattiva" : "Riattiva")</button>
                                </form>
                                <form method="post" asp-action="EliminaRegolaCustom" asp-route-id="@r.Id" style="display:inline;"
                                      onsubmit="return confirm('Eliminare la regola «@r.Titolo»?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn--ghost btn--sm" style="color:#a83a3a;">Elimina</button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</section><!-- /tab regole -->

<!-- ── Modale AI: analisi euristica con UX "machine learning" ──── -->
<dialog id="dlg-ai" class="dlg-ai" aria-label="Analisi AI dello scadenziario">
