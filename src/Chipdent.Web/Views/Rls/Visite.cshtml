@model IReadOnlyList<Chipdent.Web.Domain.Entities.VisitaMedica>
@{
    ViewData["Title"] = "Visite mediche";
    var dipendenti = (Dictionary<string, string>?)ViewData["Dipendenti"] ?? new();
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>RLS / Sicurezza</h2>
        <p class="page-head__sub">Visite mediche periodiche dei dipendenti</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--primary" asp-action="CreateVisita">+ Nuova visita</a>
    </div>
</div>

<partial name="_Tabs" />

@if (Model.Count == 0)
{
    <div class="card">
        <div class="empty">
            <div class="empty__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <h3>Nessuna visita registrata</h3>
            <p>Aggiungi la prima visita medica per un dipendente.</p>
        </div>
    </div>
}
else
{
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr><th>Dipendente</th><th>Data</th><th>Esito</th><th>Scadenza idoneità</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    var nome = dipendenti.GetValueOrDefault(v.DipendenteId, "—");
                    var scaduta = v.ScadenzaIdoneita is not null && v.ScadenzaIdoneita < DateTime.UtcNow;
                    var inScad = v.ScadenzaIdoneita is not null && v.ScadenzaIdoneita >= DateTime.UtcNow && v.ScadenzaIdoneita < DateTime.UtcNow.AddMonths(3);
                    <tr>
                        <td><div class="strong">@nome</div></td>
                        <td>@v.Data.ToString("dd/MM/yyyy")</td>
                        <td>
                            @switch (v.Esito)
                            {
                                case Chipdent.Web.Domain.Entities.EsitoVisita.Idoneo:
                                    <span class="badge badge--success"><span class="dot"></span>idoneo</span>
                                    break;
                                case Chipdent.Web.Domain.Entities.EsitoVisita.IdoneoConPrescrizioni:
                                    <span class="badge badge--warning"><span class="dot"></span>idoneo con prescrizioni</span>
                                    break;
                                case Chipdent.Web.Domain.Entities.EsitoVisita.NonIdoneo:
                                    <span class="badge badge--danger"><span class="dot"></span>non idoneo</span>
                                    break;
                                default:
                                    <span class="badge"><span class="dot"></span>sospesa</span>
                                    break;
                            }
                        </td>
                        <td>
                            @(v.ScadenzaIdoneita?.ToString("dd/MM/yyyy") ?? "—")
                            @if (scaduta) { <span class="badge badge--danger" style="margin-left:6px;"><span class="dot"></span>scaduta</span> }
                            else if (inScad) { <span class="badge badge--warning" style="margin-left:6px;"><span class="dot"></span>in scadenza</span> }
                        </td>
                        <td class="actions">
                            <a class="ibtn" asp-action="EditVisita" asp-route-id="@v.Id" title="Modifica">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
