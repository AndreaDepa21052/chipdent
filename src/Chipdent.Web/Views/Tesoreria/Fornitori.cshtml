@model Chipdent.Web.Models.FornitoriIndexViewModel
@using Chipdent.Web.Domain.Entities
@using System.Globalization
@{
    ViewData["Title"] = "Fornitori";
    ViewData["Crumb"] = "Tesoreria";
    var it = new CultureInfo("it-IT");
    var senzaSepa = Model.Fornitori.Count(r => r.Fornitore.Stato == StatoFornitore.Attivo && !r.Completezza.SepaPronto);
    // Categorie sempre ordinate alfabeticamente per uso nelle select.
    var categorie = Enum.GetValues<CategoriaSpesa>()
        .OrderBy(c => c.ToString(), StringComparer.OrdinalIgnoreCase)
        .ToList();
    var cliniche = Model.Cliniche;
    var clinicheById = cliniche.ToDictionary(c => c.Id, c => c.Nome);
}

<partial name="_Flash" />

<div class="page-head">
    <div class="forn-title-zone">
        <h2 class="forn-title">
            <span class="forn-title__icon" id="forn-title-icon">👥</span>
            <span>Fornitori</span>
            @if (senzaSepa > 0)
            {
                <span class="forn-title__pulse" aria-hidden="true"></span>
            }
        </h2>
        <p class="page-head__sub">Anagrafica passiva. Click sulle intestazioni per ordinare, trascina il bordo destro per ridimensionare le colonne.</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Tesoreria</a>
        <a class="btn btn--primary" asp-action="NuovoFornitore">＋ Nuovo fornitore</a>
    </div>
</div>

@if (senzaSepa > 0)
{
    <div class="forn-callout" data-forn-callout role="alert">
        <span class="forn-callout__caret" aria-hidden="true"></span>
        <span class="forn-callout__icon" aria-hidden="true">⚠️</span>
        <div class="forn-callout__body">
            <strong>@senzaSepa fornitor@(senzaSepa == 1 ? "e" : "i") attiv@(senzaSepa == 1 ? "o" : "i") con dati SEPA incompleti.</strong>
            <span class="muted">Senza IBAN valido (e dati anagrafici minimi) non è possibile generare la distinta di incasso/pagamento SEPA.</span>
        </div>
        <button type="button" class="forn-callout__close" data-forn-callout-close aria-label="Chiudi avviso">×</button>
    </div>
}

<form id="forn-antiforgery-host" style="display:none;">
    @Html.AntiForgeryToken()
</form>

@if (Model.Fornitori.Count == 0)
{
    <div class="card">
        <p class="muted">Nessun fornitore registrato. Inizia da "Nuovo fornitore" o usa il seed dimostrativo.</p>
    </div>
}
else
{
    <div data-table-search>
        <div class="forn-controls">
            <partial name="_TableSearch" model='new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData) { ["Placeholder"] = "Cerca fornitore per ragione sociale, categoria…", ["Singular"] = "fornitore", ["Plural"] = "fornitori" }' />
            <label class="forn-switch" title="Nasconde i fornitori-ombra collegati a dottori">
                <input type="checkbox" id="forn-hide-dottori" />
                <span class="forn-switch__track"><span class="forn-switch__thumb"></span></span>
                <span class="forn-switch__label">Non farmi vedere i dottori</span>
            </label>
        </div>
        <div class="table-search__empty">Nessun fornitore corrisponde alla ricerca.</div>
    <div class="card forn-grid-card" style="padding:0;">
        <table class="table forn-grid" id="fornitori-grid">
            <thead>
                <tr>
                    <th data-sort-key="codice" data-col="codice" style="width:56px;">
                        <span class="th-label">Codice</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-sort-key="ragsoc" data-col="ragsoc" style="width:11%;">
                        <span class="th-label">Ragione sociale</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-sort-key="ragsocpag" data-col="ragsocpag" style="width:11%;">
                        <span class="th-label">Rag. soc. pagamento</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-sort-key="cat1" data-col="cat1" style="width:11%;">
                        <span class="th-label">Cat. primaria</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-sort-key="cat2" data-col="cat2" style="width:11%;">
                        <span class="th-label">Cat. secondaria</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-sort-key="sede" data-col="sede" style="width:9%;">
                        <span class="th-label">Sede rif.</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-sort-key="stato" data-col="stato" style="width:74px;">
                        <span class="th-label">Stato</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-sort-key="completezza" data-col="completezza" title="Percentuale di completezza dell'anagrafica + dati SEPA. I campi SEPA pesano il doppio." style="width:88px;">
                        <span class="th-label">Compl.</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-sort-key="sepa" data-col="sepa" style="width:52px;">
                        <span class="th-label">SEPA</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-sort-key="esposto" data-col="esposto" data-sort-type="number" style="width:78px; text-align:right;">
                        <span class="th-label">Esposto</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-sort-key="ytd" data-col="ytd" data-sort-type="number" style="width:54px; text-align:right;">
                        <span class="th-label">YTD</span><span class="th-sort"></span><span class="th-resizer"></span>
                    </th>
                    <th data-col="azioni" style="width:104px;">
                        <span class="th-label"></span><span class="th-resizer"></span>
                    </th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model.Fornitori)
            {
                var perc = r.Completezza.Percentuale;
                var barColor = perc >= 90 ? "#3aa15b" : perc >= 60 ? "#c47830" : "#a83a3a";
                var tooltipMancanti = r.Completezza.TuttiCampiMancanti.Count == 0
                    ? "Tutti i dati anagrafici sono completi."
                    : "Campi mancanti: " + string.Join(", ", r.Completezza.TuttiCampiMancanti);
                var rsPagamento = string.IsNullOrWhiteSpace(r.Fornitore.RagioneSocialePagamento)
                    ? r.Fornitore.RagioneSociale
                    : r.Fornitore.RagioneSocialePagamento;
                var statoUi = r.Fornitore.Stato == StatoFornitore.Attivo ? StatoFornitore.Attivo : StatoFornitore.Dismesso;
                var statoSortRank = statoUi == StatoFornitore.Attivo ? 0 : 1;
                var sepaSortRank = r.Completezza.SepaPronto ? 0 : 1;
                <tr data-forn-row data-id="@r.Fornitore.Id" data-label="@r.Fornitore.RagioneSociale" data-is-dottore="@(string.IsNullOrEmpty(r.Fornitore.DottoreId) ? "0" : "1")">
                    <td class="muted" data-col="codice" data-sort-value="@(r.Fornitore.Codice ?? "")">
                        @(string.IsNullOrEmpty(r.Fornitore.Codice) ? "—" : r.Fornitore.Codice)
                        @* _TableSearch indicizza textContent; rendiamo cercabili anche i valori degli <input>. *@
                        <span style="display:none;" data-search-blob>@r.Fornitore.RagioneSociale @rsPagamento @r.Fornitore.CategoriaDefault @(r.Fornitore.CategoriaSecondaria?.ToString() ?? "")</span>
                    </td>
                    <td data-col="ragsoc" data-sort-value="@r.Fornitore.RagioneSociale">
                        <input class="inline-input" data-field="RagioneSociale" value="@r.Fornitore.RagioneSociale" />
                    </td>
                    <td data-col="ragsocpag" data-sort-value="@rsPagamento">
                        <input class="inline-input" data-field="RagioneSocialePagamento" value="@rsPagamento" placeholder="(uguale alla ragione sociale)" />
                    </td>
                    <td data-col="cat1" data-sort-value="@r.Fornitore.CategoriaDefault">
                        <select class="inline-input" data-field="CategoriaDefault">
                            @foreach (var c in categorie)
                            {
                                <option value="@c" selected="@(r.Fornitore.CategoriaDefault == c)">@c</option>
                            }
                        </select>
                    </td>
                    <td data-col="cat2" data-sort-value="@(r.Fornitore.CategoriaSecondaria?.ToString() ?? "")">
                        <select class="inline-input" data-field="CategoriaSecondaria">
                            <option value="" selected="@(r.Fornitore.CategoriaSecondaria == null)">— nessuna —</option>
                            @foreach (var c in categorie)
                            {
                                <option value="@c" selected="@(r.Fornitore.CategoriaSecondaria == c)">@c</option>
                            }
                        </select>
                    </td>
                    @{
                        var sedeNome = !string.IsNullOrEmpty(r.Fornitore.SedeRiferimentoId)
                            && clinicheById.TryGetValue(r.Fornitore.SedeRiferimentoId!, out var sn)
                            ? sn
                            : "";
                    }
                    <td data-col="sede" data-sort-value="@sedeNome">
                        <select class="inline-input" data-field="SedeRiferimentoId">
                            <option value="" selected="@string.IsNullOrEmpty(r.Fornitore.SedeRiferimentoId)">— nessuna —</option>
                            @foreach (var c in cliniche)
                            {
                                <option value="@c.Id" selected="@(r.Fornitore.SedeRiferimentoId == c.Id)">@c.Nome</option>
                            }
                        </select>
                    </td>
                    <td data-col="stato" data-sort-value="@statoSortRank">
                        <select class="inline-input" data-field="Stato" data-stato-cell>
                            <option value="@StatoFornitore.Attivo" selected="@(statoUi == StatoFornitore.Attivo)">attivo</option>
                            <option value="@StatoFornitore.Dismesso" selected="@(statoUi == StatoFornitore.Dismesso)">dismesso</option>
                        </select>
                    </td>
                    <td data-col="completezza" data-sort-value="@perc" data-sort-type="number" title="@tooltipMancanti">
                        <div style="display:flex; align-items:center; gap:4px;">
                            <div style="flex:1; height:5px; background:#eee; border-radius:3px; overflow:hidden; min-width:40px;">
                                <div style="width:@(perc)%; height:100%; background:@barColor;"></div>
                            </div>
                            <span style="font-weight:600; color:@barColor; min-width:30px; text-align:right;">@perc%</span>
                        </div>
                    </td>
                    <td data-col="sepa" data-sort-value="@sepaSortRank" data-sort-type="number">
                        @if (r.Completezza.SepaPronto)
                        {
                            <span class="badge" style="background:#dff5e6; color:#1f6e3a;" title="IBAN valido e dati anagrafici minimi presenti.">🏦 ok</span>
                        }
                        else
                        {
                            var motivo = "Dati SEPA mancanti: " + string.Join(", ", r.Completezza.CampiMancantiSepa);
                            <span class="badge" style="background:#fde2e2; color:#a83a3a;" title="@motivo">⚠</span>
                        }
                    </td>
                    <td data-col="esposto" data-sort-value="@(((double)r.EspostoCorrente).ToString(CultureInfo.InvariantCulture))" data-sort-type="number" style="text-align:right;">
                        <strong>@r.EspostoCorrente.ToString("N0", it) €</strong>
                    </td>
                    <td data-col="ytd" data-sort-value="@r.FatturePeriodoCorrente" data-sort-type="number" style="text-align:right;">@r.FatturePeriodoCorrente</td>
                    <td data-col="azioni" style="white-space:nowrap;">
                        <button type="button" class="btn btn--primary btn--sm" data-edit-fornitore="@r.Fornitore.Id" title="Modifica rapida">✎</button>
                        <button type="button" class="btn btn--ghost btn--sm" data-forn-delete title="Elimina fornitore" style="color:#a83a3a;">🗑</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="forn-pager" data-forn-pager>
        <div class="forn-pager__size">
            <label for="forn-page-size">Righe per pagina</label>
            <select id="forn-page-size" data-forn-page-size>
                <option value="25">25</option>
                <option value="50" selected>50</option>
                <option value="100">100</option>
                <option value="200">200</option>
                <option value="all">tutte</option>
            </select>
        </div>
        <div class="forn-pager__info">
            <span data-forn-pager-info>—</span>
        </div>
        <div class="forn-pager__nav">
            <button type="button" class="btn btn--ghost btn--sm" data-forn-page="first" aria-label="Prima pagina" title="Prima pagina">«</button>
            <button type="button" class="btn btn--ghost btn--sm" data-forn-page="prev" aria-label="Pagina precedente" title="Pagina precedente">‹</button>
            <span class="forn-pager__pages" data-forn-pager-pages></span>
            <button type="button" class="btn btn--ghost btn--sm" data-forn-page="next" aria-label="Pagina successiva" title="Pagina successiva">›</button>
            <button type="button" class="btn btn--ghost btn--sm" data-forn-page="last" aria-label="Ultima pagina" title="Ultima pagina">»</button>
        </div>
    </div>
    </div>
}

<dialog id="dlg-fornitore-edit" class="dotmodal-dialog" aria-label="Modifica fornitore">
    <div class="dotmodal">
        <div style="padding: 60px; text-align:center; color: var(--c-ink-soft, #6b5538);">Caricamento…</div>
    </div>
</dialog>

<partial name="_FornitoreEditModalScript" />

<style>
    /* ── Griglia fornitori: compatta + interattiva ─────────────── */
    .forn-grid-card {
        max-height: calc(100vh - 240px);
        overflow: auto;
        position: relative;
    }
    .forn-grid {
        font-size: .76rem;
        table-layout: fixed;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    .forn-grid th,
    .forn-grid td {
        padding: 2px 4px;
        vertical-align: middle;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    /* Azioni sempre visibili: sticky a destra anche se la viewport è stretta. */
    .forn-grid th[data-col="azioni"],
    .forn-grid td[data-col="azioni"] {
        position: sticky;
        right: 0;
        background: #fff;
        box-shadow: -6px 0 8px -6px rgba(60, 30, 12, .12);
    }
    .forn-grid th[data-col="azioni"] {
        background: var(--c-bg-soft, #faf6f0);
        z-index: 6;
    }
    [data-forn-row]:hover td[data-col="azioni"] { background: #fbf6ec; }
    .forn-grid td[data-col="azioni"] .btn {
        padding: 2px 6px;
        min-width: 0;
        line-height: 1.1;
    }
    .forn-grid td[data-col="azioni"] .btn + .btn { margin-left: 2px; }
    .forn-grid th {
        position: sticky;
        top: 0;
        z-index: 5;
        user-select: none;
        cursor: pointer;
        background: var(--c-bg-soft, #faf6f0);
        font-weight: 600;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .3px;
        color: var(--c-ink-soft, #6b4d2a);
        box-shadow: inset 0 -1px 0 var(--c-border, #e9e1d3);
    }
    .forn-grid th[data-sort-key]:hover { background: #f3e6cf; }
    .forn-grid th .th-label { display: inline-block; padding-right: 14px; }
    .forn-grid th .th-sort {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        font-size: .7rem;
        opacity: .35;
        pointer-events: none;
    }
    .forn-grid th[data-sort-dir="asc"] .th-sort::after { content: "▲"; opacity: 1; }
    .forn-grid th[data-sort-dir="desc"] .th-sort::after { content: "▼"; opacity: 1; }
    .forn-grid th .th-resizer {
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 6px;
        cursor: col-resize;
        z-index: 2;
    }
    .forn-grid th .th-resizer:hover,
    .forn-grid.is-resizing th .th-resizer.is-active {
        background: var(--c-accent, #c47830);
        opacity: .4;
    }
    .forn-grid.is-resizing { cursor: col-resize; user-select: none; }

    .inline-input {
        width: 100%;
        padding: 2px 4px;
        border: 1px solid transparent;
        background: transparent;
        font: inherit;
        color: inherit;
        border-radius: 3px;
        transition: border-color .1s, background-color .1s;
    }
    .inline-input:hover { border-color: #ddd; }
    .inline-input:focus {
        outline: none;
        border-color: #c47830;
        background: #fffbf3;
    }
    .inline-input--saved { background: #e7f5ec !important; transition: background-color .8s; }
    .inline-input--error { background: #fde2e2 !important; border-color: #a83a3a !important; }
    [data-forn-row].is-removing { opacity: .4; pointer-events: none; transition: opacity .2s; }
    [data-stato-cell] option[value="Dismesso"] { color: #777; }
    [data-forn-row].is-page-hidden { display: none !important; }

    /* Controls row: search + toggle sulla stessa riga. */
    .forn-controls {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        margin-bottom: var(--s-2);
        flex-wrap: wrap;
    }
    .forn-controls .table-search { margin-bottom: 0; flex: 1 1 280px; }

    /* Pill switch — "Non farmi vedere i dottori". */
    .forn-switch {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        user-select: none;
        font-size: .82rem;
        color: var(--c-ink-soft, #6b5538);
        white-space: nowrap;
        padding: 6px 12px 6px 8px;
        background: #fff;
        border: 1px solid var(--c-border, #e9e1d3);
        border-radius: 999px;
        transition: border-color .15s, box-shadow .15s, background-color .15s;
    }
    .forn-switch:hover {
        border-color: #d4c3a0;
        box-shadow: 0 1px 4px rgba(140, 90, 30, .08);
    }
    .forn-switch input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
        width: 1px; height: 1px;
    }
    .forn-switch__track {
        position: relative;
        width: 32px; height: 18px;
        background: #d8cdb6;
        border-radius: 999px;
        transition: background-color .18s ease;
        flex: none;
    }
    .forn-switch__thumb {
        position: absolute;
        top: 2px; left: 2px;
        width: 14px; height: 14px;
        background: #fff;
        border-radius: 50%;
        box-shadow: 0 1px 2px rgba(0,0,0,.22);
        transition: left .18s ease;
    }
    .forn-switch input:checked ~ .forn-switch__track { background: var(--c-accent, #c47830); }
    .forn-switch input:checked ~ .forn-switch__track .forn-switch__thumb { left: 16px; }
    .forn-switch input:focus-visible ~ .forn-switch__track {
        box-shadow: 0 0 0 3px rgba(196,120,48,.28);
    }
    .forn-switch__label { font-weight: 500; letter-spacing: .1px; }
    .forn-switch input:checked ~ .forn-switch__label { color: #6b3a0a; }

    tbody.hide-dottori [data-forn-row][data-is-dottore="1"] { display: none !important; }

    /* Title + callout SEPA ────────────────────────────────────── */
    .forn-title-zone { position: relative; }
    .forn-title {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin: 0;
        position: relative;
    }
    .forn-title__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }
    .forn-title__pulse {
        position: absolute;
        top: -2px; right: -6px;
        width: 10px; height: 10px;
        background: #d94f2a;
        border-radius: 50%;
        box-shadow: 0 0 0 0 rgba(217, 79, 42, .55);
        animation: forn-pulse 1.8s infinite;
    }
    @@keyframes forn-pulse {
        0%   { box-shadow: 0 0 0 0 rgba(217, 79, 42, .55); }
        70%  { box-shadow: 0 0 0 10px rgba(217, 79, 42, 0); }
        100% { box-shadow: 0 0 0 0 rgba(217, 79, 42, 0); }
    }

    .forn-callout {
        position: relative;
        margin: -4px 0 var(--s-3);
        max-width: 760px;
        padding: 10px 38px 10px 14px;
        background: #fff7e6;
        border: 1px solid #e0c79a;
        border-left: 3px solid #c47830;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: .88rem;
        line-height: 1.35;
        color: #6b3a0a;
        box-shadow: 0 2px 8px rgba(196, 120, 48, .10);
        animation: forn-callout-in .22s ease-out;
    }
    @@keyframes forn-callout-in {
        from { opacity: 0; transform: translateY(-4px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .forn-callout__caret {
        position: absolute;
        top: -7px; left: 22px;
        width: 12px; height: 12px;
        background: #fff7e6;
        border-top: 1px solid #e0c79a;
        border-left: 1px solid #e0c79a;
        transform: rotate(45deg);
    }
    .forn-callout__icon { font-size: 1.1rem; flex: none; }
    .forn-callout__body { flex: 1; }
    .forn-callout__body strong { color: #a86010; margin-right: 4px; }
    .forn-callout__close {
        position: absolute;
        top: 6px; right: 6px;
        background: transparent;
        border: 0;
        font-size: 1.1rem;
        line-height: 1;
        color: #a86010;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 4px;
        transition: background-color .15s;
    }
    .forn-callout__close:hover { background: rgba(196, 120, 48, .12); color: #6b3a0a; }
    .forn-callout.is-closing { animation: forn-callout-out .18s ease-in forwards; }
    @@keyframes forn-callout-out {
        to { opacity: 0; transform: translateY(-4px); height: 0; margin: 0; padding-top: 0; padding-bottom: 0; border-width: 0; }
    }

    /* ── Pager ────────────────────────────────────────────────── */
    .forn-pager {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        padding: 6px 10px;
        margin-top: 6px;
        font-size: .8rem;
        flex-wrap: wrap;
    }
    .forn-pager__size { display: flex; align-items: center; gap: 6px; }
    .forn-pager__size select {
        padding: 2px 6px;
        border: 1px solid var(--c-border, #e9e1d3);
        border-radius: 4px;
        background: #fff;
        font: inherit;
    }
    .forn-pager__info { color: var(--c-ink-soft, #7a5c3a); }
    .forn-pager__nav { margin-left: auto; display: flex; align-items: center; gap: 4px; }
    .forn-pager__nav .btn { min-width: 28px; padding: 2px 8px; }
    .forn-pager__pages {
        display: inline-flex;
        gap: 2px;
        margin: 0 6px;
    }
    .forn-pager__pages button {
        min-width: 26px;
        padding: 2px 6px;
        border: 1px solid var(--c-border, #e9e1d3);
        border-radius: 4px;
        background: #fff;
        cursor: pointer;
        font: inherit;
    }
    .forn-pager__pages button:hover { background: var(--c-bg-soft, #faf6f0); }
    .forn-pager__pages button.is-active {
        background: var(--c-accent, #c47830);
        color: #fff;
        border-color: var(--c-accent, #c47830);
    }
    .forn-pager__pages span.dots { padding: 2px 4px; color: var(--c-ink-soft, #7a5c3a); }
    .forn-pager .btn[disabled] { opacity: .35; pointer-events: none; }
</style>

@section Scripts {
<script>
    (function () {
        var grid = document.getElementById('fornitori-grid');
        if (!grid) return;

        // ── Antiforgery + helpers ────────────────────────────────
        function tokenValue() {
            var host = document.getElementById('forn-antiforgery-host');
            return host ? (host.querySelector('input[name="__RequestVerificationToken"]')?.value || '') : '';
        }
        function flashCell(el, cls) {
            el.classList.add(cls);
            setTimeout(function () { el.classList.remove(cls); }, 1200);
        }

        // ── Inline edit + delete ─────────────────────────────────
        async function save(row, control) {
            var id = row.getAttribute('data-id');
            var field = control.getAttribute('data-field');
            var value = control.value;
            var original = control.getAttribute('data-original') ?? '';
            if (value === original) return;

            var fd = new FormData();
            fd.append('__RequestVerificationToken', tokenValue());
            fd.append('field', field);
            fd.append('value', value);

            try {
                var resp = await fetch('/tesoreria/fornitori/' + encodeURIComponent(id) + '/inline', {
                    method: 'POST', body: fd, credentials: 'same-origin'
                });
                if (!resp.ok) {
                    var err = await resp.json().catch(function () { return null; });
                    flashCell(control, 'inline-input--error');
                    control.value = original;
                    if (err && err.error) alert(err.error);
                    return;
                }
                await resp.json();
                control.setAttribute('data-original', value);
                // sincronizza data-sort-value della cella ospitante
                var cell = control.closest('td');
                if (cell && cell.hasAttribute('data-sort-value')) cell.setAttribute('data-sort-value', value);
                if (field === 'RagioneSociale') {
                    row.setAttribute('data-label', value);
                    var rsp = row.querySelector('[data-field="RagioneSocialePagamento"]');
                    if (rsp && (rsp.value === '' || rsp.value === original)) {
                        rsp.value = value;
                        rsp.setAttribute('data-original', value);
                        var rspCell = rsp.closest('td');
                        if (rspCell) rspCell.setAttribute('data-sort-value', value);
                    }
                }
                flashCell(control, 'inline-input--saved');
            } catch (e) {
                flashCell(control, 'inline-input--error');
                control.value = original;
            }
        }

        grid.querySelectorAll('[data-forn-row]').forEach(function (row) {
            row.querySelectorAll('.inline-input').forEach(function (el) {
                el.setAttribute('data-original', el.value);
                if (el.tagName === 'SELECT') {
                    el.addEventListener('change', function () { save(row, el); });
                } else {
                    el.addEventListener('blur', function () { save(row, el); });
                    el.addEventListener('keydown', function (e) {
                        if (e.key === 'Enter') { e.preventDefault(); el.blur(); }
                        if (e.key === 'Escape') { el.value = el.getAttribute('data-original') || ''; el.blur(); }
                    });
                }
            });

            var delBtn = row.querySelector('[data-forn-delete]');
            if (delBtn) {
                delBtn.addEventListener('click', async function () {
                    var label = row.getAttribute('data-label') || 'questo fornitore';
                    if (!confirm('Eliminare definitivamente "' + label + '" dall\'anagrafica?\n\nLe fatture e scadenze storiche resteranno consultabili. L\'azione viene registrata nell\'audit log.')) return;
                    var id = row.getAttribute('data-id');
                    row.classList.add('is-removing');
                    var fd = new FormData();
                    fd.append('__RequestVerificationToken', tokenValue());
                    try {
                        var resp = await fetch('/tesoreria/fornitori/' + encodeURIComponent(id) + '/elimina', {
                            method: 'POST', body: fd, credentials: 'same-origin'
                        });
                        if (resp.ok) {
                            row.parentNode.removeChild(row);
                        } else {
                            row.classList.remove('is-removing');
                            var err = await resp.json().catch(function () { return null; });
                            alert((err && err.error) || 'Errore durante la cancellazione.');
                        }
                    } catch (e) {
                        row.classList.remove('is-removing');
                        alert('Errore di rete durante la cancellazione.');
                    }
                });
            }
        });

        // ── Sorting per colonna ──────────────────────────────────
        var SORT_KEY = 'chipdent.fornitori.sort';
        function cellSortValue(td) {
            if (!td) return '';
            if (td.hasAttribute('data-sort-value')) return td.getAttribute('data-sort-value');
            var inp = td.querySelector('input, select');
            if (inp) return inp.value;
            return td.textContent.trim();
        }
        function sortBy(th) {
            var key = th.getAttribute('data-sort-key');
            if (!key) return;
            var col = th.getAttribute('data-col');
            var type = th.getAttribute('data-sort-type') || 'text';
            var current = th.getAttribute('data-sort-dir');
            var dir = current === 'asc' ? 'desc' : 'asc';

            grid.querySelectorAll('th[data-sort-key]').forEach(function (h) { h.removeAttribute('data-sort-dir'); });
            th.setAttribute('data-sort-dir', dir);

            var tbody = grid.tBodies[0];
            var rows = Array.prototype.slice.call(tbody.rows);
            rows.sort(function (a, b) {
                var av = cellSortValue(a.querySelector('td[data-col="' + col + '"]'));
                var bv = cellSortValue(b.querySelector('td[data-col="' + col + '"]'));
                if (type === 'number') {
                    av = parseFloat(av); bv = parseFloat(bv);
                    if (isNaN(av)) av = -Infinity;
                    if (isNaN(bv)) bv = -Infinity;
                    return dir === 'asc' ? av - bv : bv - av;
                }
                return dir === 'asc'
                    ? av.localeCompare(bv, 'it', { sensitivity: 'base' })
                    : bv.localeCompare(av, 'it', { sensitivity: 'base' });
            });
            rows.forEach(function (r) { tbody.appendChild(r); });
            try { localStorage.setItem(SORT_KEY, JSON.stringify({ key: key, dir: dir })); } catch (e) {}
        }
        grid.querySelectorAll('th[data-sort-key]').forEach(function (th) {
            th.addEventListener('click', function (e) {
                if (e.target.classList.contains('th-resizer')) return;
                sortBy(th);
            });
        });
        // Ripristina ordinamento salvato
        try {
            var saved = JSON.parse(localStorage.getItem(SORT_KEY) || 'null');
            if (saved && saved.key) {
                var th = grid.querySelector('th[data-sort-key="' + saved.key + '"]');
                if (th) {
                    // Preimposta dir opposta in modo che sortBy la inverta a quella desiderata
                    th.setAttribute('data-sort-dir', saved.dir === 'asc' ? 'desc' : 'asc');
                    sortBy(th);
                }
            }
        } catch (e) {}

        // ── Ridimensionamento colonne ────────────────────────────
        var WIDTH_KEY = 'chipdent.fornitori.colWidths';
        function loadWidths() {
            try { return JSON.parse(localStorage.getItem(WIDTH_KEY) || '{}') || {}; }
            catch (e) { return {}; }
        }
        function saveWidth(col, px) {
            var ws = loadWidths();
            ws[col] = px;
            try { localStorage.setItem(WIDTH_KEY, JSON.stringify(ws)); } catch (e) {}
        }
        var initialWidths = loadWidths();
        grid.querySelectorAll('th[data-col]').forEach(function (th) {
            var col = th.getAttribute('data-col');
            if (initialWidths[col]) th.style.width = initialWidths[col] + 'px';
        });

        grid.querySelectorAll('th .th-resizer').forEach(function (handle) {
            handle.addEventListener('mousedown', function (e) {
                e.preventDefault();
                e.stopPropagation();
                var th = handle.parentElement;
                var col = th.getAttribute('data-col');
                var startX = e.clientX;
                var startW = th.getBoundingClientRect().width;
                handle.classList.add('is-active');
                grid.classList.add('is-resizing');

                function onMove(ev) {
                    var w = Math.max(50, startW + (ev.clientX - startX));
                    th.style.width = w + 'px';
                }
                function onUp() {
                    document.removeEventListener('mousemove', onMove);
                    document.removeEventListener('mouseup', onUp);
                    handle.classList.remove('is-active');
                    grid.classList.remove('is-resizing');
                    saveWidth(col, Math.round(th.getBoundingClientRect().width));
                }
                document.addEventListener('mousemove', onMove);
                document.addEventListener('mouseup', onUp);
            });
        });

        // ── Paginazione client-side ──────────────────────────────
        // Lavora sulle righe non-filtrate da _TableSearch (display !== "none").
        // Si re-applica dopo ogni sort, dopo ogni input di ricerca e dopo delete.
        var PAGE_SIZE_KEY = 'chipdent.fornitori.pageSize';
        var pager = document.querySelector('[data-forn-pager]');
        var pageSizeSel = document.querySelector('[data-forn-page-size]');
        var pageInfo = document.querySelector('[data-forn-pager-info]');
        var pagesEl = document.querySelector('[data-forn-pager-pages]');
        var btnFirst = document.querySelector('[data-forn-page="first"]');
        var btnPrev = document.querySelector('[data-forn-page="prev"]');
        var btnNext = document.querySelector('[data-forn-page="next"]');
        var btnLast = document.querySelector('[data-forn-page="last"]');
        var tbodyEl = grid.tBodies[0];
        var currentPage = 1;
        var pageSize = 50;

        try {
            var savedPS = localStorage.getItem(PAGE_SIZE_KEY);
            if (savedPS) {
                pageSize = savedPS === 'all' ? Infinity : (parseInt(savedPS, 10) || 50);
                if (pageSizeSel) pageSizeSel.value = savedPS;
            }
        } catch (e) {}

        function searchVisibleRows() {
            var hideDottori = tbodyEl.classList.contains('hide-dottori');
            return Array.prototype.slice.call(tbodyEl.rows)
                .filter(function (r) {
                    if (r.style.display === 'none') return false;
                    if (hideDottori && r.getAttribute('data-is-dottore') === '1') return false;
                    return true;
                });
        }

        function buildPageNumbers(total, current) {
            if (!pagesEl) return;
            pagesEl.innerHTML = '';
            if (total <= 1) return;
            var pages = [];
            var around = 1; // pagine attorno alla corrente
            function add(p) { if (pages.indexOf(p) === -1) pages.push(p); }
            add(1); add(total);
            for (var i = current - around; i <= current + around; i++) {
                if (i > 1 && i < total) add(i);
            }
            pages.sort(function (a, b) { return a - b; });
            var prev = 0;
            pages.forEach(function (p) {
                if (p - prev > 1) {
                    var dots = document.createElement('span');
                    dots.className = 'dots';
                    dots.textContent = '…';
                    pagesEl.appendChild(dots);
                }
                var btn = document.createElement('button');
                btn.type = 'button';
                btn.textContent = p;
                if (p === current) btn.className = 'is-active';
                btn.addEventListener('click', function () { goTo(p); });
                pagesEl.appendChild(btn);
                prev = p;
            });
        }

        function applyPagination() {
            var visible = searchVisibleRows();
            var total = visible.length;
            var size = pageSize === Infinity ? total : pageSize;
            var pageCount = size > 0 ? Math.max(1, Math.ceil(total / size)) : 1;
            if (currentPage > pageCount) currentPage = pageCount;
            if (currentPage < 1) currentPage = 1;

            var start = (currentPage - 1) * size;
            var end = pageSize === Infinity ? total : start + size;

            visible.forEach(function (r, idx) {
                if (idx >= start && idx < end) r.classList.remove('is-page-hidden');
                else r.classList.add('is-page-hidden');
            });
            // Le righe filtrate dalla ricerca non hanno bisogno del marker pagina.
            tbodyEl.querySelectorAll('[data-forn-row]').forEach(function (r) {
                if (r.style.display === 'none') r.classList.remove('is-page-hidden');
            });

            if (pageInfo) {
                if (total === 0) {
                    pageInfo.textContent = 'Nessun risultato';
                } else if (pageSize === Infinity) {
                    pageInfo.textContent = total + ' fornitor' + (total === 1 ? 'e' : 'i');
                } else {
                    pageInfo.textContent = (start + 1) + '–' + Math.min(end, total) + ' di ' + total;
                }
            }
            if (btnFirst) btnFirst.disabled = currentPage <= 1;
            if (btnPrev)  btnPrev.disabled  = currentPage <= 1;
            if (btnNext)  btnNext.disabled  = currentPage >= pageCount;
            if (btnLast)  btnLast.disabled  = currentPage >= pageCount;
            buildPageNumbers(pageCount, currentPage);

            // Riporta lo scroll della card in alto al cambio pagina.
            var card = grid.closest('.forn-grid-card');
            if (card && pageSize !== Infinity) card.scrollTop = 0;
        }

        function goTo(p) { currentPage = p; applyPagination(); }
        if (btnFirst) btnFirst.addEventListener('click', function () { goTo(1); });
        if (btnPrev)  btnPrev.addEventListener('click',  function () { goTo(currentPage - 1); });
        if (btnNext)  btnNext.addEventListener('click',  function () { goTo(currentPage + 1); });
        if (btnLast)  btnLast.addEventListener('click',  function () {
            var size = pageSize === Infinity ? searchVisibleRows().length : pageSize;
            var total = searchVisibleRows().length;
            goTo(size > 0 ? Math.max(1, Math.ceil(total / size)) : 1);
        });
        if (pageSizeSel) {
            pageSizeSel.addEventListener('change', function () {
                var v = pageSizeSel.value;
                pageSize = v === 'all' ? Infinity : (parseInt(v, 10) || 50);
                currentPage = 1;
                try { localStorage.setItem(PAGE_SIZE_KEY, v); } catch (e) {}
                applyPagination();
            });
        }

        // Re-applica la paginazione dopo che _TableSearch ha aggiornato display.
        var searchInput = document.querySelector('[data-table-search] .table-search__input');
        if (searchInput) {
            searchInput.addEventListener('input', function () {
                currentPage = 1;
                setTimeout(applyPagination, 0);
            });
            var clearBtn = document.querySelector('[data-table-search] .table-search__clear');
            if (clearBtn) clearBtn.addEventListener('click', function () { setTimeout(applyPagination, 0); });
        }

        // Hook sort → re-applica la pagina dopo il riordino. I click handler già
        // installati sulle <th> chiamano sortBy via closure, quindi la riassegnazione
        // qui sotto è visibile anche a loro.
        var _origSortBy = sortBy;
        sortBy = function (th) { _origSortBy(th); applyPagination(); };

        // Dopo una cancellazione la riga sparisce — re-applica il pager.
        grid.addEventListener('click', function (e) {
            if (e.target.closest('[data-forn-delete]')) {
                // attesa per rimozione DOM
                setTimeout(applyPagination, 200);
            }
        });

        // ── Toggle "Non farmi vedere i dottori" ───────────────────
        var HIDE_DOTT_KEY = 'chipdent.fornitori.hideDottori';
        var hideDottoriCb = document.getElementById('forn-hide-dottori');
        if (hideDottoriCb) {
            var saved = false;
            try { saved = localStorage.getItem(HIDE_DOTT_KEY) === '1'; } catch (e) {}
            hideDottoriCb.checked = saved;
            tbodyEl.classList.toggle('hide-dottori', saved);
            hideDottoriCb.addEventListener('change', function () {
                tbodyEl.classList.toggle('hide-dottori', hideDottoriCb.checked);
                try { localStorage.setItem(HIDE_DOTT_KEY, hideDottoriCb.checked ? '1' : '0'); } catch (e) {}
                currentPage = 1;
                applyPagination();
            });
        }

        applyPagination();

        // ── Callout SEPA: chiudibile (non persistito: ricompare a ogni accesso). ──
        var callout = document.querySelector('[data-forn-callout]');
        var closeBtn = document.querySelector('[data-forn-callout-close]');
        if (callout && closeBtn) {
            closeBtn.addEventListener('click', function () {
                callout.classList.add('is-closing');
                setTimeout(function () {
                    if (callout.parentNode) callout.parentNode.removeChild(callout);
                }, 200);
            });
        }
    })();
</script>
}
