@model Chipdent.Web.Models.NuovaProductBacklogViewModel
@{
    ViewData["Title"] = "Nuova richiesta di backlog";
    ViewData["Crumb"] = "Backlog di prodotto";
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>Proponi una nuova funzionalità</h2>
        <p class="page-head__sub">Ti guidiamo passo per passo nella scrittura della story in formato agile. Tutto ciò che inserisci sarà visibile alla rete e potrà essere votato.</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Indietro</a>
    </div>
</div>

<div class="card" style="max-width: 820px;" x-data="backlogWizard()">
    <form asp-action="Create" method="post" @@submit="onSubmit($event)">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert--danger"
             style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none");"></div>

        <!-- Stepper -->
        <ol style="display:flex; gap: 0; list-style:none; padding:0; margin: 0 0 var(--s-4); border-bottom: 1px solid var(--c-border, #e9e1d3);">
            <template x-for="(s, i) in steps" :key="i">
                <li :class="{ active: step === i+1, done: step > i+1 }"
                    style="flex:1; padding: 12px 8px; text-align:center; font-size:.78rem; font-weight:600; cursor:pointer; border-bottom: 3px solid transparent; transition: all .15s;"
                    :style="step === i+1
                        ? 'border-bottom-color: var(--c-accent, #c47830); color: var(--c-accent, #c47830);'
                        : (step > i+1
                            ? 'border-bottom-color: #3a7d44; color: #3a7d44;'
                            : 'color: var(--c-ink-soft, #7a5c3a);')"
                    @@click="goTo(i+1)">
                    <div style="font-size: 1rem; margin-bottom: 2px;">
                        <span x-show="step <= i+1" x-text="i+1"></span>
                        <span x-show="step > i+1">✓</span>
                    </div>
                    <div x-text="s"></div>
                </li>
            </template>
        </ol>

        <!-- ──── STEP 1: Per chi è la funzionalità ──── -->
        <div x-show="step === 1" x-transition>
            <h3 style="margin: 0 0 8px;">👥 Per chi è la funzionalità?</h3>
            <p class="muted" style="margin: 0 0 var(--s-3); font-size:.9rem;">
                Indica il ruolo del beneficiario. È la prima parte della story:
                <strong>«Come <em>ruolo</em> vorrei…»</strong>
            </p>

            <div class="form-group">
                <label class="form-label" asp-for="ComeRuolo">Come <em>(ruolo)</em></label>
                <input class="form-control" asp-for="ComeRuolo" list="ruoli-suggeriti" required maxlength="60"
                       placeholder="Es. Staff, Direttore di sede, Backoffice, Dottore…" />
                <datalist id="ruoli-suggeriti">
                    @foreach (var r in Model.RuoliSuggeriti)
                    {
                        <option value="@r"></option>
                    }
                </datalist>
                <span class="text-danger" asp-validation-for="ComeRuolo"></span>
                <small class="muted" style="margin-top:6px; display:block;">
                    💡 Pensa a chi userà davvero la funzionalità tutti i giorni, non solo a chi la richiede.
                </small>
            </div>
        </div>

        <!-- ──── STEP 2: Cosa vorresti e perché ──── -->
        <div x-show="step === 2" x-transition>
            <h3 style="margin: 0 0 8px;">📝 Cosa vorresti che la piattaforma facesse?</h3>
            <p class="muted" style="margin: 0 0 var(--s-3); font-size:.9rem;">
                Completa la story. Sii specifico: descrivi il comportamento atteso, non la soluzione tecnica.
            </p>

            <div style="background: var(--c-bg-soft, #faf6f0); padding: 14px 16px; border-radius: 10px; margin-bottom: var(--s-3); font-family: 'JetBrains Mono', monospace; font-size:.9rem; line-height: 1.7;">
                <div>
                    <span style="color: var(--c-ink-soft);">Come</span>
                    <strong x-text="comeRuoloPreview()"></strong>
                </div>
                <div>
                    <span style="color: var(--c-ink-soft);">vorrei</span>
                    <em x-text="vorreiPreview() || '…descrivi qui sotto…'" style="color: var(--c-accent, #c47830);"></em>
                </div>
                <div>
                    <span style="color: var(--c-ink-soft);">così che</span>
                    <em x-text="cosiChePreview() || '…indica il beneficio…'" style="color: var(--c-accent, #c47830);"></em>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Vorrei">vorrei <em>(funzionalità)</em></label>
                <textarea class="form-control" asp-for="Vorrei" rows="3" required minlength="10" maxlength="400"
                          x-model="vorrei"
                          placeholder="Es. ricevere una notifica quando il mio turno viene modificato dal direttore"></textarea>
                <span class="text-danger" asp-validation-for="Vorrei"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="CosiChe">così che <em>(beneficio)</em></label>
                <textarea class="form-control" asp-for="CosiChe" rows="3" required minlength="5" maxlength="400"
                          x-model="cosiChe"
                          placeholder="Es. possa riorganizzarmi senza dover controllare manualmente il calendario"></textarea>
                <span class="text-danger" asp-validation-for="CosiChe"></span>
            </div>
        </div>

        <!-- ──── STEP 3: Classificazione ──── -->
        <div x-show="step === 3" x-transition>
            <h3 style="margin: 0 0 8px;">🏷️ Classifica la richiesta</h3>
            <p class="muted" style="margin: 0 0 var(--s-3); font-size:.9rem;">
                Aiuta l'Owner a metterla nel posto giusto e a confrontarla con le altre.
            </p>

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" asp-for="Categoria">Categoria</label>
                    <select class="form-control" asp-for="Categoria">
                        <option value="@CategoriaBacklog.NuovaFunzionalita">✨ Nuova funzionalità</option>
                        <option value="@CategoriaBacklog.Miglioramento">🔧 Miglioramento di funzionalità esistente</option>
                        <option value="@CategoriaBacklog.Bug">🐛 Bug / problema</option>
                        <option value="@CategoriaBacklog.Integrazione">🔗 Integrazione con sistema esterno</option>
                        <option value="@CategoriaBacklog.Performance">⚡ Performance</option>
                        <option value="@CategoriaBacklog.UX">🎨 Esperienza utente / UX</option>
                        <option value="@CategoriaBacklog.Reportistica">📊 Reportistica / dati</option>
                        <option value="@CategoriaBacklog.Compliance">🛡️ Compliance / sicurezza</option>
                        <option value="@CategoriaBacklog.Altro">💡 Altro</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Area">Area funzionale</label>
                    <select class="form-control" asp-for="Area" asp-items="Html.GetEnumSelectList<AreaBacklog>()"></select>
                </div>

                <div class="form-group full">
                    <label class="form-label" asp-for="Impatto">Impatto stimato</label>
                    <div style="display:flex; gap: 8px; flex-wrap: wrap;">
                        @foreach (var imp in Enum.GetValues<ImpattoBacklog>())
                        {
                            var icon = imp switch
                            {
                                ImpattoBacklog.Critico => "🚨",
                                ImpattoBacklog.Alto    => "↑",
                                ImpattoBacklog.Medio   => "→",
                                _ => "↓"
                            };
                            var desc = imp switch
                            {
                                ImpattoBacklog.Critico => "Blocca operatività",
                                ImpattoBacklog.Alto    => "Migliora molto le routine quotidiane",
                                ImpattoBacklog.Medio   => "Utile per molti utenti",
                                _ => "Nice-to-have"
                            };
                            <label style="flex:1; min-width: 160px; padding: 12px; border: 1px solid var(--c-border, #e9e1d3); border-radius: 8px; cursor:pointer; display:flex; flex-direction:column; gap:4px;">
                                <input type="radio" asp-for="Impatto" value="@imp" style="margin-right:6px;" />
                                <strong>@icon @imp</strong>
                                <span class="muted" style="font-size:.78rem;">@desc</span>
                            </label>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ──── STEP 4: Commento aggiuntivo ──── -->
        <div x-show="step === 4" x-transition>
            <h3 style="margin: 0 0 8px;">💬 Commenti, esempi e dettagli</h3>
            <p class="muted" style="margin: 0 0 var(--s-3); font-size:.9rem;">
                Opzionale. Aggiungi contesto, esempi concreti, screenshot mentali, riferimenti a altri tool, edge case che hai in mente.
            </p>

            <div class="form-group">
                <label class="form-label" asp-for="Commento">Commento aggiuntivo (opzionale)</label>
                <textarea class="form-control" asp-for="Commento" rows="6" maxlength="2000"
                          placeholder="Es. quando il direttore sposta un turno della settimana corrente, vorrei vedere la differenza evidenziata nella mia app. Oggi devo confrontare manualmente."></textarea>
                <span class="text-danger" asp-validation-for="Commento"></span>
            </div>

            <!-- Riepilogo finale -->
            <div style="margin-top: var(--s-4); padding: var(--s-3); background: var(--c-bg-soft, #faf6f0); border-radius: 10px; border-left: 4px solid var(--c-accent, #c47830);">
                <div style="font-weight: 700; margin-bottom: var(--s-2); display:flex; align-items:center; gap:8px;">
                    📋 Riepilogo della tua richiesta
                </div>
                <div style="font-family: 'JetBrains Mono', monospace; font-size:.88rem; line-height: 1.7;">
                    <div><span class="muted">Come</span> <strong x-text="comeRuoloPreview()"></strong></div>
                    <div><span class="muted">vorrei</span> <span x-text="vorreiPreview()"></span></div>
                    <div><span class="muted">così che</span> <span x-text="cosiChePreview()"></span></div>
                </div>
                <div style="margin-top: var(--s-2); font-size:.82rem; display:flex; gap: 12px; flex-wrap:wrap;">
                    <span class="badge"><strong>Categoria:</strong> <span x-text="categoriaLabel()"></span></span>
                    <span class="badge"><strong>Area:</strong> <span x-text="areaLabel()"></span></span>
                    <span class="badge"><strong>Impatto:</strong> <span x-text="impattoLabel()"></span></span>
                </div>
            </div>
        </div>

        <!-- Pulsanti navigazione -->
        <div class="form-actions" style="display:flex; justify-content:space-between; margin-top: var(--s-4);">
            <button type="button" class="btn btn--ghost" @@click="prev()" x-show="step > 1">← Indietro</button>
            <span x-show="step === 1"></span>
            <div style="display:flex; gap: 8px;">
                <a class="btn btn--ghost" asp-action="Index">Annulla</a>
                <button type="button" class="btn btn--primary" @@click="next()" x-show="step < totalSteps">Avanti →</button>
                <button type="submit" class="btn btn--primary" x-show="step === totalSteps">📤 Invia richiesta</button>
            </div>
        </div>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.5/dist/cdn.min.js" defer></script>
<script>
    function backlogWizard() {
        return {
            step: 1,
            totalSteps: 4,
            steps: ["Per chi", "La story", "Classifica", "Commenti"],
            vorrei: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Vorrei ?? "")),
            cosiChe: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CosiChe ?? "")),
            comeRuoloPreview() {
                return document.querySelector('[name="ComeRuolo"]').value || "(ruolo)";
            },
            vorreiPreview() { return this.vorrei; },
            cosiChePreview() { return this.cosiChe; },
            categoriaLabel() { return document.querySelector('[name="Categoria"]')?.selectedOptions[0]?.text || ""; },
            areaLabel() { return document.querySelector('[name="Area"]')?.selectedOptions[0]?.text || ""; },
            impattoLabel() { return document.querySelector('[name="Impatto"]:checked')?.value || ""; },
            next() {
                if (!this.validateStep()) return;
                if (this.step < this.totalSteps) this.step++;
            },
            prev() {
                if (this.step > 1) this.step--;
            },
            goTo(n) {
                // Permette di tornare indietro liberamente; per andare avanti serve la validazione step-by-step
                if (n <= this.step) this.step = n;
            },
            validateStep() {
                const required = {
                    1: ['ComeRuolo'],
                    2: ['Vorrei', 'CosiChe'],
                    3: ['Categoria', 'Area', 'Impatto']
                }[this.step] || [];
                for (const name of required) {
                    const el = document.querySelector(`[name="${name}"]`);
                    if (!el) continue;
                    if (el.type === 'radio') {
                        if (!document.querySelector(`[name="${name}"]:checked`)) {
                            alert("Compila tutti i campi obbligatori prima di proseguire.");
                            return false;
                        }
                    } else if (!el.value || !el.value.trim()) {
                        el.focus();
                        alert("Compila tutti i campi obbligatori prima di proseguire.");
                        return false;
                    }
                }
                return true;
            },
            onSubmit(e) {
                // L'ultimo step ha già la validazione browser; il submit prosegue normalmente
            }
        };
    }
</script>
