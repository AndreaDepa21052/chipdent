<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
    <PackageReference Include="MongoDB.Driver" Version="2.28.0" />
    <PackageReference Include="PdfPig" Version="0.1.10" />
  </ItemGroup>

  <!-- Mantiene wwwroot/docs/chipdent-features.html sincronizzato con docs/chipdent-features.html -->
  <Target Name="SyncFunctionalMap" BeforeTargets="BeforeBuild">
    <Copy SourceFiles="..\..\docs\chipdent-features.html"
          DestinationFolder="$(MSBuildProjectDirectory)\wwwroot\docs"
          SkipUnchangedFiles="true"
          Condition="Exists('..\..\docs\chipdent-features.html')" />
  </Target>

</Project>
