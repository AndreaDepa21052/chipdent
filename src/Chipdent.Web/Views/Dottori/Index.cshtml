@model IReadOnlyList<Chipdent.Web.Models.DottoreListItem>
@{
    ViewData["Title"] = "Dottori";
    var totale = Model.Count;
    var attivi = Model.Count(i => i.Dottore.Attivo);
    var conAlert = Model.Count(i => i.AlertCritici + i.AlertAvvisi > 0);
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>Dottori</h2>
        <p class="page-head__sub">@totale professionisti · @attivi attivi · @conAlert con alert aperti</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--primary" asp-action="Create">+ Nuovo dottore</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="card">
        <div class="empty">
            <div class="empty__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
            </div>
            <h3>Nessun dottore</h3>
            <p>Inserisci il primo professionista della catena.</p>
        </div>
    </div>
}
else
{
    <div data-table-search>
        <partial name="_TableSearch" model='new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData) { ["Placeholder"] = "Cerca dottore per nome, clinica…", ["Singular"] = "dottore", ["Plural"] = "dottori" }' />
        <div class="table-search__empty">Nessun dottore corrisponde alla ricerca.</div>
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Nome e cognome</th>
                        <th>Cliniche</th>
                        <th>Inizio collaborazione</th>
                        <th>Fine collaborazione</th>
                        <th>Alert</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    var d = item.Dottore;
                    var clinicheAttive = item.Collaborazioni.Where(c => c.IsAttiva).ToList();
                    var clinicheTutte = item.Collaborazioni.ToList();
                    <tr>
                        <td>
                            <div class="strong">@d.NomeCompleto</div>
                            <div class="muted">@d.Specializzazione</div>
                        </td>
                        <td>
                            @if (clinicheTutte.Count == 0)
                            {
                                <span class="muted">—</span>
                            }
                            else
                            {
                                <div style="display:flex; flex-wrap:wrap; gap:4px;">
                                    @foreach (var c in clinicheTutte.OrderByDescending(x => x.IsAttiva).ThenBy(x => x.ClinicaNome))
                                    {
                                        var cls = c.IsAttiva ? "badge badge--success" : "badge";
                                        <span class="@cls" title="@(c.DataFine is null ? "Attiva" : $"Terminata il {c.DataFine:dd/MM/yyyy}")">@c.ClinicaNome</span>
                                    }
                                </div>
                            }
                        </td>
                        <td>@item.DataInizioCollaborazione.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (item.DataFineCollaborazione is null)
                            {
                                <span class="muted">in corso</span>
                            }
                            else
                            {
                                @item.DataFineCollaborazione.Value.ToString("dd/MM/yyyy")
                            }
                        </td>
                        <td>
                            @if (item.AlertCritici == 0 && item.AlertAvvisi == 0)
                            {
                                <span class="badge badge--success"><span class="dot"></span>ok</span>
                            }
                            else
                            {
                                @if (item.AlertCritici > 0)
                                {
                                    <span class="badge badge--danger" style="margin-right:4px;">🔴 @item.AlertCritici</span>
                                }
                                @if (item.AlertAvvisi > 0)
                                {
                                    <span class="badge badge--warning">🟡 @item.AlertAvvisi</span>
                                }
                            }
                        </td>
                        <td>
                            <div class="actions">
                                <a class="ibtn" asp-action="Details" asp-route-id="@d.Id" title="Dettagli">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                                </a>
                                <button type="button" class="ibtn" data-edit-dottore="@d.Id" title="Modifica rapida">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<dialog id="dlg-dottore-edit" class="dotmodal-dialog" aria-label="Modifica dottore">
    <div class="dotmodal" data-dotmodal-loading>
        <div style="padding: 60px; text-align:center; color: var(--c-ink-soft, #6b5538);">Caricamento…</div>
    </div>
</dialog>

<partial name="_DottoreEditModalScript" />
