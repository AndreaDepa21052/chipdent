<style>
    /* Modale full-screen della griglia scadenze: lasciamo respirare la
       tabella su tutta la viewport, eliminando il vincolo a 320px del
       calendario laterale. Il calendario resta fuori (la modale ospita
       solo la card .scadenze-grid). */
    dialog.dlg-fullscreen {
        border: 0;
        padding: 0;
        margin: 0;
        width: 100vw;
        max-width: 100vw;
        height: 100vh;
        max-height: 100vh;
        background: var(--c-bg, #f8f1e3);
        color: inherit;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    dialog.dlg-fullscreen::backdrop { background: rgba(59,30,12,0.55); }
    .dlg-fullscreen__bar {
        display: flex; align-items: center; gap: var(--s-3);
        padding: var(--s-3) var(--s-4);
        background: #fff;
        border-bottom: 1px solid var(--c-border, #ece0cc);
