@model Chipdent.Web.Models.ContrattoFormViewModel
@{
    var isNew = (bool)(ViewData["IsNew"] ?? false);
    ViewData["Title"] = isNew ? "Nuovo contratto" : "Modifica contratto";
    ViewData["Crumb"] = "Contratti";
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>@(isNew ? "Nuovo contratto" : "Modifica contratto")</h2>
        <p class="page-head__sub">Carica il contratto firmato e indica le scadenze.</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Torna ai contratti</a>
    </div>
</div>

<div class="card" style="max-width: 760px;">
    <form asp-action="@(isNew ? "Create" : "Edit")" asp-route-id="@(isNew ? null : Model.Id)" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="alert alert--danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none");"></div>

        <div class="form-grid">
            <div class="form-group full">
                <label class="form-label" asp-for="DipendenteId">Dipendente</label>
                @if (Model.LockedDipendente && !string.IsNullOrEmpty(Model.DipendenteId))
                {
                    var dip = Model.Dipendenti.FirstOrDefault(d => d.Id == Model.DipendenteId);
                    <input type="hidden" asp-for="DipendenteId" />
                    <input class="form-control" value="@(dip?.NomeCompleto ?? "")" disabled />
                }
                else
                {
                    <select class="form-control" asp-for="DipendenteId" required>
                        <option value="">— seleziona —</option>
                        @foreach (var d in Model.Dipendenti)
                        {
                            <option value="@d.Id">@d.NomeCompleto · @d.Ruolo</option>
                        }
                    </select>
                }
                <span class="text-danger" asp-validation-for="DipendenteId"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Tipo">Tipo</label>
                <select class="form-control" asp-for="Tipo" asp-items="Html.GetEnumSelectList<Chipdent.Web.Domain.Entities.TipoContrattoLavoro>()"></select>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Livello">Livello / inquadramento</label>
                <input class="form-control" asp-for="Livello" placeholder="Es. 3° livello CCNL Studi Odontoiatrici" />
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="DataInizio">Data inizio</label>
                <input class="form-control" asp-for="DataInizio" type="date" required />
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="DataFine">Data fine (vuota = TI)</label>
                <input class="form-control" asp-for="DataFine" type="date" />
                <span class="text-danger" asp-validation-for="DataFine"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="RetribuzioneMensileLorda">Retribuzione mensile lorda (€)</label>
                <input class="form-control" asp-for="RetribuzioneMensileLorda" type="number" step="0.01" min="0" />
            </div>
            <div class="form-group"></div>

            <div class="form-group full">
                <label class="form-label" asp-for="Note">Note</label>
                <textarea class="form-control" asp-for="Note" rows="3"></textarea>
            </div>

            <div class="form-group full">
                <label class="form-label" asp-for="Allegato">Contratto firmato (PDF, immagine, doc — max 50MB)</label>
                @if (!string.IsNullOrEmpty(Model.AllegatoNomeAttuale))
                {
                    <div class="muted" style="font-size:.82rem; margin-bottom:6px;">
                        Allegato attuale: <strong>@Model.AllegatoNomeAttuale</strong>
                        @if (!string.IsNullOrEmpty(Model.Id))
                        {
                            <a asp-action="Download" asp-route-id="@Model.Id" target="_blank" style="margin-left:8px;">scarica ↓</a>
                        }
                    </div>
                }
                <input class="form-control" asp-for="Allegato" type="file" accept=".pdf,.png,.jpg,.jpeg,.doc,.docx,.odt" />
                <span class="text-danger" asp-validation-for="Allegato"></span>
            </div>
        </div>

        <div class="form-actions">
            <a class="btn btn--ghost" asp-action="Index">Annulla</a>
            <button type="submit" class="btn btn--primary">@(isNew ? "Registra contratto" : "Salva")</button>
        </div>
    </form>
</div>

@if (!isNew)
{
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="margin-top: var(--s-5); max-width:760px; text-align:right;"
          onsubmit="return confirm('Eliminare definitivamente questo contratto?');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn--ghost" style="border-color: rgba(217, 107, 94, 0.4); color: var(--c-danger);">Elimina contratto</button>
    </form>
}
