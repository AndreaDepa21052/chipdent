                        <div class="form-group" id="dlg-step-esito-wrap" style="display:none;">
                            <label class="form-label">Esito</label>
                            <select class="form-control" name="esito">
                                <option value="">— scegli —</option>
                                @foreach (var e in Enum.GetValues<EsitoProcedimento>())
                                {
                                    <option value="@e">@e</option>
                                }
                            </select>
                        </div>
                        <div class="form-group full">
                            <label class="form-label">Allegato (PDF/DOC/JPG/PNG, max 10MB)</label>
                            <input class="form-control" type="file" name="allegato" accept=".pdf,.png,.jpg,.jpeg,.doc,.docx" />
                        </div>
                        <div class="form-group full">
                            <label class="form-label">Note</label>
                            <textarea class="form-control" name="note" rows="2"></textarea>
                        </div>
                    </div>
                    <div style="display:flex; gap:8px; justify-content:flex-end; margin-top: var(--s-3);">
                        <button type="button" class="btn btn--ghost" data-close-dlg>Annulla</button>
                        <button type="submit" class="btn btn--primary">Salva step</button>
                    </div>
                </form>
            </dialog>

            <script>
                (function () {
                    var dlg = document.getElementById('dlg-step');
                    var frm = document.getElementById('frm-step');
                    var title = document.getElementById('dlg-step-title');
                    var num = document.getElementById('dlg-step-num');
                    var esitoWrap = document.getElementById('dlg-step-esito-wrap');
                    var dipId = '@d.Id';
                    document.querySelectorAll('[data-step-add]').forEach(function (btn) {
                        btn.addEventListener('click', function () {
                            num.value = btn.dataset.step;
                            title.textContent = btn.dataset.label;
                            frm.action = '/dipendenti/' + dipId + '/disciplinari/' + btn.dataset.procid + '/step';
                            esitoWrap.style.display = (btn.dataset.step === '4') ? 'block' : 'none';
                            dlg.showModal();
                        });
                    });
                    document.querySelectorAll('[data-close-dlg]').forEach(function (b) {
                        b.addEventListener('click', function () { b.closest('dialog').close(); });
                    });
                })();
            </script>
        }
    }
    else if (tab == "premi")
    {
        <div class="card" style="padding: var(--s-4); margin-bottom: var(--s-4);">
            <h3 class="card__title" style="margin-top: 0;">Registra nuovo premio / bonus / welfare</h3>
            <form asp-action="NuovoPremio" asp-route-id="@d.Id" method="post" enctype="multipart/form-data" class="form-grid" style="margin-top: var(--s-3);">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Tipo *</label>
                    <select class="form-control" name="tipo" required>
                        @foreach (var t in Enum.GetValues<TipoPremio>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Data *</label>
                    <input class="form-control" type="date" name="data" required value="@oggi.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group full">
                    <label class="form-label">Descrizione *</label>
                    <input class="form-control" name="descrizione" required placeholder="Es. Bonus produttività Q4" />
                </div>
                <div class="form-group">
                    <label class="form-label">Importo (€)</label>
                    <input class="form-control" type="number" step="0.01" min="0" name="importo" placeholder="es. 500,00" />
                </div>
                <div class="form-group">
                    <label class="form-label">Allegato</label>
                    <input class="form-control" type="file" name="allegato" accept=".pdf,.png,.jpg,.jpeg,.doc,.docx" />
                </div>
                <div class="form-group full">
                    <label class="form-label">Motivazione</label>
                    <textarea class="form-control" name="motivazione" rows="2"></textarea>
                </div>
                <div class="form-group full">
                    <label class="form-label">Note</label>
                    <textarea class="form-control" name="note" rows="2"></textarea>
                </div>
                <div class="form-group full" style="text-align:right;">
                    <button type="submit" class="btn btn--primary">＋ Registra premio</button>
                </div>
            </form>
        </div>

        @if (Model.Premi.Count == 0)
        {
            <div class="card" style="padding: var(--s-4);">
                <p class="muted">Nessun premio o bonus registrato.</p>
            </div>
        }
        else
        {
            <div class="card" style="padding:0; overflow:auto;">
                <table class="table">
                    <thead>
                        <tr><th>Data</th><th>Tipo</th><th>Descrizione</th><th>Importo</th><th>Motivazione</th><th>Allegato</th><th></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var pr in Model.Premi)
                    {
                        <tr>
                            <td>@pr.Data.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge">@pr.Tipo</span></td>
                            <td><strong>@pr.Descrizione</strong></td>
                            <td>@(pr.Importo.HasValue ? pr.Importo.Value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("it-IT")) : "—")</td>
                            <td class="muted">@(pr.Motivazione ?? "—")</td>
                            <td>@(string.IsNullOrEmpty(pr.AllegatoNome) ? "—" : "📎 " + pr.AllegatoNome)</td>
                            <td>
                                <form asp-action="EliminaPremio" asp-route-id="@d.Id" asp-route-premioId="@pr.Id" method="post" style="display:inline;" onsubmit="return confirm('Eliminare?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn--ghost btn--sm">🗑</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    }
    else if (tab == "valutazioni")
    {
        <div class="card" style="padding: var(--s-4); margin-bottom: var(--s-4);">
            <h3 class="card__title" style="margin-top: 0;">Nuova scheda di valutazione</h3>
            <form asp-action="NuovaValutazione" asp-route-id="@d.Id" method="post" enctype="multipart/form-data" class="form-grid" style="margin-top: var(--s-3);">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Periodo *</label>
                    <input class="form-control" name="periodo" required placeholder="es. 2026 H1" />
                </div>
                <div class="form-group">
                    <label class="form-label">Data scheda *</label>
                    <input class="form-control" type="date" name="data" required value="@oggi.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group">
                    <label class="form-label">Valutatore</label>
                    <input class="form-control" name="valutatoreNome" placeholder="@(User.Identity?.Name ?? "")" />
                </div>
                <div class="form-group">
                    <label class="form-label">Stato</label>
                    <select class="form-control" name="stato">
                        @foreach (var s in Enum.GetValues<StatoSchedaValutazione>())
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>

                <div class="form-group"><label class="form-label">Competenze (1-5)</label><input class="form-control" type="number" min="1" max="5" name="competenze" /></div>
                <div class="form-group"><label class="form-label">Comportamento (1-5)</label><input class="form-control" type="number" min="1" max="5" name="comportamento" /></div>
                <div class="form-group"><label class="form-label">Teamwork (1-5)</label><input class="form-control" type="number" min="1" max="5" name="teamwork" /></div>
                <div class="form-group"><label class="form-label">Puntualità (1-5)</label><input class="form-control" type="number" min="1" max="5" name="puntualita" /></div>
                <div class="form-group"><label class="form-label">Obiettivi (1-5)</label><input class="form-control" type="number" min="1" max="5" name="obiettivi" /></div>
                <div class="form-group"><label class="form-label">Voto finale (1-5)</label><input class="form-control" type="number" min="1" max="5" name="finale" /></div>

                <div class="form-group">
                    <label class="form-label">Data colloquio</label>
                    <input class="form-control" type="date" name="dataColloquio" />
                </div>
                <div class="form-group">
                    <label class="form-label">Firme</label>
                    <div style="display:flex; gap: var(--s-3); align-items:center; padding: 8px 0;">
                        <label><input type="checkbox" name="firmaDipendente" value="true" /> dipendente</label>
                        <label><input type="checkbox" name="firmaValutatore" value="true" /> valutatore</label>
                    </div>
                </div>

                <div class="form-group full">
                    <label class="form-label">Obiettivi per il prossimo periodo</label>
                    <textarea class="form-control" name="obiettiviTesto" rows="2"></textarea>
                </div>
                <div class="form-group full">
                    <label class="form-label">Punti di forza</label>
                    <textarea class="form-control" name="puntiForza" rows="2"></textarea>
                </div>
                <div class="form-group full">
                    <label class="form-label">Aree di miglioramento</label>
                    <textarea class="form-control" name="areeMiglioramento" rows="2"></textarea>
                </div>
                <div class="form-group full">
                    <label class="form-label">Commenti</label>
                    <textarea class="form-control" name="commenti" rows="2"></textarea>
                </div>
                <div class="form-group full">
                    <label class="form-label">Allegato (scheda firmata, PDF/DOC, max 10MB)</label>
                    <input class="form-control" type="file" name="allegato" accept=".pdf,.png,.jpg,.jpeg,.doc,.docx" />
                </div>
                <div class="form-group full" style="text-align:right;">
                    <button type="submit" class="btn btn--primary">＋ Salva scheda</button>
                </div>
            </form>
        </div>

        @if (Model.Valutazioni.Count == 0)
        {
            <div class="card" style="padding: var(--s-4);">
                <p class="muted">Nessuna scheda di valutazione registrata. È previsto almeno 2 schede l'anno.</p>
            </div>
        }
        else
        {
            <div class="card" style="padding:0; overflow:auto;">
                <table class="table">
                    <thead>
                        <tr><th>Periodo</th><th>Data</th><th>Valutatore</th><th>Voto finale</th><th>Media</th><th>Stato</th><th>Firme</th><th>Allegato</th><th></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var v in Model.Valutazioni)
                    {
                        <tr>
                            <td><strong>@v.Periodo</strong></td>
                            <td>@v.Data.ToString("dd/MM/yyyy")</td>
                            <td>@(v.ValutatoreNome ?? "—")</td>
                            <td>@(v.PunteggioFinale.HasValue ? v.PunteggioFinale + "/5" : "—")</td>
                            <td>@(v.PunteggioMedio.HasValue ? v.PunteggioMedio.Value.ToString("0.0") : "—")</td>
                            <td>
                                @switch (v.Stato)
                                {
                                    case StatoSchedaValutazione.Bozza: <span class="badge"><span class="dot"></span>bozza</span> break;
                                    case StatoSchedaValutazione.InCorso: <span class="badge badge--warning"><span class="dot"></span>in corso</span> break;
                                    case StatoSchedaValutazione.Conclusa: <span class="badge badge--success"><span class="dot"></span>conclusa</span> break;
                                    default: <span class="badge"><span class="dot"></span>archiviata</span> break;
                                }
                            </td>
                            <td>
                                @(v.FirmaDipendente ? "✓ dip." : "—") · @(v.FirmaValutatore ? "✓ val." : "—")
                            </td>
                            <td>@(string.IsNullOrEmpty(v.AllegatoNome) ? "—" : "📎 " + v.AllegatoNome)</td>
                            <td>
                                <form asp-action="EliminaValutazione" asp-route-id="@d.Id" asp-route-schedaId="@v.Id" method="post" style="display:inline;" onsubmit="return confirm('Eliminare?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn--ghost btn--sm">🗑</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    }
    else if (tab == "storico")
    {
        <partial name="_TimelineTrasferimenti" model="Model.Storico" />
    }
    else if (tab == "audit")
    {
        <partial name="_AuditFeed" model="Model.Audit" />
    }
</div>
