@{
    var section = (ViewData["Section"] as string) ?? "";
    var title = ViewData["Title"] as string ?? "Chipdent";
    var crumb = ViewData["Crumb"] as string;
    var fullName = User.Identity?.Name ?? "";
    var initials = string.IsNullOrWhiteSpace(fullName)
        ? "?"
        : string.Concat(fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                .Take(2)
                                .Select(p => char.ToUpper(p[0])));
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var tenantSlug = User.FindFirst("tenant_slug")?.Value ?? "confident";
    var tenantName = "Confident Dental";

    var canSeeAnagrafiche = User.IsManagement() || User.IsDirettore() || User.IsBackoffice();
    var canSeeUsers = User.IsManagement();
    var isFullAccess = User.IsManagement();
    var roleClass = role switch
    {
        "Owner"      => "role-badge--owner",
        "Management" => "role-badge--admin",
        "Direttore"  => "role-badge--manager",
        "Backoffice" => "role-badge--hr",
        _ => ""
    };
    var roleLabel = role switch
    {
        "Owner"      => "Owner",
        "Management" => "Management",
        "Direttore"  => "Direttore di sede",
        "Backoffice" => "Backoffice",
        "Staff"      => "Staff",
        _ => role
    };

    var sectionMap = new Dictionary<string, (string label, string controller)>
    {
        ["dashboard"]      = ("Dashboard", "Dashboard"),
        ["turni"]          = ("Turni", "Turni"),
        ["comunicazioni"]  = ("Comunicazioni", "Comunicazioni"),
        ["rls"]            = ("RLS / Sicurezza", "Rls"),
        ["documentazione"] = ("Documentazione", "Documentazione"),
        ["cliniche"]       = ("Cliniche", "Cliniche"),
        ["dottori"]        = ("Dottori", "Dottori"),
        ["dipendenti"]     = ("Dipendenti", "Dipendenti"),
        ["users"]          = ("Utenti", "Users")
    };
    sectionMap.TryGetValue(section, out var sectionInfo);
    var hasCrumb = !string.IsNullOrEmpty(crumb);
    var sectionIsRoot = !string.IsNullOrEmpty(sectionInfo.label) && sectionInfo.label.Equals(title, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title · Chipdent</title>
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content="#c47830" />
    <link rel="icon" type="image/png" href="~/img/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tour.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Chipdent.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app">
        <aside class="app__sidebar">

            <details class="ws" data-tour="workspace">
                <summary class="ws__chip" aria-label="Workspace switcher">
                    <span class="ws__mark"><img src="~/img/logo.png" alt="" width="32" height="32" /></span>
                    <span class="ws__text">
                        <span class="ws__name">@tenantName</span>
                        <span class="ws__slug">@(tenantSlug).chipdent.it</span>
                    </span>
                    <svg class="ws__chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 9l4-4 4 4"/><path d="M16 15l-4 4-4-4"/></svg>
                </summary>
                <div class="ws__menu" role="menu">
                    <div class="ws__menu-title">Workspace attivo</div>
                    <a class="ws__item is-active" href="#" role="menuitem">
                        <span class="ws__mark ws__mark--sm"><img src="~/img/logo.png" alt="" width="22" height="22" /></span>
                        <span style="flex:1;">@tenantName</span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><polyline points="20 6 9 17 4 12"/></svg>
                    </a>
                    <hr/>
                    <a class="ws__item" href="#" role="menuitem">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.6 1.6 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.6 1.6 0 0 0-1.8-.3 1.6 1.6 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.6 1.6 0 0 0-1-1.5 1.6 1.6 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.6 1.6 0 0 0 .3-1.8 1.6 1.6 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1a1.6 1.6 0 0 0 1.5-1 1.6 1.6 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.6 1.6 0 0 0 1.8.3H9a1.6 1.6 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.6 1.6 0 0 0 1 1.5 1.6 1.6 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.6 1.6 0 0 0-.3 1.8V9a1.6 1.6 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.6 1.6 0 0 0-1.5 1z"/></svg>
                        Impostazioni workspace
                    </a>
                    <a class="ws__item" href="#" role="menuitem">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                        Nuovo workspace
                    </a>
                </div>
            </details>

            <button class="ws-search" data-search-trigger data-tour="search" type="button">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                <span>Cerca…</span>
                <kbd>⌘K</kbd>
            </button>

            <nav class="nav" data-tour="sidebar-nav">
                <div class="nav__group-title">Operatività</div>
                <a class="nav__item @(section == "dashboard" ? "is-active" : "")" data-tour="nav-dashboard" asp-controller="Dashboard" asp-action="Index">
                    <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
                    Dashboard
                </a>
                <a class="nav__item @(section == "turni" ? "is-active" : "")" data-tour="nav-turni" asp-controller="Turni" asp-action="Index">
                    <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                    Turni
                </a>
                <a class="nav__item @(section == "comunicazioni" ? "is-active" : "")" data-tour="nav-comunicazioni" asp-controller="Comunicazioni" asp-action="Index">
                    <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    Comunicazioni
                </a>

                @if (canSeeAnagrafiche)
                {
                    <div class="nav__group-title">Anagrafiche</div>
                    <a class="nav__item @(section == "cliniche" ? "is-active" : "")" data-tour="nav-cliniche" asp-controller="Cliniche" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 21V12h6v9"/></svg>
                        Cliniche
                    </a>
                    <a class="nav__item @(section == "dottori" ? "is-active" : "")" data-tour="nav-dottori" asp-controller="Dottori" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
                        Dottori
                    </a>
                    <a class="nav__item @(section == "dipendenti" ? "is-active" : "")" data-tour="nav-dipendenti" asp-controller="Dipendenti" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="8" r="4"/><path d="M2 21a7 7 0 0 1 14 0"/><circle cx="17" cy="9" r="3"/><path d="M22 20a5 5 0 0 0-5-5"/></svg>
                        Dipendenti
                    </a>

                    <div class="nav__group-title">Compliance</div>
                    <a class="nav__item @(section == "rls" ? "is-active" : "")" data-tour="nav-rls" asp-controller="Rls" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        RLS / Sicurezza
                    </a>
                    <a class="nav__item @(section == "documentazione" ? "is-active" : "")" data-tour="nav-documentazione" asp-controller="Documentazione" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                        Documentazione
                    </a>
                }

                @if (canSeeAnagrafiche)
                {
                    <a class="nav__item @(section == "audit" ? "is-active" : "")" data-tour="nav-audit" asp-controller="Audit" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                        Audit log
                    </a>
                }

                @if (canSeeUsers)
                {
                    <div class="nav__group-title">Amministrazione</div>
                    <a class="nav__item @(section == "users" ? "is-active" : "")" data-tour="nav-users" asp-controller="Users" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M20 8v6M23 11h-6"/></svg>
                        Utenti
                    </a>
                }
            </nav>

            <details class="user-bar" data-tour="user-menu">
                <summary class="user-bar__chip" aria-label="Menu utente">
                    <span class="avatar">@initials</span>
                    <span class="user-bar__text">
                        <span class="user-bar__name">@fullName</span>
                        <span class="user-bar__role">
                            <span class="role-badge @roleClass">@roleLabel</span>
                        </span>
                    </span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg>
                </summary>
                <div class="user-bar__menu">
                    <div class="user-bar__menu-head">
                        <strong>@fullName</strong>
                        <span>@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</span>
                    </div>
                    <div class="access-pill @(isFullAccess ? "access-pill--full" : "access-pill--limited")">
                        @if (isFullAccess)
                        {
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><polyline points="20 6 9 17 4 12"/></svg>
                            <span><strong>@roleLabel · accesso completo</strong> — vedi tutti i dati del workspace</span>
                        }
                        else
                        {
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>
                            <span><strong>@roleLabel · vista limitata</strong> — alcune sezioni non sono disponibili</span>
                        }
                    </div>
                    <hr/>
                    <a class="user-bar__item" asp-controller="Account" asp-action="Profile">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
                        Il mio profilo
                    </a>
                    <a class="user-bar__item" asp-controller="Account" asp-action="Preferences">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v6M12 17v6M4.22 4.22l4.24 4.24M15.54 15.54l4.24 4.24M1 12h6M17 12h6M4.22 19.78l4.24-4.24M15.54 8.46l4.24-4.24"/></svg>
                        Preferenze
                    </a>
                    <button type="button" class="user-bar__item" data-tour-launcher>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
                        Tour guidato
                    </button>
                    <hr/>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="user-bar__item user-bar__item--danger">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="m16 17 5-5-5-5"/><path d="M21 12H9"/></svg>
                            Esci
                        </button>
                    </form>
                </div>
            </details>
        </aside>

        <main class="app__main">
            <header class="app__topbar">
                <nav class="crumbs" aria-label="Breadcrumb">
                    <a class="crumbs__home" asp-controller="Dashboard" asp-action="Index" aria-label="Home">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l9-9 9 9"/><path d="M5 10v10h14V10"/></svg>
                    </a>
                    @if (!string.IsNullOrEmpty(sectionInfo.label))
                    {
                        <span class="crumbs__sep">/</span>
                        @if (sectionIsRoot && !hasCrumb)
                        {
                            <span class="crumbs__current">@sectionInfo.label</span>
                        }
                        else
                        {
                            <a class="crumbs__item" asp-controller="@sectionInfo.controller" asp-action="Index">@sectionInfo.label</a>
                        }
                    }
                    @if (hasCrumb)
                    {
                        <span class="crumbs__sep">/</span>
                        <a class="crumbs__item" asp-controller="@sectionInfo.controller" asp-action="Index">@crumb</a>
                    }
                    @if (!sectionIsRoot)
                    {
                        <span class="crumbs__sep">/</span>
                        <span class="crumbs__current">@title</span>
                    }
                </nav>

                <div class="topbar__actions">
                    <span class="conn" data-conn data-state="connecting">
                        <span class="dot"></span>
                        <span class="label">connessione…</span>
                    </span>
                    <details class="bell" data-tour="bell">
                        <summary class="icon-btn icon-btn--sm" title="Notifiche" aria-label="Notifiche">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10 21a2 2 0 0 0 4 0"/></svg>
                            <span class="dot" data-bell-dot hidden></span>
                        </summary>
                        <div class="bell__panel" role="dialog" aria-label="Notifiche">
                            <div class="bell__head">
                                <strong>Notifiche</strong>
                                <button type="button" class="bell__mark" data-bell-mark>Segna come lette</button>
                            </div>
                            <div class="bell__body" data-bell-body>
                                <div class="bell__empty" data-bell-empty>
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--c-ink-soft); margin-bottom: 8px;"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10 21a2 2 0 0 0 4 0"/></svg>
                                    <p>Nessuna notifica ancora.</p>
                                    <p class="muted">Le novità del workspace appariranno qui in tempo reale.</p>
                                </div>
                            </div>
                            <div class="bell__foot">
                                <a asp-controller="Audit" asp-action="Index">Vedi tutto l'audit log →</a>
                            </div>
                        </div>
                    </details>
                </div>
            </header>

            <section class="app__content">
                @RenderBody()
            </section>
        </main>
    </div>

    <div class="toasts" aria-live="polite"></div>

    <div class="cmdk" data-cmdk hidden>
        <div class="cmdk__panel" role="dialog" aria-label="Cerca">
            <div class="cmdk__head">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="search" placeholder="Cerca clinica, dottore, documento…" autocomplete="off" />
                <kbd>esc</kbd>
            </div>
            <div class="cmdk__body">
                <div class="cmdk__group-title">Vai a</div>
                <a class="cmdk__item" asp-controller="Dashboard" asp-action="Index"><span>Dashboard</span><kbd>D</kbd></a>
                <a class="cmdk__item" asp-controller="Turni" asp-action="Index"><span>Turni</span><kbd>T</kbd></a>
                <a class="cmdk__item" asp-controller="Cliniche" asp-action="Index"><span>Cliniche</span><kbd>C</kbd></a>
                <a class="cmdk__item" asp-controller="Dottori" asp-action="Index"><span>Dottori</span><kbd>R</kbd></a>
                <a class="cmdk__item" asp-controller="Dipendenti" asp-action="Index"><span>Dipendenti</span><kbd>P</kbd></a>
                <a class="cmdk__item" asp-controller="Comunicazioni" asp-action="Index"><span>Comunicazioni</span><kbd>M</kbd></a>
                <a class="cmdk__item" asp-controller="Rls" asp-action="Index"><span>RLS / Sicurezza</span><kbd>S</kbd></a>
                <a class="cmdk__item" asp-controller="Documentazione" asp-action="Index"><span>Documentazione</span><kbd>O</kbd></a>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script src="~/js/cmdk.js" asp-append-version="true"></script>
    <script src="~/js/tour.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
