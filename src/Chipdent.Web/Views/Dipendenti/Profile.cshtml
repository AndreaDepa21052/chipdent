                var stepLabels = new[] { "1 · Lettera disciplinare", "2 · Lettera firmata", "3 · Risposta dipendente", "4 · Conclusione" };
                var stepDate = new DateTime?[] { p.Step1LetteraData, p.Step2FirmataData, p.Step3RispostaData, p.Step4ConclusioneData };
                var stepNote = new string?[] { p.Step1Note, p.Step2Note, p.Step3Note, p.Step4Note };
                var stepAlleg = new string?[] { p.Step1AllegatoNome, p.Step2AllegatoNome, p.Step3AllegatoNome, p.Step4AllegatoNome };

                <div class="card" style="padding: var(--s-4); margin-bottom: var(--s-4);">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap: var(--s-3);">
