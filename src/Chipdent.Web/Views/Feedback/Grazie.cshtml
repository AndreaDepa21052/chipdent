@model Chipdent.Web.Models.FeedbackGrazieViewModel
@{
    Layout = null;
    var emoji = Model.Score >= 9 ? "🌟" : Model.Score >= 7 ? "🙂" : "🙏";
    var msg = Model.Score >= 9
        ? "Grazie mille! Siamo felici che tu sia rimasto soddisfatto."
        : Model.Score >= 7
            ? "Grazie del tuo feedback. Continueremo a migliorare."
            : "Ci dispiace di non aver fatto meglio. Faremo tesoro del tuo riscontro.";
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Grazie · @Model.ClinicaNome</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Inter', system-ui, sans-serif; background: linear-gradient(135deg, #f5e8d0 0%, #e9d6b4 100%); min-height: 100vh; display: grid; place-items: center; padding: 24px; color: #3b1e0c; text-align: center; }
        .box { background: #fff; padding: 40px 32px; border-radius: 16px; max-width: 460px; box-shadow: 0 10px 40px rgba(0,0,0,0.08); }
        .em { font-size: 4rem; line-height: 1; margin-bottom: 14px; }
        h1 { font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 12px; }
        p { color: #6b4226; line-height: 1.5; font-size: 1.05rem; }
        .sede { margin-top: 18px; color: #c47830; font-weight: 600; font-size: 0.9rem; }
    </style>
</head>
<body>
    <div class="box">
        <div class="em">@emoji</div>
        <h1>Grazie!</h1>
        <p>@msg</p>
        <div class="sede">@Model.ClinicaNome</div>
    </div>
</body>
</html>
