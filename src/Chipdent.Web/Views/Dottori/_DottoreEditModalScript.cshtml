@{
    // Script condiviso che gestisce apertura/chiusura/submit AJAX della modale
    // di modifica dottore. Si aggancia a qualunque elemento con [data-edit-dottore="<id>"]
    // e al <dialog id="dlg-dottore-edit"> presente nella pagina.
}
<script>
(function () {
    const dlg = document.getElementById('dlg-dottore-edit');
    if (!dlg) return;

    let currentId = null;

    function setLoading() {
        dlg.innerHTML = '<div class="dotmodal" data-dotmodal-loading><div style="padding:60px;text-align:center;color:#6b5538;">Caricamento…</div></div>';
    }

    function close() {
        if (typeof dlg.close === 'function') dlg.close();
        else dlg.removeAttribute('open');
    }

    async function open(id) {
        currentId = id;
        setLoading();
        if (typeof dlg.showModal === 'function') dlg.showModal();
        else dlg.setAttribute('open', '');

        try {
            const r = await fetch('/dottori/' + encodeURIComponent(id) + '/edit-modal', {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            if (!r.ok) throw new Error('Errore caricamento (' + r.status + ')');
            const html = await r.text();
            dlg.innerHTML = html;
            wireUpInner();
        } catch (err) {
            dlg.innerHTML = '<div class="dotmodal"><div style="padding:30px;color:#7a2a2a;">Impossibile caricare la scheda: ' + (err.message || err) + ' <button type="button" class="btn btn--ghost" onclick="this.closest(\'dialog\').close()">Chiudi</button></div></div>';
        }
    }

    function wireUpInner() {
        dlg.querySelectorAll('[data-dotmodal-close]').forEach(b =>
            b.addEventListener('click', () => close()));

        // Section nav scrollspy + smooth scroll
        const nav = dlg.querySelector('.dotmodal__sectionnav');
        const scroll = dlg.querySelector('.dotmodal__scroll');
        if (nav && scroll) {
            nav.querySelectorAll('a').forEach(a => {
                a.addEventListener('click', (e) => {
                    e.preventDefault();
                    const target = scroll.querySelector(a.getAttribute('href'));
                    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
            });
            const sections = Array.from(scroll.querySelectorAll('.dotmodal__section'));
            scroll.addEventListener('scroll', () => {
                const top = scroll.scrollTop + 20;
                let active = sections[0];
                for (const s of sections) {
                    if (s.offsetTop - 30 <= top) active = s;
                }
                if (active) {
                    nav.querySelectorAll('a').forEach(a => a.classList.toggle(
                        'is-active', a.getAttribute('href') === '#' + active.id));
                }
            }, { passive: true });
        }

        // Form submit via fetch
        const form = dlg.querySelector('#dotmodal-form');
        const errorsBox = dlg.querySelector('[data-dotmodal-errors]');
        const saveBtn = dlg.querySelector('[data-dotmodal-save]');
        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                if (errorsBox) { errorsBox.hidden = true; errorsBox.textContent = ''; }
                const fd = new FormData(form);
                if (saveBtn) { saveBtn.setAttribute('disabled', 'disabled'); saveBtn.textContent = 'Salvataggio…'; }
                try {
                    const r = await fetch(form.action, {
                        method: 'POST',
                        body: fd,
                        headers: { 'X-Edit-Modal': '1', 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    if (r.ok) {
                        const data = await r.json().catch(() => ({}));
                        close();
                        // Reload per riflettere le modifiche (lista o profilo)
                        window.location.reload();
                        return;
                    }
                    if (r.status === 400) {
                        const data = await r.json().catch(() => ({}));
                        if (errorsBox) {
                            const lines = [];
                            if (data && data.errors) {
                                for (const k of Object.keys(data.errors)) {
                                    for (const m of data.errors[k]) lines.push((k ? k + ': ' : '') + m);
                                }
                            }
                            errorsBox.textContent = lines.length ? lines.join(' · ') : 'Validazione fallita.';
                            errorsBox.hidden = false;
                            errorsBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                    } else {
                        if (errorsBox) {
                            errorsBox.textContent = 'Errore inatteso (' + r.status + ').';
                            errorsBox.hidden = false;
                        }
                    }
                } catch (err) {
                    if (errorsBox) {
                        errorsBox.textContent = 'Errore rete: ' + (err.message || err);
                        errorsBox.hidden = false;
                    }
                } finally {
                    if (saveBtn) { saveBtn.removeAttribute('disabled'); saveBtn.textContent = 'Salva modifiche'; }
                }
            });
        }
    }

    // Trigger globale: tutti gli elementi con [data-edit-dottore]
    document.addEventListener('click', (e) => {
        const t = e.target.closest('[data-edit-dottore]');
        if (!t) return;
        e.preventDefault();
        const id = t.getAttribute('data-edit-dottore');
        if (id) open(id);
    });

    // Chiusura con click su backdrop
    dlg.addEventListener('click', (e) => {
        if (e.target === dlg) close();
    });
})();
</script>
