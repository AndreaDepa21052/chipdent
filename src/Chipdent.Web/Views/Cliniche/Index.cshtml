@model IReadOnlyList<Chipdent.Web.Domain.Entities.Clinica>
@{
    ViewData["Title"] = "Cliniche";
    var viewMode = (ViewData["ViewMode"] as string) ?? "lista";
    var geoCount = Model.Count(c => c.IsGeolocalized);
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>Cliniche</h2>
        <p class="page-head__sub">@Model.Count sedi · @Model.Count(c => c.Stato == Chipdent.Web.Domain.Entities.ClinicaStato.Operativa) operative · @geoCount geolocalizzate</p>
    </div>
    <div class="page-head__actions">
        <div class="seg" role="tablist" aria-label="Modalità di visualizzazione" style="display:inline-flex; gap:0; border:1px solid var(--c-border, #e9e1d3); border-radius: 8px; overflow:hidden; margin-right: var(--s-2);">
            <a class="btn @(viewMode == "lista" ? "btn--primary" : "btn--ghost")" asp-action="Index" style="border-radius: 0;">Lista</a>
            <a class="btn @(viewMode == "mappa" ? "btn--primary" : "btn--ghost")" asp-action="Index" asp-route-view="mappa" style="border-radius: 0;">Mappa</a>
        </div>
        <a class="btn btn--primary" asp-action="Create">+ Nuova clinica</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="card">
        <div class="empty">
            <div class="empty__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21V8l9-5 9 5v13"/></svg>
            </div>
            <h3>Nessuna clinica ancora</h3>
            <p>Aggiungi la prima sede della tua catena per iniziare.</p>
            <a class="btn btn--primary" asp-action="Create" style="margin-top: var(--s-3);">+ Nuova clinica</a>
        </div>
    </div>
}
else if (viewMode == "mappa")
{
    <div class="card" style="padding:0; overflow:hidden;">
        <div id="cliniche-map" style="width: 100%; height: 70vh; min-height: 480px;"></div>
    </div>

    @if (geoCount < Model.Count)
    {
        <div class="alert alert--info" style="margin-top: var(--s-3);">
            @(Model.Count - geoCount) sed@(Model.Count - geoCount == 1 ? "e" : "i") senza coordinate. Modifica la clinica per aggiungere latitudine e longitudine.
        </div>
    }
}
else
{
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Città</th>
                    <th>Riuniti</th>
                    <th>Stato</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>
                            <div class="strong">@c.Nome</div>
                            <div class="muted">@c.Indirizzo @(c.IsGeolocalized ? "📍" : "")</div>
                        </td>
                        <td>@c.Citta</td>
                        <td>@c.NumeroRiuniti</td>
                        <td>
                            @switch (c.Stato)
                            {
                                case Chipdent.Web.Domain.Entities.ClinicaStato.Operativa:
                                    <span class="badge badge--success"><span class="dot"></span>operativa</span>
                                    break;
                                case Chipdent.Web.Domain.Entities.ClinicaStato.InApertura:
                                    <span class="badge badge--warning"><span class="dot"></span>in apertura</span>
                                    break;
                                default:
                                    <span class="badge badge--danger"><span class="dot"></span>chiusa</span>
                                    break;
                            }
                        </td>
                        <td>
                            <div class="actions">
                                <a class="ibtn" asp-action="Details" asp-route-id="@c.Id" title="Dettagli">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                                </a>
                                <a class="ibtn" asp-action="Edit" asp-route-id="@c.Id" title="Modifica">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (viewMode == "mappa")
{
    @section Scripts {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
        <script>
            (function () {
                var map = L.map('cliniche-map').setView([42.0, 12.5], 5);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
                }).addTo(map);

                var stateColor = {
                    'Operativa':  '#2d7a50',
                    'InApertura': '#c47830',
                    'Chiusa':     '#a83a3a'
                };

                fetch('@Url.Action("MapData", "Cliniche")')
                    .then(function (r) { return r.json(); })
                    .then(function (pins) {
                        if (!pins.length) return;
                        var bounds = [];
                        pins.forEach(function (p) {
                            var color = stateColor[p.stato] || '#7a5c3a';
                            var icon = L.divIcon({
                                className: 'clinica-pin',
                                html: '<svg width="32" height="40" viewBox="0 0 32 40" xmlns="http://www.w3.org/2000/svg">' +
                                      '<path d="M16 0C7.16 0 0 7.16 0 16c0 12 16 24 16 24s16-12 16-24C32 7.16 24.84 0 16 0z" fill="' + color + '"/>' +
                                      '<circle cx="16" cy="16" r="6" fill="#fff"/></svg>',
                                iconSize: [32, 40],
                                iconAnchor: [16, 40],
                                popupAnchor: [0, -36]
                            });
                            var m = L.marker([p.lat, p.lng], { icon: icon }).addTo(map);
                            m.bindPopup(
                                '<div style="font-family:Inter,sans-serif; min-width:180px;">' +
                                '<div style="font-weight:700; color:#3b1e0c; margin-bottom:4px;">' + p.nome + '</div>' +
                                '<div style="font-size:12px; color:#7a5c3a; margin-bottom:6px;">' + p.indirizzo + ' · ' + p.citta + '</div>' +
                                '<div style="font-size:11px; color:#7a5c3a;">' + p.riuniti + ' riuniti · ' + p.stato + '</div>' +
                                '<a href="/cliniche/' + p.id + '" style="display:inline-block; margin-top:8px; font-size:11px; color:' + color + ';">Vai al dettaglio →</a>' +
                                '</div>'
                            );
                            bounds.push([p.lat, p.lng]);
                        });
                        if (bounds.length === 1) {
                            map.setView(bounds[0], 13);
                        } else if (bounds.length > 1) {
                            map.fitBounds(bounds, { padding: [40, 40] });
                        }
                    });
            })();
        </script>
    }
}
