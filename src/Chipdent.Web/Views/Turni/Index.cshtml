@model Chipdent.Web.Models.TurniWeekViewModel
@{
    ViewData["Title"] = "Turni";
    var culture = new System.Globalization.CultureInfo("it-IT");
    // Usa UTC come Turno.Data per evitare mismatch di fuso orario nel confronto
    // delle celle giornaliere (Turno.Data è salvato come UTC midnight).
    var today = DateTime.UtcNow.Date;
    var prevWeek = Model.WeekStart.AddDays(-7);
    var nextWeek = Model.WeekStart.AddDays(7);
    var restricted = (bool)(ViewData["RestrictedView"] ?? false);
    var noLink = (bool)(ViewData["NoLinkedPerson"] ?? false);
    var canRequestSwap = (bool)(ViewData["CanRequestSwap"] ?? false);

    // Indicizza i conflitti per (personaId, data) per evidenziare le celle.
    var conflittiByCell = Model.Conflitti
        .GroupBy(c => $"{c.PersonaId}|{c.Data:yyyy-MM-dd}")
        .ToDictionary(g => g.Key, g => g.Select(c => c.Motivo).ToList());

    // Copertura per giorno (sede × giorno × tipo persona): conta turni totali per giorno per warning copertura minima.
    var coperturaPerGiorno = Model.Days
        .ToDictionary(d => d, d => Model.Righe.Sum(r => r.Turni.Count(t => t.Data.Date == d.Date)));
}

<partial name="_Flash" />

@if (restricted)
{
    <div class="alert alert--info" style="margin-bottom: var(--s-4);">
        Stai vedendo solo i tuoi turni. Per la pianificazione completa contatta il responsabile.
    </div>
}
@if (noLink)
{
    <div class="alert alert--info" style="margin-bottom: var(--s-4);">
        Il tuo account non è ancora collegato a un dottore o dipendente — chiedi all'amministratore di completare il collegamento per vedere i tuoi turni.
    </div>
}

@if (Model.Conflitti.Any())
{
    <div class="alert alert--danger" style="margin-bottom: var(--s-4);">
        <strong>@Model.Conflitti.Count conflitt@(Model.Conflitti.Count == 1 ? "o" : "i") rilevat@(Model.Conflitti.Count == 1 ? "o" : "i"):</strong>
        <ul style="margin: 6px 0 0; padding-left: 20px; font-size:.85rem;">
            @foreach (var c in Model.Conflitti.Take(5))
            {
                <li>@c.PersonaNome · @c.Data.ToString("dd/MM") — @c.Motivo</li>
            }
            @if (Model.Conflitti.Count > 5)
            {
                <li><em>… e altri @(Model.Conflitti.Count - 5)</em></li>
            }
        </ul>
    </div>
}

<div class="page-head">
    <div>
        <h2>Turni</h2>
        <p class="page-head__sub">
            Settimana dal @Model.WeekStart.ToString("dd MMM", culture) al @Model.WeekEnd.ToString("dd MMM yyyy", culture)
        </p>
    </div>
    <div class="page-head__actions cal-nav">
        <a class="ibtn" asp-action="Index" asp-route-week="@prevWeek.ToString("yyyy-MM-dd")" title="Settimana precedente">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </a>
        <a class="ibtn" asp-action="Index" asp-route-week="@today.ToString("yyyy-MM-dd")" title="Oggi" style="width:auto; padding: 0 12px;">Oggi</a>
        <a class="ibtn" asp-action="Index" asp-route-week="@nextWeek.ToString("yyyy-MM-dd")" title="Settimana successiva">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </a>
        @if (Model.CanEdit)
        {
            <form asp-action="CopiaSettimana" method="post" style="display:inline; margin-left: var(--s-2);"
                  onsubmit="return confirm('Copiare i turni di questa settimana nella settimana successiva?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="week" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                <button type="submit" class="btn btn--ghost" style="font-size:.82rem;">📋 Copia → settimana succ.</button>
            </form>
            <a class="btn btn--ghost" asp-action="Templates" style="font-size:.82rem;">⚙️ Template</a>
            <a class="btn btn--primary" asp-action="Create" asp-route-week="@Model.WeekStart.ToString("yyyy-MM-dd")" style="margin-left: var(--s-2);">+ Nuovo turno</a>
        }
    </div>
</div>

@if (Model.Templates.Any() && Model.CanEdit)
{
    <div class="card" style="padding: var(--s-3); margin-bottom: var(--s-3);">
        <div style="display:flex; align-items:center; gap: var(--s-3); flex-wrap:wrap; font-size:.82rem;">
            <span class="muted">Template rapidi (drag su una cella):</span>
            @foreach (var tpl in Model.Templates)
            {
                <span class="tpl-pill" draggable="true"
                      data-template-id="@tpl.Id"
                      data-template-nome="@tpl.Nome"
                      style="background: @(tpl.ColoreHex ?? "#c47830"); color:#fff; padding: 4px 10px; border-radius: 12px; cursor: grab; user-select:none;">
                    @tpl.Nome · @tpl.OraInizio.ToString(@"hh\:mm")–@tpl.OraFine.ToString(@"hh\:mm")
                </span>
            }
        </div>
    </div>
}

@if (Model.Righe.Count == 0)
{
    <div class="card">
        <div class="empty">
            <div class="empty__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            </div>
            <h3>Nessuna persona attiva</h3>
            <p>Aggiungi dottori o dipendenti per pianificare i turni.</p>
        </div>
    </div>
}
else
{
    <div class="cal">
        <div class="cal__head">
            <div>Persona</div>
            @foreach (var d in Model.Days)
            {
                var isToday = d.Date == today;
                var copertura = coperturaPerGiorno[d];
                var sotto = copertura < Model.CoperturaMinimaPerGiorno;
                <div class="@(isToday ? "today" : "")" title="@copertura turni">
                    @d.ToString("ddd", culture)
                    <span class="day-num">@d.Day</span>
                    @if (sotto && d.DayOfWeek != DayOfWeek.Saturday && d.DayOfWeek != DayOfWeek.Sunday)
                    {
                        <span title="Sotto la copertura minima (@Model.CoperturaMinimaPerGiorno)" style="color:#c47830; font-size:.7rem;">⚠</span>
                    }
                </div>
            }
        </div>
        @foreach (var riga in Model.Righe)
        {
            <div class="cal__row">
                <div class="cal__person">
                    <div class="name">@riga.Nome</div>
                    <div class="meta">@riga.Sotto</div>
                </div>
                @foreach (var d in Model.Days)
                {
                    var turniDelGiorno = riga.Turni.Where(t => t.Data.Date == d.Date).OrderBy(t => t.OraInizio).ToList();
                    var conflictKey = $"{riga.Id}|{d:yyyy-MM-dd}";
                    var hasConflict = conflittiByCell.ContainsKey(conflictKey);
                    var createUrl = Url.Action("Create", "Turni", new {
                        data = d.ToString("yyyy-MM-dd"),
                        personaId = riga.Id,
                        tipo = riga.Tipo,
                        week = Model.WeekStart.ToString("yyyy-MM-dd")
                    });
                    <div class="cal__cell @(hasConflict ? "cal__cell--conflict" : "")"
                         data-persona-id="@riga.Id"
                         data-persona-tipo="@riga.Tipo"
                         data-data="@d.ToString("yyyy-MM-dd")"
                         data-href="@createUrl"
                         @(hasConflict ? $"title=⚠ {string.Join(" — ", conflittiByCell[conflictKey])}" : "")
                         onclick="if(Model_canEdit && !event.target.closest('.cal__shift')) location.href=this.dataset.href;">
                        @foreach (var t in turniDelGiorno)
                        {
                            var clinicaNome = Model.ClinicheLookup.TryGetValue(t.ClinicaId, out var n) ? n : "";
                            if (canRequestSwap)
                            {
                                <a class="cal__shift @(riga.Tipo == Chipdent.Web.Domain.Entities.TipoPersona.Dipendente ? "cal__shift--alt" : "")"
                                   data-turno-id="@t.Id"
                                   asp-controller="CambioTurno" asp-action="Create" asp-route-turnoId="@t.Id"
                                   title="Cedi questo turno a un collega">
                                    @t.OraInizio.ToString(@"hh\:mm")–@t.OraFine.ToString(@"hh\:mm")
                                    <small>@clinicaNome ↔</small>
                                </a>
                            }
                            else
                            {
                                <a class="cal__shift @(riga.Tipo == Chipdent.Web.Domain.Entities.TipoPersona.Dipendente ? "cal__shift--alt" : "")"
                                   draggable="true"
                                   data-turno-id="@t.Id"
                                   asp-action="Edit"
                                   asp-route-id="@t.Id"
                                   asp-route-week="@Model.WeekStart.ToString("yyyy-MM-dd")">
                                    @t.OraInizio.ToString(@"hh\:mm")–@t.OraFine.ToString(@"hh\:mm")
                                    <small>@clinicaNome</small>
                                </a>
                            }
                        }
                    </div>
                }
            </div>
        }
    </div>
}

<style>
    .tpl-pill[draggable="true"]:active { cursor: grabbing; }
    .cal__cell--conflict { background: rgba(217, 107, 94, 0.08); outline: 1px dashed rgba(217, 107, 94, 0.5); outline-offset: -2px; }
    .cal__cell.is-drop-target { background: rgba(196, 120, 48, 0.12); outline: 2px dashed var(--c-accent, #c47830); outline-offset: -2px; }
    .cal__shift[draggable="true"] { cursor: grab; }
    .cal__shift[draggable="true"]:active { cursor: grabbing; }
</style>

@if (Model.CanEdit)
{
    <!-- Modale selezione clinica per drop template -->
    <div id="cliniche-modal" class="cdm-modal" hidden role="dialog" aria-modal="true" aria-labelledby="cdm-title">
        <div class="cdm-modal__backdrop" data-close></div>
        <div class="cdm-modal__panel">
            <header class="cdm-modal__head">
                <h3 id="cdm-title">📍 Scegli la clinica</h3>
                <button type="button" class="cdm-modal__close" data-close aria-label="Chiudi">✕</button>
            </header>
            <p class="cdm-modal__sub" id="cdm-sub"></p>
            <div class="cdm-clinic-list">
                @foreach (var kv in Model.ClinicheLookup.OrderBy(k => k.Value))
                {
                    <button type="button" class="cdm-clinic-btn" data-clinica-id="@kv.Key">
                        <span class="cdm-clinic-icon">🏥</span>
                        <span class="cdm-clinic-name">@kv.Value</span>
                        <span class="cdm-clinic-arrow">→</span>
                    </button>
                }
            </div>
            <footer class="cdm-modal__foot">
                <button type="button" class="btn btn--ghost" data-close>Annulla</button>
            </footer>
        </div>
    </div>

    <style>
        .cdm-modal { position: fixed; inset: 0; z-index: 9000; display: flex; align-items: center; justify-content: center; padding: 16px; }
        .cdm-modal[hidden] { display: none; }
        .cdm-modal__backdrop { position: absolute; inset: 0; background: rgba(42, 21, 8, 0.5); backdrop-filter: blur(2px); animation: cdm-fade 0.18s ease-out; }
        .cdm-modal__panel { position: relative; background: #fff; border-radius: 16px; max-width: 460px; width: 100%; box-shadow: 0 24px 60px rgba(59,30,12,0.3); overflow: hidden; animation: cdm-slide 0.22s cubic-bezier(0.2, 0.9, 0.3, 1); }
        .cdm-modal__head { display: flex; justify-content: space-between; align-items: center; padding: 18px 22px 6px; }
        .cdm-modal__head h3 { font-family: 'Playfair Display', serif; font-size: 1.25rem; color: var(--c-ink, #2a1508); margin: 0; }
        .cdm-modal__close { background: none; border: 0; font-size: 18px; color: var(--c-ink-soft, #7a5c3a); cursor: pointer; padding: 4px 8px; border-radius: 6px; }
        .cdm-modal__close:hover { background: var(--c-bg-soft, #faf6f0); }
        .cdm-modal__sub { padding: 0 22px; font-size: .85rem; color: var(--c-ink-soft, #7a5c3a); margin: 0 0 14px; }
        .cdm-clinic-list { padding: 0 22px 12px; display: flex; flex-direction: column; gap: 8px; max-height: 360px; overflow-y: auto; }
        .cdm-clinic-btn { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border: 1.5px solid var(--c-border, #e9e1d3); border-radius: 12px; background: #fff; cursor: pointer; font-size: 1rem; color: var(--c-ink, #2a1508); transition: all 0.12s; text-align: left; font-family: inherit; }
        .cdm-clinic-btn:hover { border-color: var(--c-accent, #c47830); background: var(--c-bg-soft, #faf6f0); transform: translateX(2px); }
        .cdm-clinic-btn:focus { outline: 2px solid var(--c-accent, #c47830); outline-offset: 2px; }
        .cdm-clinic-icon { font-size: 1.25rem; }
        .cdm-clinic-name { flex: 1; font-weight: 600; }
        .cdm-clinic-arrow { color: var(--c-ink-soft, #7a5c3a); transition: transform 0.12s; }
        .cdm-clinic-btn:hover .cdm-clinic-arrow { transform: translateX(4px); color: var(--c-accent, #c47830); }
        .cdm-modal__foot { padding: 12px 22px 18px; display: flex; justify-content: flex-end; border-top: 1px solid var(--c-bg-soft, #f3ece0); }
        @@keyframes cdm-fade { from { opacity: 0; } to { opacity: 1; } }
        @@keyframes cdm-slide { from { opacity: 0; transform: translateY(12px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
    </style>

    @section Scripts {
    <script>
        var Model_canEdit = @Json.Serialize(Model.CanEdit);

        (function () {
            // ── Drag & drop turni esistenti ──
            var draggedTurnoId = null;
            document.querySelectorAll('.cal__shift[draggable="true"]').forEach(function (el) {
                el.addEventListener('dragstart', function (e) {
                    draggedTurnoId = el.dataset.turnoId;
                    e.dataTransfer.effectAllowed = 'move';
                    e.dataTransfer.setData('text/plain', 'turno:' + draggedTurnoId);
                });
            });

            // ── Drag template ──
            var draggedTemplate = null;
            document.querySelectorAll('.tpl-pill[draggable="true"]').forEach(function (el) {
                el.addEventListener('dragstart', function (e) {
                    draggedTemplate = el.dataset.templateId;
                    e.dataTransfer.effectAllowed = 'copy';
                    e.dataTransfer.setData('text/plain', 'template:' + draggedTemplate);
                });
            });

            // ── Drop su una cella ──
            document.querySelectorAll('.cal__cell').forEach(function (cell) {
                cell.addEventListener('dragover', function (e) { e.preventDefault(); cell.classList.add('is-drop-target'); });
                cell.addEventListener('dragleave', function () { cell.classList.remove('is-drop-target'); });
                cell.addEventListener('drop', function (e) {
                    e.preventDefault();
                    cell.classList.remove('is-drop-target');
                    var data = e.dataTransfer.getData('text/plain') || '';
                    var personaId = cell.dataset.personaId;
                    var personaTipo = cell.dataset.personaTipo;
                    var dataIso = cell.dataset.data;

                    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

                    if (data.indexOf('turno:') === 0) {
                        var id = data.substring(6);
                        var fd = new FormData();
                        fd.append('data', dataIso);
                        fd.append('personaId', personaId);
                        fd.append('tipo', personaTipo);
                        fd.append('__RequestVerificationToken', token);
                        fetch('/turni/' + encodeURIComponent(id) + '/sposta', { method: 'POST', body: fd })
                            .then(function (r) {
                                if (r.ok) location.reload();
                                else r.text().then(function (t) { alert('Spostamento fallito (' + r.status + '): ' + (t || r.statusText)); });
                            })
                            .catch(function (err) { alert('Spostamento fallito: ' + err); });
                    }
                    else if (data.indexOf('template:') === 0) {
                        var tid = data.substring(9);
                        var personaNome = cell.closest('.cal__row')?.querySelector('.cal__person .name')?.textContent?.trim() || 'persona';
                        var giornoLabel = new Date(dataIso).toLocaleDateString('it-IT', { weekday: 'long', day: 'numeric', month: 'short' });

                        var modal = document.getElementById('cliniche-modal');
                        var subEl = document.getElementById('cdm-sub');
                        if (subEl) subEl.textContent = 'Seleziona la sede in cui assegnare il turno di ' + personaNome + ' di ' + giornoLabel + '.';

                        var clinicBtns = modal.querySelectorAll('.cdm-clinic-btn');

                        // Auto-submit se c'è una sola clinica
                        if (clinicBtns.length === 1) {
                            submitQuickShift(tid, dataIso, personaId, personaTipo, clinicBtns[0].dataset.clinicaId, token);
                            return;
                        }

                        // Apri la modale e collega i pulsanti
                        modal.hidden = false;
                        var firstBtn = clinicBtns[0];
                        if (firstBtn) firstBtn.focus();

                        clinicBtns.forEach(function (btn) {
                            btn.onclick = function () {
                                modal.hidden = true;
                                submitQuickShift(tid, dataIso, personaId, personaTipo, btn.dataset.clinicaId, token);
                            };
                        });
                    }
                });
            });

            // ── Helper: crea turno rapido da template ──
            function submitQuickShift(templateId, dataIso, personaId, personaTipo, clinicaId, token) {
                var fd2 = new FormData();
                fd2.append('templateId', templateId);
                fd2.append('data', dataIso);
                fd2.append('personaId', personaId);
                fd2.append('tipo', personaTipo);
                fd2.append('clinicaId', clinicaId);
                fd2.append('__RequestVerificationToken', token);
                fetch('/turni/rapido', { method: 'POST', body: fd2 })
                    .then(function (r) {
                        if (r.ok) location.reload();
                        else r.text().then(function (t) { alert('Creazione fallita (' + r.status + '): ' + (t || r.statusText)); });
                    })
                    .catch(function (err) { alert('Creazione fallita: ' + err); });
            }

            // ── Modale: chiusura via backdrop / pulsanti / ESC ──
            var modal = document.getElementById('cliniche-modal');
            if (modal) {
                modal.querySelectorAll('[data-close]').forEach(function (el) {
                    el.addEventListener('click', function () { modal.hidden = true; });
                });
                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape' && !modal.hidden) modal.hidden = true;
                });
            }
        })();
    </script>
    <form id="afh" style="display:none;">@Html.AntiForgeryToken()</form>
    }
}
