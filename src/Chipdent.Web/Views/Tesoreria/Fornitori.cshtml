@model Chipdent.Web.Models.FornitoriIndexViewModel
@using Chipdent.Web.Domain.Entities
@using System.Globalization
@{
    ViewData["Title"] = "Fornitori";
    ViewData["Crumb"] = "Tesoreria";
    var it = new CultureInfo("it-IT");
    var senzaSepa = Model.Fornitori.Count(r => r.Fornitore.Stato == StatoFornitore.Attivo && !r.Completezza.SepaPronto);
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>👥 Fornitori</h2>
        <p class="page-head__sub">Anagrafica passiva. Ogni fornitore può essere abilitato al portale per caricare le proprie fatture e consultare lo stato dei pagamenti.</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Tesoreria</a>
        <a class="btn btn--primary" asp-action="NuovoFornitore">＋ Nuovo fornitore</a>
    </div>
</div>

@if (senzaSepa > 0)
{
    <div class="card" style="background:#fff7e6; border-left: 4px solid #c47830; margin-bottom: var(--s-3);">
        <strong style="color:#a86010;">⚠️ @senzaSepa fornitor@(senzaSepa == 1 ? "e" : "i") attiv@(senzaSepa == 1 ? "o" : "i") con dati SEPA incompleti.</strong>
        <span class="muted">Senza IBAN valido (e dati anagrafici minimi) non è possibile generare la distinta di incasso/pagamento SEPA.</span>
    </div>
}

@if (Model.Fornitori.Count == 0)
{
    <div class="card">
        <p class="muted">Nessun fornitore registrato. Inizia da "Nuovo fornitore" o usa il seed dimostrativo.</p>
    </div>
}
else
{
    <div data-table-search>
        <partial name="_TableSearch" model='new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData) { ["Placeholder"] = "Cerca fornitore per ragione sociale, P.IVA, categoria…", ["Singular"] = "fornitore", ["Plural"] = "fornitori" }' />
        <div class="table-search__empty">Nessun fornitore corrisponde alla ricerca.</div>
    <div class="card" style="padding:0; overflow:auto;">
        <table class="table">
            <thead>
                <tr>
                    <th style="white-space:nowrap;">Codice</th>
                    <th>Ragione sociale</th>
                    <th>P.IVA</th>
                    <th>Categoria</th>
                    <th>Stato</th>
                    <th title="Percentuale di completezza dell'anagrafica + dati SEPA. I campi richiesti per la distinta SEPA pesano il doppio.">Completezza</th>
                    <th>SEPA</th>
                    <th>Portale</th>
                    <th style="text-align:right;">Esposto</th>
                    <th style="text-align:right;">Fatture YTD</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model.Fornitori)
            {
                var perc = r.Completezza.Percentuale;
                var barColor = perc >= 90 ? "#3aa15b" : perc >= 60 ? "#c47830" : "#a83a3a";
                var tooltipMancanti = r.Completezza.TuttiCampiMancanti.Count == 0
                    ? "Tutti i dati anagrafici sono completi."
                    : "Campi mancanti: " + string.Join(", ", r.Completezza.TuttiCampiMancanti);
                <tr>
                    <td class="muted" style="white-space:nowrap;">@(string.IsNullOrEmpty(r.Fornitore.Codice) ? "—" : r.Fornitore.Codice)</td>
                    <td><strong>@r.Fornitore.RagioneSociale</strong></td>
                    <td class="muted">@(r.Fornitore.PartitaIva ?? "—")</td>
                    <td>@r.Fornitore.CategoriaDefault</td>
                    <td>
                        @if (r.Fornitore.Stato == StatoFornitore.Attivo)
                        {
                            <span class="badge" style="background:#dff5e6; color:#1f6e3a;">attivo</span>
                        }
                        else if (r.Fornitore.Stato == StatoFornitore.Sospeso)
                        {
                            <span class="badge" style="background:#fff2dd; color:#a86010;">sospeso</span>
                        }
                        else
                        {
                            <span class="badge" style="background:#eee; color:#666;">cessato</span>
                        }
                    </td>
                    <td title="@tooltipMancanti" style="min-width: 130px;">
                        <div style="display:flex; align-items:center; gap:6px;">
                            <div style="flex:1; height:6px; background:#eee; border-radius:3px; overflow:hidden;">
                                <div style="width:@(perc)%; height:100%; background:@barColor;"></div>
                            </div>
                            <span style="font-size:.78rem; font-weight:600; color:@barColor; min-width:34px; text-align:right;">@perc%</span>
                        </div>
                    </td>
                    <td>
                        @if (r.Completezza.SepaPronto)
                        {
                            <span class="badge" style="background:#dff5e6; color:#1f6e3a;" title="IBAN valido e dati anagrafici minimi presenti.">🏦 ok</span>
                        }
                        else
                        {
                            var motivo = "Dati SEPA mancanti: " + string.Join(", ", r.Completezza.CampiMancantiSepa);
                            <span class="badge" style="background:#fde2e2; color:#a83a3a;" title="@motivo">⚠️ manca</span>
                        }
                    </td>
                    <td>
                        @if (r.HaUtentePortale)
                        {
                            <span class="badge" style="background:#e3edff; color:#2457a4;">🔓 abilitato</span>
                        }
                        else
                        {
                            <span class="muted">—</span>
                        }
                    </td>
                    <td style="text-align:right;"><strong>@r.EspostoCorrente.ToString("N0", it) €</strong></td>
                    <td style="text-align:right;">@r.FatturePeriodoCorrente</td>
                    <td><a class="btn btn--ghost btn--sm" asp-action="EditFornitore" asp-route-id="@r.Fornitore.Id">Apri</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    </div>
}
