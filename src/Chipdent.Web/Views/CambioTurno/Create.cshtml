@model Chipdent.Web.Models.NuovaCambioTurnoViewModel
@{
    ViewData["Title"] = "Nuova richiesta cambio";
    ViewData["Crumb"] = "Cambio turno";
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>Nuova richiesta di cambio turno</h2>
        <p class="page-head__sub">Stai cedendo il turno: <strong>@Model.TurnoLabel</strong> · @Model.ClinicaNome</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Indietro</a>
    </div>
</div>

<div class="card" style="max-width: 640px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="TurnoId" />

        <div class="form-grid">
            <div class="form-group full">
                <label class="form-label" asp-for="DestinatarioUserId">A chi proporre il turno</label>
                <select class="form-control" asp-for="DestinatarioUserId">
                    <option value="">📢 Broadcast — qualsiasi collega della sede può accettare</option>
                    @foreach (var c in Model.Colleghi)
                    {
                        <option value="@c.UserId">@c.Nome · @c.Ruolo</option>
                    }
                </select>
                @if (!Model.Colleghi.Any())
                {
                    <small class="muted" style="font-size:.78rem;">Nessun collega con account collegato disponibile per questa sede/tipo. Verrà inviato come broadcast.</small>
                }
            </div>

            <div class="form-group full">
                <label class="form-label" asp-for="Note">Note (opzionale)</label>
                <textarea class="form-control" asp-for="Note" rows="3" maxlength="500" placeholder="Es. visita medica, esame all'università, ecc."></textarea>
            </div>
        </div>

        <div class="form-actions">
            <a class="btn btn--ghost" asp-action="Index">Annulla</a>
            <button type="submit" class="btn btn--primary">Invia richiesta</button>
        </div>
    </form>
</div>
