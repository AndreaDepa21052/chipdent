@{
    Layout = null;
    var next = ViewData["Next"] as string ?? "/dashboard";
    ViewData["Title"] = "Caricamento";
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chipdent · Caricamento</title>
    <link rel="icon" type="image/png" href="~/img/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; font-family: 'Inter', system-ui, sans-serif; }

        .space {
            position: fixed; inset: 0;
            background:
                radial-gradient(ellipse at 20% 20%, rgba(196, 120, 48, 0.18) 0%, transparent 45%),
                radial-gradient(ellipse at 80% 70%, rgba(122, 169, 201, 0.18) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, #0a1230 0%, #050818 60%, #02030a 100%);
            color: #f0d5a8;
            display: flex; align-items: center; justify-content: center;
        }

        .countdown {
            font-size: clamp(120px, 28vmin, 280px);
            font-weight: 600;
            line-height: 1;
            color: #faf3e8;
            text-shadow:
                0 0 40px rgba(217, 148, 58, 0.55),
                0 0 100px rgba(122, 169, 201, 0.35);
            font-variant-numeric: tabular-nums;
            transition: opacity .25s ease, transform .25s ease;
        }
        .countdown.tick {
            animation: tick .9s ease-out;
        }
        @@keyframes tick {
            0%   { opacity: 0; transform: scale(0.75); }
            30%  { opacity: 1; transform: scale(1.08); }
            100% { opacity: 1; transform: scale(1); }
        }

        .skip {
            position: absolute; bottom: 24px; right: 28px;
            font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase;
            color: rgba(240, 213, 168, 0.55); text-decoration: none;
            border: 1px solid rgba(240, 213, 168, 0.2);
            padding: 8px 14px; border-radius: 999px;
            transition: all 0.2s ease;
        }
        .skip:hover { color: #faf3e8; border-color: rgba(240, 213, 168, 0.5); }

        @@media (prefers-reduced-motion: reduce) {
            .countdown.tick { animation: none; }
        }
    </style>
</head>
<body>
    <div class="space" aria-hidden="true">
        <div id="countdown" class="countdown" role="status" aria-live="polite">5</div>
        <a href="@next" class="skip">Entra ora</a>
    </div>

    <script>
        (function () {
            var dest = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(next));
            var el = document.getElementById('countdown');
            var n = 5;
            function tick() {
                if (n === 0) {
                    window.location.replace(dest);
                    return;
                }
                el.textContent = n;
                el.classList.remove('tick');
                void el.offsetWidth; // restart animation
                el.classList.add('tick');
                n--;
                setTimeout(tick, 1000);
            }
            tick();
        })();
    </script>
</body>
</html>
