@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Section"] = "dashboard";
}

<div style="margin-bottom: var(--s-6); display:flex; justify-content:space-between; align-items:flex-end; gap:var(--s-4); flex-wrap:wrap;">
    <div>
        <h2 style="margin-bottom:var(--s-1);">Ciao, @Model.UserFullName</h2>
        <p style="color:var(--c-ink-muted); margin:0;">
            Stato in tempo reale di <strong style="color:var(--c-ink);">@Model.TenantName</strong> ·
            @DateTime.Now.ToString("dddd d MMMM yyyy", new System.Globalization.CultureInfo("it-IT"))
        </p>
    </div>
    <form asp-controller="Dashboard" asp-action="Ping" method="post" style="display:inline;">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn--primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 2L11 13"/><path d="m22 2-7 20-4-9-9-4 20-7z"/>
            </svg>
            Test notifica live
        </button>
    </form>
</div>

<div class="grid grid--stats" style="margin-bottom: var(--s-6);">
    <div class="stat">
        <div class="stat__label">Cliniche</div>
        <div class="stat__value">@Model.ClinicheTotali</div>
        <div class="stat__hint">
            <span class="badge badge--success"><span class="dot"></span>@Model.ClinicheOperative operative</span>
        </div>
    </div>
    <div class="stat">
        <div class="stat__label">Dottori attivi</div>
        <div class="stat__value">@Model.DottoriAttivi</div>
        <div class="stat__hint"><span class="delta-up">▲ 2</span> rispetto al mese scorso</div>
    </div>
    <div class="stat">
        <div class="stat__label">Dipendenti</div>
        <div class="stat__value">@Model.DipendentiAttivi</div>
        <div class="stat__hint">3 in onboarding · 5 in ferie</div>
    </div>
    <div class="stat">
        <div class="stat__label">RLS in scadenza</div>
        <div class="stat__value">@Model.RlsInScadenza</div>
        <div class="stat__hint"><span class="badge badge--warning"><span class="dot"></span>azione richiesta</span></div>
    </div>
</div>

<div class="grid grid--main">
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Turni di oggi</h3>
            <a class="card__action" href="#">vedi tutti →</a>
        </div>
        <ul class="list">
            @foreach (var t in Model.TurniOggi)
            {
                <li class="list__item">
                    <div class="list__icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div>
                        <div class="list__title">@t.Persona <span class="badge" style="margin-left:6px;">@t.Ruolo</span></div>
                        <div class="list__meta">@t.Clinica</div>
                    </div>
                    <div class="list__when">@t.Orario</div>
                </li>
            }
        </ul>
    </div>

    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Attività recenti</h3>
            <span class="badge badge--accent">live</span>
        </div>
        <ul class="list" data-feed>
            @foreach (var a in Model.Attivita)
            {
                <li class="list__item">
                    <div class="list__icon">
                        @switch (a.Kind)
                        {
                            case "shift":
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                                break;
                            case "doc":
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                                break;
                            case "rls":
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                                break;
                            default:
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                break;
                        }
                    </div>
                    <div>
                        <div class="list__title">@a.Title</div>
                        <div class="list__meta">@a.Description</div>
                    </div>
                    <div class="list__when">@a.When.ToString("HH:mm")</div>
                </li>
            }
        </ul>
    </div>
</div>
