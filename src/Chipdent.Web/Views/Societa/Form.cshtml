@model Chipdent.Web.Domain.Entities.Societa
@{
    var isNew = (bool)(ViewData["IsNew"] ?? false);
    ViewData["Title"] = isNew ? "Nuova società" : "Modifica società";
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>@(isNew ? "Nuova società" : Model.Nome)</h2>
        <p class="page-head__sub">@(isNew ? "Aggiungi una nuova persona giuridica del gruppo." : "Aggiorna i dati anagrafici e bancari.")</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Torna all'elenco</a>
    </div>
</div>

<div class="card">
    <form asp-action="@(isNew ? "Create" : "Edit")" asp-route-id="@(isNew ? null : Model.Id)" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <fieldset style="padding: var(--s-3); border: 1px solid var(--c-border, #ece0cc); border-radius: 8px;">
            <legend style="padding: 0 8px; font-size: .85rem; color: var(--c-ink-soft);">🏢 Identità</legend>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" asp-for="Nome">Nome breve *</label>
                    <input class="form-control" asp-for="Nome" required placeholder="Es. Ident Cormano" />
                    <span class="text-danger" asp-validation-for="Nome"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="RagioneSociale">Ragione sociale *</label>
                    <input class="form-control" asp-for="RagioneSociale" required placeholder="Es. IDENT CORMANO SRL" />
                    <span class="text-danger" asp-validation-for="RagioneSociale"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="FormaGiuridica">Forma giuridica</label>
                    <input class="form-control" asp-for="FormaGiuridica" placeholder="Es. società a responsabilità limitata" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="DataCostituzione">Data costituzione</label>
                    <input class="form-control" asp-for="DataCostituzione" type="date" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="CapitaleSociale">Capitale sociale (€)</label>
                    <input class="form-control" asp-for="CapitaleSociale" type="number" step="0.01" min="0" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="CodiceAteco">Codice ATECO</label>
                    <input class="form-control" asp-for="CodiceAteco" placeholder="Es. 86.23.00" />
                </div>
                <div class="form-group">
                    <label class="form-check" style="margin-top: 24px;">
                        <input type="checkbox" asp-for="IsHolding" />
                        Sede legale principale (holding)
                    </label>
                </div>
            </div>
        </fieldset>

        <fieldset style="margin-top: var(--s-4); padding: var(--s-3); border: 1px solid var(--c-border, #ece0cc); border-radius: 8px;">
            <legend style="padding: 0 8px; font-size: .85rem; color: var(--c-ink-soft);">📋 Dati fiscali</legend>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" asp-for="CodiceFiscale">Codice fiscale</label>
                    <input class="form-control" asp-for="CodiceFiscale" maxlength="16" style="font-family: monospace;" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="PartitaIva">Partita IVA</label>
                    <input class="form-control" asp-for="PartitaIva" maxlength="11" style="font-family: monospace;" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="NumeroRea">Numero REA</label>
                    <input class="form-control" asp-for="NumeroRea" placeholder="Es. VA - 386325" />
                </div>
            </div>
        </fieldset>

        <fieldset style="margin-top: var(--s-4); padding: var(--s-3); border: 1px solid var(--c-border, #ece0cc); border-radius: 8px;">
            <legend style="padding: 0 8px; font-size: .85rem; color: var(--c-ink-soft);">📍 Sede legale</legend>
            <div class="form-grid">
                <div class="form-group full">
                    <label class="form-label" asp-for="IndirizzoSedeLegale">Indirizzo</label>
                    <input class="form-control" asp-for="IndirizzoSedeLegale" placeholder="Via / Piazza, numero civico" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="ComuneSedeLegale">Comune</label>
                    <input class="form-control" asp-for="ComuneSedeLegale" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="ProvinciaSedeLegale">Provincia (sigla)</label>
                    <input class="form-control" asp-for="ProvinciaSedeLegale" maxlength="2" placeholder="VA" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="CapSedeLegale">CAP</label>
                    <input class="form-control" asp-for="CapSedeLegale" maxlength="5" />
                </div>
            </div>
        </fieldset>

        <fieldset style="margin-top: var(--s-4); padding: var(--s-3); border: 1px solid var(--c-border, #ece0cc); border-radius: 8px;">
            <legend style="padding: 0 8px; font-size: .85rem; color: var(--c-ink-soft);">🏥 Sede operativa (unità locale)</legend>
            <p class="muted" style="font-size:.82rem; margin: 0 0 8px;">
                Indirizzo dove la società opera effettivamente (in genere coincide con l'indirizzo della clinica).
                Estratto dalla sezione «Unità Locali» della visura camerale.
            </p>
            <div class="form-grid">
                <div class="form-group full">
                    <label class="form-label" asp-for="IndirizzoSedeOperativa">Indirizzo</label>
                    <input class="form-control" asp-for="IndirizzoSedeOperativa" placeholder="Via / Piazza, numero civico" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="ComuneSedeOperativa">Comune</label>
                    <input class="form-control" asp-for="ComuneSedeOperativa" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="ProvinciaSedeOperativa">Provincia (sigla)</label>
                    <input class="form-control" asp-for="ProvinciaSedeOperativa" maxlength="2" placeholder="MI" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="CapSedeOperativa">CAP</label>
                    <input class="form-control" asp-for="CapSedeOperativa" maxlength="5" />
                </div>
            </div>
        </fieldset>

        <fieldset style="margin-top: var(--s-4); padding: var(--s-3); border: 1px solid var(--c-border, #ece0cc); border-radius: 8px;">
            <legend style="padding: 0 8px; font-size: .85rem; color: var(--c-ink-soft);">📞 Contatti</legend>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" asp-for="Pec">PEC</label>
                    <input class="form-control" asp-for="Pec" type="email" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Email">Email</label>
                    <input class="form-control" asp-for="Email" type="email" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Telefono">Telefono</label>
                    <input class="form-control" asp-for="Telefono" />
                </div>
            </div>
        </fieldset>

        <fieldset style="margin-top: var(--s-4); padding: var(--s-3); border: 1px solid var(--c-accent, #c47830); border-radius: 8px; background: rgba(196,120,48,0.04);">
            <legend style="padding: 0 8px; font-size: .85rem; color: var(--c-accent, #c47830); font-weight:600;">🏦 IBAN per pagamenti</legend>
            <p class="muted" style="font-size:.85rem; margin: 0 0 8px;">
                IBAN della società su cui verranno disposti i pagamenti delle scadenze associate.
                Le scadenze legate a una clinica seguiranno l'IBAN della società di appartenenza.
            </p>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label" asp-for="Iban">IBAN</label>
                    <input class="form-control" asp-for="Iban" placeholder="IT…" style="font-family: monospace;" />
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Bic">BIC / SWIFT</label>
                    <input class="form-control" asp-for="Bic" placeholder="UNCRITMM" maxlength="11" style="font-family: monospace;" />
                </div>
            </div>
        </fieldset>

        <fieldset style="margin-top: var(--s-4); padding: var(--s-3); border: 1px solid var(--c-border, #ece0cc); border-radius: 8px;">
            <legend style="padding: 0 8px; font-size: .85rem; color: var(--c-ink-soft);">📝 Note</legend>
            <div class="form-grid">
                <div class="form-group full">
                    <textarea class="form-control" asp-for="Note" rows="3"></textarea>
                </div>
            </div>
        </fieldset>

        <div class="form-actions">
            <a class="btn btn--ghost" asp-action="Index">Annulla</a>
            <button type="submit" class="btn btn--primary">@(isNew ? "Crea società" : "Salva modifiche")</button>
        </div>
    </form>
</div>

@if (!isNew)
{
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="margin-top: var(--s-5); text-align:right;"
          onsubmit="return confirm('Eliminare definitivamente questa società? Le cliniche associate verranno svincolate.');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn--ghost" style="border-color: rgba(217, 107, 94, 0.4); color: var(--c-danger);">
            Elimina società
        </button>
    </form>
}
