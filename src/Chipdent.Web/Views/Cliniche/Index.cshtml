@model IReadOnlyList<Chipdent.Web.Domain.Entities.Clinica>
@{
    ViewData["Title"] = "Cliniche";
    var viewMode = (ViewData["ViewMode"] as string) ?? "lista";
    var geoCount = Model.Count(c => c.IsGeolocalized);
    var alerts = (ViewData["Alerts"] as Dictionary<string, Chipdent.Web.Controllers.ClinicheController.ClinicaAlerts>) ?? new();
    var societaMap = (ViewData["SocietaMap"] as Dictionary<string, Chipdent.Web.Domain.Entities.Societa>) ?? new();

    // Cliniche con criticità in cima (scaduti prima, poi imminenti); poi alfabetico.
    Chipdent.Web.Controllers.ClinicheController.ClinicaAlerts? AlertOf(string id) => alerts.TryGetValue(id, out var a) ? a : null;
    var ordered = Model
        .OrderByDescending(c => AlertOf(c.Id)?.Scaduti ?? 0)
        .ThenByDescending(c => AlertOf(c.Id)?.Imminenti ?? 0)
        .ThenBy(c => c.Nome)
        .ToList();
    var totScaduti = alerts.Values.Sum(a => a.Scaduti);
    var totImminenti = alerts.Values.Sum(a => a.Imminenti);
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>Cliniche</h2>
        <p class="page-head__sub">
            @Model.Count sedi · @Model.Count(c => c.Stato == Chipdent.Web.Domain.Entities.ClinicaStato.Operativa) operative · @geoCount geolocalizzate
            @if (totScaduti + totImminenti > 0)
            {
                <text> · </text>
                @if (totScaduti > 0) { <strong style="color: var(--c-danger, #b8442e);">@totScaduti interventi scaduti</strong> }
                @if (totScaduti > 0 && totImminenti > 0) { <text> · </text> }
                @if (totImminenti > 0) { <strong style="color: var(--c-warning, #c47830);">@totImminenti in scadenza ≤ 30 gg</strong> }
                <a asp-controller="CalendarioInterventi" asp-action="Index" style="margin-left:8px; font-size:.82rem;">apri calendario →</a>
            }
        </p>
    </div>
    <div class="page-head__actions">
        <div class="seg" role="tablist" aria-label="Modalità di visualizzazione" style="display:inline-flex; gap:0; border:1px solid var(--c-border, #e9e1d3); border-radius: 8px; overflow:hidden; margin-right: var(--s-2);">
            <a class="btn @(viewMode == "lista" ? "btn--primary" : "btn--ghost")" asp-action="Index" style="border-radius: 0;">Lista</a>
            <a class="btn @(viewMode == "mappa" ? "btn--primary" : "btn--ghost")" asp-action="Index" asp-route-view="mappa" style="border-radius: 0;">Mappa</a>
        </div>
        <a class="btn btn--primary" asp-action="Create">+ Nuova clinica</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="card">
        <div class="empty">
            <div class="empty__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21V8l9-5 9 5v13"/></svg>
            </div>
            <h3>Nessuna clinica ancora</h3>
            <p>Aggiungi la prima sede della tua catena per iniziare.</p>
            <a class="btn btn--primary" asp-action="Create" style="margin-top: var(--s-3);">+ Nuova clinica</a>
        </div>
    </div>
}
else if (viewMode == "mappa")
{
    <div class="card" style="padding:0; overflow:hidden;">
        <div id="cliniche-map" style="width: 100%; height: 70vh; min-height: 480px;"></div>
    </div>

    @if (geoCount < Model.Count)
    {
        <div class="alert alert--info" style="margin-top: var(--s-3);">
            @(Model.Count - geoCount) sed@(Model.Count - geoCount == 1 ? "e" : "i") senza coordinate. Modifica la clinica per aggiungere latitudine e longitudine.
        </div>
    }
}
else
{
    <div data-table-search data-table-search-target=".table">
        <partial name="_TableSearch" model='new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData) { ["Placeholder"] = "Cerca clinica per nome, città, indirizzo…", ["Singular"] = "clinica", ["Plural"] = "cliniche" }' />
        <div class="table-search__empty">Nessuna clinica corrisponde alla ricerca.</div>
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Società</th>
                    <th>Città</th>
                    <th>Riuniti</th>
                    <th>Stato</th>
                    <th>Calendario interventi</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in ordered)
                {
                    var a = AlertOf(c.Id);
                    var rowCls = a is null ? "" : (a.Scaduti > 0 ? "row--alert-danger" : (a.Imminenti > 0 ? "row--alert-warn" : ""));
                    var societa = !string.IsNullOrEmpty(c.SocietaId) && societaMap.TryGetValue(c.SocietaId, out var sv) ? sv : null;
                    <tr class="@rowCls">
                        <td>
                            <div class="strong">@c.Nome</div>
                            <div class="muted">@c.Indirizzo @(c.IsGeolocalized ? "📍" : "")</div>
                        </td>
                        <td>
                            @if (societa is not null)
                            {
                                <a asp-controller="Societa" asp-action="Details" asp-route-id="@societa.Id"
                                   style="text-decoration:none;" title="@societa.RagioneSociale">
                                    <span class="strong" style="font-size:.88rem;">@societa.Nome</span>
                                    @if (societa.IsHolding)
                                    {
                                        <span class="badge badge--warning" style="margin-left:4px; font-size:.65rem;">holding</span>
                                    }
                                </a>
                            }
                            else
                            {
                                <span class="muted" style="font-size:.82rem;" title="Apri «Modifica rapida» per associare la società">— non associata</span>
                            }
                        </td>
                        <td>@c.Citta</td>
                        <td>@c.NumeroRiuniti</td>
                        <td>
                            @switch (c.Stato)
                            {
                                case Chipdent.Web.Domain.Entities.ClinicaStato.Operativa:
                                    <span class="badge badge--success"><span class="dot"></span>operativa</span>
                                    break;
                                case Chipdent.Web.Domain.Entities.ClinicaStato.InApertura:
                                    <span class="badge badge--warning"><span class="dot"></span>in apertura</span>
                                    break;
                                default:
                                    <span class="badge badge--danger"><span class="dot"></span>chiusa</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (a is null)
                            {
                                <span class="muted" style="font-size:.82rem;">—</span>
                            }
                            else
                            {
                                <a asp-controller="Cliniche" asp-action="Details" asp-route-id="@c.Id" asp-fragment="interventi"
                                   asp-route-tab="interventi" style="text-decoration:none; display:inline-flex; gap:6px; flex-wrap:wrap;">
                                    @if (a.Scaduti > 0)
                                    {
                                        <span class="badge badge--danger" title="Interventi scaduti">⛔ @a.Scaduti scadut@(a.Scaduti == 1 ? "o" : "i")</span>
                                    }
                                    @if (a.Imminenti > 0)
                                    {
                                        <span class="badge badge--warning" title="Scadenze ≤ 30 gg">⚠️ @a.Imminenti ≤ 30 gg</span>
                                    }
                                </a>
                            }
                        </td>
                        <td>
                            <div class="actions">
                                <a class="ibtn" asp-action="Details" asp-route-id="@c.Id" title="Dettagli">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                                </a>
                                <button type="button" class="ibtn" data-edit-clinica="@c.Id" title="Modifica rapida">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    </div>

    <style>
        tr.row--alert-danger > td:first-child { box-shadow: inset 3px 0 0 var(--c-danger, #b8442e); }
        tr.row--alert-warn   > td:first-child { box-shadow: inset 3px 0 0 var(--c-warning, #c47830); }
    </style>
}

<dialog id="dlg-clinica-edit" class="dotmodal-dialog" aria-label="Modifica clinica">
    <div class="dotmodal">
        <div style="padding:60px; text-align:center; color: var(--c-ink-soft, #6b5538);">Caricamento…</div>
    </div>
</dialog>

<partial name="_EditModalScript" />

@if (viewMode == "mappa")
{
    @section Scripts {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
        <script>
            (function () {
                var map = L.map('cliniche-map').setView([42.0, 12.5], 5);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
                }).addTo(map);

                var stateColor = {
                    'Operativa':  '#2d7a50',
                    'InApertura': '#c47830',
                    'Chiusa':     '#a83a3a'
                };

                fetch('@Url.Action("MapData", "Cliniche")')
                    .then(function (r) { return r.json(); })
                    .then(function (pins) {
                        if (!pins.length) return;
                        var bounds = [];
                        pins.forEach(function (p) {
                            var color = stateColor[p.stato] || '#7a5c3a';
                            var icon = L.divIcon({
                                className: 'clinica-pin',
                                html: '<svg width="32" height="40" viewBox="0 0 32 40" xmlns="http://www.w3.org/2000/svg">' +
                                      '<path d="M16 0C7.16 0 0 7.16 0 16c0 12 16 24 16 24s16-12 16-24C32 7.16 24.84 0 16 0z" fill="' + color + '"/>' +
                                      '<circle cx="16" cy="16" r="6" fill="#fff"/></svg>',
                                iconSize: [32, 40],
                                iconAnchor: [16, 40],
                                popupAnchor: [0, -36]
                            });
                            var m = L.marker([p.lat, p.lng], { icon: icon }).addTo(map);
                            m.bindPopup(
                                '<div style="font-family:Inter,sans-serif; min-width:180px;">' +
                                '<div style="font-weight:700; color:#3b1e0c; margin-bottom:4px;">' + p.nome + '</div>' +
                                '<div style="font-size:12px; color:#7a5c3a; margin-bottom:6px;">' + p.indirizzo + ' · ' + p.citta + '</div>' +
                                '<div style="font-size:11px; color:#7a5c3a;">' + p.riuniti + ' riuniti · ' + p.stato + '</div>' +
                                '<a href="/cliniche/' + p.id + '" style="display:inline-block; margin-top:8px; font-size:11px; color:' + color + ';">Vai al dettaglio →</a>' +
                                '</div>'
                            );
                            bounds.push([p.lat, p.lng]);
                        });
                        if (bounds.length === 1) {
                            map.setView(bounds[0], 13);
                        } else if (bounds.length > 1) {
                            map.fitBounds(bounds, { padding: [40, 40] });
                        }
                    });
            })();
        </script>
    }
}
