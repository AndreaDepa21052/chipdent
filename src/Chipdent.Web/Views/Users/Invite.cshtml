@model Chipdent.Web.Models.InviteUserViewModel
@{
    ViewData["Title"] = "Invita utente";

    string RoleLabel(UserRole r) => r switch
    {
        UserRole.Direttore => "Direttore di sede",
        _ => r.ToString()
    };
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>Invita utente</h2>
        <p class="page-head__sub">L'utente riceverà un link per impostare la propria password.</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Torna agli utenti</a>
    </div>
</div>

<div class="card" style="max-width: 540px;">
    <form asp-action="Invite" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label class="form-label" asp-for="FullName"></label>
            <input class="form-control" asp-for="FullName" required />
            <span class="text-danger" asp-validation-for="FullName"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Email"></label>
            <input class="form-control" asp-for="Email" type="email" required />
            <span class="text-danger" asp-validation-for="Email"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Ruolo"></label>
            <select class="form-control" asp-for="Ruolo">
                @foreach (var r in Enum.GetValues<UserRole>())
                {
                    <option value="@r" selected="@(r == Model.Ruolo)">@RoleLabel(r)</option>
                }
            </select>
        </div>

        @if (Model.Cliniche.Count > 0)
        {
            <div class="form-group">
                <label class="form-label" asp-for="ClinicaIds">Cliniche assegnate</label>
                <div class="checkbox-list">
                    @foreach (var c in Model.Cliniche)
                    {
                        var sel = Model.ClinicaIds.Contains(c.Id);
                        <label class="form-check" style="display:inline-flex; margin-right: var(--s-3); margin-bottom: var(--s-2);">
                            <input type="checkbox" name="ClinicaIds" value="@c.Id" checked="@sel" />
                            @c.Nome <span class="muted" style="margin-left:4px;">@c.Citta</span>
                        </label>
                    }
                </div>
                <span class="text-danger" asp-validation-for="ClinicaIds"></span>
                <p style="color: var(--c-ink-soft); font-size:.82rem; margin-top: 4px;">
                    Obbligatorio per il <strong>Direttore</strong>. Lascia vuoto per Management/Owner per dare visibilità su tutte le sedi.
                </p>
            </div>
        }

        <div class="form-actions">
            <a class="btn btn--ghost" asp-action="Index">Annulla</a>
            <button type="submit" class="btn btn--primary">Genera invito</button>
        </div>
    </form>
</div>
