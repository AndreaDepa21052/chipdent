@model IReadOnlyList<Chipdent.Web.Domain.Entities.Corso>
@{
    ViewData["Title"] = "Corsi";
    var dipendenti = (Dictionary<string, string>?)ViewData["Dipendenti"] ?? new();
    var dottori = (Dictionary<string, string>?)ViewData["Dottori"] ?? new();
    var cliniche = (Dictionary<string, string>?)ViewData["Cliniche"] ?? new();

    string Destinatario(Chipdent.Web.Domain.Entities.Corso c) => c.DestinatarioTipo switch
    {
        Chipdent.Web.Domain.Entities.DestinatarioCorso.Dottore => dottori.GetValueOrDefault(c.DestinatarioId, "—"),
        Chipdent.Web.Domain.Entities.DestinatarioCorso.Dipendente => dipendenti.GetValueOrDefault(c.DestinatarioId, "—"),
        _ => cliniche.GetValueOrDefault(c.DestinatarioId, "—")
    };
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>RLS / Sicurezza</h2>
        <p class="page-head__sub">Corsi obbligatori e formazione</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--primary" asp-action="CreateCorso">+ Nuovo corso</a>
    </div>
</div>

<partial name="_Tabs" />

@if (Model.Count == 0)
{
    <div class="card">
        <div class="empty">
            <div class="empty__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            </div>
            <h3>Nessun corso registrato</h3>
        </div>
    </div>
}
else
{
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr><th>Tipo</th><th>Destinatario</th><th>Conseguito</th><th>Scadenza</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    var scaduto = c.Scadenza is not null && c.Scadenza < DateTime.UtcNow;
                    var inScad = c.Scadenza is not null && c.Scadenza >= DateTime.UtcNow && c.Scadenza < DateTime.UtcNow.AddMonths(3);
                    <tr>
                        <td><span class="badge">@c.Tipo</span></td>
                        <td>
                            <div class="strong">@Destinatario(c)</div>
                            <div class="muted">@c.DestinatarioTipo</div>
                        </td>
                        <td>@c.DataConseguimento.ToString("dd/MM/yyyy")</td>
                        <td>
                            @(c.Scadenza?.ToString("dd/MM/yyyy") ?? "—")
                            @if (scaduto) { <span class="badge badge--danger" style="margin-left:6px;"><span class="dot"></span>scaduto</span> }
                            else if (inScad) { <span class="badge badge--warning" style="margin-left:6px;"><span class="dot"></span>in scadenza</span> }
                        </td>
                        <td class="actions">
                            <a class="ibtn" asp-action="EditCorso" asp-route-id="@c.Id" title="Modifica">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
