@model Chipdent.Web.Models.FatturaFormViewModel
@using Chipdent.Web.Domain.Entities
@{
    var isNew = string.IsNullOrEmpty(Model.Id);
    ViewData["Title"] = isNew ? "Nuova fattura" : "Modifica fattura";
    ViewData["Crumb"] = "Tesoreria";
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>📄 @ViewData["Title"]</h2>
        <p class="page-head__sub">Inserisci una fattura passiva e la prima scadenza di pagamento. La scadenza viene creata automaticamente a partire dalla data e dal metodo indicati.</p>
    </div>
</div>

<form method="post" enctype="multipart/form-data" class="card" style="padding: var(--s-4);">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="alert alert--danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none");"></div>

    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: var(--s-3);">
        <div class="form-group">
            <label class="form-label" asp-for="FornitoreId">Fornitore *</label>
            <select class="form-control" asp-for="FornitoreId" required>
                <option value="">— seleziona —</option>
                @foreach (var f in Model.Fornitori)
                {
                    <option value="@f.Id" selected="@(Model.FornitoreId == f.Id)">@f.RagioneSociale</option>
                }
            </select>
            <span class="text-danger" asp-validation-for="FornitoreId"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="ClinicaId">Sede destinataria *</label>
            <select class="form-control" asp-for="ClinicaId" required>
                <option value="">— seleziona —</option>
                @foreach (var c in Model.Cliniche)
                {
                    <option value="@c.Id" selected="@(Model.ClinicaId == c.Id)">@c.Nome</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Numero">Numero documento *</label>
            <input class="form-control" asp-for="Numero" placeholder="es. 2024-FE17315-970" required />
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Categoria">Categoria spesa</label>
            <select class="form-control" asp-for="Categoria">
                @foreach (var v in Enum.GetValues<CategoriaSpesa>())
                {
                    <option value="@v" selected="@(Model.Categoria == v)">@v</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="DataEmissione">Data emissione *</label>
            <input class="form-control" type="date" asp-for="DataEmissione" required />
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="MeseCompetenza">Competenza</label>
            <input class="form-control" type="month" name="MeseCompetenza" value="@Model.MeseCompetenza.ToString("yyyy-MM")" />
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Imponibile">Imponibile (€) *</label>
            <input class="form-control" type="number" step="0.01" asp-for="Imponibile" required />
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Iva">IVA (€)</label>
            <input class="form-control" type="number" step="0.01" asp-for="Iva" />
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="DataScadenza">Data scadenza *</label>
            <input class="form-control" type="date" asp-for="DataScadenza" required />
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Metodo">Metodo pagamento</label>
            <select class="form-control" asp-for="Metodo">
                @foreach (var v in Enum.GetValues<MetodoPagamento>())
                {
                    <option value="@v" selected="@(Model.Metodo == v)">@v</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="FlagEM">E/M</label>
            <input class="form-control" asp-for="FlagEM" placeholder="es. E" />
        </div>

        <div class="form-group" style="display:flex; align-items:end; padding-bottom:8px;">
            <label class="form-check">
                <input type="checkbox" asp-for="FlagBM" /> BM (Bonifico Manuale)
            </label>
        </div>
    </div>

    <div class="form-group">
        <label class="form-label" asp-for="Allegato">Allegato (PDF/XML SDI)</label>
        <input class="form-control" type="file" asp-for="Allegato" accept=".pdf,.png,.jpg,.jpeg,.xml,.p7m" />
        @if (!string.IsNullOrEmpty(Model.AllegatoNomeAttuale))
        {
            <div class="muted" style="font-size:.85rem; margin-top:4px;">📎 Attuale: @Model.AllegatoNomeAttuale</div>
        }
    </div>

    <div class="form-group">
        <label class="form-label" asp-for="Note">Note</label>
        <textarea class="form-control" asp-for="Note" rows="2" placeholder="es. bolletta apr 24"></textarea>
    </div>

    <div style="display:flex; gap:8px; justify-content:flex-end; margin-top: var(--s-3);">
        <a class="btn btn--ghost" asp-action="Index">Annulla</a>
        <button type="submit" class="btn btn--primary">Registra fattura</button>
    </div>
</form>
