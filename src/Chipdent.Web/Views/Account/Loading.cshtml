@{
    Layout = null;
    var next = ViewData["Next"] as string ?? "/dashboard";
    ViewData["Title"] = "Caricamento";
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chipdent · Caricamento</title>
    <link rel="icon" type="image/png" href="~/img/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap">
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; font-family: 'Inter', system-ui, sans-serif; }

        .space {
            position: fixed; inset: 0;
            background:
                radial-gradient(ellipse at 20% 20%, rgba(196, 120, 48, 0.18) 0%, transparent 45%),
                radial-gradient(ellipse at 80% 70%, rgba(122, 169, 201, 0.18) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, #0a1230 0%, #050818 60%, #02030a 100%);
            color: #f0d5a8;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            gap: 14px;
        }

        /* Sistema orbitale compatto: 3 anelli, 3 pianeti che ruotano. */
        .orbit {
            position: relative;
            width: 88px; height: 88px;
        }
        .orbit__ring {
            position: absolute; inset: 0;
            border: 1px dashed rgba(217, 148, 58, 0.35);
            border-radius: 50%;
        }
        .orbit__ring--2 { inset: 14px; border-color: rgba(122, 169, 201, 0.30); border-style: solid; opacity: .5; }
        .orbit__ring--3 { inset: 28px; border-color: rgba(240, 213, 168, 0.22); }
        .orbit__core {
            position: absolute; top: 50%; left: 50%;
            width: 6px; height: 6px; border-radius: 50%;
            background: radial-gradient(circle at 30% 30%, #faf3e8, #d9943a 60%, #7d4a23);
            box-shadow: 0 0 8px 1px rgba(217, 148, 58, 0.65);
            transform: translate(-50%, -50%);
        }
        .orbit__arm {
            position: absolute; top: 50%; left: 50%;
            transform-origin: 0 0;
        }
        .orbit__arm--1 { animation: spin 4.2s linear infinite; }
        .orbit__arm--2 { animation: spin 6.8s linear infinite reverse; }
        .orbit__arm--3 { animation: spin 9.4s linear infinite; }
        .orbit__planet {
            position: absolute;
            width: 6px; height: 6px; border-radius: 50%;
            transform: translate(-50%, -50%);
        }
        .orbit__arm--1 .orbit__planet {
            left: 44px; top: 0;
            background: radial-gradient(circle at 30% 30%, #faf3e8, #d9943a 60%, #7d4a23);
            box-shadow: 0 0 6px 1px rgba(217, 148, 58, 0.55);
        }
        .orbit__arm--2 .orbit__planet {
            left: 30px; top: 0;
            width: 5px; height: 5px;
            background: radial-gradient(circle at 30% 30%, #cfe7ff, #7aa9c9 60%, #2c4a66);
            box-shadow: 0 0 5px 1px rgba(122, 169, 201, 0.55);
        }
        .orbit__arm--3 .orbit__planet {
            left: 16px; top: 0;
            width: 4px; height: 4px;
            background: radial-gradient(circle at 30% 30%, #ffe1c2, #c47830 60%, #5a2f10);
            box-shadow: 0 0 4px 1px rgba(196, 120, 48, 0.5);
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        .secs {
            font-size: 13px;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            color: rgba(240, 213, 168, 0.7);
            font-variant-numeric: tabular-nums;
        }
        .secs strong {
            color: #faf3e8;
            font-weight: 600;
            margin: 0 2px;
        }

        .skip {
            position: absolute; bottom: 24px; right: 28px;
            font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
            color: rgba(240, 213, 168, 0.55); text-decoration: none;
            border: 1px solid rgba(240, 213, 168, 0.2);
            padding: 6px 12px; border-radius: 999px;
            transition: all 0.2s ease;
        }
        .skip:hover { color: #faf3e8; border-color: rgba(240, 213, 168, 0.5); }

        @@media (prefers-reduced-motion: reduce) {
            .orbit__arm--1, .orbit__arm--2, .orbit__arm--3 { animation: none !important; }
        }
    </style>
</head>
<body>
    <div class="space" aria-hidden="true">
        <div class="orbit">
            <div class="orbit__ring"></div>
            <div class="orbit__ring orbit__ring--2"></div>
            <div class="orbit__ring orbit__ring--3"></div>
            <div class="orbit__core"></div>
            <div class="orbit__arm orbit__arm--1"><div class="orbit__planet"></div></div>
            <div class="orbit__arm orbit__arm--2"><div class="orbit__planet"></div></div>
            <div class="orbit__arm orbit__arm--3"><div class="orbit__planet"></div></div>
        </div>
        <div class="secs" role="status" aria-live="polite"><strong id="secs">0</strong> s</div>
        <a href="@next" class="skip">Entra ora</a>
    </div>

    <script>
        (function () {
            var dest = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(next));
            var DURATION = 5;
            var el = document.getElementById('secs');
            var n = 0;
            function tick() {
                el.textContent = n;
                if (n >= DURATION) { window.location.replace(dest); return; }
                n++;
                setTimeout(tick, 1000);
            }
            tick();
        })();
    </script>
</body>
</html>
