@model Chipdent.Web.Models.TesoreriaIndexViewModel
@using Chipdent.Web.Models
@using Chipdent.Web.Domain.Entities
@using Chipdent.Web.Domain.Common
@using System.Globalization
@{
    ViewData["Title"] = "Tesoreria — Scadenziario pagamenti";
    var oggi = DateTime.UtcNow.Date;
    var it = new CultureInfo("it-IT");
    // Pre-calcolo set degli id padre per indentare le scadenze figlie F24/ritenute.
    var idPadri = Model.Righe.Where(r => !string.IsNullOrEmpty(r.ScadenzaPadreId))
                              .Select(r => r.ScadenzaPadreId!).ToHashSet();

    // ── Calendario "split-view": determino il mese visibile (cm = "yyyy-MM") ──
    var cmRaw = Context.Request.Query["cm"].ToString();
    DateTime calMese;
    if (!string.IsNullOrEmpty(cmRaw) && DateTime.TryParseExact(cmRaw, "yyyy-MM", CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var parsed))
    {
        calMese = new DateTime(parsed.Year, parsed.Month, 1);
    }
    else if (Model.Filtro.Dal.HasValue)
    {
        calMese = new DateTime(Model.Filtro.Dal.Value.Year, Model.Filtro.Dal.Value.Month, 1);
    }
    else
    {
        calMese = new DateTime(oggi.Year, oggi.Month, 1);
    }

    // Aggrego le scadenze per giorno (solo del mese visibile). Lo statuso più "caldo" vince
    // per la dot principale; il totale euro alimenta l'heatmap.
    var righePerGiorno = Model.Righe
        .Where(r => r.DataScadenza.Year == calMese.Year && r.DataScadenza.Month == calMese.Month)
        .GroupBy(r => r.DataScadenza.Date)
        .ToDictionary(g => g.Key, g => g.ToList());
    var maxTotaleGiorno = righePerGiorno.Count == 0 ? 0m : righePerGiorno.Values.Max(l => l.Sum(r => r.Totale));

    // Helper: costruisce un URL preservando filtri attuali e sostituendo cm/Dal/Al/tab.
    // clearSort = true rimuove eventuali sort/dir preesistenti (utile per i link sull'header
    // della tabella, dove il caller imposta sort/dir nuovi).
    string CalUrl(DateTime? mese = null, DateTime? dataFiltro = null, bool clearDate = false, bool clearSort = false)
    {
        var qp = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrEmpty(Model.Filtro.Q))            qp["Q"] = Model.Filtro.Q;
        if (!string.IsNullOrEmpty(Model.Filtro.FornitoreId))  qp["FornitoreId"] = Model.Filtro.FornitoreId;
        if (!string.IsNullOrEmpty(Model.Filtro.ClinicaId))    qp["ClinicaId"] = Model.Filtro.ClinicaId;
        if (Model.Filtro.Categoria.HasValue)                  qp["Categoria"] = Model.Filtro.Categoria.ToString();
        if (Model.Filtro.Stato.HasValue)                      qp["Stato"] = Model.Filtro.Stato.ToString();
        if (Model.Filtro.Metodo.HasValue)                     qp["Metodo"] = Model.Filtro.Metodo.ToString();
        if (Model.Filtro.SoloFuoriTermini)                    qp["SoloFuoriTermini"] = "true";
        if (!clearSort && !string.IsNullOrEmpty(Model.Filtro.Sort)) qp["Sort"] = Model.Filtro.Sort;
        if (!clearSort && !string.IsNullOrEmpty(Model.Filtro.Dir))  qp["Dir"]  = Model.Filtro.Dir;
        // cm: mese visibile del calendario
        if (mese.HasValue) qp["cm"] = mese.Value.ToString("yyyy-MM");
        // Dal/Al
        if (dataFiltro.HasValue)
        {
            qp["Dal"] = dataFiltro.Value.ToString("yyyy-MM-dd");
            qp["Al"]  = dataFiltro.Value.ToString("yyyy-MM-dd");
        }
        else if (!clearDate)
        {
            if (Model.Filtro.Dal.HasValue) qp["Dal"] = Model.Filtro.Dal.Value.ToString("yyyy-MM-dd");
            if (Model.Filtro.Al.HasValue)  qp["Al"]  = Model.Filtro.Al.Value.ToString("yyyy-MM-dd");
        }
        qp["tab"] = "scadenze";
        var qs = string.Join("&", qp.Where(kv => !string.IsNullOrEmpty(kv.Value))
                                    .Select(kv => $"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(kv.Value!)}"));
        return Url.Action("Index") + (string.IsNullOrEmpty(qs) ? "" : "?" + qs);
    }
}

@functions {
    string Eur(decimal v) => v.ToString("N0", new CultureInfo("it-IT")) + " €";
    string EurDec(decimal v) => v.ToString("N2", new CultureInfo("it-IT")) + " €";

    string StatoBadge(StatoScadenza s) => s switch
    {
        StatoScadenza.Pagato => "<span class='badge' style='background:#dff5e6; color:#1f6e3a;'>✓ pagato</span>",
        StatoScadenza.Programmato => "<span class='badge' style='background:#e3edff; color:#2457a4;'>📅 programmato</span>",
        StatoScadenza.DaPagare => "<span class='badge' style='background:#fff2dd; color:#a86010;'>● da pagare</span>",
        StatoScadenza.Insoluto => "<span class='badge' style='background:#fbe1e1; color:#a83a3a;'>⚠ scaduto</span>",
        StatoScadenza.MaiPagato => "<span class='badge' style='background:#444; color:#fff;'>✕ mai pagato</span>",
        StatoScadenza.Annullato => "<span class='badge' style='background:#eee; color:#666;'>annullato</span>",
        _ => $"<span class='badge'>{s}</span>"
    };
}

