@{
    var section = (ViewData["Section"] as string) ?? "";
    var title = ViewData["Title"] as string ?? "Chipdent";
    var crumb = ViewData["Crumb"] as string;
    var fullName = User.Identity?.Name ?? "";
    var initials = string.IsNullOrWhiteSpace(fullName)
        ? "?"
        : string.Concat(fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                .Take(2)
                                .Select(p => char.ToUpper(p[0])));
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";

    var canSeeAnagrafiche = User.IsManagement() || User.IsDirettore() || User.IsBackoffice();
    var canSeeUsers = User.IsManagement();
    var isFullAccess = User.IsManagement();
    var roleClass = role switch
    {
        "Owner"      => "role-badge--owner",
        "Management" => "role-badge--admin",
        "Direttore"  => "role-badge--manager",
        "Backoffice" => "role-badge--hr",
        "Fornitore"  => "role-badge--supplier",
        _ => ""
    };
    var roleLabel = role switch
    {
        "Owner"      => "Owner",
        "Management" => "Management",
        "Direttore"  => "Direttore di sede",
        "Backoffice" => "Backoffice",
        "Staff"      => "Staff",
        "Fornitore"  => "Fornitore",
        _ => role
    };

    var sectionMap = new Dictionary<string, (string label, string controller)>
    {
        ["dashboard"]      = ("Dashboard", "Dashboard"),
        ["turni"]          = ("Turni", "Turni"),
        ["ferie"]          = ("Ferie", "Ferie"),
        ["cambio-turno"]   = ("Cambio turno", "CambioTurno"),
        ["sostituzioni"]   = ("Sostituzioni", "Sostituzioni"),
        ["dpi"]            = ("DPI", "Dpi"),
        ["presenze"]       = ("Presenze", "Presenze"),
        ["miei-documenti"] = ("I miei documenti", "MieiDocumenti"),
        ["mie-timbrature"] = ("Le mie timbrature", "MieTimbrature"),
        ["segnalazioni"]   = ("Segnalazioni", "Segnalazioni"),
        ["videoassistenza"]= ("Videoassistenza", "Videoassistenza"),
        ["chat"]           = ("Chat", "Chat"),
        ["comunicazioni"]  = ("Comunicazioni", "Comunicazioni"),
        ["product-backlog"]= ("Backlog di prodotto", "ProductBacklog"),
        ["rls"]            = ("RLS / Sicurezza", "Rls"),
        ["documentazione"] = ("Documentazione", "Documentazione"),
        ["cliniche"]       = ("Cliniche", "Cliniche"),
        ["dottori"]        = ("Dottori", "Dottori"),
        ["dipendenti"]     = ("Dipendenti", "Dipendenti"),
        ["contratti"]      = ("Contratti", "Contratti"),
        ["ai-insights"]    = ("AI Insights", "AiInsights"),
        ["ottimizzazione"] = ("Ottimizzazione AI", "Ottimizzazione"),
        ["benchmark"]      = ("Benchmark sedi", "Benchmark"),
        ["predizioni"]     = ("Predizione assenze", "Predizioni"),
        ["scadenziario"]   = ("Scadenziario", "Scadenziario"),
        ["tesoreria"]      = ("Tesoreria", "Tesoreria"),
        ["tesoreria-distinte"] = ("Distinte SEPA", "Tesoreria"),
        ["fornitori"]      = ("Fornitori", "Tesoreria"),
        ["operations"]     = ("Operations", "Operations"),
        ["feedback"]       = ("Feedback pazienti", "Feedback"),
        ["whistleblowing"] = ("Whistleblowing", "Whistleblowing"),
        ["headcount"]      = ("Headcount", "Headcount"),
        ["formazione"]     = ("Formazione", "Formazione"),
        ["report"]         = ("Report", "Report"),
        ["configurazione"] = ("Configurazione", "Configurazione"),
        ["users"]          = ("Utenti", "Users"),
        ["novita"]         = ("Novità", "WhatsNew")
    };
    sectionMap.TryGetValue(section, out var sectionInfo);
    var hasCrumb = !string.IsNullOrEmpty(crumb);
    var sectionIsRoot = !string.IsNullOrEmpty(sectionInfo.label) && sectionInfo.label.Equals(title, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title · Chipdent</title>
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="theme-color" content="#c47830" />
    <link rel="icon" type="image/png" href="~/img/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tour.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Chipdent.Web.styles.css" asp-append-version="true" />
    <style>
        /* Sidebar nav: gruppi collassabili */
        .nav__group { margin-bottom: 4px; }
        .nav__group > summary {
            list-style: none;
            cursor: pointer;
            user-select: none;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 14px 6px;
            border-radius: 6px;
            transition: background 0.12s;
        }
        .nav__group > summary::-webkit-details-marker,
        .nav__group > summary::marker { display: none; content: ''; }
        .nav__group > summary:hover { background: var(--c-bg-soft, #faf6f0); }
        .nav__group > summary:focus-visible {
            outline: 2px solid var(--c-accent, #c47830);
            outline-offset: -2px;
        }
        .nav__group-chev {
            transition: transform 0.18s ease;
            opacity: 0.6;
            flex-shrink: 0;
        }
        .nav__group:not([open]) > summary .nav__group-chev { transform: rotate(-90deg); }
        .nav__group > summary > span:first-child { flex: 1; }
        /* Disabilita lo stile heading default che potrebbe conflittare */
        .nav__group > summary.nav__group-title {
            font-family: 'JetBrains Mono', 'Inter', monospace;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--c-ink-soft, #7a5c3a);
            font-weight: 600;
            margin: 0;
        }
    </style>
</head>
<body>
    <div class="app">
        <aside class="app__sidebar" id="app-sidebar">

            @await Component.InvokeAsync("WorkspaceSwitcher")

            <button class="ws-search" data-search-trigger data-tour="search" type="button">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                <span>Cerca…</span>
                <kbd>⌘K</kbd>
            </button>

            <nav class="nav" data-tour="sidebar-nav">
                <details class="nav__group" data-group-key="operativita" open>
                    <summary class="nav__group-title">
                        <span>Operatività</span>
                        <svg class="nav__group-chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                    </summary>
                    <a class="nav__item @(section == "dashboard" ? "is-active" : "")" data-tour="nav-dashboard" asp-controller="Dashboard" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
                        Dashboard
                    </a>
                    <a class="nav__item @(section == "turni" ? "is-active" : "")" data-tour="nav-turni" asp-controller="Turni" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                        Turni
                    </a>
                    <a class="nav__item @(section == "ferie" ? "is-active" : "")" data-tour="nav-ferie" asp-controller="Ferie" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 22a8 8 0 0 1 16 0"/><path d="M14 9V2M14 9l4-2M14 9l4 2"/><circle cx="14" cy="9" r="1"/></svg>
                        Ferie
                    </a>
                    <a class="nav__item @(section == "cambio-turno" ? "is-active" : "")" asp-controller="CambioTurno" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                        Cambio turno
                    </a>
                    <a class="nav__item @(section == "sostituzioni" ? "is-active" : "")" asp-controller="Sostituzioni" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/><circle cx="12" cy="12" r="4"/></svg>
                        Sostituzioni
                    </a>
                    <a class="nav__item @(section == "presenze" ? "is-active" : "")" asp-controller="Presenze" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Presenze
                    </a>
                    <a class="nav__item @(section == "dpi" ? "is-active" : "")" asp-controller="Dpi" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L4 5v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V5l-8-3z"/></svg>
                        DPI
                    </a>
                    <a class="nav__item @(section == "miei-documenti" ? "is-active" : "")" asp-controller="MieiDocumenti" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h4"/></svg>
                        I miei documenti
                    </a>
                    <a class="nav__item @(section == "mie-timbrature" ? "is-active" : "")" data-tour="nav-mie-timbrature" asp-controller="MieTimbrature" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Le mie timbrature
                    </a>
                    <a class="nav__item @(section == "segnalazioni" ? "is-active" : "")" asp-controller="Segnalazioni" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        Segnalazioni
                    </a>
                    <a class="nav__item @(section == "videoassistenza" ? "is-active" : "")" data-tour="nav-videoassistenza" asp-controller="Videoassistenza" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                        Videoassistenza
                    </a>
                    <a class="nav__item @(section == "chat" ? "is-active" : "")" data-tour="nav-chat" asp-controller="Chat" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                        Chat
                    </a>
                    <a class="nav__item @(section == "comunicazioni" ? "is-active" : "")" data-tour="nav-comunicazioni" asp-controller="Comunicazioni" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        Comunicazioni
                    </a>
                    <a class="nav__item @(section == "product-backlog" ? "is-active" : "")" asp-controller="ProductBacklog" asp-action="Index">
                        <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/><circle cx="6" cy="6" r="1"/></svg>
                        Backlog di prodotto
                    </a>
                </details>

                @if (canSeeAnagrafiche)
                {
                    <details class="nav__group" data-group-key="anagrafiche" open>
                        <summary class="nav__group-title">
                            <span>Anagrafiche</span>
                            <svg class="nav__group-chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                        </summary>
                        <a class="nav__item @(section == "cliniche" ? "is-active" : "")" data-tour="nav-cliniche" asp-controller="Cliniche" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 21V12h6v9"/></svg>
                            Cliniche
                        </a>
                        <a class="nav__item @(section == "dottori" ? "is-active" : "")" data-tour="nav-dottori" asp-controller="Dottori" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
                            Dottori
                        </a>
                        <a class="nav__item @(section == "dipendenti" ? "is-active" : "")" data-tour="nav-dipendenti" asp-controller="Dipendenti" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="8" r="4"/><path d="M2 21a7 7 0 0 1 14 0"/><circle cx="17" cy="9" r="3"/><path d="M22 20a5 5 0 0 0-5-5"/></svg>
                            Dipendenti
                        </a>
                        @if (User.IsOwner() || User.IsManagement() || User.IsBackoffice())
                        {
                            <a class="nav__item @(section == "fornitori" ? "is-active" : "")" asp-controller="Tesoreria" asp-action="Fornitori">
                                <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 21v-7h6v7"/><path d="M3 21h18"/></svg>
                                Fornitori
                            </a>
                        }
                        <a class="nav__item @(section == "contratti" ? "is-active" : "")" asp-controller="Contratti" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h4"/></svg>
                            Contratti
                        </a>
                        <a class="nav__item @(section == "formazione" ? "is-active" : "")" asp-controller="Formazione" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                            Formazione &amp; ECM
                        </a>
                    </details>

                    @if (User.IsManagement())
                    {
                        <details class="nav__group" data-group-key="direzionale" open>
                            <summary class="nav__group-title">
                                <span>Direzionale</span>
                                <svg class="nav__group-chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                            </summary>
                            <a class="nav__item @(section == "ai-insights" ? "is-active" : "")" asp-controller="AiInsights" asp-action="Index" style="background: linear-gradient(90deg, rgba(196,120,48,0.1), rgba(122,92,154,0.1));">
                                <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2 7h7l-5.5 4 2 7-5.5-4-5.5 4 2-7L3 9h7z"/></svg>
                                ✨ AI Insights
                            </a>
                            <a class="nav__item @(section == "ottimizzazione" ? "is-active" : "")" asp-controller="Ottimizzazione" asp-action="Index" style="background: linear-gradient(90deg, rgba(196,120,48,0.1), rgba(122,92,154,0.1));">
                                <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2 7h7l-5.5 4 2 7-5.5-4-5.5 4 2-7L3 9h7z"/></svg>
                                ✨ Ottimizzazione AI
                            </a>
                            <a class="nav__item @(section == "benchmark" ? "is-active" : "")" asp-controller="Benchmark" asp-action="Index">
                                <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                                Benchmark sedi
                            </a>
                            <a class="nav__item @(section == "predizioni" ? "is-active" : "")" data-tour="nav-predizioni" asp-controller="Predizioni" asp-action="Assenze">
                                <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                                🔮 Predizione assenze
                            </a>
                            <a class="nav__item @(section == "feedback" ? "is-active" : "")" data-tour="nav-feedback" asp-controller="Feedback" asp-action="Index">
                                <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M9 10l2 2 4-4"/></svg>
                                Feedback pazienti
                            </a>
                            <a class="nav__item @(section == "headcount" ? "is-active" : "")" asp-controller="Headcount" asp-action="Index">
                                <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 14l3-3 4 4 5-6"/></svg>
                                Headcount
                            </a>
                            <a class="nav__item @(section == "report" ? "is-active" : "")" asp-controller="Report" asp-action="Index">
                                <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>
                                Report
                            </a>
                        </details>
                    }

                    @if (User.IsOwner() || User.IsManagement() || User.IsBackoffice())
                    {
                        <details class="nav__group" data-group-key="tesoreria" open>
                            <summary class="nav__group-title">
                                <span>Tesoreria</span>
                                <svg class="nav__group-chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                            </summary>
                            <a class="nav__item @(section == "tesoreria" ? "is-active" : "")" asp-controller="Tesoreria" asp-action="Index">
                                <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                                💰 Scadenziario
                            </a>
                            <a class="nav__item @(section == "tesoreria-distinte" ? "is-active" : "")" asp-controller="Tesoreria" asp-action="Distinte">
                                <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                                Distinte SEPA
                            </a>
                        </details>
                    }

                    <details class="nav__group" data-group-key="compliance" open>
                        <summary class="nav__group-title">
                            <span>Compliance</span>
                            <svg class="nav__group-chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                        </summary>
                        <a class="nav__item @(section == "rls" ? "is-active" : "")" data-tour="nav-rls" asp-controller="Rls" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            RLS / Sicurezza
                        </a>
                        <a class="nav__item @(section == "documentazione" ? "is-active" : "")" data-tour="nav-documentazione" asp-controller="Documentazione" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                            Documentazione
                        </a>
                        <a class="nav__item @(section == "scadenziario" ? "is-active" : "")" data-tour="nav-scadenziario" asp-controller="Scadenziario" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            📅 Scadenziario
                        </a>
                        <a class="nav__item @(section == "operations" ? "is-active" : "")" data-tour="nav-operations" asp-controller="Operations" asp-action="RondaIndex">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                            Operations
                        </a>
                        <a class="nav__item @(section == "audit" ? "is-active" : "")" data-tour="nav-audit" asp-controller="Audit" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                            Audit log
                        </a>
                    </details>
                }

                @if (canSeeUsers)
                {
                    <details class="nav__group" data-group-key="amministrazione" open>
                        <summary class="nav__group-title">
                            <span>Amministrazione</span>
                            <svg class="nav__group-chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                        </summary>
                        <a class="nav__item @(section == "users" ? "is-active" : "")" data-tour="nav-users" asp-controller="Users" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M20 8v6M23 11h-6"/></svg>
                            Utenti
                        </a>
                        <a class="nav__item @(section == "configurazione" ? "is-active" : "")" asp-controller="Configurazione" asp-action="Index">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.6 1.6 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.6 1.6 0 0 0-1.8-.3 1.6 1.6 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.6 1.6 0 0 0-1-1.5 1.6 1.6 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.6 1.6 0 0 0 .3-1.8 1.6 1.6 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1a1.6 1.6 0 0 0 1.5-1 1.6 1.6 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.6 1.6 0 0 0 1.8.3H9a1.6 1.6 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.6 1.6 0 0 0 1 1.5 1.6 1.6 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.6 1.6 0 0 0-.3 1.8V9a1.6 1.6 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.6 1.6 0 0 0-1.5 1z"/></svg>
                            Configurazione
                        </a>
                        <a class="nav__item @(section == "whistleblowing" ? "is-active" : "")" asp-controller="Whistleblowing" asp-action="Admin">
                            <svg class="nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            🛡️ Whistleblowing
                        </a>
                    </details>
                }
            </nav>

            <details class="user-bar" data-tour="user-menu">
                <summary class="user-bar__chip" aria-label="Menu utente">
                    <span class="avatar">@initials</span>
                    <span class="user-bar__text">
                        <span class="user-bar__name">@fullName</span>
                        <span class="user-bar__role">
                            <span class="role-badge @roleClass">@roleLabel</span>
                        </span>
                    </span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg>
                </summary>
                <div class="user-bar__menu">
                    <div class="user-bar__menu-head">
                        <strong>@fullName</strong>
                        <span>@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</span>
                    </div>
                    <div class="access-pill @(isFullAccess ? "access-pill--full" : "access-pill--limited")">
                        @if (isFullAccess)
                        {
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><polyline points="20 6 9 17 4 12"/></svg>
                            <span><strong>@roleLabel · accesso completo</strong> — vedi tutti i dati del workspace</span>
                        }
                        else
                        {
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>
                            <span><strong>@roleLabel · vista limitata</strong> — alcune sezioni non sono disponibili</span>
                        }
                    </div>
                    <hr/>
                    <a class="user-bar__item" asp-controller="Account" asp-action="Profile">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
                        Il mio profilo
                    </a>
                    <a class="user-bar__item" asp-controller="Account" asp-action="Preferences">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v6M12 17v6M4.22 4.22l4.24 4.24M15.54 15.54l4.24 4.24M1 12h6M17 12h6M4.22 19.78l4.24-4.24M15.54 8.46l4.24-4.24"/></svg>
                        Preferenze
                    </a>
                    <a class="user-bar__item" asp-controller="WhatsNew" asp-action="Index">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                        Novità
                    </a>
                    <button type="button" class="user-bar__item" data-tour-launcher>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
                        Tour guidato
                    </button>
                    <hr/>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="user-bar__item user-bar__item--danger">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="m16 17 5-5-5-5"/><path d="M21 12H9"/></svg>
                            Esci
                        </button>
                    </form>
                </div>
            </details>
        </aside>

        <div class="nav-backdrop" data-nav-backdrop aria-hidden="true" style="display:none;"></div>

        <main class="app__main">
            <header class="app__topbar">
                <button type="button" class="nav-toggle" data-nav-toggle aria-label="Apri menu" aria-controls="app-sidebar" style="display:none;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
                </button>
                <nav class="crumbs" aria-label="Breadcrumb">
                    <a class="crumbs__home" asp-controller="Dashboard" asp-action="Index" aria-label="Home">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l9-9 9 9"/><path d="M5 10v10h14V10"/></svg>
                    </a>
                    @if (!string.IsNullOrEmpty(sectionInfo.label))
                    {
                        <span class="crumbs__sep">/</span>
                        @if (sectionIsRoot && !hasCrumb)
                        {
                            <span class="crumbs__current">@sectionInfo.label</span>
                        }
                        else
                        {
                            <a class="crumbs__item" asp-controller="@sectionInfo.controller" asp-action="Index">@sectionInfo.label</a>
                        }
                    }
                    @if (hasCrumb)
                    {
                        <span class="crumbs__sep">/</span>
                        <a class="crumbs__item" asp-controller="@sectionInfo.controller" asp-action="Index">@crumb</a>
                    }
                    @if (!sectionIsRoot)
                    {
                        <span class="crumbs__sep">/</span>
                        <span class="crumbs__current">@title</span>
                    }
                </nav>

                <div class="topbar__actions">
                    <span class="conn" data-conn data-state="connecting">
                        <span class="dot"></span>
                        <span class="label">connessione…</span>
                    </span>
                    <details class="bell" data-tour="bell">
                        <summary class="icon-btn icon-btn--sm" title="Notifiche" aria-label="Notifiche">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10 21a2 2 0 0 0 4 0"/></svg>
                            <span class="dot" data-bell-dot hidden></span>
                        </summary>
                        <div class="bell__panel" role="dialog" aria-label="Notifiche">
                            <div class="bell__head">
                                <strong>Notifiche</strong>
                                <button type="button" class="bell__mark" data-bell-mark>Segna come lette</button>
                            </div>
                            <div class="bell__body" data-bell-body>
                                <div class="bell__empty" data-bell-empty>
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--c-ink-soft); margin-bottom: 8px;"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10 21a2 2 0 0 0 4 0"/></svg>
                                    <p>Nessuna notifica ancora.</p>
                                    <p class="muted">Le novità del workspace appariranno qui in tempo reale.</p>
                                </div>
                            </div>
                            <div class="bell__foot">
                                <a asp-controller="Audit" asp-action="Index">Vedi tutto l'audit log →</a>
                            </div>
                        </div>
                    </details>
                </div>
            </header>

            <section class="app__content">
                @RenderBody()
            </section>

            <footer class="app__footer" style="padding: 14px 24px; text-align: right; font-size: 10.5px; color: var(--c-ink-soft); border-top: 1px solid var(--c-border, #e9e1d3);">
                <a asp-controller="WhatsNew" asp-action="Index" style="color: inherit; text-decoration: none; opacity: 0.7;">@Chipdent.Web.Infrastructure.AppVersion.Display</a>
                <span style="opacity: 0.4; margin: 0 6px;">·</span>
                <a href="~/docs/chipdent-features.html" target="_blank" rel="noopener" style="color: inherit; text-decoration: none; opacity: 0.7;">
                    Mappa funzionale
                </a>
            </footer>
        </main>
    </div>

    <div class="toasts" aria-live="polite"></div>

    <div class="cmdk" data-cmdk hidden>
        <div class="cmdk__panel" role="dialog" aria-label="Cerca">
            <div class="cmdk__head">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="search" placeholder="Cerca clinica, dottore, documento…" autocomplete="off" />
                <kbd>esc</kbd>
            </div>
            <div class="cmdk__body">
                <div class="cmdk__group-title">Vai a</div>
                <a class="cmdk__item" asp-controller="Dashboard" asp-action="Index"><span>Dashboard</span><kbd>D</kbd></a>
                <a class="cmdk__item" asp-controller="Turni" asp-action="Index"><span>Turni</span><kbd>T</kbd></a>
                <a class="cmdk__item" asp-controller="Cliniche" asp-action="Index"><span>Cliniche</span><kbd>C</kbd></a>
                <a class="cmdk__item" asp-controller="Dottori" asp-action="Index"><span>Dottori</span><kbd>R</kbd></a>
                <a class="cmdk__item" asp-controller="Dipendenti" asp-action="Index"><span>Dipendenti</span><kbd>P</kbd></a>
                <a class="cmdk__item" asp-controller="Comunicazioni" asp-action="Index"><span>Comunicazioni</span><kbd>M</kbd></a>
                <a class="cmdk__item" asp-controller="Rls" asp-action="Index"><span>RLS / Sicurezza</span><kbd>S</kbd></a>
                <a class="cmdk__item" asp-controller="Documentazione" asp-action="Index"><span>Documentazione</span><kbd>O</kbd></a>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Espone userId corrente al client per filtraggio notifiche utente-specifiche.
        window.Chipdent = window.Chipdent || {};
        Chipdent.currentUserId = "@(User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "")";
    </script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script src="~/js/cmdk.js" asp-append-version="true"></script>
    <script>
        // Mobile: hamburger toggle sidebar overlay
        (function () {
            var btn = document.querySelector("[data-nav-toggle]");
            var sidebar = document.getElementById("app-sidebar");
            var backdrop = document.querySelector("[data-nav-backdrop]");
            if (!btn || !sidebar || !backdrop) return;

            function open() {
                sidebar.classList.add("is-open");
                backdrop.classList.add("is-active");
                document.body.style.overflow = "hidden";
            }
            function close() {
                sidebar.classList.remove("is-open");
                backdrop.classList.remove("is-active");
                document.body.style.overflow = "";
            }
            btn.addEventListener("click", function () {
                if (sidebar.classList.contains("is-open")) close(); else open();
            });
            backdrop.addEventListener("click", close);
            // Chiudi quando si clicca un link nav (per UX su mobile)
            sidebar.querySelectorAll(".nav__item").forEach(function (a) {
                a.addEventListener("click", function () {
                    if (window.matchMedia("(max-width: 960px)").matches) close();
                });
            });
            document.addEventListener("keydown", function (e) {
                if (e.key === "Escape" && sidebar.classList.contains("is-open")) close();
            });
        })();

        // Sidebar nav: persistenza stato collassato + auto-open gruppo della sezione attiva
        (function () {
            var STORAGE_KEY = "chipdent.nav.collapsed";
            var groups = document.querySelectorAll(".nav__group[data-group-key]");
            if (!groups.length) return;

            var collapsed = {};
            try { collapsed = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}") || {}; }
            catch (e) { collapsed = {}; }

            // 1. Ripristina stato salvato
            groups.forEach(function (g) {
                var key = g.dataset.groupKey;
                if (collapsed[key] === true) g.removeAttribute("open");
            });

            // 2. Forza apertura del gruppo contenente .nav__item.is-active
            groups.forEach(function (g) {
                if (g.querySelector(".nav__item.is-active")) {
                    g.setAttribute("open", "");
                    var key = g.dataset.groupKey;
                    if (collapsed[key]) {
                        delete collapsed[key];
                        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(collapsed)); } catch (e) {}
                    }
                }
            });

            // 3. Salva stato a ogni toggle
            groups.forEach(function (g) {
                g.addEventListener("toggle", function () {
                    var key = g.dataset.groupKey;
                    if (g.open) delete collapsed[key];
                    else collapsed[key] = true;
                    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(collapsed)); } catch (e) {}
                });
            });
        })();
    </script>
    <script src="~/js/tour.js" asp-append-version="true"></script>
    <script>
        // Service Worker registration (PWA)
        if ("serviceWorker" in navigator) {
            window.addEventListener("load", function () {
                navigator.serviceWorker.register("/sw.js", { scope: "/" })
                    .catch(function (err) { console.warn("SW registration failed:", err); });
            });
        }

        // Install prompt: cattura beforeinstallprompt e mostra un toast cliccabile
        (function () {
            var deferredPrompt = null;
            var bannerShown = false;
            window.addEventListener("beforeinstallprompt", function (e) {
                e.preventDefault();
                deferredPrompt = e;
                if (bannerShown) return;
                if (sessionStorage.getItem("chipdent.installDismissed") === "1") return;
                bannerShown = true;

                var banner = document.createElement("div");
                banner.id = "pwa-install-banner";
                banner.style.cssText = "position:fixed; bottom:20px; right:20px; z-index:9000; background:#fff; border:1px solid #e9e1d3; border-radius:14px; padding:14px 16px; box-shadow:0 12px 36px rgba(59,30,12,0.18); max-width:340px; font-family:Inter,sans-serif; font-size:.85rem;";
                banner.innerHTML =
                    '<div style="display:flex; gap:10px; align-items:flex-start;">' +
                    '<span style="font-size:24px;">📱</span>' +
                    '<div style="flex:1;">' +
                    '<strong style="color:#3b1e0c;">Installa Chipdent</strong>' +
                    '<div style="color:#7a5c3a; margin-top:4px;">Aggiungi alla home screen per accesso rapido come un\'app.</div>' +
                    '<div style="display:flex; gap:8px; margin-top:10px;">' +
                    '<button id="pwa-install-yes" style="background:#c47830; color:#fff; border:0; padding:6px 14px; border-radius:8px; font-weight:600; cursor:pointer;">Installa</button>' +
                    '<button id="pwa-install-no" style="background:none; border:0; color:#7a5c3a; cursor:pointer;">Più tardi</button>' +
                    '</div></div></div>';
                document.body.appendChild(banner);

                document.getElementById("pwa-install-yes").addEventListener("click", function () {
                    banner.remove();
                    if (!deferredPrompt) return;
                    deferredPrompt.prompt();
                    deferredPrompt.userChoice.finally(function () { deferredPrompt = null; });
                });
                document.getElementById("pwa-install-no").addEventListener("click", function () {
                    banner.remove();
                    sessionStorage.setItem("chipdent.installDismissed", "1");
                });
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
