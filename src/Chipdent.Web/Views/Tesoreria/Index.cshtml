    /* Quando la card è nella modale, rimuoviamo i vincoli di larghezza
       e il margine inferiore per sfruttare tutta la viewport. */
    .dlg-fullscreen__body > .card { margin-bottom: 0; }
    .dlg-fullscreen__body .scadenze-grid .table { font-size: .85rem; }
    .dlg-fullscreen__body .scadenze-grid .table thead th { font-size: .7rem; }
</style>

