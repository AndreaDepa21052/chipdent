@model Chipdent.Web.Models.CalendarioInterventiViewModel
@using Chipdent.Web.Domain.Entities
@{
    ViewData["Title"] = "Calendario interventi";
    var oggi = DateTime.UtcNow.Date;
    var tipoFiltro = ViewData["TipoFiltro"] as TipoIntervento?;

    string Stato(InterventoClinica? iv)
    {
        if (iv?.ProssimaScadenza is null) return "—";
        var gg = (iv.ProssimaScadenza.Value.Date - oggi).TotalDays;
        if (gg < 0) return "scaduta";
        if (gg <= 30) return "imminente";
        if (gg <= 90) return "in arrivo";
        return "ok";
    }

    string Badge(InterventoClinica? iv) => Stato(iv) switch
    {
        "scaduta"   => "badge--danger",
        "imminente" => "badge--warning",
        "in arrivo" => "badge",
        "ok"        => "badge--success",
        _           => "badge"
    };

    string MeseAnno(DateTime? d) => d?.ToString("MMM-yy", System.Globalization.CultureInfo.GetCultureInfo("it-IT")) ?? "—";
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>📅 Calendario interventi</h2>
        <p class="page-head__sub">
            @Model.Totali interventi tracciati ·
            <strong style="color: var(--c-danger, #b8442e);">@Model.Scaduti scaduti</strong> ·
            <strong style="color: var(--c-warning, #c47830);">@Model.Imminenti in scadenza ≤ 30 gg</strong>
        </p>
    </div>
    <div class="page-head__actions">
        <a class="btn @(tipoFiltro is null ? "btn--primary" : "btn--ghost")" asp-action="Index">Tutte</a>
    </div>
</div>

<div class="tabs cal-tabs" style="margin-bottom: var(--s-4);">
    <a class="tab @(tipoFiltro is null ? "is-active" : "")" asp-action="Index">Tutte</a>
    @foreach (var def in Chipdent.Web.Controllers.CalendarioInterventiController.SezioniDef)
    {
        <a class="tab @(tipoFiltro == def.Tipo ? "is-active" : "")" title="@def.Titolo"
           asp-action="Index" asp-route-tipo="@def.Tipo">@def.Icona @def.TitoloBreve</a>
    }
</div>

@{
    // Pannello proattivo: massimo 8 voci visibili (le altre dietro un "mostra altre N").
    var topUrgenti = Model.Urgenti.Take(8).ToList();
    var altreUrgenti = Model.Urgenti.Skip(8).ToList();
}
@if (topUrgenti.Count > 0)
{
    <section class="action-panel">
        <div class="action-panel__head">
            <div>
                <h3 class="action-panel__title">⚡ Azioni urgenti</h3>
                <div class="action-panel__sub">
                    @Model.Scaduti scadut@(Model.Scaduti == 1 ? "a" : "e") · @Model.Imminenti in scadenza ≤ 30 gg
                    · @Model.Urgenti.Count entro 60 gg da gestire
                </div>
            </div>
        </div>

        <div class="action-panel__list">
            @foreach (var a in topUrgenti)
            {
                var iv = a.Intervento;
                <article class="action-row @(a.IsScaduto ? "is-overdue" : (a.GiorniAllaScadenza <= 30 ? "is-soon" : ""))">
                    <div class="action-row__when">
                        @if (a.IsScaduto)
                        {
                            <span class="action-row__badge action-row__badge--danger">scaduto da @(-a.GiorniAllaScadenza)gg</span>
                        }
                        else if (a.GiorniAllaScadenza == 0)
                        {
                            <span class="action-row__badge action-row__badge--warn">oggi</span>
                        }
                        else
                        {
                            <span class="action-row__badge @(a.GiorniAllaScadenza <= 30 ? "action-row__badge--warn" : "")">tra @a.GiorniAllaScadenza gg</span>
                        }
                        <div class="action-row__date">@iv.ProssimaScadenza?.ToString("dd MMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("it-IT"))</div>
                    </div>
                    <div class="action-row__what">
                        <div class="action-row__title">@a.IconaSezione @a.TitoloSezione</div>
                        <div class="action-row__meta">
                            <strong>@a.ClinicaNome</strong>
                            @if (a.Fornitore is not null) { <text> · </text> <span class="muted">@a.Fornitore.RagioneSociale</span> }
                        </div>
                    </div>
                    <div class="action-row__cta">
                        @if (a.Fornitore is not null && !string.IsNullOrEmpty(a.Fornitore.Email))
                        {
                            <a class="btn btn--ghost btn--sm" href="@a.MailtoUrl()" title="Componi mail al fornitore">📧 Contatta</a>
                        }
                        @if (a.Fornitore is not null && !string.IsNullOrEmpty(a.Fornitore.Telefono))
                        {
                            <a class="btn btn--ghost btn--sm" href="tel:@a.Fornitore.Telefono.Replace(" ", "")" title="Chiama il fornitore">📞</a>
                        }
                        else if (a.Fornitore is not null && !string.IsNullOrEmpty(a.Fornitore.Cellulare))
                        {
                            <a class="btn btn--ghost btn--sm" href="tel:@a.Fornitore.Cellulare.Replace(" ", "")" title="Chiama il fornitore">📞</a>
                        }
                        <button type="button" class="btn btn--primary btn--sm"
                                data-open-modale
                                data-clinica="@iv.ClinicaId"
                                data-tipo="@iv.Tipo">📅 Pianifica</button>
                    </div>
                </article>
            }
        </div>

        @if (altreUrgenti.Count > 0)
        {
            <details class="action-panel__more">
                <summary>＋ altre @altreUrgenti.Count voci entro 60 giorni</summary>
                <div class="action-panel__list">
                    @foreach (var a in altreUrgenti)
                    {
                        var iv = a.Intervento;
                        <article class="action-row">
                            <div class="action-row__when">
                                <span class="action-row__badge">tra @a.GiorniAllaScadenza gg</span>
                                <div class="action-row__date">@iv.ProssimaScadenza?.ToString("dd MMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("it-IT"))</div>
                            </div>
                            <div class="action-row__what">
                                <div class="action-row__title">@a.IconaSezione @a.TitoloSezione</div>
                                <div class="action-row__meta"><strong>@a.ClinicaNome</strong></div>
                            </div>
                            <div class="action-row__cta">
                                @if (a.Fornitore is not null && !string.IsNullOrEmpty(a.Fornitore.Email))
                                {
                                    <a class="btn btn--ghost btn--sm" href="@a.MailtoUrl()">📧</a>
                                }
                                <button type="button" class="btn btn--ghost btn--sm"
                                        data-open-modale
                                        data-clinica="@iv.ClinicaId"
                                        data-tipo="@iv.Tipo">📅 Pianifica</button>
                            </div>
                        </article>
                    }
                </div>
            </details>
        }
    </section>
}

@foreach (var sez in Model.Sezioni)
{
    var conScad = sez.Righe.Count(r => r.Intervento?.ProssimaScadenza != null);
    var fi = sez.FornitoreInfo;
    <section class="card" style="margin-bottom: var(--s-5);">
        <div class="card__header" style="align-items:flex-start;">
            <div>
                <h3 class="card__title">@sez.Icona @sez.Titolo</h3>
                <div class="muted" style="font-size:.82rem;">
                    Frequenza: <strong>@sez.Frequenza</strong> · @conScad / @sez.Righe.Count cliniche tracciate
                </div>
            </div>
        </div>

        @if (fi is not null)
        {
            <div class="fornitore-card">
                <div class="fornitore-card__title">@fi.RagioneSociale</div>
                @if (!string.IsNullOrEmpty(fi.Indirizzo))
                {
                    <div class="fornitore-card__row">📍 @fi.Indirizzo</div>
                }
                <div class="fornitore-card__contacts">
                    @if (!string.IsNullOrEmpty(fi.Telefono))  { <span>📞 <a href="tel:@(fi.Telefono.Replace(" ", ""))">@fi.Telefono</a></span> }
                    @if (!string.IsNullOrEmpty(fi.Cellulare)) { <span>📱 <a href="tel:@(fi.Cellulare.Replace(" ", ""))">@fi.Cellulare</a></span> }
                    @if (!string.IsNullOrEmpty(fi.Fax))       { <span>📠 @fi.Fax</span> }
                    @if (!string.IsNullOrEmpty(fi.Email))     { <span>✉️ <a href="mailto:@fi.Email">@fi.Email</a></span> }
                    @if (!string.IsNullOrEmpty(fi.EmailSecondaria)) { <span>✉️ <a href="mailto:@fi.EmailSecondaria">@fi.EmailSecondaria</a></span> }
                    @if (!string.IsNullOrEmpty(fi.Pec))       { <span>📨 PEC: <a href="mailto:@fi.Pec">@fi.Pec</a></span> }
                </div>
                @if (!string.IsNullOrEmpty(fi.Note))
                {
                    <div class="fornitore-card__note">@fi.Note</div>
                }
            </div>
        }

        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Studio</th>
                        <th>Ultimo intervento</th>
                        <th>Archiviato in faldone ATS</th>
                        <th>Prossima scadenza</th>
                        <th>Note</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in sez.Righe)
                    {
                        var iv = r.Intervento;
                        <tr>
                            <td><strong>@r.ClinicaNome</strong></td>
                            <td>@MeseAnno(iv?.DataUltimoIntervento)</td>
                            <td>
                                @if (iv?.ArchiviatoFaldoneAts == true) { <span class="badge badge--success">☑</span> }
                                else { <span class="muted">—</span> }
                            </td>
                            <td>
                                @if (iv?.ProssimaScadenza is not null)
                                {
                                    <span class="badge @Badge(iv)">@MeseAnno(iv.ProssimaScadenza)</span>
                                }
                                else { <span class="muted">—</span> }
                            </td>
                            <td style="max-width: 360px; font-size:.85rem;">@(iv?.Note ?? "")</td>
                            <td style="text-align:right;">
                                <button type="button" class="btn btn--ghost btn--sm"
                                        data-open-modale
                                        data-clinica="@r.ClinicaId"
                                        data-tipo="@sez.Tipo">
                                    @(iv is null ? "+ Compila" : "✎ Modifica")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

<dialog id="dlg-intervento" class="dlg-intervento">
    <div data-modale-body>
        <div style="padding: var(--s-5); text-align:center; color: var(--c-ink-muted);">Caricamento…</div>
    </div>
</dialog>

<style>
    dialog.dlg-intervento {
        border: 0; border-radius: 14px; padding: 0;
        max-width: 560px; width: 92vw;
        box-shadow: 0 24px 80px rgba(59, 30, 12, 0.22);
    }
    dialog.dlg-intervento::backdrop { background: rgba(59, 30, 12, 0.35); backdrop-filter: blur(2px); }
    .dett-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-3); }
    .dett-grid .full { grid-column: 1 / -1; }

    .fornitore-card {
        background: linear-gradient(180deg, rgba(245, 232, 208, 0.45) 0%, rgba(245, 232, 208, 0.15) 100%);
        border: 1px solid var(--c-border);
        border-radius: var(--r-md);
        padding: var(--s-3) var(--s-4);
        margin: var(--s-3) 0;
        font-size: .85rem;
    }
    .fornitore-card__title { font-weight: 700; color: var(--c-ink-strong); margin-bottom: 4px; }
    .fornitore-card__row   { color: var(--c-ink); margin-bottom: 6px; }
    .fornitore-card__contacts { display: flex; flex-wrap: wrap; gap: var(--s-3) var(--s-4); color: var(--c-ink-soft); }
    .fornitore-card__contacts a { color: var(--c-accent-strong); }
    .fornitore-card__note  { margin-top: 6px; color: var(--c-ink-muted); font-style: italic; font-size: .78rem; }

    /* Tab-bar compatta: 12 voci su una riga (Tutte + 11 sezioni). */
    .cal-tabs.tabs { flex-wrap: nowrap; gap: 2px; }
    .cal-tabs .tab {
        padding: var(--s-2) var(--s-3);
        font-size: .82rem;
        white-space: nowrap;
        flex-shrink: 0;
    }
    @@media (max-width: 1280px) {
        .cal-tabs .tab { padding: var(--s-2) 8px; font-size: .78rem; }
    }

    /* ── Pannello proattivo "Azioni urgenti" ────────────────────── */
    .action-panel {
        background: linear-gradient(180deg, rgba(245, 232, 208, 0.55) 0%, rgba(245, 232, 208, 0.18) 100%);
        border: 1px solid var(--c-border);
        border-left: 4px solid var(--c-warning, #c47830);
        border-radius: var(--r-lg);
        padding: var(--s-4);
        margin-bottom: var(--s-5);
        box-shadow: var(--shadow-sm);
    }
    .action-panel__head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: var(--s-3); }
    .action-panel__title { margin: 0 0 4px; font-size: 1.05rem; color: var(--c-ink-strong); }
    .action-panel__sub   { font-size: .82rem; color: var(--c-ink-muted); }
    .action-panel__list  { display: flex; flex-direction: column; gap: var(--s-2); }
    .action-panel__more  { margin-top: var(--s-3); }
    .action-panel__more summary { cursor: pointer; font-size: .85rem; color: var(--c-accent-strong); padding: 4px 0; }
    .action-panel__more .action-panel__list { margin-top: var(--s-2); }

    .action-row {
        display: grid;
        grid-template-columns: 140px 1fr auto;
        align-items: center;
        gap: var(--s-3);
        padding: 10px 12px;
        background: #fff;
        border: 1px solid var(--c-divider);
        border-radius: var(--r-md);
    }
    .action-row.is-overdue { border-left: 3px solid var(--c-danger, #b8442e); }
    .action-row.is-soon    { border-left: 3px solid var(--c-warning, #c47830); }
    .action-row__when     { font-size: .78rem; color: var(--c-ink-soft); }
    .action-row__date     { margin-top: 2px; }
    .action-row__badge    { display: inline-block; padding: 2px 8px; border-radius: 999px; background: var(--c-bg-panel); font-weight: 700; font-size: .72rem; color: var(--c-ink); }
    .action-row__badge--warn   { background: rgba(196, 120, 48, 0.15); color: var(--c-warning, #c47830); }
    .action-row__badge--danger { background: rgba(184, 68, 46, 0.15); color: var(--c-danger, #b8442e); }
    .action-row__title    { font-weight: 600; color: var(--c-ink-strong); margin-bottom: 2px; font-size: .9rem; }
    .action-row__meta     { font-size: .8rem; color: var(--c-ink-soft); }
    .action-row__cta      { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }

    /* ── Cronologia modifiche dentro la modale ──────────────────── */
    .modale-cronologia { padding: 0 var(--s-5) var(--s-5); }
    .modale-cronologia summary { cursor: pointer; font-size: .85rem; color: var(--c-accent-strong); padding: 6px 0; }
    .cronologia { list-style: none; padding: 0; margin: var(--s-2) 0 0; display: flex; flex-direction: column; gap: 8px; }
    .cronologia__item { padding: 8px 10px; background: #fff; border: 1px solid var(--c-divider); border-radius: var(--r-sm); font-size: .82rem; }
    .cronologia__head { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .cronologia__user { font-weight: 600; color: var(--c-ink); }
    .cronologia__when { color: var(--c-ink-muted); margin-left: auto; font-size: .75rem; }
    .cronologia__changes { list-style: none; padding-left: 6px; margin: 4px 0 0; font-size: .78rem; color: var(--c-ink-soft); }
    .cronologia__changes li { margin-bottom: 2px; line-height: 1.5; }
    .cronologia__old { color: var(--c-danger, #b8442e); text-decoration: line-through; }
    .cronologia__new { color: var(--c-success, #2f7a44); font-weight: 600; }
    .cronologia__arrow { color: var(--c-ink-muted); margin: 0 4px; }
</style>

@section Scripts {
<script>
    (function () {
        const dlg = document.getElementById('dlg-intervento');
        const body = dlg.querySelector('[data-modale-body]');

        async function open(clinicaId, tipo) {
            body.innerHTML = '<div style="padding:32px; text-align:center; color:#888;">Caricamento…</div>';
            dlg.showModal();
            try {
                const r = await fetch(`@Url.Action("Modale")?clinicaId=${encodeURIComponent(clinicaId)}&tipo=${encodeURIComponent(tipo)}`);
                if (!r.ok) throw new Error(r.statusText);
                body.innerHTML = await r.text();
            } catch (e) {
                body.innerHTML = '<div style="padding:24px; color:#b8442e;">Errore caricamento.</div>';
            }
        }

        document.addEventListener('click', (ev) => {
            const t = ev.target.closest('[data-open-modale]');
            if (t) { ev.preventDefault(); open(t.dataset.clinica, t.dataset.tipo); return; }
            if (ev.target.matches('[data-close-dlg]')) { ev.preventDefault(); dlg.close(); }
        });
    })();
</script>
}
