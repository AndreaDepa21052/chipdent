@model Chipdent.Web.Models.ProductBacklogRow
@{
    var item = Model.Item;
    ViewData["Title"] = "Richiesta backlog";

    string StatoBadge(StatoBacklog s) => s switch
    {
        StatoBacklog.Proposta      => "<span class='badge'><span class='dot'></span>proposta</span>",
        StatoBacklog.InEsame       => "<span class='badge badge--warning'><span class='dot'></span>in esame</span>",
        StatoBacklog.InLavorazione => "<span class='badge badge--success'><span class='dot'></span>in lavorazione</span>",
        StatoBacklog.Completata    => "<span class='badge badge--success'>✓ completata</span>",
        StatoBacklog.Scartata      => "<span class='badge'>scartata</span>",
        _ => "—"
    };
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>Dettaglio richiesta</h2>
        <p class="page-head__sub">@item.CreatedAt.ToLocalTime().ToString("dd MMMM yyyy 'alle' HH:mm", new System.Globalization.CultureInfo("it-IT"))</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Indietro</a>
    </div>
</div>

<div class="card" style="max-width: 820px;">
    <div style="display:flex; gap:12px; align-items:flex-start; flex-wrap: wrap;">
        <div style="flex:1; min-width: 260px;">
            <div style="font-size:1.15rem; font-weight: 700; line-height: 1.5;">
                <span style="color: var(--c-ink-soft);">Come</span>
                <strong>@item.ComeRuolo</strong>
                <span style="color: var(--c-ink-soft);">vorrei</span>
                @item.Vorrei
            </div>
            <div style="margin-top:8px; font-size:1rem; color: var(--c-ink-soft, #7a5c3a);">
                <em>così che @item.CosiChe</em>
            </div>
        </div>
        <div style="display:flex; flex-direction:column; gap:6px; align-items:flex-end;">
            @Html.Raw(StatoBadge(item.Stato))
            <span class="badge">@item.Categoria</span>
            <span class="badge">area: @item.Area</span>
            <span class="badge">impatto: @item.Impatto</span>
        </div>
    </div>

    <hr style="margin: var(--s-3) 0; border: 0; border-top: 1px solid var(--c-border, #e9e1d3);" />

    <div class="muted" style="font-size:.85rem;">
        Proposta da <strong>@item.AutoreNome</strong>
        @if (!string.IsNullOrEmpty(item.AutoreRuolo)) { <span class="role-badge" style="margin-left:4px; font-size:.7rem; padding:1px 6px;">@item.AutoreRuolo</span> }
    </div>

    @if (!string.IsNullOrEmpty(item.Commento))
    {
        <div style="margin-top: var(--s-3);">
            <h4 style="margin: 0 0 8px;">Commento</h4>
            <div style="padding: 12px 14px; background: var(--c-bg-soft, #faf6f0); border-radius: 8px; white-space: pre-wrap;">@item.Commento</div>
        </div>
    }

    @if (!string.IsNullOrEmpty(item.NotaOwner))
    {
        <div style="margin-top: var(--s-3); padding: 12px 14px; background: #fff8ed; border-left: 3px solid #c47830; border-radius: 4px;">
            <strong>Decisione Owner</strong>
            @if (!string.IsNullOrEmpty(item.GestitaDaNome)) { <span class="muted"> · @item.GestitaDaNome</span> }
            @if (item.DataDecisione is not null) { <span class="muted"> · @item.DataDecisione?.ToLocalTime().ToString("dd MMM HH:mm")</span> }
            <div style="margin-top:6px; white-space: pre-wrap;">@item.NotaOwner</div>
            @if (!string.IsNullOrEmpty(item.SprintTarget))
            {
                <div style="margin-top: 6px;"><strong>🎯 Sprint target:</strong> @item.SprintTarget</div>
            }
        </div>
    }

    <div style="display:flex; align-items:center; gap: var(--s-3); margin-top: var(--s-4); justify-content: space-between; flex-wrap:wrap;">
        <form asp-action="ToggleVote" asp-route-id="@item.Id" method="post" style="display:inline;">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="btn @(Model.VotatoDaMe ? "btn--primary" : "btn--ghost")"
                    style="display:inline-flex; align-items:center; gap:8px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="@(Model.VotatoDaMe ? "currentColor" : "none")" stroke="currentColor" stroke-width="2">
                    <path d="M7 10v12M15 5.88L14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2h0a3.13 3.13 0 0 1 3 3.88z"/>
                </svg>
                <strong>@item.VotantiUserIds.Count voti</strong>
                <span class="muted">@(Model.VotatoDaMe ? "· hai votato" : "· vota")</span>
            </button>
        </form>

        <div class="muted" style="font-size:.82rem;">
            ID: <code>@item.Id</code>
        </div>
    </div>
</div>
