@model Chipdent.Web.Models.FornitoreFormViewModel
@using Chipdent.Web.Domain.Entities
@{
    var isNew = string.IsNullOrEmpty(Model.Id);
    ViewData["Title"] = isNew ? "Nuovo fornitore" : Model.RagioneSociale;
    ViewData["Crumb"] = "Tesoreria";
    // Categorie sempre ordinate alfabeticamente nei dropdown.
    var categorieOrdinate = Enum.GetValues<CategoriaSpesa>()
        .OrderBy(c => c.ToString(), StringComparer.OrdinalIgnoreCase)
        .ToList();
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>@(isNew ? "＋ Nuovo fornitore" : "✎ " + Model.RagioneSociale)</h2>
        <p class="page-head__sub">Anagrafica fiscale + opzionale abilitazione del portale fornitori.</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Fornitori">← Lista</a>
    </div>
</div>

<form method="post" class="card" style="padding: var(--s-4);">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="alert alert--danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none");"></div>

    @if (Model.IsDottoreOmbra)
    {
        <div class="alert alert--info" style="margin-bottom: var(--s-3);">
            🩺 Questo fornitore è la <strong>controparte fattura di un Dottore</strong>. I dati anagrafici (P.IVA, IBAN, ragione sociale, stato) sono sincronizzati automaticamente dalla scheda Dottore: modificali da lì.
        </div>
    }

    <div class="grid" style="grid-template-columns: 1fr 2fr 1fr; gap: var(--s-3);">
        <div class="form-group">
            <label class="form-label" asp-for="Codice">Codice</label>
            <input class="form-control" asp-for="Codice" placeholder="@(isNew ? "auto F####" : "")" />
            <span class="hint">@(isNew ? "Lascia vuoto per auto-generare." : "Codice anagrafico interno.")</span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="RagioneSociale">Ragione sociale *</label>
            <input id="rs-fiscale" class="form-control" asp-for="RagioneSociale" required />
            <span class="text-danger" asp-validation-for="RagioneSociale"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Stato">Stato</label>
            <select class="form-control" asp-for="Stato">
                <option value="@StatoFornitore.Attivo" selected="@(Model.Stato == StatoFornitore.Attivo)">Attivo</option>
                <option value="@StatoFornitore.Dismesso" selected="@(Model.Stato != StatoFornitore.Attivo)">Dismesso</option>
            </select>
        </div>
    </div>

    <div class="grid" style="grid-template-columns: 1fr; gap: var(--s-3);">
        <div class="form-group">
            <label class="form-label">Sedi di riferimento</label>
            <partial name="_SediRiferimentoSelect" model="new Chipdent.Web.Models.SediRiferimentoSelectViewModel { Selected = Model.SediRiferimentoIds, Cliniche = Model.Cliniche }" />
            <span class="hint">Sedi della catena a cui il fornitore è associato. Seleziona <strong>TUTTE</strong> per applicarlo a tutte le sedi.</span>
        </div>
    </div>

    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: var(--s-3);">
        <div class="form-group">
            <label class="form-label" asp-for="RagioneSocialePagamento">Ragione sociale pagamento</label>
            <input id="rs-pagamento" class="form-control" asp-for="RagioneSocialePagamento"
                   placeholder="(uguale alla ragione sociale)" />
            <span class="hint">Beneficiario reale del bonifico. Default = ragione sociale.</span>
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="CategoriaSecondaria">Categoria secondaria</label>
            <select class="form-control" asp-for="CategoriaSecondaria">
                <option value="">— nessuna —</option>
                @foreach (var v in categorieOrdinate)
                {
                    <option value="@v" selected="@(Model.CategoriaSecondaria == v)">@v</option>
                }
            </select>
        </div>
    </div>


    <div class="grid" style="grid-template-columns: 1fr 1fr 1fr; gap: var(--s-3);">
        <div class="form-group">
            <label class="form-label" asp-for="PartitaIva">P. IVA</label>
            <input class="form-control" asp-for="PartitaIva" />
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="CodiceFiscale">Codice fiscale</label>
            <input class="form-control" asp-for="CodiceFiscale" />
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="CodiceSdi">Codice SDI</label>
            <input class="form-control" asp-for="CodiceSdi" placeholder="7 caratteri" />
        </div>
    </div>

    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: var(--s-3);">
        <div class="form-group">
            <label class="form-label" asp-for="Pec">PEC</label>
            <input class="form-control" type="email" asp-for="Pec" />
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="EmailContatto">Email contatto / portale</label>
            <input class="form-control" type="email" asp-for="EmailContatto" />
        </div>
    </div>

    <div class="grid" style="grid-template-columns: 1fr 2fr; gap: var(--s-3);">
        <div class="form-group">
            <label class="form-label" asp-for="Telefono">Telefono</label>
            <input class="form-control" asp-for="Telefono" />
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="Indirizzo">Indirizzo</label>
            <input class="form-control" asp-for="Indirizzo" placeholder="Via / Piazza, numero civico" />
        </div>
    </div>

    <div class="grid" style="grid-template-columns: 2fr 1fr 1fr; gap: var(--s-3);">
        <div class="form-group">
            <label class="form-label" asp-for="Localita">Località</label>
            <input class="form-control" asp-for="Localita" placeholder="Comune" />
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="Provincia">Provincia</label>
            <input class="form-control" asp-for="Provincia" maxlength="2" placeholder="MI" />
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="CodicePostale">CAP</label>
            <input class="form-control" asp-for="CodicePostale" maxlength="10" placeholder="20100" />
        </div>
    </div>

    <div class="grid" style="grid-template-columns: 2fr 1fr; gap: var(--s-3);">
        <div class="form-group">
            <label class="form-label" asp-for="Iban">IBAN per bonifici</label>
            <input class="form-control" asp-for="Iban" placeholder="IT…" />
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="CategoriaDefault">Categoria di default</label>
            <select class="form-control" asp-for="CategoriaDefault">
                @foreach (var v in categorieOrdinate)
                {
                    <option value="@v" selected="@(Model.CategoriaDefault == v)">@v</option>
                }
            </select>
        </div>
    </div>

    <div class="card" style="background: var(--c-bg-soft, #faf6f0); padding: var(--s-3); margin-top: var(--s-3);">
        <h4 style="margin: 0 0 8px;">📅 Termini di pagamento</h4>
        <p class="muted" style="font-size: .85rem; margin: 0 0 8px;">Usati per calcolare la data di scadenza attesa quando il fornitore carica una fattura. Tipico: <em>30 gg D.F.</em>, <em>30 gg F.M.</em>, <em>60 gg F.M.S.</em>.</p>
        <div class="grid" style="grid-template-columns: 1fr 2fr; gap: var(--s-3);">
            <div class="form-group" style="margin: 0;">
                <label class="form-label" asp-for="TerminiPagamentoGiorni">Giorni</label>
                <input class="form-control" type="number" min="0" max="365" asp-for="TerminiPagamentoGiorni" />
            </div>
            <div class="form-group" style="margin: 0;">
                <label class="form-label" asp-for="BasePagamento">Base di calcolo</label>
                <select class="form-control" asp-for="BasePagamento">
                    <option value="@BasePagamento.DataFattura" selected="@(Model.BasePagamento == BasePagamento.DataFattura)">Data fattura (D.F.)</option>
                    <option value="@BasePagamento.FineMeseFattura" selected="@(Model.BasePagamento == BasePagamento.FineMeseFattura)">Fine mese fattura (F.M.)</option>
                    <option value="@BasePagamento.FineMeseSuccessivo" selected="@(Model.BasePagamento == BasePagamento.FineMeseSuccessivo)">Fine mese successivo (F.M.S.)</option>
                </select>
            </div>
        </div>
        <div class="grid" style="grid-template-columns: 1fr 1fr; gap: var(--s-3); margin-top: var(--s-3);">
            <div class="form-group" style="margin: 0;">
                <label class="form-label" asp-for="EmissioneFattura">Modalità di pagamento</label>
                <select class="form-control" asp-for="EmissioneFattura">
                    <option value="@EmissioneFattura.PrimaDelPagamento" selected="@(Model.EmissioneFattura == EmissioneFattura.PrimaDelPagamento)">Prima fattura, poi pagamento</option>
                    <option value="@EmissioneFattura.DopoIlPagamento" selected="@(Model.EmissioneFattura == EmissioneFattura.DopoIlPagamento)">Prima pagamento, poi emissione fattura</option>
                    <option value="@EmissioneFattura.Nd" selected="@(Model.EmissioneFattura == EmissioneFattura.Nd)">— non specificato —</option>
                </select>
            </div>
            <div class="form-group" style="margin: 0;">
                <label class="form-label" asp-for="PagamentoRicorrente">Pagamento con importo ricorrente</label>
                <select class="form-control" asp-for="PagamentoRicorrente">
                    <option value="false" selected="@(!Model.PagamentoRicorrente)">No</option>
                    <option value="true" selected="@(Model.PagamentoRicorrente)">Sì</option>
                </select>
                <span class="hint">Canoni, abbonamenti, rate periodiche.</span>
            </div>
        </div>
    </div>

    <div class="form-group">
        <label class="form-label" asp-for="Note">Note</label>
        <textarea class="form-control" asp-for="Note" rows="2"></textarea>
    </div>

    <div class="card" style="background: var(--c-bg-soft, #faf6f0); padding: var(--s-3); margin-top: var(--s-3);">
        <h4 style="margin: 0 0 8px;">🔓 Portale fornitore</h4>
        @if (Model.HaUtentePortale)
        {
            <p class="muted" style="font-size: .9rem;">L'utente per @Model.EmailContatto è già attivo. Inserisci una nuova password qui sotto solo se vuoi <strong>resettarla</strong>.</p>
        }
        else
        {
            <p class="muted" style="font-size: .9rem;">Crea un account portale per permettere al fornitore di consultare le proprie scadenze e caricare le fatture. Email = quella di contatto.</p>
        }
        <div style="display:flex; gap: var(--s-3); align-items:end;">
            <label class="form-check">
                <input type="checkbox" asp-for="AbilitaPortale" /> @(Model.HaUtentePortale ? "Reset password" : "Abilita portale")
            </label>
            <div class="form-group" style="flex:1; margin: 0;">
                <label class="form-label" asp-for="PortalePassword">Password</label>
                <input class="form-control" type="text" asp-for="PortalePassword" autocomplete="off" placeholder="lascia vuoto per non cambiarla" />
            </div>
        </div>
    </div>

    <div style="display:flex; gap:8px; justify-content:flex-end; margin-top: var(--s-3);">
        <a class="btn btn--ghost" asp-action="Fornitori">Annulla</a>
        <button type="submit" class="btn btn--primary">@(isNew ? "Crea fornitore" : "Salva modifiche")</button>
    </div>
</form>

<partial name="_SediRiferimentoStyles" />

@section Scripts {
<script>
    (function () {
        var fiscale = document.getElementById('rs-fiscale');
        var pagamento = document.getElementById('rs-pagamento');
        if (!fiscale || !pagamento) return;
        var pagamentoToccato = pagamento.value.trim().length > 0;
        pagamento.addEventListener('input', function () { pagamentoToccato = true; });
        fiscale.addEventListener('input', function () {
            if (!pagamentoToccato) pagamento.value = fiscale.value;
        });
    })();
</script>
}
