@model Chipdent.Web.Models.ImportFattureDettaglioViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Dettaglio import fatture";
    ViewData["Crumb"] = "Tesoreria";
    var it = new CultureInfo("it-IT");
    var b = Model.Batch;
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>📥 Caricamento del @b.DataCaricamento.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</h2>
        <p class="page-head__sub">
            Caricato da <strong>@Model.CaricatoDaNome</strong> · Tipo
            <span class="pill pill--type">@b.Tipo</span>
            @if (!string.IsNullOrEmpty(b.Note)) { <text>· <em>@b.Note</em></text> }
        </p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="ImportFatture">← Tutti i caricamenti</a>
    </div>
</div>

<style>
    .imp-stats { display:grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap:10px; margin-bottom:18px; }
    .imp-kpi { background:#fff; border:1px solid #e9dcc1; border-radius:10px; padding:12px 14px; }
    .imp-kpi .lbl { font-size:.72rem; text-transform:uppercase; letter-spacing:.5px; color:#7a5c3a; }
    .imp-kpi .val { font-size:1.5rem; font-weight:700; color:#3b1e0c; }
    .pill { display:inline-block; padding:2px 9px; border-radius:99px; font-size:.72rem; font-weight:600; }
    .pill--ok { background:#d6f5dc; color:#1a6b32; }
    .pill--warn { background:#fbe5b8; color:#7a4a00; }
    .pill--err { background:#fcd9d9; color:#9a1c1c; }
    .pill--type { background:#e7e0f5; color:#473780; }
    .file-block { margin-top: 18px; }
    .file-block__head {
        display:flex; align-items:center; gap:12px; padding:10px 14px;
        background:#3b1e0c; color:#f5e8d0; border-radius:10px 10px 0 0;
    }
    .file-block__head h3 { margin:0; font-size:1rem; flex:1; }
    .file-block__head .meta { font-size:.78rem; opacity:.85; }
    .file-block__totals {
        display:flex; gap:18px; padding:10px 14px; background:#fff7e8;
        border-left:1px solid #e9dcc1; border-right:1px solid #e9dcc1; font-size:.88rem;
    }
    .file-block__totals strong { color:#3b1e0c; }
    .grid-righe { padding:0; overflow:auto; border:1px solid #e9dcc1; border-radius:0 0 10px 10px; }
    .grid-righe table { width:100%; border-collapse: collapse; font-size:.85rem; }
    .grid-righe th, .grid-righe td { padding:6px 10px; border-bottom:1px solid #f1e6cf; white-space: nowrap; }
    .grid-righe th { position:sticky; top:0; background:#fff7e8; text-align:left; font-weight:600; color:#3b1e0c; }
    .grid-righe tr.has-err { background: #fff5f5; }
    .grid-righe td.num { text-align:right; font-variant-numeric: tabular-nums; }
    .err-list { font-size:.75rem; color:#9a1c1c; margin-top:2px; }

    /* ── Search overlay ─────────────────────────────────────────── */
    .imp-search-fab {
        position: fixed; right: 24px; bottom: 24px;
        z-index: 60;
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 18px;
        background: linear-gradient(135deg, #c47830 0%, #3b1e0c 100%);
        color: #fff7e8; font-weight: 600; font-size: .92rem;
        border: none; border-radius: 999px; cursor: pointer;
        box-shadow: 0 10px 30px rgba(59,30,12,.28), 0 2px 6px rgba(59,30,12,.18);
        transition: transform .18s, box-shadow .18s;
    }
    .imp-search-fab:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 16px 36px rgba(59,30,12,.32); }
    .imp-search-fab kbd {
        background: rgba(255,255,255,.18); padding: 2px 6px; border-radius: 4px;
        font-size: .72rem; font-family: 'JetBrains Mono', monospace;
    }
    @@keyframes impFadeIn { from { opacity:0; backdrop-filter: blur(0); } to { opacity:1; backdrop-filter: blur(6px); } }
    @@keyframes impSlideDown { from { transform: translateY(-12px); opacity:0; } to { transform: translateY(0); opacity:1; } }

    .imp-search-overlay {
        position: fixed; inset: 0; z-index: 80;
        background: rgba(40, 22, 8, .55);
        backdrop-filter: blur(6px) saturate(140%);
        -webkit-backdrop-filter: blur(6px) saturate(140%);
        display: none;
        animation: impFadeIn .18s ease-out;
    }
    .imp-search-overlay.is-open { display: block; }

    .imp-search-panel {
        position: absolute; top: 8vh; left: 50%; transform: translateX(-50%);
        width: min(720px, 92vw);
        background: linear-gradient(180deg, #fffaf0 0%, #fff6e2 100%);
        border-radius: 18px;
        box-shadow: 0 30px 80px rgba(0,0,0,.4), 0 0 0 1px rgba(196,120,48,.25);
        padding: 18px 18px 14px;
        animation: impSlideDown .22s cubic-bezier(.2,.8,.2,1);
    }
    .imp-search-panel__field {
        display: flex; align-items: center; gap: 12px;
        padding: 10px 14px; background: #fff;
        border: 2px solid #e9dcc1; border-radius: 12px;
        transition: border-color .15s, box-shadow .15s;
    }
    .imp-search-panel__field:focus-within {
        border-color: #c47830;
        box-shadow: 0 0 0 4px rgba(196,120,48,.18);
    }
    .imp-search-panel__field svg { flex-shrink: 0; opacity: .6; }
    .imp-search-panel input {
        flex: 1; border: none; outline: none; background: transparent;
        font-size: 1.05rem; color: #3b1e0c;
        font-family: inherit;
    }
    .imp-search-panel input::placeholder { color: #b29a78; }
    .imp-search-panel__hint {
        margin-top: 10px;
        display: flex; flex-wrap: wrap; gap: 14px; align-items: center;
        font-size: .78rem; color: #7a5c3a;
    }
    .imp-search-panel__hint kbd {
        background: #fff; border: 1px solid #e9dcc1; border-radius: 5px;
        padding: 1px 6px; font-family: 'JetBrains Mono', monospace; font-size: .72rem;
    }
    .imp-search-panel__summary {
        margin-top: 14px; padding-top: 12px;
        border-top: 1px dashed #e9dcc1;
        display: grid; gap: 6px;
        max-height: 40vh; overflow-y: auto;
    }
    .imp-search-panel__row {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 12px; border-radius: 8px;
        background: rgba(255,255,255,.6);
        font-size: .88rem; color: #3b1e0c;
        cursor: pointer;
        transition: background .12s, transform .12s;
    }
    .imp-search-panel__row:hover { background: #fff; transform: translateX(2px); }
    .imp-search-panel__row.is-empty { color: #b29a78; cursor: default; }
    .imp-search-panel__row.is-empty:hover { background: rgba(255,255,255,.6); transform: none; }
    .imp-search-panel__row strong { flex: 1; }
    .imp-search-panel__row .count {
        background: #c47830; color: #fff; border-radius: 999px;
        padding: 2px 10px; font-size: .75rem; font-weight: 700;
        min-width: 28px; text-align: center;
    }
    .imp-search-panel__row.is-empty .count { background: #d8c8a8; }

    /* highlight nelle celle */
    .grid-righe mark {
        background: #ffe89a; color: #3b1e0c; padding: 0 2px; border-radius: 3px;
        box-shadow: 0 0 0 1px rgba(196,120,48,.4) inset;
    }
    .file-block.is-search-empty { opacity: .35; }
    .file-block .imp-match-badge {
        margin-left: auto;
        background: rgba(255,255,255,.18);
        border-radius: 999px; padding: 2px 10px;
        font-size: .72rem; font-weight: 600;
        opacity: 0; transform: scale(.8);
        transition: opacity .15s, transform .15s;
    }
    .file-block.is-search-active .imp-match-badge { opacity: 1; transform: scale(1); }

    /* ── Resizable columns ──────────────────────────────────────── */
    .grid-righe table { table-layout: fixed; }
    .grid-righe th { position: sticky; top: 0; }
    .grid-righe th, .grid-righe td { overflow: hidden; text-overflow: ellipsis; }
    .grid-righe th { position: relative; }
    .col-resizer {
        position: absolute; top: 0; right: -3px; width: 8px; height: 100%;
        cursor: col-resize; user-select: none;
        background: transparent;
        z-index: 5;
    }
    .col-resizer::after {
        content: ''; position: absolute; top: 6px; bottom: 6px; right: 3px;
        width: 2px; border-radius: 2px;
        background: transparent;
        transition: background .15s;
    }
    .col-resizer:hover::after, .col-resizer.is-dragging::after { background: #c47830; }
    .grid-righe table.is-resizing { user-select: none; }
    .grid-righe table.is-resizing * { cursor: col-resize !important; }
    .col-reset-btn {
        position: absolute; top: 6px; right: 8px;
        font-size: .68rem; color: rgba(245,232,208,.7);
        background: rgba(0,0,0,.18); border: none; border-radius: 4px;
        padding: 2px 6px; cursor: pointer;
        opacity: 0; transition: opacity .15s;
    }
    .file-block:hover .col-reset-btn { opacity: 1; }
    .col-reset-btn:hover { color: #fff; background: rgba(0,0,0,.35); }
</style>

<div class="imp-stats">
    <div class="imp-kpi"><div class="lbl">File</div><div class="val">@b.Files.Count</div></div>
    <div class="imp-kpi"><div class="lbl">Righe totali</div><div class="val">@b.TotaleRighe.ToString("N0", it)</div></div>
    <div class="imp-kpi"><div class="lbl">Righe valide</div><div class="val" style="color:#1a6b32;">@b.RigheValide.ToString("N0", it)</div></div>
    <div class="imp-kpi"><div class="lbl">Righe con errori</div><div class="val" style="color:@(b.RigheConErrore > 0 ? "#9a1c1c" : "#3b1e0c");">@b.RigheConErrore.ToString("N0", it)</div></div>
</div>

@foreach (var g in Model.Files)
{
    var sezCls = g.Header.Sezione == "CCH" ? "pill--ok" : (g.Header.Sezione == "Ident" ? "pill--warn" : "pill--err");
    <div class="file-block" data-file-block data-file-name="@g.Header.NomeFile" data-batch-id="@b.Id">
        <div class="file-block__head">
            <span class="pill @sezCls">@g.Header.Sezione</span>
            <h3>@g.Header.NomeFile</h3>
            <span class="meta">
                @if (g.Header.TipoFile == "pdf")
                {
                    <span><strong>@g.Header.FattureEstrattePdf</strong> fatture estratte</span>
                }
                else
                {
                    <span>@g.Header.RigheTotali righe · @g.Header.RigheValide valide · @g.Header.RigheConErrore con errori</span>
                }
                · @((g.Header.DimensioneByte / 1024.0).ToString("N1", it)) KB
            </span>
            @if (!string.IsNullOrEmpty(g.Header.StoragePath))
            {
                <a class="btn btn--ghost btn--sm"
                   asp-action="ScaricaFileBatch"
                   asp-route-batchId="@b.Id"
                   asp-route-nome="@g.Header.NomeFile"
                   title="Scarica il file originale di questo caricamento">⬇ Scarica originale</a>
            }
            <span class="imp-match-badge"><span data-match-count>0</span> match</span>
            <button type="button" class="col-reset-btn" data-reset-cols title="Ripristina larghezze colonne">↺ reset</button>
        </div>
        <div class="file-block__totals">
            <span>Tot. documenti: <strong>@g.TotaleDocumenti.ToString("N2", it) €</strong></span>
            <span>Netto a pagare: <strong>@g.TotaleNetto.ToString("N2", it) €</strong></span>
            @if (g.Header.Sezione == "CCH")
            {
                <span>IVA: <strong>@g.TotaleIva.ToString("N2", it) €</strong></span>
            }
            <span class="muted" style="margin-left:auto;">SHA-256: <code style="font-size:.72rem;">@(g.Header.ChecksumSha256?.Substring(0, Math.Min(16, g.Header.ChecksumSha256.Length)) ?? "—")…</code></span>
        </div>

        <div class="grid-righe">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Protocollo</th>
                        <th>Data reg.</th>
                        <th>Numero</th>
                        <th>Data doc.</th>
                        <th>Fornitore</th>
                        <th>Tipo doc.</th>
                        <th class="num">Totale</th>
                        @if (g.Header.Sezione == "CCH") { <th class="num">IVA</th> }
                        <th class="num">Netto</th>
                        <th class="num">Ritenuta</th>
                        <th>Competenza</th>
                        <th>Scadenza (PDF)</th>
                        <th>Mod. pag.</th>
                        <th>IBAN</th>
                        <th>P.IVA</th>
                        <th>Causale</th>
                        <th>Allegati</th>
                        <th>Stato</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in g.Righe)
                {
                    <tr class="@(r.HaErrori ? "has-err" : "")">
                        <td>@r.NumeroRiga</td>
                        <td>@r.Protocollo</td>
                        <td>@(r.DataRegistrazione?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>@r.Numero</td>
                        <td>@(r.DataDocumento?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>@r.Fornitore</td>
                        <td>@r.TipoDocumento</td>
                        <td class="num">@(r.TotaleDocumento?.ToString("N2", it) ?? "—")</td>
                        @if (g.Header.Sezione == "CCH") { <td class="num">@(r.Iva?.ToString("N2", it) ?? "—")</td> }
                        <td class="num">@(r.NettoAPagare?.ToString("N2", it) ?? "—")</td>
                        <td class="num">@(r.Ritenuta?.ToString("N2", it) ?? "—")</td>
                        <td>@(r.MeseCompetenza.HasValue ? $"{r.MeseCompetenza:00}/{r.AnnoCompetenza ?? r.DataDocumento?.Year ?? 0}" : "—")</td>
                        <td>@(r.DataScadenzaPdf?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>@(r.ModalitaPagamentoPdf ?? "—")</td>
                        <td style="font-family:monospace; font-size:.78rem;">@(r.IbanFornitore ?? "—")</td>
                        <td style="font-family:monospace; font-size:.78rem;">@(r.PartitaIvaFornitore ?? "—")</td>
                        <td>@r.Causale</td>
                        <td>@r.Allegati</td>
                        <td>
                            @if (r.HaErrori)
                            {
                                <span class="pill pill--err">errore</span>
                                <div class="err-list">@string.Join(" · ", r.Errori)</div>
                            }
                            else
                            {
                                <span class="pill pill--ok">ok</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<button type="button" id="impSearchFab" class="imp-search-fab" aria-label="Apri ricerca">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/>
        <path d="m21 21-4.3-4.3"/>
    </svg>
    <span>Cerca</span>
    <kbd>⌘K</kbd>
</button>

<div id="impSearchOverlay" class="imp-search-overlay" role="dialog" aria-modal="true" aria-label="Ricerca nelle tabelle">
    <div class="imp-search-panel" role="document">
        <div class="imp-search-panel__field">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="7"/>
                <path d="m21 21-4.3-4.3"/>
            </svg>
            <input id="impSearchInput" type="search" autocomplete="off" spellcheck="false"
                   placeholder="Cerca fornitore, numero, protocollo, importo…" />
        </div>
        <div class="imp-search-panel__hint">
            <span><kbd>↵</kbd> chiude e mantiene il filtro</span>
            <span><kbd>Esc</kbd> annulla</span>
            <span><kbd>↑</kbd>/<kbd>↓</kbd> naviga i file</span>
            <span style="margin-left:auto;" id="impSearchTotal">—</span>
        </div>
        <div id="impSearchSummary" class="imp-search-panel__summary"></div>
    </div>
</div>

<script>
// ── Resizable columns con persistenza in localStorage ────────────
(function () {
    const MIN_W = 50;
    const MAX_W = 800;

    function storageKey(block) {
        return 'imp-cols:' + (block.dataset.batchId || '') + ':' + (block.dataset.fileName || '');
    }

    function setupBlock(block) {
        const table = block.querySelector('.grid-righe table');
        if (!table) return;
        const headers = Array.from(table.tHead.rows[0].cells);
        const key = storageKey(block);

        // colgroup per ancorare le larghezze (più affidabile di width sui th)
        let colgroup = table.querySelector('colgroup');
        if (!colgroup) {
            colgroup = document.createElement('colgroup');
            headers.forEach(() => colgroup.appendChild(document.createElement('col')));
            table.insertBefore(colgroup, table.firstChild);
        }
        const cols = Array.from(colgroup.children);

        // Restore da localStorage
        let saved = {};
        try { saved = JSON.parse(localStorage.getItem(key) || '{}') || {}; } catch (_) {}
        headers.forEach((th, i) => {
            const w = saved[i];
            if (w && Number.isFinite(w)) cols[i].style.width = w + 'px';
        });

        // Crea handle per ogni th (tranne l'ultimo, dove non ha senso un resizer a destra)
        headers.forEach((th, i) => {
            if (i === headers.length - 1) return;
            const handle = document.createElement('span');
            handle.className = 'col-resizer';
            handle.setAttribute('aria-hidden', 'true');
            th.appendChild(handle);

            handle.addEventListener('mousedown', e => startDrag(e, i, th, table, cols, key));
            handle.addEventListener('dblclick', () => {
                // doppio click = autoresize sulla colonna (in base al contenuto visibile)
                const w = autoSize(table, i);
                cols[i].style.width = w + 'px';
                persist(table, cols, key);
            });
        });

        // Bottone reset nel block header
        const resetBtn = block.querySelector('[data-reset-cols]');
        if (resetBtn) {
            resetBtn.addEventListener('click', () => {
                cols.forEach(c => { c.style.width = ''; });
                try { localStorage.removeItem(key); } catch (_) {}
            });
        }
    }

    function startDrag(e, index, th, table, cols, key) {
        e.preventDefault();
        const handle = e.currentTarget;
        const startX = e.clientX;
        const startW = th.getBoundingClientRect().width;
        handle.classList.add('is-dragging');
        table.classList.add('is-resizing');

        function onMove(ev) {
            let w = startW + (ev.clientX - startX);
            w = Math.max(MIN_W, Math.min(MAX_W, w));
            cols[index].style.width = w + 'px';
        }
        function onUp() {
            document.removeEventListener('mousemove', onMove);
            document.removeEventListener('mouseup', onUp);
            handle.classList.remove('is-dragging');
            table.classList.remove('is-resizing');
            persist(table, cols, key);
        }
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
    }

    function persist(table, cols, key) {
        const out = {};
        cols.forEach((c, i) => {
            const w = c.style.width;
            if (w) out[i] = parseFloat(w);
        });
        try { localStorage.setItem(key, JSON.stringify(out)); } catch (_) {}
    }

    function autoSize(table, index) {
        // misura il contenuto: usa un canvas per approssimare la width massima
        const cells = [table.tHead.rows[0].cells[index]]
            .concat(Array.from(table.tBodies[0].rows).map(r => r.cells[index]).filter(Boolean));
        const ctx = document.createElement('canvas').getContext('2d');
        const sample = window.getComputedStyle(cells[0]);
        ctx.font = sample.fontWeight + ' ' + sample.fontSize + ' ' + sample.fontFamily;
        let max = 60;
        cells.forEach(c => {
            const w = ctx.measureText(c.textContent.trim()).width + 28; // padding
            if (w > max) max = w;
        });
        return Math.max(MIN_W, Math.min(MAX_W, Math.round(max)));
    }

    document.querySelectorAll('[data-file-block]').forEach(setupBlock);
})();
</script>

<script>
(function () {
    const fab = document.getElementById('impSearchFab');
    const overlay = document.getElementById('impSearchOverlay');
    const input = document.getElementById('impSearchInput');
    const summary = document.getElementById('impSearchSummary');
    const totalEl = document.getElementById('impSearchTotal');
    const fileBlocks = Array.from(document.querySelectorAll('[data-file-block]'));

    // Pre-cache righe e testo normalizzato per blocco
    const blocks = fileBlocks.map(block => {
        const tbody = block.querySelector('table tbody');
        const rows = tbody ? Array.from(tbody.rows) : [];
        rows.forEach(r => {
            // Ricostruisco textContent originale (senza <mark>) per evitare contaminazione
            r.__origCells = Array.from(r.cells).map(c => c.innerHTML);
            r.__searchText = normalize(r.textContent);
        });
        return {
            el: block,
            name: block.dataset.fileName,
            rows,
            badge: block.querySelector('[data-match-count]'),
        };
    });

    function normalize(s) {
        return (s || '').toString().toLowerCase()
            .normalize('NFD').replace(/[̀-ͯ]/g, '');
    }

    function escapeHtml(s) {
        return s.replace(/[&<>"']/g, ch => ({
            '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        }[ch]));
    }

    function escapeRegex(s) {
        return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function open() {
        overlay.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        setTimeout(() => input.focus(), 30);
    }
    function close() {
        overlay.classList.remove('is-open');
        document.body.style.overflow = '';
    }

    function apply() {
        const raw = input.value.trim();
        const q = normalize(raw);
        const tokens = q.length ? q.split(/\s+/) : [];
        let totalMatches = 0;
        const summaryRows = [];

        const highlightRegex = tokens.length
            ? new RegExp('(' + tokens.map(escapeRegex).join('|') + ')', 'gi')
            : null;

        blocks.forEach(b => {
            let visible = 0;
            b.rows.forEach((r, i) => {
                const match = tokens.length === 0
                    || tokens.every(t => r.__searchText.indexOf(t) !== -1);
                r.style.display = match ? '' : 'none';
                if (match) visible++;

                // Highlight: sostituisco la cella con la versione marcata; se nessuna query, ripristino.
                Array.from(r.cells).forEach((c, ci) => {
                    const orig = r.__origCells[ci] || '';
                    if (!highlightRegex || !match) {
                        c.innerHTML = orig;
                    } else {
                        // Solo dentro nodi di testo: per semplicità ricostruisco da textContent
                        // dei wrapper testuali, lasciando i tag innesto (es. <span>) intatti.
                        c.innerHTML = highlightWithinHtml(orig, highlightRegex);
                    }
                });
            });
            if (b.badge) b.badge.textContent = visible;
            b.el.classList.toggle('is-search-active', tokens.length > 0);
            b.el.classList.toggle('is-search-empty', tokens.length > 0 && visible === 0);
            totalMatches += visible;
            summaryRows.push({ name: b.name, count: visible, el: b.el });
        });

        // Summary panel
        summary.innerHTML = '';
        if (tokens.length === 0) {
            totalEl.textContent = blocks.reduce((a, b) => a + b.rows.length, 0) + ' righe totali';
            summaryRows.forEach(r => {
                const div = document.createElement('div');
                div.className = 'imp-search-panel__row';
                div.innerHTML = `<strong>${escapeHtml(r.name)}</strong><span class="count">${r.el.querySelectorAll('tbody tr').length}</span>`;
                div.addEventListener('click', () => { close(); r.el.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
                summary.appendChild(div);
            });
        } else {
            totalEl.textContent = totalMatches + ' match in ' + summaryRows.filter(r => r.count > 0).length + ' file';
            summaryRows.forEach(r => {
                const div = document.createElement('div');
                div.className = 'imp-search-panel__row' + (r.count === 0 ? ' is-empty' : '');
                div.innerHTML = `<strong>${escapeHtml(r.name)}</strong><span class="count">${r.count}</span>`;
                if (r.count > 0) {
                    div.addEventListener('click', () => { close(); r.el.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
                }
                summary.appendChild(div);
            });
        }
    }

    // Evidenzia i match preservando i tag HTML esistenti nella cella.
    function highlightWithinHtml(html, regex) {
        // Itero sui chunk: preservo tutto ciò che è dentro un tag, applico il regex solo al testo fra i tag.
        return html.replace(/(<[^>]+>)|([^<]+)/g, (m, tag, text) => {
            if (tag) return tag;
            return text.replace(regex, '<mark>$1</mark>');
        });
    }

    fab.addEventListener('click', open);
    overlay.addEventListener('click', e => { if (e.target === overlay) close(); });
    input.addEventListener('input', apply);
    input.addEventListener('keydown', e => {
        if (e.key === 'Escape') { input.value = ''; apply(); close(); }
        else if (e.key === 'Enter') { close(); }
    });
    document.addEventListener('keydown', e => {
        const isCmdK = (e.key === 'k' || e.key === 'K') && (e.metaKey || e.ctrlKey);
        const isSlash = e.key === '/' && !overlay.classList.contains('is-open')
            && !/^(INPUT|TEXTAREA|SELECT)$/.test(document.activeElement?.tagName || '');
        if (isCmdK || isSlash) {
            e.preventDefault();
            overlay.classList.contains('is-open') ? close() : open();
        }
    });

    // Inizializza il pannello con il riepilogo "totale righe per file"
    apply();
})();
</script>
