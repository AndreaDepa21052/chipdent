@model Chipdent.Web.Models.DvrFormViewModel
@{
    var isNew = (bool)(ViewData["IsNew"] ?? false);
    ViewData["Title"] = isNew ? "Nuovo DVR" : "Modifica DVR";
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>@(isNew ? "Nuovo DVR" : "Modifica DVR")</h2>
        <p class="page-head__sub">Documento di Valutazione dei Rischi</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Dvr">← DVR</a>
    </div>
</div>

<div class="card" style="max-width: 720px;">
    <form asp-action="@(isNew ? "CreateDvr" : "EditDvr")" asp-route-id="@(isNew ? null : Model.Id)" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-grid">
            <div class="form-group full">
                <label class="form-label" asp-for="ClinicaId">Clinica</label>
                <select class="form-control" asp-for="ClinicaId" required>
                    <option value="">— seleziona —</option>
                    @foreach (var c in Model.Cliniche)
                    {
                        <option value="@c.Id" selected="@(c.Id == Model.ClinicaId)">@c.Nome</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Versione">Versione</label>
                <input class="form-control" asp-for="Versione" required />
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Stato">Stato</label>
                <select class="form-control" asp-for="Stato" asp-items="Html.GetEnumSelectList<Chipdent.Web.Domain.Entities.StatoDVR>()"></select>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="DataApprovazione">Data approvazione</label>
                <input class="form-control" asp-for="DataApprovazione" type="date" required />
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="ProssimaRevisione">Prossima revisione</label>
                <input class="form-control" asp-for="ProssimaRevisione" type="date" />
            </div>
            <div class="form-group full">
                <label class="form-label" asp-for="Note">Note</label>
                <textarea class="form-control" asp-for="Note"></textarea>
            </div>
        </div>

        <div class="form-actions">
            <a class="btn btn--ghost" asp-action="Dvr">Annulla</a>
            <button type="submit" class="btn btn--primary">@(isNew ? "Crea DVR" : "Salva")</button>
        </div>
    </form>
</div>

@if (!isNew)
{
    <form asp-action="DeleteDvr" asp-route-id="@Model.Id" method="post" style="margin-top: var(--s-5); max-width:720px; text-align:right;"
          onsubmit="return confirm('Eliminare questo DVR?');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn--ghost" style="border-color: rgba(217, 107, 94, 0.4); color: var(--c-danger);">Elimina DVR</button>
    </form>
}
