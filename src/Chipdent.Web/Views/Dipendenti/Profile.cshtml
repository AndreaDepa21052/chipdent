            <dialog id="dlg-step" style="border:0; border-radius: 12px; padding: 0; max-width: 480px; box-shadow: 0 20px 60px rgba(0,0,0,0.18);">
                <form id="frm-step" method="post" enctype="multipart/form-data" style="padding: var(--s-4);">
                    @Html.AntiForgeryToken()
                    <h3 style="margin: 0 0 var(--s-3);" id="dlg-step-title">Registra step</h3>
                    <input type="hidden" name="step" id="dlg-step-num" />
                    <div class="form-grid">
