@model Chipdent.Web.Models.PermissionsMatrixViewModel
@{
    ViewData["Title"] = "Matrice permessi";
    ViewData["Crumb"] = "Utenti";

    string RoleClass(UserRole r) => r switch
    {
        UserRole.Owner      => "role-badge--owner",
        UserRole.Management => "role-badge--admin",
        UserRole.Direttore  => "role-badge--manager",
        UserRole.Backoffice => "role-badge--hr",
        _ => ""
    };
    string RoleLabel(UserRole r) => r switch
    {
        UserRole.Direttore => "Direttore",
        _ => r.ToString()
    };
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>Matrice permessi</h2>
        <p class="page-head__sub">Cosa può fare ciascun ruolo all'interno del workspace.</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Utenti</a>
    </div>
</div>

<div class="card">
    <div class="table-wrap" style="border:0; box-shadow:none; background:transparent;">
        <table class="table perm-matrix">
            <thead>
                <tr>
                    <th style="width: 30%;">Modulo</th>
                    <th style="width: 22%;">Azione</th>
                    @foreach (var r in Model.Roles)
                    {
                        <th style="text-align:center;"><span class="role-badge @RoleClass(r)">@RoleLabel(r)</span></th>
                    }
                </tr>
            </thead>
            <tbody>
                @{ string? lastModule = null; }
                @foreach (var row in Model.Rows)
                {
                    var newGroup = row.Modulo != lastModule;
                    lastModule = row.Modulo;
                    <tr class="@(newGroup ? "perm-matrix__group" : "")">
                        <td>@(newGroup ? row.Modulo : "")</td>
                        <td class="muted">@row.Azione</td>
                        @foreach (var r in Model.Roles)
                        {
                            var allowed = row.Allowed.TryGetValue(r, out var v) && v;
                            <td style="text-align:center;">
                                @if (allowed)
                                {
                                    <span class="perm-yes" title="consentito">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                                    </span>
                                }
                                else
                                {
                                    <span class="perm-no" title="non consentito">—</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="grid grid--stats" style="margin-top: var(--s-6);">
    <div class="stat">
        <div class="stat__label">Owner</div>
        <div class="stat__value" style="font-size: 1rem; color: var(--c-ink); margin-top: var(--s-2);">Ruolo tecnico · garante del workspace (last-owner-guard)</div>
    </div>
    <div class="stat">
        <div class="stat__label">Management</div>
        <div class="stat__value" style="font-size: 1rem; color: var(--c-ink); margin-top: var(--s-2);">Vista direzionale · tutta la catena · gestione utenti</div>
    </div>
    <div class="stat">
        <div class="stat__label">Direttore di sede</div>
        <div class="stat__value" style="font-size: 1rem; color: var(--c-ink); margin-top: var(--s-2);">Operatività della propria sede · turni · approvazioni</div>
    </div>
    <div class="stat">
        <div class="stat__label">Backoffice</div>
        <div class="stat__value" style="font-size: 1rem; color: var(--c-ink); margin-top: var(--s-2);">Anagrafiche cross-sede · RLS · documentazione</div>
    </div>
    <div class="stat">
        <div class="stat__label">Staff</div>
        <div class="stat__value" style="font-size: 1rem; color: var(--c-ink); margin-top: var(--s-2);">App personale · turni propri · comunicazioni</div>
    </div>
</div>
