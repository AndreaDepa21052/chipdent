@model Chipdent.Web.Domain.Entities.Clinica
@{
    var isNew = (bool)(ViewData["IsNew"] ?? false);
    ViewData["Title"] = isNew ? "Nuova clinica" : "Modifica clinica";
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>@(isNew ? "Nuova clinica" : Model.Nome)</h2>
        <p class="page-head__sub">@(isNew ? "Aggiungi una nuova sede alla catena." : "Aggiorna i dati della sede.")</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Torna all'elenco</a>
    </div>
</div>

<div class="card">
    <form asp-action="@(isNew ? "Create" : "Edit")" asp-route-id="@(isNew ? null : Model.Id)" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-grid">
            <div class="form-group full">
                <label class="form-label" asp-for="Nome">Nome clinica</label>
                <input class="form-control" asp-for="Nome" required placeholder="Es. Confident Bologna" />
                <span class="text-danger" asp-validation-for="Nome"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Citta">Città</label>
                <input class="form-control" asp-for="Citta" required />
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Indirizzo">Indirizzo</label>
                <input class="form-control" asp-for="Indirizzo" required />
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Telefono">Telefono</label>
                <input class="form-control" asp-for="Telefono" placeholder="+39 …" />
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Email">Email</label>
                <input class="form-control" asp-for="Email" type="email" />
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="NumeroRiuniti">Numero riuniti</label>
                <input class="form-control" asp-for="NumeroRiuniti" type="number" min="0" />
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="OrganicoTarget">Organico target (n. dipendenti)</label>
                <input class="form-control" asp-for="OrganicoTarget" type="number" min="0" placeholder="Es. 8" />
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Stato">Stato</label>
                <select class="form-control" asp-for="Stato" asp-items="Html.GetEnumSelectList<Chipdent.Web.Domain.Entities.ClinicaStato>()"></select>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Latitudine">Latitudine</label>
                <input class="form-control" asp-for="Latitudine" type="number" step="any" placeholder="Es. 45.4654" id="lat-input" />
                <span class="text-danger" asp-validation-for="Latitudine"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Longitudine">Longitudine</label>
                <input class="form-control" asp-for="Longitudine" type="number" step="any" placeholder="Es. 9.1859" id="lng-input" />
                <span class="text-danger" asp-validation-for="Longitudine"></span>
            </div>

            <div class="form-group full">
                <button type="button" class="btn btn--ghost" id="geocode-btn" style="font-size: .82rem;">
                    📍 Cerca coordinate dall'indirizzo
                </button>
                <span id="geocode-status" style="margin-left: 8px; font-size: .8rem; color: var(--c-ink-soft);"></span>
            </div>
        </div>

        <div class="form-actions">
            <a class="btn btn--ghost" asp-action="Index">Annulla</a>
            <button type="submit" class="btn btn--primary">@(isNew ? "Crea clinica" : "Salva modifiche")</button>
        </div>
    </form>
</div>

@if (!isNew)
{
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="margin-top: var(--s-5); text-align:right;"
          onsubmit="return confirm('Eliminare definitivamente questa clinica?');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn--ghost" style="border-color: rgba(217, 107, 94, 0.4); color: var(--c-danger);">
            Elimina clinica
        </button>
    </form>
}

@section Scripts {
<script>
    (function () {
        var btn = document.getElementById('geocode-btn');
        var status = document.getElementById('geocode-status');
        var indirizzo = document.querySelector('[name="Indirizzo"]');
        var citta = document.querySelector('[name="Citta"]');
        var lat = document.getElementById('lat-input');
        var lng = document.getElementById('lng-input');

        btn.addEventListener('click', function () {
            var query = [indirizzo.value, citta.value].filter(Boolean).join(', ');
            if (!query) { status.textContent = 'Compila prima Indirizzo e Città.'; return; }
            status.textContent = 'Ricerca in corso…';
            // Nominatim — gratuito, no API key. Limite ~1 req/sec.
            fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(query), {
                headers: { 'Accept': 'application/json' }
            })
            .then(function (r) { return r.json(); })
            .then(function (results) {
                if (!results || !results.length) { status.textContent = 'Nessun risultato.'; return; }
                lat.value = parseFloat(results[0].lat).toFixed(6);
                lng.value = parseFloat(results[0].lon).toFixed(6);
                status.textContent = '✓ Coordinate trovate.';
            })
            .catch(function () { status.textContent = 'Errore di rete.'; });
        });
    })();
</script>
}
