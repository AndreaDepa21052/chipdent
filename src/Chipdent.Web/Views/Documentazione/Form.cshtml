@model Chipdent.Web.Models.DocumentoFormViewModel
@{
    var isNew = (bool)(ViewData["IsNew"] ?? false);
    ViewData["Title"] = isNew ? "Nuovo documento" : Model.Titolo;
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>@(isNew ? "Nuovo documento" : "Modifica documento")</h2>
        <p class="page-head__sub">Documenti normativi e contrattuali della sede.</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Documentazione</a>
    </div>
</div>

<div class="card" style="max-width: 760px;">
    <form asp-action="@(isNew ? "Create" : "Edit")" asp-route-id="@(isNew ? null : Model.Id)" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label" asp-for="ClinicaId">Clinica</label>
                <select class="form-control" asp-for="ClinicaId" required>
                    <option value="">— seleziona —</option>
                    @foreach (var c in Model.Cliniche)
                    {
                        <option value="@c.Id" selected="@(c.Id == Model.ClinicaId)">@c.Nome</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Tipo">Tipo</label>
                <select class="form-control" asp-for="Tipo" asp-items="Html.GetEnumSelectList<Chipdent.Web.Domain.Entities.TipoDocumento>()"></select>
            </div>
            <div class="form-group full">
                <label class="form-label" asp-for="Titolo">Titolo</label>
                <input class="form-control" asp-for="Titolo" required placeholder="Es. Autorizzazione sanitaria 2024" />
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Numero">Numero / protocollo</label>
                <input class="form-control" asp-for="Numero" />
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="EnteEmittente">Ente emittente</label>
                <input class="form-control" asp-for="EnteEmittente" placeholder="Es. ATS Milano" />
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="DataEmissione">Data emissione</label>
                <input class="form-control" asp-for="DataEmissione" type="date" />
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="DataScadenza">Data scadenza</label>
                <input class="form-control" asp-for="DataScadenza" type="date" />
            </div>
            <div class="form-group full">
                <label class="form-label" asp-for="Note">Note</label>
                <textarea class="form-control" asp-for="Note"></textarea>
            </div>
        </div>

        <div class="form-actions">
            <a class="btn btn--ghost" asp-action="Index">Annulla</a>
            <button type="submit" class="btn btn--primary">@(isNew ? "Crea documento" : "Salva")</button>
        </div>
    </form>
</div>

@if (!isNew)
{
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="margin-top: var(--s-5); max-width:760px; text-align:right;"
          onsubmit="return confirm('Eliminare questo documento?');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn--ghost" style="border-color: rgba(217, 107, 94, 0.4); color: var(--c-danger);">Elimina documento</button>
    </form>
}
