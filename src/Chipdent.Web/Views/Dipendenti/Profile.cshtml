@model Chipdent.Web.Models.DipendenteProfileViewModel
@using Chipdent.Web.Models
@using Chipdent.Web.Domain.Entities
@{
    ViewData["Title"] = Model.Dipendente.NomeCompleto;
    ViewData["Crumb"] = "Dipendenti";
    var d = Model.Dipendente;
    var tab = Model.Tab;
    var ferieBasse = d.GiorniFerieResidui <= 5;
    var oggi = DateTime.UtcNow.Date;
    var clinicheLookup = Model.Cliniche.ToDictionary(c => c.Id, c => c.Nome);

    // Pre-calcolo flag scadenze per badge
    bool ScadeEntro(DateTime? data, int giorni) =>
        data.HasValue && data.Value.Date <= oggi.AddDays(giorni) && data.Value.Date >= oggi;
    bool Scaduto(DateTime? data) => data.HasValue && data.Value.Date < oggi;
}

@functions {
    static ComplianceStato StatoDa(DateTime? data, int giorniSoglia)
    {
        if (data is null) return ComplianceStato.NonRegistrato;
        var oggi = DateTime.UtcNow.Date;
        if (data.Value.Date < oggi) return ComplianceStato.Scaduto;
        if (data.Value.Date <= oggi.AddDays(giorniSoglia)) return ComplianceStato.InScadenza;
        return ComplianceStato.InRegola;
    }
}

<partial name="_Flash" />

<div class="profile">
    <div class="profile__header">
        <div class="profile__avatar">@d.Iniziali</div>
        <div class="profile__head-text">
            <h2>@d.NomeCompleto</h2>
            <div class="profile__sub">
                <span>@d.Ruolo</span>
                @if (!string.IsNullOrWhiteSpace(d.MansioneSpecifica))
                {
                    <span>·</span><span>@d.MansioneSpecifica</span>
                }
                <span>·</span><span>@d.TipoContratto</span>
                @if (Model.ClinicaCorrenteNome is not null)
                {
                    <span>·</span><span>📍 @Model.ClinicaCorrenteNome</span>
                }
                @{
                    var distaccoCorrente = Model.Distacchi.FirstOrDefault(x => x.IsInCorso);
                }
                @if (distaccoCorrente is not null)
                {
                    var nomeDist = clinicheLookup.GetValueOrDefault(distaccoCorrente.ClinicaDistaccoId, "—");
                    <span>·</span><span>↗ Distaccato a @nomeDist</span>
                }
            </div>
            <div class="profile__chips">
                @switch (d.Stato)
                {
                    case StatoDipendente.Attivo:
                        <span class="badge badge--success"><span class="dot"></span>attivo</span>
                        break;
                    case StatoDipendente.Onboarding:
                        <span class="badge badge--info"><span class="dot"></span>onboarding</span>
                        break;
                    case StatoDipendente.Cessato:
                        <span class="badge badge--danger"><span class="dot"></span>cessato</span>
                        @if (d.DataDimissioni is not null)
                        {
                            <span class="badge">dimissione @d.DataDimissioni.Value.ToString("dd/MM/yyyy")</span>
                        }
                        break;
                    default:
                        <span class="badge badge--warning"><span class="dot"></span>@d.Stato</span>
                        break;
                }
                @if (d.AnniServizio is not null)
                {
                    <span class="badge">@d.AnniServizio @(d.AnniServizio == 1 ? "anno" : "anni") · dal @d.DataAssunzione.ToString("MM/yyyy")</span>
                }
                @if (ferieBasse && !d.IsCessato)
                {
                    <span class="badge badge--warning"><span class="dot"></span>ferie residue: @d.GiorniFerieResidui gg</span>
                }
                @if (Scaduto(d.ScadenzaCartaIdentita))
                {
                    <span class="badge badge--danger"><span class="dot"></span>C.I. scaduta</span>
                }
                else if (ScadeEntro(d.ScadenzaCartaIdentita, 60))
                {
                    <span class="badge badge--warning"><span class="dot"></span>C.I. in scadenza</span>
                }
                @if (Scaduto(d.ScadenzaPermessoSoggiorno))
                {
                    <span class="badge badge--danger"><span class="dot"></span>permesso soggiorno scaduto</span>
                }
                else if (ScadeEntro(d.ScadenzaPermessoSoggiorno, 90))
                {
                    <span class="badge badge--warning"><span class="dot"></span>permesso soggiorno in scadenza</span>
                }
                @if (d.InizioMaternita is not null && d.ScadenzaDocumentiMaternita is not null && d.ScadenzaDocumentiMaternita.Value > oggi)
                {
                    <span class="badge badge--info"><span class="dot"></span>maternità in corso</span>
                }
            </div>
        </div>
        <div class="profile__actions">
            <a class="btn btn--ghost" asp-action="Index">← Lista</a>
            @if (!d.IsCessato)
            {
                <a class="btn btn--ghost" asp-action="Transfer" asp-route-id="@d.Id">↗ Trasferisci</a>
                <a class="btn btn--ghost" asp-action="Dismiss" asp-route-id="@d.Id" style="border-color: rgba(196, 88, 75, 0.4); color: var(--c-danger);">Dimetti</a>
            }
            else
            {
                <form asp-action="Reactivate" asp-route-id="@d.Id" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn--ghost">↺ Riattiva</button>
                </form>
            }
            <a class="btn btn--primary" asp-action="Edit" asp-route-id="@d.Id">Modifica</a>
        </div>
    </div>

    <div class="tabs">
        <a class="tab @(tab == "anagrafica" ? "is-active" : "")" asp-action="Details" asp-route-id="@d.Id" asp-route-tab="anagrafica">Anagrafica</a>
        <a class="tab @(tab == "compliance" ? "is-active" : "")" asp-action="Details" asp-route-id="@d.Id" asp-route-tab="compliance">
            Compliance &amp; checklist
        </a>
        <a class="tab @(tab == "distacchi" ? "is-active" : "")" asp-action="Details" asp-route-id="@d.Id" asp-route-tab="distacchi">
            Distacchi <span class="tab__count">@Model.Distacchi.Count</span>
        </a>
        <a class="tab @(tab == "storico" ? "is-active" : "")" asp-action="Details" asp-route-id="@d.Id" asp-route-tab="storico">
            Storico cliniche <span class="tab__count">@Model.Storico.Count</span>
        </a>
        <a class="tab @(tab == "audit" ? "is-active" : "")" asp-action="Details" asp-route-id="@d.Id" asp-route-tab="audit">
            Audit log <span class="tab__count">@Model.Audit.Count</span>
        </a>
    </div>

    @if (tab == "anagrafica")
    {
        <div class="profile__grid">
            <div class="card">
                <div class="card__header"><h3 class="card__title">Identità</h3></div>
                <dl class="kv">
                    <dt>Nome</dt><dd>@d.Nome @d.Cognome</dd>
                    <dt>Sesso</dt><dd>@(d.Sesso?.ToString() ?? "—")</dd>
                    <dt>Nato il</dt><dd>@(d.DataNascita?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    <dt>Luogo</dt><dd>@(d.LuogoNascita ?? "—")</dd>
                    <dt>Nazionalità</dt><dd>@(d.Nazionalita ?? "—")</dd>
                    <dt>Codice fiscale</dt><dd>@(d.CodiceFiscale ?? "—")</dd>
                </dl>
            </div>

            <div class="card">
                <div class="card__header"><h3 class="card__title">Contatti &amp; residenza</h3></div>
                <dl class="kv">
                    <dt>Email lavoro</dt><dd>@d.Email</dd>
                    <dt>Email personale</dt><dd>@(d.EmailPersonale ?? "—")</dd>
                    <dt>Telefono</dt><dd>@(d.Telefono ?? "—")</dd>
                    <dt>Cellulare</dt><dd>@(d.Cellulare ?? "—")</dd>
                    <dt>Indirizzo</dt><dd>@(d.IndirizzoResidenza ?? "—")</dd>
                    <dt>Città</dt><dd>@(d.CittaResidenza ?? "—") @(string.IsNullOrEmpty(d.CapResidenza) ? "" : "(" + d.CapResidenza + ")")</dd>
                </dl>
            </div>

            <div class="card">
                <div class="card__header"><h3 class="card__title">Ruolo</h3></div>
                <dl class="kv">
                    <dt>Ruolo</dt><dd>@d.Ruolo</dd>
                    <dt>Mansione</dt><dd>@(d.MansioneSpecifica ?? "—")</dd>
                    <dt>Reparto</dt><dd>@(d.Reparto ?? "—")</dd>
                    <dt>Manager</dt><dd>@(Model.ManagerNome ?? "—")</dd>
                    <dt>Titolo studio</dt><dd>@(d.TitoloStudio ?? "—") @(d.AutocertificazioneTitolo ? "(autocert.)" : "")</dd>
                </dl>
            </div>

            <div class="card">
                <div class="card__header"><h3 class="card__title">Contratto &amp; CCNL</h3></div>
                <dl class="kv">
                    <dt>Tipo</dt><dd>@d.TipoContratto · @d.Ccnl</dd>
                    <dt>Livello</dt><dd>@(d.LivelloContratto ?? "—") @(d.MeseAnnoCcnl is null ? "" : "(rif. " + d.MeseAnnoCcnl + ")")</dd>
                    <dt>Sede</dt><dd>@(Model.ClinicaCorrenteNome ?? "—")</dd>
                    <dt>Primo rapporto</dt><dd>@(d.DataPrimoRapporto?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    <dt>Inizio rapp. corrente</dt><dd>@d.DataAssunzione.ToString("dd/MM/yyyy") @(d.MesiRapportoCorrente is null ? "" : "(" + d.MesiRapportoCorrente + " mesi)")</dd>
                    <dt>Fine periodo prova</dt><dd>@(d.DataFinePeriodoProva?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    <dt>Scad. contratto</dt><dd>@(d.DataScadenzaContratto?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    <dt>Scad. proroga</dt><dd>@(d.DataScadenzaProroga?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    <dt>Trasformazione</dt><dd>@(d.DataTrasformazioneContratto?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    <dt>Aumento livello</dt><dd>@(d.DataAumentoLivelli?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    <dt>Monte ore</dt><dd>@(d.MonteOreSettimanale is null ? "—" : d.MonteOreSettimanale + "h/settimana")</dd>
                    <dt>Ticket</dt><dd>@(d.BeneficioTicket ? "✓ sì" : "—")</dd>
                    <dt>Ex tirocinante</dt><dd>@(d.ExTirocinante ? "✓ sì" : "—")</dd>
                    <dt>Dimesso il</dt><dd>@(d.DataDimissioni?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    @if (d.MotivoDimissioni is not null)
                    {
                        <dt>Motivo</dt><dd>@d.MotivoDimissioni</dd>
                    }
                    <dt>IBAN</dt><dd style="font-family: monospace;">@(d.IBAN ?? "—")</dd>
                </dl>
            </div>

            <div class="card">
                <div class="card__header"><h3 class="card__title">Documenti &amp; scadenze</h3></div>
                <dl class="kv">
                    <dt>N. documento</dt><dd>@(d.DocumentoNumero ?? "—")</dd>
                    <dt>Scad. C.I.</dt><dd>@(d.ScadenzaCartaIdentita?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    <dt>Scad. tessera sanitaria</dt><dd>@(d.ScadenzaTesseraSanitaria?.ToString("dd/MM/yyyy") ?? "—")</dd>
                    <dt>Scad. permesso soggiorno</dt><dd>@(d.ScadenzaPermessoSoggiorno?.ToString("dd/MM/yyyy") ?? "—")</dd>
                </dl>
            </div>

            @if (d.InizioMaternita is not null || !string.IsNullOrWhiteSpace(d.NoteInfortunio))
            {
                <div class="card">
                    <div class="card__header"><h3 class="card__title">Maternità &amp; eventi</h3></div>
                    <dl class="kv">
                        <dt>Inizio maternità</dt><dd>@(d.InizioMaternita?.ToString("dd/MM/yyyy") ?? "—")</dd>
                        <dt>Scad. doc. maternità</dt><dd>@(d.ScadenzaDocumentiMaternita?.ToString("dd/MM/yyyy") ?? "—")</dd>
                        @if (!string.IsNullOrWhiteSpace(d.NoteInfortunio))
                        {
                            <dt>Note infortuni</dt><dd style="white-space: pre-wrap;">@d.NoteInfortunio</dd>
                        }
                    </dl>
                </div>
            }

            <div class="card">
                <div class="card__header"><h3 class="card__title">Ferie</h3></div>
                <div class="stat" style="border:0; padding:0; box-shadow:none; background:transparent;">
                    <div class="stat__label">Giorni residui</div>
                    <div class="stat__value">@d.GiorniFerieResidui</div>
                    <div class="stat__hint">su 26 totali annui</div>
                </div>
            </div>

            @if (d.IsCessato && (d.RiconsegnaMaterialeStudio || d.RiconsegnaMaterialeSede))
            {
                <div class="card">
                    <div class="card__header"><h3 class="card__title">Riconsegne</h3></div>
                    <dl class="kv">
                        <dt>Studio</dt><dd>@(d.RiconsegnaMaterialeStudio ? "✓ effettuata" : "✕ pendente")</dd>
                        <dt>Sede</dt><dd>@(d.RiconsegnaMaterialeSede ? "✓ effettuata" : "✕ pendente")</dd>
                    </dl>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(d.Note))
            {
                <div class="card" style="grid-column: 1 / -1;">
                    <div class="card__header"><h3 class="card__title">Note</h3></div>
                    <p style="white-space: pre-wrap; margin:0;">@d.Note</p>
                </div>
            }
        </div>
    }
    else if (tab == "compliance")
    {
        // ── Costruzione checklist ─────────────────────────────────
        var ultimaVisita = Model.VisiteMediche.OrderByDescending(v => v.Data).FirstOrDefault();
        Corso? Ultimo(TipoCorso t) => Model.Corsi
            .Where(c => c.Tipo == t).OrderByDescending(c => c.DataConseguimento).FirstOrDefault();

        // Riga della checklist: o una visita medica, o un corso di tipo specifico
        var righe = new List<(string Label, DateTime? DataUltima, DateTime? Scadenza, ComplianceStato Stato, string Bordo, string? Riferimento, string AzioneTipo, TipoCorso? TipoCorso, int MesiPeriodicita)>();

        var visitaPeriodicita = VisitaMedica.PeriodicitaDefault(d.Ruolo);
        var visitaScadCalc = ultimaVisita?.ScadenzaIdoneita ?? (ultimaVisita is null ? (DateTime?)null : ultimaVisita.Data.AddMonths(visitaPeriodicita));
        var visitaStato = StatoDa(visitaScadCalc, 90);
        var visitaBordo = visitaStato switch
        {
            ComplianceStato.InRegola => "#1f6e3a",
            ComplianceStato.InScadenza => "#a86010",
            ComplianceStato.Scaduto => "#a83a3a",
            _ => "#aaa"
        };
        righe.Add(($"🩺 Visita medica idoneità ({(visitaPeriodicita == 12 ? "1 anno" : visitaPeriodicita + " mesi")})",
            ultimaVisita?.Data, visitaScadCalc, visitaStato, visitaBordo, ultimaVisita?.Esito.ToString(), "visita", null, visitaPeriodicita));

        var requisiti = new (TipoCorso Tipo, string Label, int SuggMesi)[]
        {
            (TipoCorso.FormazioneGeneraleSicurezza,         "📚 Formazione generale sicurezza (4h, una tantum)", 0),
            (TipoCorso.FormazioneSpecificaRischioBasso,     "📘 Formazione specifica rischio basso (5 anni)", 60),
            (TipoCorso.FormazioneSpecificaRischioAltoASO,   "📕 Formazione specifica rischio alto ASO (5 anni)", 60),
            (TipoCorso.AggiornamentoASO10H,                 "🔁 Aggiornamento ASO 10H (annuale)", 12),
            (TipoCorso.Radioprotezione,                     "☢️ Radioprotezione (5 anni)", 60),
            (TipoCorso.Antincendio,                         "🔥 Antincendio (5 anni)", 60),
            (TipoCorso.RLS,                                 "🛡 RLS (annuale)", 12)
        };
        foreach (var r in requisiti)
        {
            var ult = Ultimo(r.Tipo);
            var stato = StatoDa(ult?.Scadenza, 60);
            var bordo = stato switch
            {
                ComplianceStato.InRegola => "#1f6e3a",
                ComplianceStato.InScadenza => "#a86010",
                ComplianceStato.Scaduto => "#a83a3a",
                _ => "#aaa"
            };
            var rif = r.Tipo == TipoCorso.RLS ? ult?.VerbaleNomina : null;
            righe.Add((r.Label, ult?.DataConseguimento, ult?.Scadenza, stato, bordo, rif, "corso", r.Tipo, r.SuggMesi));
        }

        var inRegola = righe.Count(x => x.Stato == ComplianceStato.InRegola);
        var inScadenza = righe.Count(x => x.Stato == ComplianceStato.InScadenza);
        var scaduti = righe.Count(x => x.Stato == ComplianceStato.Scaduto);
        var mancanti = righe.Count(x => x.Stato == ComplianceStato.NonRegistrato);

        <div class="grid grid--stats" style="margin-bottom: var(--s-4);">
            <div class="stat">
                <div class="stat__label">✅ In regola</div>
                <div class="stat__value" style="color:#1f6e3a;">@inRegola</div>
            </div>
            <div class="stat">
                <div class="stat__label">🟡 In scadenza</div>
                <div class="stat__value" style="color:#a86010;">@inScadenza</div>
            </div>
            <div class="stat">
                <div class="stat__label">🔴 Scaduti</div>
                <div class="stat__value" style="color:#a83a3a;">@scaduti</div>
            </div>
            <div class="stat">
                <div class="stat__label">⬜ Mancanti</div>
                <div class="stat__value">@mancanti</div>
            </div>
        </div>

        <div class="card" style="padding: 0; max-width: 980px;">
            <div class="card__header" style="padding: var(--s-3);">
                <h3 class="card__title">Checklist compliance</h3>
                <span class="muted" style="font-size:.85rem;">Clicca su una riga per registrare un nuovo conseguimento</span>
            </div>
            <ul class="list" style="margin: 0;">
                @foreach (var riga in righe)
                {
                    var azioneLabel = riga.Stato == ComplianceStato.NonRegistrato ? "＋ Registra" : "＋ Aggiorna";
                    var dataAttrs = riga.AzioneTipo == "visita"
                        ? $"data-tipo=\"visita\" data-mesi=\"{riga.MesiPeriodicita}\""
                        : $"data-tipo=\"corso\" data-corso=\"{riga.TipoCorso}\" data-label=\"{riga.Label}\" data-mesi=\"{riga.MesiPeriodicita}\"";
                    <li class="list__item" style="padding: var(--s-3) var(--s-4); border-left: 3px solid @riga.Bordo; gap: var(--s-3); align-items:center;">
                        <div class="list__icon" style="font-size: 1.05rem; background: transparent; border: 0; width: 28px; height: 28px;">
                            @(riga.Stato switch {
                                ComplianceStato.InRegola => "✅",
                                ComplianceStato.InScadenza => "🟡",
                                ComplianceStato.Scaduto => "🔴",
                                _ => "⬜"
                            })
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <div class="list__title" style="line-height: 1.2;">@riga.Label</div>
                            <div class="muted" style="font-size:.78rem; margin-top: 2px;">
                                @if (riga.DataUltima.HasValue)
                                {
                                    <text>Ultima: @riga.DataUltima.Value.ToString("dd/MM/yyyy")</text>
                                }
                                else
                                {
                                    <text>Nessuna registrazione</text>
                                }
                                @if (!string.IsNullOrWhiteSpace(riga.Riferimento))
                                {
                                    <text> · @riga.Riferimento</text>
                                }
                            </div>
                        </div>
                        <div style="text-align: right; flex-shrink: 0; min-width: 110px;">
                            @if (riga.Scadenza.HasValue)
                            {
                                <strong style="color: @riga.Bordo; display:block;">scade @riga.Scadenza.Value.ToString("dd/MM/yy")</strong>
                            }
                            else if (riga.Stato == ComplianceStato.NonRegistrato)
                            {
                                <span class="muted" style="display:block;">da registrare</span>
                            }
                            else
                            {
                                <span class="muted" style="display:block;">no scadenza</span>
                            }
                        </div>
                        <button type="button" class="btn btn--ghost btn--sm" data-checklist-add @Html.Raw(dataAttrs) title="@azioneLabel">@azioneLabel</button>
                    </li>
                }
            </ul>
        </div>

        <!-- Dialog: registra visita medica -->
        <dialog id="dlg-visita" style="border:0; border-radius: 12px; padding: 0; max-width: 480px; box-shadow: 0 20px 60px rgba(0,0,0,0.18);">
            <form asp-action="RegistraVisitaMedica" asp-route-id="@d.Id" method="post" enctype="multipart/form-data" style="padding: var(--s-4);">
                @Html.AntiForgeryToken()
                <h3 style="margin: 0 0 var(--s-3);">🩺 Registra visita medica</h3>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Data visita *</label>
                        <input class="form-control" type="date" name="data" required value="@oggi.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Esito *</label>
                        <select class="form-control" name="esito" required>
                            @foreach (var e in Enum.GetValues<EsitoVisita>())
                            {
                                <option value="@e">@e</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Periodicità (mesi)</label>
                        <input class="form-control" type="number" min="1" max="120" name="mesiPeriodicita" id="dlg-visita-mesi" />
                        <span class="muted" style="font-size:.78rem;">Default: @VisitaMedica.PeriodicitaDefault(d.Ruolo) mesi (per @d.Ruolo)</span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Scadenza idoneità (opzionale)</label>
                        <input class="form-control" type="date" name="scadenza" />
                        <span class="muted" style="font-size:.78rem;">Se vuota: data + periodicità</span>
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Allegato (PDF/JPG/PNG, max 10MB)</label>
                        <input class="form-control" type="file" name="allegato" accept=".pdf,.png,.jpg,.jpeg" />
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Note</label>
                        <textarea class="form-control" name="note" rows="2"></textarea>
                    </div>
                </div>
                <div style="display:flex; gap:8px; justify-content:flex-end; margin-top: var(--s-3);">
                    <button type="button" class="btn btn--ghost" data-close-dlg>Annulla</button>
                    <button type="submit" class="btn btn--primary">Salva visita</button>
                </div>
            </form>
        </dialog>

        <!-- Dialog: registra corso -->
        <dialog id="dlg-corso" style="border:0; border-radius: 12px; padding: 0; max-width: 480px; box-shadow: 0 20px 60px rgba(0,0,0,0.18);">
            <form asp-action="RegistraCorso" asp-route-id="@d.Id" method="post" enctype="multipart/form-data" style="padding: var(--s-4);">
                @Html.AntiForgeryToken()
                <h3 style="margin: 0 0 var(--s-3);">📚 Registra corso</h3>
                <p class="muted" id="dlg-corso-label" style="margin-top: -8px; margin-bottom: var(--s-3); font-size:.85rem;"></p>
                <input type="hidden" name="tipo" id="dlg-corso-tipo" />
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Data conseguimento *</label>
                        <input class="form-control" type="date" name="dataConseguimento" id="dlg-corso-data" required value="@oggi.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Scadenza</label>
                        <input class="form-control" type="date" name="scadenza" id="dlg-corso-scadenza" />
                        <span class="muted" style="font-size:.78rem;" id="dlg-corso-scad-hint"></span>
                    </div>
                    <div class="form-group full" id="dlg-corso-verbale-wrap" style="display:none;">
                        <label class="form-label">Verbale di nomina (RLS)</label>
                        <input class="form-control" type="text" name="verbaleNomina" placeholder="es. Verbale 2025/04 del 12/03/2025" />
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Attestato (PDF/JPG/PNG, max 10MB)</label>
                        <input class="form-control" type="file" name="allegato" accept=".pdf,.png,.jpg,.jpeg" />
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Note</label>
                        <textarea class="form-control" name="note" rows="2"></textarea>
                    </div>
                </div>
                <div style="display:flex; gap:8px; justify-content:flex-end; margin-top: var(--s-3);">
                    <button type="button" class="btn btn--ghost" data-close-dlg>Annulla</button>
                    <button type="submit" class="btn btn--primary">Salva corso</button>
                </div>
            </form>
        </dialog>

        @section Scripts {
        <script>
            (function () {
                var dlgV = document.getElementById('dlg-visita');
                var dlgC = document.getElementById('dlg-corso');
                var dlgVMesi = document.getElementById('dlg-visita-mesi');
                var dlgCTipo = document.getElementById('dlg-corso-tipo');
                var dlgCLabel = document.getElementById('dlg-corso-label');
                var dlgCData = document.getElementById('dlg-corso-data');
                var dlgCScad = document.getElementById('dlg-corso-scadenza');
                var dlgCScadHint = document.getElementById('dlg-corso-scad-hint');
                var dlgCVerbaleWrap = document.getElementById('dlg-corso-verbale-wrap');

                function autoScadenza(mesi) {
                    if (!mesi || mesi <= 0) { dlgCScad.value = ''; dlgCScadHint.textContent = 'Una tantum: nessuna scadenza'; return; }
                    var d = new Date(dlgCData.value || Date.now());
                    d.setMonth(d.getMonth() + parseInt(mesi, 10));
                    dlgCScad.value = d.toISOString().slice(0, 10);
                    dlgCScadHint.textContent = '+' + mesi + ' mesi dalla data di conseguimento (modificabile)';
                }
                dlgCData.addEventListener('change', function () {
                    var m = parseInt(dlgCScadHint.dataset.mesi || '0', 10);
                    if (m > 0) autoScadenza(m);
                });

                document.querySelectorAll('[data-checklist-add]').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        var tipo = btn.dataset.tipo;
                        if (tipo === 'visita') {
                            dlgVMesi.value = '';
                            dlgV.showModal();
                        } else if (tipo === 'corso') {
                            dlgCTipo.value = btn.dataset.corso;
                            dlgCLabel.textContent = btn.dataset.label;
                            dlgCVerbaleWrap.style.display = (btn.dataset.corso === 'RLS') ? 'block' : 'none';
                            var mesi = parseInt(btn.dataset.mesi || '0', 10);
                            dlgCScadHint.dataset.mesi = mesi;
                            autoScadenza(mesi);
                            dlgC.showModal();
                        }
                    });
                });
                document.querySelectorAll('[data-close-dlg]').forEach(function (b) {
                    b.addEventListener('click', function () { b.closest('dialog').close(); });
                });
            })();
        </script>
        }
    }
    else if (tab == "distacchi")
    {
        <div class="card" style="padding: var(--s-4); margin-bottom: var(--s-4);">
            <h3 class="card__title" style="margin-top: 0;">Nuovo distacco</h3>
            <form asp-action="NuovoDistacco" asp-route-id="@d.Id" method="post" class="form-grid" style="margin-top: var(--s-3);">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Clinica destinazione *</label>
                    <select class="form-control" name="clinicaDistaccoId" required>
                        <option value="">— seleziona —</option>
                        @foreach (var c in Model.Cliniche.Where(x => x.Id != d.ClinicaId))
                        {
                            <option value="@c.Id">@c.Nome</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Data inizio *</label>
                    <input class="form-control" type="date" name="dataInizio" required value="@oggi.ToString("yyyy-MM-dd")" />
                </div>
                <div class="form-group">
                    <label class="form-label">Data fine (opzionale)</label>
                    <input class="form-control" type="date" name="dataFine" />
                </div>
                <div class="form-group full">
                    <label class="form-label">Motivo</label>
                    <input class="form-control" name="motivo" placeholder="Es. copertura ferie collega" />
                </div>
                <div class="form-group full" style="text-align:right;">
                    <button type="submit" class="btn btn--primary">＋ Registra distacco</button>
                </div>
            </form>
        </div>

        @if (Model.Distacchi.Count == 0)
        {
            <div class="card" style="padding: var(--s-4);">
                <p class="muted">Nessun distacco registrato.</p>
            </div>
        }
        else
        {
            <div class="card" style="padding:0; overflow:auto;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Clinica destinazione</th>
                            <th>Inizio</th>
                            <th>Fine</th>
                            <th>Durata</th>
                            <th>Motivo</th>
                            <th>Stato</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var dist in Model.Distacchi)
                    {
                        <tr>
                            <td><strong>@clinicheLookup.GetValueOrDefault(dist.ClinicaDistaccoId, "—")</strong></td>
                            <td>@dist.DataInizio.ToString("dd/MM/yyyy")</td>
                            <td>@(dist.DataFine?.ToString("dd/MM/yyyy") ?? "—")</td>
                            <td>@dist.DurataMesi mesi</td>
                            <td class="muted">@(dist.Motivo ?? "—")</td>
                            <td>
                                @if (dist.IsInCorso)
                                {
                                    <span class="badge badge--success"><span class="dot"></span>in corso</span>
                                }
                                else
                                {
                                    <span class="badge">chiuso</span>
                                }
                            </td>
                            <td style="white-space:nowrap;">
                                @if (dist.IsInCorso)
                                {
                                    <form asp-action="ChiudiDistacco" asp-route-id="@d.Id" asp-route-distaccoId="@dist.Id" method="post" style="display:inline;" onsubmit="return confirm('Chiudere il distacco oggi?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="dataFine" value="@oggi.ToString("yyyy-MM-dd")" />
                                        <button type="submit" class="btn btn--ghost btn--sm" title="Chiudi distacco oggi">✕ chiudi</button>
                                    </form>
                                }
                                <form asp-action="EliminaDistacco" asp-route-id="@d.Id" asp-route-distaccoId="@dist.Id" method="post" style="display:inline;" onsubmit="return confirm('Eliminare il distacco?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn--ghost btn--sm" title="Elimina">🗑</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    }
    else if (tab == "storico")
    {
        <partial name="_TimelineTrasferimenti" model="Model.Storico" />
    }
    else if (tab == "audit")
    {
        <partial name="_AuditFeed" model="Model.Audit" />
    }
</div>
