@model LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Accedi";
    ViewData["MetaDescription"] = "Accedi a Chipdent, la dental suite italiana per gestire turni, RLS, documentazione e comunicazioni di catene di studi dentistici multi-sede in tempo reale.";
}

<div class="auth__form" itemscope itemtype="https://schema.org/WebPage">
    <meta itemprop="name" content="Accedi a Chipdent" />
    <meta itemprop="description" content="Pagina di accesso al gestionale Chipdent per cliniche dentali multi-sede." />

    <h2>Bentornato</h2>
    <p class="lead">Accedi al tuo workspace Chipdent.</p>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert alert--danger" role="alert">@Model.Error</div>
    }

    <form asp-action="Login" method="post" novalidate aria-label="Modulo di accesso">
        <input type="hidden" asp-for="ReturnUrl" />

        <div class="form-group">
            <label class="form-label" asp-for="Email">Email</label>
            <input class="form-control" asp-for="Email" type="email" autocomplete="email" inputmode="email" placeholder="nome@chipdent.it" required />
            <span class="text-danger" asp-validation-for="Email"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Password">Password</label>
            <input class="form-control" asp-for="Password" type="password" autocomplete="current-password" placeholder="••••••••" required />
            <span class="text-danger" asp-validation-for="Password"></span>
        </div>

        @if (Model.Workspaces.Count > 0)
        {
            <div class="form-group">
                <label class="form-label" asp-for="TenantSlug">Workspace</label>
                <select class="form-control" asp-for="TenantSlug" required>
                    <option value="">— seleziona —</option>
                    @foreach (var w in Model.Workspaces)
                    {
                        <option value="@w.Slug" selected="@(w.Slug == Model.TenantSlug)">@w.DisplayName (@w.Slug)</option>
                    }
                </select>
            </div>
        }
        else if (!string.IsNullOrEmpty(Model.TenantSlug))
        {
            <input type="hidden" asp-for="TenantSlug" />
            <div class="muted" style="font-size:.8rem; margin: -8px 0 12px;">Accedi al workspace <code>@Model.TenantSlug</code></div>
        }

        <div class="form-group" style="display:flex; justify-content:space-between; align-items:center;">
            <label class="form-check">
                <input asp-for="RememberMe" type="checkbox" />
                Ricordami
            </label>
            <a href="#" style="font-size:.85rem;">Password dimenticata?</a>
        </div>

        <button type="submit" class="btn btn--primary btn--block">Accedi</button>
    </form>

    <div class="auth__hint" style="line-height:1.7;">
        <strong>Demo accounts</strong> · password comune <code>chipdent</code><br/>
        🏢 <code>owner@chipdent.it</code> — Management<br/>
        🏥 <code>direttore.milano@chipdent.it</code> — Direttore (sede Milano)<br/>
        📋 <code>backoffice@chipdent.it</code> — Backoffice<br/>
        👤 <code>staff@chipdent.it</code> — Staff (Igienista, Milano)
    </div>

    <div style="margin-top: var(--s-4); padding-top: var(--s-3); border-top: 1px solid var(--c-border, #e9e1d3); text-align:center;">
        <a asp-controller="Presenze" asp-action="Kiosk" target="_blank" rel="noopener"
           style="display:inline-flex; align-items:center; gap:6px; font-size:.85rem; color: var(--c-ink-soft); text-decoration:none;">
            📱 Sei in sede? Apri il kiosk timbrature →
        </a>
    </div>
</div>

<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "FAQPage",
    "mainEntity": [
        {
            "@@type": "Question",
            "name": "Cos'è Chipdent?",
            "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Chipdent è una dental suite italiana per la gestione operativa di catene di studi dentistici multi-sede: turni di dottori e dipendenti, RLS, documenti, comunicazioni interne e audit completo."
            }
        },
        {
            "@@type": "Question",
            "name": "Per chi è pensato Chipdent?",
            "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Per cliniche dentali con più sedi che vogliono governare turni, RLS, documenti e comunicazioni interne da un'unica piattaforma in tempo reale, con permessi differenziati per Owner, Management, Direttore, Backoffice e Staff."
            }
        },
        {
            "@@type": "Question",
            "name": "Posso vedere chi modifica i dati delle persone?",
            "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Sì. Ogni modifica all'anagrafica di dottori e dipendenti viene tracciata in un audit log con diff campo per campo, l'utente che ha effettuato l'operazione e una notifica live a tutti gli amministratori del workspace."
            }
        },
        {
            "@@type": "Question",
            "name": "Chipdent supporta i trasferimenti tra cliniche?",
            "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Sì. Ogni cambio di sede principale viene registrato come trasferimento con data di effetto, motivo e responsabile della decisione, e visualizzato come timeline storica sul profilo della persona."
            }
        }
    ]
}
</script>
