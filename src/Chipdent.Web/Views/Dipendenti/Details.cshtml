@model Chipdent.Web.Domain.Entities.Dipendente
@{
    ViewData["Title"] = Model.NomeCompleto;
    var cliniche = (Dictionary<string, string>?)ViewData["Cliniche"] ?? new();
    var clinicaNome = cliniche.TryGetValue(Model.ClinicaId, out var n) ? n : null;
    var anniServizio = (int)Math.Floor((DateTime.UtcNow - Model.DataAssunzione).TotalDays / 365);
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>@Model.NomeCompleto</h2>
        <p class="page-head__sub">@Model.Ruolo · @(clinicaNome ?? "—")</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Dipendenti</a>
        <a class="btn btn--primary" asp-action="Edit" asp-route-id="@Model.Id">Modifica</a>
    </div>
</div>

<div class="detail-grid">
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Anagrafica</h3>
            @switch (Model.Stato)
            {
                case Chipdent.Web.Domain.Entities.StatoDipendente.Attivo:
                    <span class="badge badge--success"><span class="dot"></span>attivo</span>
                    break;
                case Chipdent.Web.Domain.Entities.StatoDipendente.Onboarding:
                    <span class="badge badge--info"><span class="dot"></span>onboarding</span>
                    break;
                default:
                    <span class="badge badge--warning"><span class="dot"></span>@Model.Stato</span>
                    break;
            }
        </div>
        <dl class="kv">
            <dt>Email</dt><dd>@Model.Email</dd>
            <dt>Telefono</dt><dd>@(Model.Telefono ?? "—")</dd>
            <dt>Ruolo</dt><dd>@Model.Ruolo</dd>
            <dt>Sede</dt><dd>@(clinicaNome ?? "—")</dd>
            <dt>Contratto</dt><dd>@Model.TipoContratto</dd>
            <dt>Assunto il</dt><dd>@Model.DataAssunzione.ToLocalTime().ToString("dd MMM yyyy") · @anniServizio @(anniServizio == 1 ? "anno" : "anni") di servizio</dd>
        </dl>
    </div>

    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Ferie</h3>
        </div>
        <div class="stat" style="border:0; padding:0; box-shadow:none; background:transparent;">
            <div class="stat__label">Giorni residui</div>
            <div class="stat__value">@Model.GiorniFerieResidui</div>
            <div class="stat__hint">su 26 totali annui</div>
        </div>
    </div>
</div>
