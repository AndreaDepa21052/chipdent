@model Chipdent.Web.Models.AcceptInviteViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Imposta password";
}

<div class="auth__form">
    <h2>Benvenuto, @Model.FullName</h2>
    <p class="lead">Imposta la tua password per accedere a <strong style="color:var(--c-ink-strong);">@Model.TenantName</strong>.</p>

    <form asp-action="Accept" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Token" />
        <input type="hidden" asp-for="Email" />
        <input type="hidden" asp-for="FullName" />
        <input type="hidden" asp-for="TenantName" />

        <div class="form-group">
            <label class="form-label">Email</label>
            <input class="form-control" value="@Model.Email" disabled />
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Password">Password</label>
            <input class="form-control" asp-for="Password" autocomplete="new-password" placeholder="••••••••" />
            <span class="text-danger" asp-validation-for="Password"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="ConfirmPassword">Conferma password</label>
            <input class="form-control" asp-for="ConfirmPassword" autocomplete="new-password" placeholder="••••••••" />
            <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
        </div>

        <button type="submit" class="btn btn--primary btn--block">Crea account</button>
    </form>
</div>
