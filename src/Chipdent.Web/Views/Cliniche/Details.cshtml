@model Chipdent.Web.Domain.Entities.Clinica
@using Chipdent.Web.Domain.Entities
@using Chipdent.Web.Infrastructure.Rls
@{
    ViewData["Title"] = Model.Nome;
    var dottori = (List<Dottore>?)ViewData["Dottori"] ?? new();
    var dipendenti = (List<Dipendente>?)ViewData["Dipendenti"] ?? new();
    var rentri = ViewData["Rentri"] as IscrizioneRentri;
    var protocolli = (List<ProtocolloClinica>?)ViewData["Protocolli"] ?? new();
    var interventi = (List<InterventoClinica>?)ViewData["Interventi"] ?? new();
    var nomineRls = (IReadOnlyList<NomineGroup>?)ViewData["NomineRls"] ?? Array.Empty<NomineGroup>();
    var corsiRls = (IReadOnlyList<CorsiPerTipoGroup>?)ViewData["CorsiRls"] ?? Array.Empty<CorsiPerTipoGroup>();
    var visiteRls = (List<VisitaMedica>?)ViewData["VisiteRls"] ?? new();
    var dvrRls = (List<DVR>?)ViewData["DvrRls"] ?? new();
    var oggi = DateTime.UtcNow.Date;
    var oggiUtc = DateTime.UtcNow;
    var sogliaRls = oggiUtc.AddMonths(3);
    var sezDef = Chipdent.Web.Controllers.CalendarioInterventiController.SezioniDef;
    var queryTab = Context.Request.Query["tab"].ToString();
    var activeTab = string.IsNullOrEmpty(queryTab) ? "anagrafica" : queryTab;

    string BadgeForRls(StatoCompliance s) => s switch
    {
        StatoCompliance.InRegola => "badge badge--success",
        StatoCompliance.InScadenza => "badge badge--warning",
        StatoCompliance.Scaduto => "badge badge--danger",
        _ => "badge"
    };
    string LabelForRls(StatoCompliance s) => s switch
    {
        StatoCompliance.InRegola => "in regola",
        StatoCompliance.InScadenza => "in scadenza",
        StatoCompliance.Scaduto => "scaduto",
        _ => "—"
    };

    int TotaliNomine = nomineRls.Sum(n => n.Items.Count);
    int CorsiCriticIRls = corsiRls.Sum(g => g.Scaduti + g.InScadenza);
    int VisiteCriticIRls = visiteRls.Count(v => v.ScadenzaIdoneita.HasValue && v.ScadenzaIdoneita < sogliaRls);
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>@Model.Nome</h2>
        <p class="page-head__sub">@Model.Indirizzo · @Model.Citta</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Cliniche</a>
        <a class="btn btn--ghost" target="_blank" rel="noopener"
           href="@Url.Action("Index", "Bacheca", new { tenantSlug = User.FindFirst("tenant_slug")?.Value, clinicaId = Model.Id })">📺 Apri bacheca TV</a>
        <a class="btn btn--primary" asp-action="Edit" asp-route-id="@Model.Id">Modifica</a>
    </div>
</div>

<div class="tabs" data-clinica-tabs style="margin-bottom: var(--s-5);">
    <a class="tab @(activeTab == "anagrafica" ? "is-active" : "")"  href="#" data-tab="anagrafica">Anagrafica &amp; team</a>
    <a class="tab @(activeTab == "compliance" ? "is-active" : "")"  href="#" data-tab="compliance">RENTRI &amp; protocolli</a>
    <a class="tab @(activeTab == "rls" ? "is-active" : "")"  href="#" data-tab="rls">🛡 RLS / Sicurezza @if (CorsiCriticIRls + VisiteCriticIRls > 0) { <span class="tab__count">@(CorsiCriticIRls + VisiteCriticIRls)</span> }</a>
    <a class="tab @(activeTab == "interventi" ? "is-active" : "")"  href="#" data-tab="interventi">🛠️ Calendario interventi <span class="tab__count">@interventi.Count(i => i.ProssimaScadenza != null && i.ProssimaScadenza.Value.Date >= oggi && i.ProssimaScadenza.Value.Date <= oggi.AddDays(60))</span></a>
</div>

<section data-tab-pane="anagrafica" style="@(activeTab == "anagrafica" ? "" : "display:none;")">
<div class="detail-grid">
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Anagrafica</h3>
            @switch (Model.Stato)
            {
                case Chipdent.Web.Domain.Entities.ClinicaStato.Operativa:
                    <span class="badge badge--success"><span class="dot"></span>operativa</span>
                    break;
                case Chipdent.Web.Domain.Entities.ClinicaStato.InApertura:
                    <span class="badge badge--warning"><span class="dot"></span>in apertura</span>
                    break;
                default:
                    <span class="badge badge--danger"><span class="dot"></span>chiusa</span>
                    break;
            }
        </div>
        <dl class="kv">
            <dt>Indirizzo</dt><dd>@Model.Indirizzo, @Model.Citta</dd>
            <dt>Telefono</dt><dd>@(Model.Telefono ?? "—")</dd>
            <dt>Email</dt><dd>@(Model.Email ?? "—")</dd>
            <dt>Riuniti</dt><dd>@Model.NumeroRiuniti</dd>
            <dt>Creata</dt><dd>@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</dd>
        </dl>
    </div>

    <div style="display:flex; flex-direction:column; gap: var(--s-5);">
        <div class="stat">
            <div class="stat__label">Dottori assegnati</div>
            <div class="stat__value">@dottori.Count</div>
            <div class="stat__hint">come sede principale</div>
        </div>
        <div class="stat">
            <div class="stat__label">Dipendenti</div>
            <div class="stat__value">@dipendenti.Count</div>
            <div class="stat__hint">@dipendenti.Count(d => d.Stato == Chipdent.Web.Domain.Entities.StatoDipendente.Attivo) attivi</div>
        </div>
    </div>
</div>

<div style="margin-top: var(--s-6);">
    <div class="card" data-team-card>
        <div class="card__header">
            <h3 class="card__title">Team della sede</h3>
        </div>
        @if (dottori.Count == 0 && dipendenti.Count == 0)
        {
            <p style="color: var(--c-ink-soft); margin:0;">Nessun membro assegnato a questa clinica.</p>
        }
        else
        {
            <ul class="list">
                @foreach (var d in dottori)
                {
                    <li class="list__item">
                        <div class="list__icon">D</div>
                        <div>
                            <div class="list__title">@d.NomeCompleto <span class="badge" style="margin-left:6px;">@d.Specializzazione</span></div>
                            <div class="list__meta">@d.TipoContratto · Albo @d.NumeroAlbo</div>
                        </div>
                        <a class="list__when" asp-controller="Dottori" asp-action="Details" asp-route-id="@d.Id">apri →</a>
                    </li>
                }
                @foreach (var p in dipendenti)
                {
                    <li class="list__item">
                        <div class="list__icon">@p.Nome[0]</div>
                        <div>
                            <div class="list__title">@p.NomeCompleto <span class="badge" style="margin-left:6px;">@p.Ruolo</span></div>
                            <div class="list__meta">@p.TipoContratto · @p.Stato</div>
                        </div>
                        <a class="list__when" asp-controller="Dipendenti" asp-action="Details" asp-route-id="@p.Id">apri →</a>
                    </li>
                }
            </ul>
        }
    </div>
</div>

</section><!-- /tab anagrafica -->

<section data-tab-pane="compliance" style="@(activeTab == "compliance" ? "" : "display:none;")">
<div class="grid" style="grid-template-columns: 1fr 1fr; gap: var(--s-4); margin-top: var(--s-4);">
    <!-- RENTRI -->
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">♻️ RENTRI</h3>
            @if (rentri?.DataAttivazione is not null)
            {
                <span class="badge badge--success"><span class="dot"></span>attivo dal @rentri.DataAttivazione.Value.ToString("dd/MM/yyyy")</span>
            }
            else
            {
                <span class="badge badge--warning"><span class="dot"></span>non attivato</span>
            }
        </div>
        <p class="muted" style="font-size:.85rem; margin: 0 0 var(--s-3);">
            Iscrizione al Registro Elettronico Nazionale per la Tracciabilità dei Rifiuti (D.M. 119/2023).
        </p>
        <form asp-action="SalvaRentri" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Data attivazione</label>
                    <input class="form-control" type="date" name="dataAttivazione" value="@(rentri?.DataAttivazione?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="form-group">
                    <label class="form-label">N° iscrizione</label>
                    <input class="form-control" name="numeroIscrizione" value="@rentri?.NumeroIscrizione" />
                </div>
                <div class="form-group">
                    <label class="form-label">Username portale</label>
                    <input class="form-control" name="username" value="@rentri?.Username" autocomplete="off" />
                </div>
                <div class="form-group">
                    <label class="form-label">Password / token</label>
                    <input class="form-control" type="password" name="password" value="@rentri?.Password" autocomplete="new-password" placeholder="••••••" />
                </div>
                <div class="form-group full">
                    <label class="form-label">Note</label>
                    <textarea class="form-control" name="note" rows="2">@rentri?.Note</textarea>
                </div>
                <div class="form-group full" style="text-align:right;">
                    <button type="submit" class="btn btn--primary btn--sm">Salva RENTRI</button>
                </div>
            </div>
        </form>
    </div>

    <!-- PROTOCOLLI -->
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">📋 Protocolli operativi</h3>
            <span class="muted" style="font-size:.85rem;">@protocolli.Count totali · @protocolli.Count(p => p.Attivo) attivi</span>
        </div>

        @if (protocolli.Count > 0)
        {
            <ul class="list" style="margin: 0 0 var(--s-3);">
                @foreach (var p in protocolli)
                {
                    <li class="list__item">
                        <div class="list__icon">@(p.Attivo ? "✅" : "⬜")</div>
                        <div>
                            <div class="list__title"><strong>@p.Tipo</strong> @(string.IsNullOrEmpty(p.Versione) ? "" : "v" + p.Versione)</div>
                            <div class="muted" style="font-size:.78rem;">
                                @(p.DataAdozione?.ToString("dd/MM/yyyy") ?? "—")
                                @if (p.ProssimaRevisione.HasValue)
                                {
                                    <text> · prossima revisione @p.ProssimaRevisione.Value.ToString("dd/MM/yyyy")</text>
                                }
                            </div>
                        </div>
                        <div class="list__when" style="display:flex; gap:6px;">
                            <form asp-action="ToggleProtocollo" asp-route-id="@Model.Id" asp-route-protocolloId="@p.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn--ghost btn--sm" title="@(p.Attivo ? "Disattiva" : "Attiva")">@(p.Attivo ? "⊘" : "✓")</button>
                            </form>
                            <form asp-action="EliminaProtocollo" asp-route-id="@Model.Id" asp-route-protocolloId="@p.Id" method="post" style="display:inline;" onsubmit="return confirm('Rimuovere?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn--ghost btn--sm" title="Elimina">🗑</button>
                            </form>
                        </div>
                    </li>
                }
            </ul>
        }

        <details>
            <summary style="cursor: pointer; font-size:.9rem;">＋ Aggiungi protocollo</summary>
            <form asp-action="NuovoProtocollo" asp-route-id="@Model.Id" method="post" class="form-grid" style="margin-top: var(--s-3);">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Tipo</label>
                    <select class="form-control" name="tipo">
                        @foreach (var t in Enum.GetValues<TipoProtocollo>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Versione</label>
                    <input class="form-control" name="versione" placeholder="1.0" />
                </div>
                <div class="form-group">
                    <label class="form-label">Adozione</label>
                    <input class="form-control" type="date" name="dataAdozione" />
                </div>
                <div class="form-group">
                    <label class="form-label">Prossima revisione</label>
                    <input class="form-control" type="date" name="prossimaRevisione" />
                </div>
                <div class="form-group full">
                    <label class="form-label">Note</label>
                    <textarea class="form-control" name="note" rows="2"></textarea>
                </div>
                <div class="form-group full" style="text-align:right;">
                    <button type="submit" class="btn btn--primary btn--sm">＋ Aggiungi</button>
                </div>
            </form>
        </details>
    </div>
</div>
</section><!-- /tab compliance -->

<section data-tab-pane="rls" style="@(activeTab == "rls" ? "" : "display:none;")">
    <div class="grid grid--stats" style="margin-bottom: var(--s-5);">
        <div class="stat">
            <div class="stat__label">Addetti designati</div>
            <div class="stat__value">@TotaliNomine</div>
            <div class="stat__hint">RLS, antincendio, primo soccorso</div>
        </div>
        <div class="stat">
            <div class="stat__label">Corsi critici</div>
            <div class="stat__value">@CorsiCriticIRls</div>
            <div class="stat__hint">scaduti o in scadenza ≤ 3 mesi</div>
        </div>
        <div class="stat">
            <div class="stat__label">Visite mediche critiche</div>
            <div class="stat__value">@VisiteCriticIRls</div>
            <div class="stat__hint">idoneità in scadenza ≤ 3 mesi</div>
        </div>
        <div class="stat">
            <div class="stat__label">DVR</div>
            <div class="stat__value">@dvrRls.Count</div>
            <div class="stat__hint">
                @{
                    var dvrAttivo = dvrRls.FirstOrDefault();
                }
                @if (dvrAttivo is null)
                {
                    <text>nessun DVR registrato</text>
                }
                else
                {
                    <text>v@(dvrAttivo.Versione) · @dvrAttivo.Stato</text>
                }
            </div>
        </div>
    </div>

    <!-- Nomine designate per la sede -->
    <div class="card" style="margin-bottom: var(--s-5);">
        <div class="card__header">
            <h3 class="card__title">Nomine designate</h3>
            <a class="btn btn--ghost btn--sm" asp-controller="Rls" asp-action="Corsi">Gestisci nel modulo RLS →</a>
        </div>

        <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--s-4);">
            @foreach (var g in nomineRls)
            {
                <div style="padding: var(--s-3); border: 1px solid rgba(59,30,12,.08); border-radius: 10px;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: var(--s-2);">
                        <strong>@g.Icon @g.Label</strong>
                        @if (g.Items.Count == 0)
                        {
                            <span class="badge badge--danger"><span class="dot"></span>nessun addetto</span>
                        }
                        else
                        {
                            <span class="badge">@g.Items.Count</span>
                        }
                    </div>
                    @if (g.Items.Count == 0)
                    {
                        <p class="muted" style="margin:0; font-size:.82rem;">Designare un addetto per questa tipologia.</p>
                    }
                    else
                    {
                        <ul class="list" style="margin:0;">
                            @foreach (var item in g.Items)
                            {
                                <li class="list__item" style="padding: var(--s-2) 0;">
                                    <div>
                                        <div class="list__title" style="font-size:.9rem;">@item.Nome</div>
                                        <div class="muted" style="font-size:.78rem;">@item.Ruolo
                                            @if (!string.IsNullOrWhiteSpace(item.VerbaleNomina))
                                            {
                                                <text> · verb. @item.VerbaleNomina</text>
                                            }
                                        </div>
                                    </div>
                                    <div style="text-align:right;">
                                        <span class="@BadgeForRls(item.Stato)"><span class="dot"></span>@LabelForRls(item.Stato)</span>
                                        @if (item.Scadenza.HasValue)
                                        {
                                            <div class="muted" style="font-size:.72rem; margin-top:2px;">@item.Scadenza.Value.ToString("dd/MM/yyyy")</div>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Corsi in scadenza per il personale di sede -->
    <div class="card" style="margin-bottom: var(--s-5);">
        <div class="card__header">
            <h3 class="card__title">Corsi del personale di sede in scadenza</h3>
            <span class="muted" style="font-size:.85rem;">Personale assegnato a questa sede.</span>
        </div>
        @if (corsiRls.Count == 0)
        {
            <p style="color: var(--c-ink-soft); margin:0;">Nessun corso in scadenza nei prossimi 3 mesi. 🎯</p>
        }
        else
        {
            @foreach (var g in corsiRls)
            {
                <details open style="margin-bottom: var(--s-3); border: 1px solid rgba(59,30,12,.08); border-radius: 10px;">
                    <summary style="padding: var(--s-3) var(--s-4); cursor:pointer; display:flex; align-items:center; gap: var(--s-3); list-style:none;">
                        <span style="font-size:1.05rem;">@g.Icon</span>
                        <strong style="flex:1;">@g.Label</strong>
                        @if (g.Scaduti > 0)
                        {
                            <span class="badge badge--danger"><span class="dot"></span>@g.Scaduti scaduti</span>
                        }
                        @if (g.InScadenza > 0)
                        {
                            <span class="badge badge--warning"><span class="dot"></span>@g.InScadenza in scadenza</span>
                        }
                    </summary>
                    <ul class="list" style="margin: 0; padding: 0 var(--s-4) var(--s-3);">
                        @foreach (var item in g.Items)
                        {
                            <li class="list__item">
                                <div>
                                    <div class="list__title">@item.PersonaNome</div>
                                    <div class="muted" style="font-size:.78rem;">@item.Ruolo</div>
                                </div>
                                <div class="list__when" style="text-align:right;">
                                    <span class="@BadgeForRls(item.Stato)"><span class="dot"></span>@LabelForRls(item.Stato)</span>
                                    @if (item.Scadenza.HasValue)
                                    {
                                        <div class="muted" style="font-size:.72rem; margin-top:2px;">@item.Scadenza.Value.ToString("dd/MM/yyyy")</div>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                </details>
            }
        }
    </div>

    <!-- Visite mediche del personale di sede -->
    <div class="card" style="margin-bottom: var(--s-5);">
        <div class="card__header">
            <h3 class="card__title">Visite mediche del personale di sede</h3>
            <span class="muted" style="font-size:.85rem;">Solo dipendenti con idoneità in scadenza.</span>
        </div>
        @{
            var visiteCritiche = visiteRls
                .Where(v => v.ScadenzaIdoneita.HasValue && v.ScadenzaIdoneita < sogliaRls)
                .OrderBy(v => v.ScadenzaIdoneita)
                .ToList();
            var dipMap = dipendenti.ToDictionary(d => d.Id, d => d.NomeCompleto);
        }
        @if (visiteCritiche.Count == 0)
        {
            <p class="muted" style="margin:0;">Nessuna visita medica in scadenza nei prossimi 3 mesi.</p>
        }
        else
        {
            <ul class="list" style="margin:0;">
                @foreach (var v in visiteCritiche)
                {
                    var stato = RlsAggregator.ComputeStato(v.ScadenzaIdoneita, oggiUtc, sogliaRls);
                    <li class="list__item">
                        <div>
                            <div class="list__title">@(dipMap.GetValueOrDefault(v.DipendenteId, "—"))</div>
                            <div class="muted" style="font-size:.78rem;">esito @v.Esito</div>
                        </div>
                        <div class="list__when" style="text-align:right;">
                            <span class="@BadgeForRls(stato)"><span class="dot"></span>@LabelForRls(stato)</span>
                            @if (v.ScadenzaIdoneita.HasValue)
                            {
                                <div class="muted" style="font-size:.72rem; margin-top:2px;">@v.ScadenzaIdoneita.Value.ToString("dd/MM/yyyy")</div>
                            }
                        </div>
                    </li>
                }
            </ul>
        }
    </div>

    <!-- DVR -->
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">DVR di sede</h3>
            <a class="btn btn--ghost btn--sm" asp-controller="Rls" asp-action="Dvr">Gestisci DVR →</a>
        </div>
        @if (dvrRls.Count == 0)
        {
            <p class="muted" style="margin:0;">Nessun DVR registrato per questa sede.</p>
        }
        else
        {
            <ul class="list" style="margin:0;">
                @foreach (var d in dvrRls)
                {
                    var statoDvr = RlsAggregator.ComputeStato(d.ProssimaRevisione, oggiUtc, sogliaRls);
                    <li class="list__item">
                        <div>
                            <div class="list__title">DVR v@(d.Versione)</div>
                            <div class="muted" style="font-size:.78rem;">approvato il @d.DataApprovazione.ToString("dd/MM/yyyy") · stato @d.Stato</div>
                        </div>
                        <div class="list__when" style="text-align:right;">
                            <span class="@BadgeForRls(statoDvr)"><span class="dot"></span>@LabelForRls(statoDvr)</span>
                            @if (d.ProssimaRevisione.HasValue)
                            {
                                <div class="muted" style="font-size:.72rem; margin-top:2px;">prossima @d.ProssimaRevisione.Value.ToString("dd/MM/yyyy")</div>
                            }
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
</section><!-- /tab rls -->

<section data-tab-pane="interventi" style="@(activeTab == "interventi" ? "" : "display:none;")">
    <div class="card">
        <div class="card__header" style="align-items:flex-start;">
            <div>
                <h3 class="card__title">🛠️ Calendario interventi</h3>
                <div class="muted" style="font-size:.82rem;">
                    Manutenzioni e contratti ricorrenti tracciati per questa sede.
                    @{
                        var imminenti = interventi.Count(i => i.ProssimaScadenza != null && i.ProssimaScadenza.Value.Date >= oggi && i.ProssimaScadenza.Value.Date <= oggi.AddDays(60));
                        var scaduti = interventi.Count(i => i.ProssimaScadenza != null && i.ProssimaScadenza.Value.Date < oggi);
                    }
                    @if (scaduti > 0) { <strong style="color: var(--c-danger, #b8442e);">@scaduti scaduti</strong> <text>·</text> }
                    @imminenti in scadenza ≤ 60 gg
                </div>
            </div>
            <a class="btn btn--ghost btn--sm" asp-controller="CalendarioInterventi" asp-action="Index">Vai al calendario completo →</a>
        </div>

        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Tipologia</th>
                        <th>Fornitore</th>
                        <th>Frequenza</th>
                        <th>Ultimo</th>
                        <th>Prossima scadenza</th>
                        <th>Faldone ATS</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var def in sezDef)
                    {
                        var iv = interventi.FirstOrDefault(x => x.Tipo == def.Tipo);
                        var gg = iv?.ProssimaScadenza is null ? (double?)null : (iv.ProssimaScadenza.Value.Date - oggi).TotalDays;
                        string badge = gg switch
                        {
                            null => "badge",
                            < 0 => "badge--danger",
                            <= 30 => "badge--warning",
                            <= 90 => "badge",
                            _ => "badge--success"
                        };
                        <tr>
                            <td>@def.Icona <strong>@def.Titolo</strong></td>
                            <td>@(string.IsNullOrEmpty(iv?.Fornitore) ? def.Fornitore.RagioneSociale : iv!.Fornitore)</td>
                            <td>@(iv?.Frequenza ?? def.Frequenza)</td>
                            <td>@(iv?.DataUltimoIntervento?.ToString("MMM-yy", System.Globalization.CultureInfo.GetCultureInfo("it-IT")) ?? "—")</td>
                            <td>
                                @if (iv?.ProssimaScadenza is not null)
                                {
                                    <span class="badge @badge">@iv.ProssimaScadenza.Value.ToString("MMM-yy", System.Globalization.CultureInfo.GetCultureInfo("it-IT"))</span>
                                }
                                else { <span class="muted">—</span> }
                            </td>
                            <td>
                                @if (iv?.ArchiviatoFaldoneAts == true) { <span class="badge badge--success">☑</span> }
                                else { <span class="muted">—</span> }
                            </td>
                            <td style="text-align:right;">
                                <button type="button" class="btn btn--ghost btn--sm"
                                        data-open-modale-clinica
                                        data-clinica="@Model.Id"
                                        data-tipo="@def.Tipo">
                                    @(iv is null ? "+ Compila" : "✎ Modifica")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (interventi.Any(i => !string.IsNullOrEmpty(i.Note) || i.Dettagli.Count > 0))
        {
            <details style="margin-top: var(--s-3);">
                <summary class="muted" style="cursor:pointer; font-size:.85rem;">Mostra note e dettagli per ciascuna voce</summary>
                <ul class="list" style="margin-top: var(--s-2);">
                    @foreach (var iv in interventi.Where(i => !string.IsNullOrEmpty(i.Note) || i.Dettagli.Count > 0))
                    {
                        var defm = sezDef.FirstOrDefault(d => d.Tipo == iv.Tipo);
                        <li class="list__item" style="align-items:flex-start;">
                            <div class="list__icon">@(defm?.Icona ?? "🛠️")</div>
                            <div>
                                <div class="list__title">@(defm?.Titolo ?? iv.Tipo.ToString())</div>
                                @if (!string.IsNullOrEmpty(iv.Note))
                                {
                                    <div class="list__meta">@iv.Note</div>
                                }
                                @if (iv.Dettagli.Count > 0)
                                {
                                    <div class="muted" style="font-size:.78rem; margin-top:4px;">
                                        @string.Join(" · ", iv.Dettagli.Select(kv => $"{kv.Key}: {kv.Value}"))
                                    </div>
                                }
                            </div>
                        </li>
                    }
                </ul>
            </details>
        }
    </div>
</section>

<dialog id="dlg-intervento-clinica" class="dlg-intervento-clinica">
    <div data-modale-body>
        <div style="padding: 24px; text-align:center; color:#888;">Caricamento…</div>
    </div>
</dialog>

<style>
    dialog.dlg-intervento-clinica {
        border: 0; border-radius: 14px; padding: 0;
        max-width: 560px; width: 92vw;
        box-shadow: 0 24px 80px rgba(59, 30, 12, 0.22);
    }
    dialog.dlg-intervento-clinica::backdrop { background: rgba(59, 30, 12, 0.35); backdrop-filter: blur(2px); }
    .dett-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-3); }
    .dett-grid .full { grid-column: 1 / -1; }
</style>

@section Scripts {
<script>
    (function () {
        // ── Tab switching (persiste nella querystring così che back-nav torni qui) ──
        const tabs = document.querySelectorAll('[data-clinica-tabs] .tab');
        const panes = document.querySelectorAll('[data-tab-pane]');
        tabs.forEach(t => t.addEventListener('click', (ev) => {
            ev.preventDefault();
            const target = t.dataset.tab;
            tabs.forEach(x => x.classList.toggle('is-active', x === t));
            panes.forEach(p => p.style.display = (p.dataset.tabPane === target ? '' : 'none'));
            const u = new URL(location.href);
            u.searchParams.set('tab', target);
            history.replaceState(null, '', u.toString());
        }));

        // ── Modale intervento (riusa stesso endpoint del Calendario interventi globale) ──
        const dlg = document.getElementById('dlg-intervento-clinica');
        const body = dlg.querySelector('[data-modale-body]');
        async function openModale(clinicaId, tipo) {
            body.innerHTML = '<div style="padding:32px; text-align:center; color:#888;">Caricamento…</div>';
            dlg.showModal();
            try {
                const r = await fetch(`@Url.Action("Modale", "CalendarioInterventi")?clinicaId=${encodeURIComponent(clinicaId)}&tipo=${encodeURIComponent(tipo)}&returnTo=clinica`);
                if (!r.ok) throw new Error(r.statusText);
                body.innerHTML = await r.text();
            } catch (e) {
                body.innerHTML = '<div style="padding:24px; color:#b8442e;">Errore caricamento.</div>';
            }
        }
        document.addEventListener('click', (ev) => {
            const t = ev.target.closest('[data-open-modale-clinica]');
            if (t) { ev.preventDefault(); openModale(t.dataset.clinica, t.dataset.tipo); return; }
            if (ev.target.matches('[data-close-dlg]')) { ev.preventDefault(); dlg.close(); }
        });
    })();
</script>
}
