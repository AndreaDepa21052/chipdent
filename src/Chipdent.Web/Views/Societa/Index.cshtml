@model IReadOnlyList<Chipdent.Web.Domain.Entities.Societa>
@{
    ViewData["Title"] = "Società";
    var clinicheCount = (Dictionary<string, int>)(ViewData["ClinicheCount"] ?? new Dictionary<string, int>());
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>Società</h2>
        <p class="page-head__sub">
            @Model.Count società · @Model.Count(s => s.IsHolding) holding
        </p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--primary" asp-action="Create">+ Nuova società</a>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="card">
        <div class="empty">
            <div class="empty__icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M3 7l9-4 9 4M5 21V11M19 21V11M9 21v-6h6v6"/></svg>
            </div>
            <h3>Nessuna società ancora</h3>
            <p>Aggiungi la prima persona giuridica del gruppo.</p>
            <a class="btn btn--primary" asp-action="Create" style="margin-top: var(--s-3);">+ Nuova società</a>
        </div>
    </div>
}
else
{
    <div data-table-search data-table-search-target=".table">
        <partial name="_TableSearch" model='new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData) { ["Placeholder"] = "Cerca società per nome, ragione sociale, CF, P.IVA, REA…", ["Singular"] = "società", ["Plural"] = "società" }' />
        <div class="table-search__empty">Nessuna società corrisponde alla ricerca.</div>
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Ragione sociale</th>
                        <th>Sede legale</th>
                        <th>P.IVA / CF</th>
                        <th>REA</th>
                        <th>Cliniche</th>
                        <th>IBAN</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        var nClin = clinicheCount.TryGetValue(s.Id, out var n) ? n : 0;
                        <tr>
                            <td>
                                <div class="strong">
                                    @s.Nome
                                    @if (s.IsHolding)
                                    {
                                        <span class="badge badge--warning" style="margin-left:6px;" title="Sede legale principale">holding</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(s.Pec))
                                {
                                    <div class="muted" style="font-size:.78rem;">@s.Pec</div>
                                }
                            </td>
                            <td>@s.RagioneSociale</td>
                            <td>
                                @if (!string.IsNullOrEmpty(s.IndirizzoSedeLegale) || !string.IsNullOrEmpty(s.ComuneSedeLegale))
                                {
                                    <div>@s.IndirizzoSedeLegale</div>
                                    <div class="muted" style="font-size:.8rem;">
                                        @s.CapSedeLegale @s.ComuneSedeLegale @(string.IsNullOrEmpty(s.ProvinciaSedeLegale) ? "" : $"({s.ProvinciaSedeLegale})")
                                    </div>
                                }
                                else
                                {
                                    <span class="muted">—</span>
                                }
                            </td>
                            <td style="font-family: monospace; font-size:.85rem;">
                                @if (!string.IsNullOrEmpty(s.PartitaIva))
                                {
                                    <div>@s.PartitaIva</div>
                                }
                                @if (!string.IsNullOrEmpty(s.CodiceFiscale) && s.CodiceFiscale != s.PartitaIva)
                                {
                                    <div class="muted">CF @s.CodiceFiscale</div>
                                }
                                @if (string.IsNullOrEmpty(s.PartitaIva) && string.IsNullOrEmpty(s.CodiceFiscale))
                                {
                                    <span class="muted">—</span>
                                }
                            </td>
                            <td style="font-size:.85rem;">@(s.NumeroRea ?? "—")</td>
                            <td>
                                @if (nClin > 0)
                                {
                                    <span class="badge badge--success">@nClin sed@(nClin == 1 ? "e" : "i")</span>
                                }
                                else
                                {
                                    <span class="muted">0</span>
                                }
                            </td>
                            <td style="font-family: monospace; font-size:.8rem;">
                                @if (!string.IsNullOrEmpty(s.Iban))
                                {
                                    <span title="@s.Iban">@(s.Iban.Length > 12 ? s.Iban.Substring(0, 6) + "…" + s.Iban.Substring(s.Iban.Length - 4) : s.Iban)</span>
                                }
                                else
                                {
                                    <span class="muted" title="IBAN mancante: necessario per i pagamenti">⚠ —</span>
                                }
                            </td>
                            <td>
                                <div class="actions">
                                    <a class="ibtn" asp-action="Details" asp-route-id="@s.Id" title="Dettagli">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                                    </a>
                                    <a class="ibtn" asp-action="Edit" asp-route-id="@s.Id" title="Modifica">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
