@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
    // Persistenza stato dei <details> con data-persist-key in localStorage
    (function () {
        document.querySelectorAll('details[data-persist-key]').forEach(function (d) {
            var k = 'cd:' + d.dataset.persistKey;
            var v = localStorage.getItem(k);
            if (v === '1') d.open = true;
            else if (v === '0') d.open = false;
            d.addEventListener('toggle', function () {
                localStorage.setItem(k, d.open ? '1' : '0');
            });
        });
    })();

    // Tabs della pagina Tesoreria (Scadenze / Dashboard).
    // I chart sono in un pane inizialmente nascosto: alla prima attivazione del tab
    // chiamiamo resize() per fargli prendere le dimensioni reali del canvas.
    (function () {
        var tabs = document.querySelectorAll('[data-tesoreria-tabs] .tab');
        var panes = document.querySelectorAll('[data-tab-pane]');
        var dashboardTouched = document.querySelector('[data-tab-pane="dashboard"]')?.style.display !== 'none';
        tabs.forEach(function (t) {
            t.addEventListener('click', function (ev) {
                ev.preventDefault();
                var target = t.dataset.tab;
                tabs.forEach(function (x) { x.classList.toggle('is-active', x === t); });
                panes.forEach(function (p) { p.style.display = (p.dataset.tabPane === target ? '' : 'none'); });
                var u = new URL(location.href);
                u.searchParams.set('tab', target);
                history.replaceState(null, '', u.toString());
                if (target === 'dashboard' && !dashboardTouched && window.Chart) {
                    dashboardTouched = true;
                    setTimeout(function () {
                        Object.values(Chart.instances).forEach(function (c) { c.resize(); });
                    }, 50);
                }
            });
        });
    })();

    // Griglia scadenze a tutto schermo.
    // Sposta la card della griglia dentro il dialog <dlg-grid-fullscreen>
    // al click sul bottone; al close la ripristina nella sua posizione
    // originale. Niente clone: lo spostamento conserva event listener,
    // selezioni e stato del form filtri.
    (function () {
        var toggle = document.querySelector('[data-grid-fullscreen-toggle]');
        var dlg = document.getElementById('dlg-grid-fullscreen');
        var slot = document.getElementById('dlg-grid-fullscreen-body');
        var card = document.querySelector('[data-grid-card]');
        var root = document.getElementById('scadenze-grid-root');
        var closeBtn = document.querySelector('[data-grid-fullscreen-close]');
        if (!toggle || !dlg || !slot || !card || !root) return;

        function open() {
            if (!dlg.open) {
                slot.appendChild(card);
                if (typeof dlg.showModal === 'function') dlg.showModal();
                else dlg.setAttribute('open', '');
                document.body.style.overflow = 'hidden';
            }
        }
        function close() {
            if (dlg.open) {
                if (typeof dlg.close === 'function') dlg.close();
                else dlg.removeAttribute('open');
            }
        }
        toggle.addEventListener('click', open);
        if (closeBtn) closeBtn.addEventListener('click', close);
        dlg.addEventListener('close', function () {
            root.appendChild(card);
            document.body.style.overflow = '';
        });
        // Click sul backdrop chiude la modale (Esc è gestito nativamente).
        dlg.addEventListener('click', function (e) {
            if (e.target === dlg) close();
        });
    })();

    // Colonne ridimensionabili (table-layout: fixed) — drag del bordo destro
    // dell'header per cambiare la larghezza. Larghezze persistite per colonna
    // in localStorage e ripristinate al caricamento. Min 36px, max 800px.
    (function () {
        var table = document.querySelector('.scadenze-grid .table');
        var row = table && table.querySelector('thead tr[data-resizable-row]');
        if (!table || !row) return;

        var STORAGE_KEY = 'chipdent.tesoreria.colWidths';
        var widths = {};
        try { widths = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}') || {}; } catch (e) {}

        var ths = row.querySelectorAll('th[data-col]');
        ths.forEach(function (th) {
            var col = th.getAttribute('data-col');
            if (widths[col]) th.style.width = widths[col] + 'px';
        });

        function persist() {
            try { localStorage.setItem(STORAGE_KEY, JSON.stringify(widths)); } catch (e) {}
        }

        var dragging = null, startX = 0, startW = 0;
        row.querySelectorAll('[data-col-resizer]').forEach(function (handle) {
            handle.addEventListener('mousedown', function (e) {
                e.preventDefault();
                e.stopPropagation();
                var th = handle.parentElement;
                dragging = th;
                startX = e.clientX;
                startW = th.getBoundingClientRect().width;
                handle.classList.add('is-active');
                document.body.style.cursor = 'col-resize';
                document.body.style.userSelect = 'none';
            });
        });
        document.addEventListener('mousemove', function (e) {
            if (!dragging) return;
            var w = Math.min(800, Math.max(36, Math.round(startW + (e.clientX - startX))));
            dragging.style.width = w + 'px';
        });
        document.addEventListener('mouseup', function () {
            if (!dragging) return;
            var col = dragging.getAttribute('data-col');
            var w = Math.round(dragging.getBoundingClientRect().width);
            if (col) { widths[col] = w; persist(); }
            dragging.querySelectorAll('.col-resizer').forEach(function (h) { h.classList.remove('is-active'); });
            dragging = null;
            document.body.style.cursor = '';
            document.body.style.userSelect = '';
        });
    })();

    // Modale AI: simula l'avanzamento di un motore ML mostrando step in
    // sequenza, poi fetch dei risultati euristici dal server e rendering
    // delle "insight card". Niente LLM: la fonte dati è /tesoreria/ai/analisi
    // che calcola statistiche server-side; la UX vende l'esperienza AI.
    (function () {
        var trigger = document.querySelector('[data-ai-trigger]');
        var dlg = document.getElementById('dlg-ai');
        var closeBtn = document.querySelector('[data-ai-close]');
        var loader = document.querySelector('[data-ai-loader]');
        var result = document.querySelector('[data-ai-result]');
        if (!trigger || !dlg) return;

        function escapeHtml(s) {
            return String(s == null ? '' : s)
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        }

        function renderInsights(data) {
            var fmt = new Intl.NumberFormat('it-IT', { style: 'currency', currency: 'EUR' });
            var html = '';
            html += '<div class="ai-result__head">';
            html += '<div>Esposto totale aperte: <strong>' + fmt.format(data.esposto || 0) + '</strong></div>';
            html += '<div>Scadute: <strong>' + (data.scadute || 0) + '</strong></div>';
            html += '<div>Posizioni aperte: <strong>' + (data.apertiCount || 0) + '</strong></div>';
            html += '<div>Regole custom attive: <strong>' + (data.regoleCount || 0) + '</strong></div>';
            html += '</div>';
            (data.insights || []).forEach(function (ins, i) {
                html += '<div class="ai-card ai-card--' + escapeHtml(ins.kind) + '" style="animation-delay:' + (i * 60) + 'ms;">';
                html += '<div class="ai-card__icon">' + escapeHtml(ins.icon || '•') + '</div>';
                html += '<div class="ai-card__title">' + escapeHtml(ins.titolo) + '</div>';
                html += '<div class="ai-card__desc">' + escapeHtml(ins.descrizione) + '</div>';
                if (ins.azione) html += '<div class="ai-card__action">' + escapeHtml(ins.azione) + '</div>';
                html += '</div>';
            });
            html += '<div class="ai-disclaimer">Analisi euristica calcolata sul tuo scadenziario corrente. ';
            html += 'Le raccomandazioni sono consultive: la decisione finale resta del responsabile tesoreria.</div>';
            result.innerHTML = html;
        }

        function runLoadingSequence(onComplete) {
            var steps = loader.querySelectorAll('.ai-loader__step');
            steps.forEach(function (s) { s.classList.remove('is-active', 'is-done'); });
            var i = 0;
            steps[0].classList.add('is-active');
            var iv = setInterval(function () {
                steps[i].classList.remove('is-active');
                steps[i].classList.add('is-done');
                i++;
                if (i >= steps.length) {
                    clearInterval(iv);
                    onComplete();
                    return;
                }
                steps[i].classList.add('is-active');
            }, 420);
        }

        function open() {
            loader.hidden = false;
            result.hidden = true;
            result.innerHTML = '';
            if (typeof dlg.showModal === 'function') dlg.showModal();
            else dlg.setAttribute('open', '');

            var fetchDone = false, animDone = false;
            var data = null;
            function maybeRender() {
                if (fetchDone && animDone && data) {
                    loader.hidden = true;
                    result.hidden = false;
                    renderInsights(data);
                }
            }
            fetch('@Url.Action("AiAnalisi")', { headers: { 'Accept': 'application/json' } })
                .then(function (r) { return r.json(); })
                .then(function (json) { data = json; fetchDone = true; maybeRender(); })
                .catch(function () {
                    fetchDone = true;
                    data = { insights: [{ kind: 'critical', icon: '⚠️',
                        titolo: 'Analisi non disponibile',
                        descrizione: 'Errore nel recupero dei dati dal server. Riprova tra qualche secondo.',
                        azione: 'Se persiste, controlla la connessione o contatta il supporto.' }] };
                    maybeRender();
                });
            runLoadingSequence(function () { animDone = true; maybeRender(); });
        }

        trigger.addEventListener('click', open);
        if (closeBtn) closeBtn.addEventListener('click', function () {
            if (typeof dlg.close === 'function') dlg.close(); else dlg.removeAttribute('open');
        });
        dlg.addEventListener('click', function (e) {
            if (e.target === dlg) { if (typeof dlg.close === 'function') dlg.close(); else dlg.removeAttribute('open'); }
        });
    })();

    // Calendario fluttuante draggabile + chiudibile dal bottone in alto.
    // Quando aperto è SEMPRE in modalità floating (position:fixed) e quindi
    // sempre draggabile dalla testata. Il bottone "📅 Calendario" del page
    // header lo apre/chiude; alla pagina viene mostrato aperto al primo
    // accesso. Stato (open, x, y) persistito in localStorage.
    (function () {
        var cal = document.querySelector('.scadenze-cal');
        var split = document.querySelector('.scadenze-split');
        var pinBtn = document.querySelector('[data-cal-toggle]');
        var openBtn = document.querySelector('[data-cal-open-toggle]');
        var openLbl = document.querySelector('[data-cal-open-label]');
        var head = cal && cal.querySelector('.scadenze-cal__head');
        if (!cal || !split || !head) return;

        var STORAGE_KEY = 'chipdent.tesoreria.cal';
        // Default: aperto, posizione in alto a destra. Migrazione: i record
        // legacy avevano "floating: bool" — adesso il calendario è sempre
        // floating quando visibile, quindi quel flag viene ignorato.
        var state = { open: true, x: Math.max(20, window.innerWidth - 360), y: 96 };
        try { Object.assign(state, JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}')); }
        catch (e) { /* state default */ }
        if (typeof state.open !== 'boolean') state.open = true;

        function clampInViewport() {
            var maxX = Math.max(0, window.innerWidth  - cal.offsetWidth);
            var maxY = Math.max(0, window.innerHeight - 60);
            state.x = Math.min(Math.max(0, state.x), maxX);
            state.y = Math.min(Math.max(0, state.y), maxY);
        }

        function apply() {
            // La griglia occupa SEMPRE tutta la larghezza: il calendario non
            // è mai più in colonna a sinistra.
            split.classList.add('is-cal-floating');
            if (state.open) {
                cal.style.display = '';
                cal.classList.add('is-floating');
                clampInViewport();
                cal.style.left = state.x + 'px';
                cal.style.top  = state.y + 'px';
                if (openLbl) openLbl.textContent = 'Nascondi calendario';
                if (openBtn) openBtn.setAttribute('aria-pressed', 'true');
            } else {
                cal.style.display = 'none';
                cal.classList.remove('is-floating', 'is-dragging');
                if (openLbl) openLbl.textContent = 'Mostra calendario';
                if (openBtn) openBtn.setAttribute('aria-pressed', 'false');
            }
        }
        function persist() {
            try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch (e) {}
        }

        apply();

        // Il pin sulla testata del calendario lo CHIUDE (icona già a tema).
        if (pinBtn) {
            pinBtn.title = 'Chiudi calendario';
            pinBtn.setAttribute('aria-label', 'Chiudi calendario');
            pinBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                state.open = false;
                apply();
                persist();
            });
        }
        // Bottone in alto: apre/chiude.
        if (openBtn) {
            openBtn.addEventListener('click', function () {
                state.open = !state.open;
                apply();
                persist();
            });
        }

        // Drag dalla testata, ma non dai bottoni interni (frecce mese, pin).
        var dragging = false, offX = 0, offY = 0;
        function pt(e) { return e.touches && e.touches[0] ? e.touches[0] : e; }
        function onDown(e) {
            if (!state.open) return;
            if (e.target.closest('.scadenze-cal__nav, .scadenze-cal__pin')) return;
            var p = pt(e);
            var rect = cal.getBoundingClientRect();
            offX = p.clientX - rect.left;
            offY = p.clientY - rect.top;
            dragging = true;
            cal.classList.add('is-dragging');
            if (e.cancelable) e.preventDefault();
        }
        function onMove(e) {
            if (!dragging) return;
            var p = pt(e);
            var maxX = Math.max(0, window.innerWidth  - cal.offsetWidth);
            var maxY = Math.max(0, window.innerHeight - 60);
            state.x = Math.min(Math.max(0, p.clientX - offX), maxX);
            state.y = Math.min(Math.max(0, p.clientY - offY), maxY);
            cal.style.left = state.x + 'px';
            cal.style.top  = state.y + 'px';
            if (e.cancelable) e.preventDefault();
        }
        function onUp() {
            if (!dragging) return;
            dragging = false;
            cal.classList.remove('is-dragging');
            persist();
        }

        head.addEventListener('mousedown', onDown);
        head.addEventListener('touchstart', onDown, { passive: false });
        document.addEventListener('mousemove', onMove);
        document.addEventListener('touchmove', onMove, { passive: false });
        document.addEventListener('mouseup', onUp);
        document.addEventListener('touchend', onUp);

        // Riposiziona se la finestra si restringe oltre il calendario.
        window.addEventListener('resize', function () {
            if (!state.open) return;
            clampInViewport();
            cal.style.left = state.x + 'px';
            cal.style.top  = state.y + 'px';
        });
    })();
</script>
<script>
    (function () {
        var palette = ['#c47830', '#3b1e0c', '#2d7a50', '#2457a4', '#7a5c9a', '#d9943a', '#a83a3a', '#5b8a72', '#a86010', '#1f6e3a', '#666', '#aaa'];

        // Cash-out 90gg
        var cashout = @Json.Serialize(Model.CashOutFuturo90gg);
        if (cashout.length) {
            new Chart(document.getElementById('chart-cashout').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: cashout.map(function (m) { return m.mese; }),
                    datasets: [{ label: 'Esposto', data: cashout.map(function (m) { return m.valore; }), backgroundColor: '#c47830' }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { callbacks: { label: function (ctx) { return ctx.parsed.y.toLocaleString('it-IT') + ' €'; } } } },
                    scales: { y: { beginAtZero: true, ticks: { callback: function (v) { return v.toLocaleString('it-IT') + ' €'; } } } }
                }
            });
        }

        // Stati
        var stati = @Json.Serialize(Model.RipartizioneStati);
        var statiKeys = Object.keys(stati);
        if (statiKeys.length) {
            new Chart(document.getElementById('chart-stati').getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: statiKeys,
                    datasets: [{ data: statiKeys.map(function (k) { return stati[k]; }), backgroundColor: palette }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
            });
        }

        // Categoria
        var cat = @Json.Serialize(Model.SpesaPerCategoria12m);
        if (cat.length) {
            new Chart(document.getElementById('chart-categoria').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: cat.map(function (m) { return m.mese; }),
                    datasets: [{ label: 'Spesa', data: cat.map(function (m) { return m.valore; }), backgroundColor: palette }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { x: { beginAtZero: true, ticks: { callback: function (v) { return v.toLocaleString('it-IT') + ' €'; } } } }
                }
            });
        }

        // Sede
        var sede = @Json.Serialize(Model.SpesaPerSede);
        if (sede.length) {
            new Chart(document.getElementById('chart-sede').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: sede.map(function (s) { return s.sigla + ' · ' + s.nome; }),
                    datasets: [{ label: 'Spesa', data: sede.map(function (s) { return s.valore; }), backgroundColor: '#3b1e0c' }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { callback: function (v) { return v.toLocaleString('it-IT') + ' €'; } } } }
                }
            });
        }

        // Modali
        var dlgPaga = document.getElementById('dlg-paga');
        var dlgProg = document.getElementById('dlg-prog');
        var dlgDett = document.getElementById('dlg-dettaglio');
        var dettBody = dlgDett.querySelector('[data-dettaglio-body]');
        var formPaga = document.getElementById('form-paga');
        var formProg = document.getElementById('form-prog');
        document.querySelectorAll('[data-pay-trigger]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                formPaga.action = '/tesoreria/scadenza/' + btn.dataset.id + '/paga';
                dlgPaga.showModal();
            });
        });
        // Modale Dettagli/Modifica: caricamento lazy del partial
        document.querySelectorAll('[data-edit-trigger]').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                dettBody.innerHTML = '<div style="padding:32px; text-align:center; color:#888;">caricamento…</div>';
                dlgDett.showModal();
                try {
                    var r = await fetch('/tesoreria/scadenza/' + btn.dataset.id + '/dettaglio');
                    var body = await r.text();
                    if (!r.ok) {
                        // Mostra il body dell'errore se il server lo fornisce (HTML), altrimenti generico.
                        dettBody.innerHTML = body && body.indexOf('<') === 0
                            ? body
                            : '<div style="padding:24px; color:#b8442e;">errore caricamento (' + r.status + ')</div>';
                        return;
                    }
                    dettBody.innerHTML = body;
                } catch (e) {
                    dettBody.innerHTML = '<div style="padding:24px; color:#b8442e;">errore caricamento: ' + (e && e.message ? e.message : 'rete') + '</div>';
                }
            });
        });
        document.querySelectorAll('[data-schedule-trigger]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                formProg.action = '/tesoreria/scadenza/' + btn.dataset.id + '/programma';
                dlgProg.showModal();
            });
        });

        // Modale callout "Nuova fattura": fetch del partial e showModal()
        var dlgNuova = document.getElementById('dlg-nuova-fattura');
        var nuovaBody = dlgNuova.querySelector('[data-nuova-fattura-body]');
        document.querySelectorAll('[data-new-fattura]').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                nuovaBody.innerHTML = '<div style="padding:48px; text-align:center; color:#888;">caricamento…</div>';
                dlgNuova.showModal();
                try {
                    var r = await fetch('/tesoreria/fattura/nuova/modale');
                    if (!r.ok) throw new Error(r.statusText);
                    nuovaBody.innerHTML = await r.text();
                    // Esegui gli <script> inline del partial appena iniettato
                    nuovaBody.querySelectorAll('script').forEach(function (s) {
                        var ns = document.createElement('script');
                        if (s.src) ns.src = s.src;
                        else ns.textContent = s.textContent;
                        s.parentNode.replaceChild(ns, s);
                    });
                    // Focus sul primo campo
                    var firstField = nuovaBody.querySelector('select[name="FornitoreId"]');
                    if (firstField) firstField.focus();
                } catch (e) {
                    nuovaBody.innerHTML = '<div style="padding:24px; color:#b8442e;">errore caricamento</div>';
                }
            });
        });
        // Event delegation: cattura anche i [data-close-dlg] iniettati a runtime nelle
        // modali partial (es. _DettaglioScadenza), che non esistono al page-load.
        document.addEventListener('click', function (ev) {
            var b = ev.target.closest('[data-close-dlg]');
            if (!b) return;
            var dlg = b.closest('dialog');
            if (dlg) { ev.preventDefault(); dlg.close(); }
        });

        // ── Selezione massiva per distinta SEPA ─────────────────────────
        var toolbar = document.querySelector('[data-sepa-toolbar]');
        var elCount = document.querySelector('[data-sepa-count]');
        var elTotal = document.querySelector('[data-sepa-total]');
        var elSumCount = document.querySelector('[data-sepa-summary-count]');
        var elSumTotal = document.querySelector('[data-sepa-summary-total]');
        var rows = document.querySelectorAll('input.sepa-row');
        var master = document.querySelector('[data-sepa-master]');
        var dlgSepa = document.getElementById('dlg-sepa');
        var hidden = document.getElementById('sepa-hidden-fields');

        function fmtEur(n) { return n.toLocaleString('it-IT', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €'; }

        function refreshSelection() {
            var checked = Array.prototype.filter.call(rows, function (r) { return r.checked; });
            var total = checked.reduce(function (acc, r) { return acc + parseFloat(r.dataset.amount || '0'); }, 0);
            elCount.textContent = checked.length;
            elTotal.textContent = fmtEur(total);
            toolbar.style.display = checked.length > 0 ? 'flex' : 'none';
            if (master) master.checked = checked.length > 0 && checked.length === rows.length;
            return { checked: checked, total: total };
        }

        rows.forEach(function (cb) { cb.addEventListener('change', refreshSelection); });
        if (master) master.addEventListener('change', function () {
            rows.forEach(function (r) { r.checked = master.checked; });
            refreshSelection();
        });

        var openBtn = document.querySelector('[data-sepa-open]');
        var clearBtn = document.querySelector('[data-sepa-clear]');
        if (clearBtn) clearBtn.addEventListener('click', function () {
            rows.forEach(function (r) { r.checked = false; });
            refreshSelection();
        });
        if (openBtn) openBtn.addEventListener('click', function () {
            var sel = refreshSelection();
            if (sel.checked.length === 0) return;
            // Popola hidden fields scadenzaIds[]
            hidden.innerHTML = '';
            sel.checked.forEach(function (r) {
                var i = document.createElement('input');
                i.type = 'hidden'; i.name = 'scadenzaIds'; i.value = r.dataset.id;
                hidden.appendChild(i);
            });
            elSumCount.textContent = sel.checked.length;
            elSumTotal.textContent = fmtEur(sel.total);
            dlgSepa.showModal();
        });
    })();
</script>
}
