@model Chipdent.Web.Models.MovimentiMensiliReport
@using System.Globalization
@{
    ViewData["Title"] = "Movimenti dipendenti — " + Model.MeseAnnoLabel;
    var ci = CultureInfo.GetCultureInfo("it-IT");
    var anno = (int)ViewData["Anno"]!;
    var mese = (int)ViewData["Mese"]!;
    var oggi = DateTime.UtcNow;
}

<partial name="_Flash" />

<div class="page-head">
    <div>
        <h2>Movimenti dipendenti</h2>
        <p class="page-head__sub">@Model.MeseAnnoLabel — riepilogo per sede di assunzioni, cessazioni, proroghe, distacchi e trasformazioni</p>
    </div>
    <div class="page-head__actions">
        <a class="btn btn--ghost" asp-action="Index">← Lista</a>
        <a class="btn btn--ghost" asp-action="MovimentiCsv" asp-route-anno="@anno" asp-route-mese="@mese">⬇ Export CSV</a>
        <a class="btn btn--primary" asp-action="MovimentiXlsx" asp-route-anno="@anno" asp-route-mese="@mese">⬇ Export Excel</a>
    </div>
</div>

<div class="card" style="padding: var(--s-3); margin-bottom: var(--s-4);">
    <form method="get" asp-action="Movimenti" style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
        <label class="form-label" style="margin:0;">Mese</label>
        <select class="form-control" name="mese" style="max-width:160px;">
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m" selected="@(m == mese)">@ci.DateTimeFormat.GetMonthName(m)</option>
            }
        </select>
        <label class="form-label" style="margin:0;">Anno</label>
        <select class="form-control" name="anno" style="max-width:120px;">
            @for (int y = oggi.Year - 3; y <= oggi.Year + 1; y++)
            {
                <option value="@y" selected="@(y == anno)">@y</option>
            }
        </select>
        <button type="submit" class="btn btn--primary btn--sm">Aggiorna</button>
    </form>
</div>

<div class="movimenti-kpis">
    <div class="kpi"><div class="kpi__label">Assunzioni</div><div class="kpi__value" style="color:#1f6e3a;">@Model.TotaleAssunzioni</div></div>
    <div class="kpi"><div class="kpi__label">Cessazioni</div><div class="kpi__value" style="color:#a83a3a;">@Model.TotaleCessazioni</div></div>
    <div class="kpi"><div class="kpi__label">Proroghe</div><div class="kpi__value">@Model.TotaleProroghe</div></div>
    <div class="kpi"><div class="kpi__label">Distacchi</div><div class="kpi__value">@Model.TotaleDistacchi</div></div>
    <div class="kpi"><div class="kpi__label">Trasf. / aumenti</div><div class="kpi__value" style="color:#a86010;">@Model.TotaleTrasformazioni</div></div>
    <div class="kpi"><div class="kpi__label">Trasf. sede</div><div class="kpi__value">@Model.TotaleTrasferimenti</div></div>
    <div class="kpi"><div class="kpi__label">Cambi mansione</div><div class="kpi__value">@Model.TotaleCambiMansione</div></div>
</div>

<div class="card movimenti-report" style="padding:0; overflow-x:auto;">
    <table class="table movimenti-table">
        <thead>
            <tr>
                <th>Mese/Anno</th>
                <th>Società</th>
                <th>Assunzioni</th>
                <th>Annull. assunzioni</th>
                <th>Cessazioni anticipate</th>
                <th>Non rinnovati</th>
                <th>Non rinnovati prossimo mese</th>
                <th>Proroghe</th>
                <th>Distacchi</th>
                <th>Rettifiche distacchi</th>
                <th>Trasformazioni / livello</th>
                <th>Trasferimenti sede</th>
                <th>Cambi mansione</th>
                <th>Note</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Righe)
            {
                <tr>
                    <td>@Model.MeseAnnoLabel</td>
                    <td><strong>@r.ClinicaNome</strong></td>
                    <td>@(r.NumeroAssunzioni == 0 ? "" : r.NumeroAssunzioni.ToString())</td>
                    <td>@(r.NumeroAnnullamentiAssunzione == 0 ? "" : r.NumeroAnnullamentiAssunzione.ToString())</td>
                    <td>@(r.NumeroCessazioniAnticipate == 0 ? "" : r.NumeroCessazioniAnticipate.ToString())</td>
                    <td>@(r.NumeroContrattiNonRinnovati == 0 ? "" : r.NumeroContrattiNonRinnovati.ToString())</td>
                    <td>@(r.NumeroContrattiNonRinnovatiProssimoMese == 0 ? "" : r.NumeroContrattiNonRinnovatiProssimoMese.ToString())</td>
                    <td>@(r.NumeroProroghe == 0 ? "" : r.NumeroProroghe.ToString())</td>
                    <td>@(r.NumeroDistacchi == 0 ? "" : r.NumeroDistacchi.ToString())</td>
                    <td>@(r.NumeroRettificheDistacchi == 0 ? "" : r.NumeroRettificheDistacchi.ToString())</td>
                    <td>@(r.NumeroTrasformazioniLivello == 0 ? "" : r.NumeroTrasformazioniLivello.ToString())</td>
                    <td>@(r.NumeroTrasferimentiSede == 0 ? "" : r.NumeroTrasferimentiSede.ToString())</td>
                    <td>@(r.NumeroCambiMansione == 0 ? "" : r.NumeroCambiMansione.ToString())</td>
                    <td class="muted" style="font-size:.8rem;">@string.Join(" · ", r.Note)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<p class="muted" style="margin-top: var(--s-3); font-size:.85rem;">
    Il riepilogo è calcolato in tempo reale aggregando le operazioni registrate in piattaforma:
    anagrafica dipendenti (assunzioni, cessazioni, proroghe, trasformazioni), distacchi,
    trasferimenti tra sedi, cambi livello/retribuzione e cambi mansione/reparto.
    Le operazioni si registrano dal profilo del singolo dipendente (tab «Carriera», «Distacchi», «Storico cliniche»).
</p>

<style>
    .movimenti-kpis {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: var(--s-2);
        margin-bottom: var(--s-4);
    }
    .kpi {
        background: linear-gradient(180deg, var(--c-bg-panel) 0%, var(--c-bg-surface) 100%);
        border: 1px solid var(--c-border);
        border-radius: var(--r-md);
        padding: var(--s-2) var(--s-3);
        min-width: 0;
    }
    .kpi__label {
        font-size: 0.62rem;
        color: var(--c-ink-soft);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .kpi__value {
        font-family: var(--f-display);
        font-size: 1.4rem;
        color: var(--c-ink-strong);
        line-height: 1.1;
    }
    @@media (max-width: 1100px) {
        .movimenti-kpis { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    }
    @@media (max-width: 640px) {
        .movimenti-kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    .movimenti-table {
        font-size: 0.78rem;
        min-width: 100%;
    }
    .movimenti-table thead th {
        font-size: 0.68rem;
        padding: var(--s-2) var(--s-2);
        white-space: normal;
        line-height: 1.2;
        vertical-align: bottom;
    }
    .movimenti-table tbody td {
        padding: var(--s-2) var(--s-2);
        white-space: nowrap;
    }
    .movimenti-table tbody td:last-child {
        white-space: normal;
        max-width: 240px;
    }
</style>
